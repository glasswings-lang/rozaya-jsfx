desc: Sweep Dwell Filter
// Designed by Rozaya, developed with Claude (Anthropic)
//
// This work is dedicated to the public domain under CC0 1.0 Universal.
// https://creativecommons.org/publicdomain/zero/1.0/

slider1:500<20,20000,1>Frequency Low Hz
slider2:5000<20,20000,1>Frequency High Hz
slider3:4<0.001,60,0.001>High Dwell sec
slider4:6<0.001,60,0.001>Low Dwell sec
slider5:1<0.001,30,0.001>Fade Down sec
slider6:1<0,3,1{Linear,Cosine,Logarithmic,Exponential}>Fade Down Shape
slider7:1<0.001,30,0.001>Fade Up sec
slider8:1<0,3,1{Linear,Cosine,Logarithmic,Exponential}>Fade Up Shape
slider9:0.7<0,1,0.01>Resonance
slider10:1<0,1,0.01>Wet/Dry Mix
slider11:0<-180,180,0.1>Stereo Phase Offset degrees
slider12:0<0,1,1{Independent L+R,Offset from L}>Phase Mode
// ===== PAN BLOCK SLIDERS START =====
slider13:0<0,1,1{Off,On}>Pan Enabled
slider14:0<0,12,1{Mono,Alternating,Alternating (Flipped),Distributed,Distributed (Flipped),Distributed (Ping-pong),Converging,Converging (Ping-pong),Diverging,Diverging (Ping-pong),Pan Sweep,Pan Sweep (Flipped),Linked Sweep}>Pan Mode
slider15:1<0,1,0.01>Pan Spread (0=mono, 1=full)
slider16:5<0,100,0.1>Pan Glide ms (0=instant)
slider17:8<2,32,1>Cycle Steps (per-cycle modes)
slider18:2<0.001,1000,0.001>Pan Sweep Rate
slider19:0<0,2,1{Hz,Seconds,BPM}>Pan Sweep Rate Unit
slider20:1<0.125,8,0.125>Filter Speed Multiplier (Linked Sweep)
// ===== PAN BLOCK SLIDERS END =====

// Pass-through for N seconds after playback starts, then apply the
// sweep-dwell filter + pan effect normally. As an EFFECT plugin the
// dry signal passes through during the delay. Re-arms on every
// transport stop/start. 0 disables the delay.
slider21:0<0,1000,0.001>Start Delay (seconds)

// Per-cycle Play/Rest gate. Effect is applied normally for N
// cycles, then enters its rest period for M cycles, then resumes
// — repeats forever. One "cycle" is one full dwell pattern (High
// Dwell + Fade Down + Low Dwell + Fade Up). So with the default
// settings (4 + 1 + 6 + 1 = 12 sec/cycle), "Play for = 4" plays
// 48 seconds of the sweep before entering rest. The LFO at rest /
// Output at rest sliders below pick what happens during rest.
// 0 in either slider disables the gate. Resets on every transport
// stop/start.
slider22:0<0,1000,1>Play for (cycles)
slider23:0<0,1000,1>Rest for (cycles)

// What the LFOs do during the rest period.
//   Walk through (default) — filter dwell LFO and pan LFOs keep
//     cycling during rest. When the effect resumes, the LFOs are
//     at new positions reflecting wall-clock time passed.
//   Freeze in place — LFO phases pause, frozen at their values at
//     rest entry. When the effect resumes, the cutoff picks up
//     from the same position. The dwell pattern pauses and
//     resumes in lockstep with the gate.
slider24:0<0,1,1{Walk through,Freeze in place}>LFO at rest

// What the output does during the rest period.
//   Pass-through (default) — dry signal passes through unchanged
//     (matches Start Delay's behavior).
//   Silence — wet+dry mix smooths to 0; audio fades into silence
//     instead of passing dry. Useful when you want the gate to
//     act like a hard mute rather than a filter bypass.
slider25:0<0,1,1{Pass-through,Silence}>Output at rest

// Speed ramp: in-plugin slowdown/speedup over time. Scales the dwell
// pattern's frequency on top of the four dwell/fade timing sliders.
// 0.5 = half speed (the whole pattern takes twice as long), 2.0 =
// double. The existing ~3 ms cut smoother already absorbs clicks
// from manual dwell-slider tweaks, so no additional rate smoother is
// needed here — just the ramp.
slider26:1.0<0.1,4.0,0.01>Speed ramp target (multiplier)
slider27:0<0,60,0.1>Speed ramp duration (minutes)
slider28:0<0,1,1{Off,On}>Speed ramp engage

// Wobble slot: read a slowly-wandering multiplier from a shared
// mailbox and apply it to the dwell-pattern rate. 0 = no wobble.
slider29:0<0,16,1>Wobble slot (0 = no wobble)

in_pin:left input
in_pin:right input
out_pin:left output
out_pin:right output

@init
phase_l = 0;
phase_r = 0;
n3 = n4 = rn3 = rn4 = 0;
cut_smooth_l = cut_smooth_r = 0.1;

// ===== PAN BLOCK INIT START =====
pan_l           = 0;
pan_l_smooth    = 0;
pan_cycle_index = 0;
pan_cycle_dir   = 1;
last_phase_l    = 0;
pan_phase       = 0;
// ===== PAN BLOCK INIT END =====


function apply_curve(t, shape) (
  shape == 0 ? t :
  shape == 1 ? 0.5 - 0.5 * cos(t * $pi) :
  shape == 2 ? log(1 + 9*t) / log(10) :
               (10^t - 1) / 9
);

function calc_lfo(ph, high_secs, low_secs, fade_down_secs, fade_up_secs, fade_down_shape, fade_up_shape)
local(period, high_frac, fade_down_frac, low_frac, fade_up_frac, t, result) (
  period         = high_secs + fade_down_secs + low_secs + fade_up_secs;
  high_frac      = high_secs / period;
  fade_down_frac = fade_down_secs / period;
  low_frac       = low_secs / period;
  fade_up_frac   = fade_up_secs / period;
  ph < high_frac ? (
    result = 1;
  ) :
  ph < high_frac + fade_down_frac ? (
    fade_down_frac > 0.0001 ? (
      t = (ph - high_frac) / fade_down_frac;
      result = 1 - apply_curve(t, fade_down_shape);
    ) : (result = 0);
  ) :
  ph < high_frac + fade_down_frac + low_frac ? (
    result = 0;
  ) : (
    fade_up_frac > 0.0001 ? (
      t = (ph - high_frac - fade_down_frac - low_frac) / fade_up_frac;
      result = apply_curve(t, fade_up_shape);
    ) : (result = 1);
  );
  result
);

// ===== PAN BLOCK FUNCTIONS START =====
function percycle_pan(idx, n_steps) local(steps, step, pos) (
  n_steps = max(n_steps, 1);
  steps   = max(ceil((n_steps - 1) / 2.0), 1);

  pan_mode == 0 ? (
    pos = 0;
  ) : pan_mode == 1 ? (
    pos = (idx % 2 == 0) ? -1 : 1;
  ) : pan_mode == 2 ? (
    pos = (idx % 2 == 0) ? 1 : -1;
  ) : pan_mode == 3 ? (
    n_steps > 1 ? (pos = (idx % n_steps) / (n_steps - 1.0) * 2.0 - 1.0) : (pos = 0);
  ) : pan_mode == 4 ? (
    n_steps > 1 ? (pos = 1.0 - (idx % n_steps) / (n_steps - 1.0) * 2.0) : (pos = 0);
  ) : pan_mode == 5 ? (
    n_steps > 1 ? (pos = idx / (n_steps - 1.0) * 2.0 - 1.0) : (pos = 0);
  ) : pan_mode == 6 ? (
    idx = idx % n_steps;
    idx == 0 ? (
      pos = -1.0;
    ) : (
      step = ceil((idx + 1) / 2);
      pos = (idx % 2 == 1) ?  (1.0 - (step - 1.0) / steps)
                            : -(1.0 - (step - 1.0) / steps);
      pos = max(-1.0, min(1.0, pos));
    );
  ) : pan_mode == 7 ? (
    idx = idx % n_steps;
    idx == 0 ? (
      pos = -1.0;
    ) : (
      step = ceil((idx + 1) / 2);
      pos = (idx % 2 == 1) ?  (1.0 - (step - 1.0) / steps)
                            : -(1.0 - (step - 1.0) / steps);
      pos = max(-1.0, min(1.0, pos));
    );
  ) : pan_mode == 8 ? (
    idx = idx % n_steps;
    idx == 0 ? (
      pos = 0.0;
    ) : (
      step = floor((idx + 1) / 2);
      pos = (idx % 2 == 1) ? -(step / steps)
                            :  (step / steps);
      pos = max(-1.0, min(1.0, pos));
    );
  ) : pan_mode == 9 ? (
    idx = idx % n_steps;
    idx == 0 ? (
      pos = 0.0;
    ) : (
      step = floor((idx + 1) / 2);
      pos = (idx % 2 == 1) ? -(step / steps)
                            :  (step / steps);
      pos = max(-1.0, min(1.0, pos));
    );
  ) : (
    pos = 0;
  );

  pos * pan_spread
);
// ===== PAN BLOCK FUNCTIONS END =====

// Start Delay state.
last_play_state     = 0;
start_delay_elapsed = 0;
start_delay_sec     = 0;

// Play/Rest gate state. Same per-cycle counter + effect_mix design
// used in the other effect plugins. effect_mix smoothly transitions
// between 1 (effect on) and 0 (rest target — either dry pass-through
// or silence, picked by Output at rest).
pr_resting        = 0;
pr_cycle_progress = 0;
play_for_cycles   = 0;
rest_for_cycles   = 0;
pr_enabled        = 0;
rest_lfo_mode     = 0;
rest_output_mode  = 0;
effect_mix        = 1;

// Speed ramp state.
speed_ramp_engaged_last = 0;
speed_scale_current     = 1.0;
speed_scale_start       = 1.0;
speed_ramp_t            = 0.0;

// Wobble: shared mailbox base in gmem. Must match wobble_modulator.jsfx.
WOBBLE_BASE = 100000;


@slider

freq_lo         = min(slider1, slider2);
freq_hi         = max(slider1, slider2);
high_secs       = slider3;
low_secs        = slider4;
fade_down_secs  = slider5;
fade_down_shape = slider6;
fade_up_secs    = slider7;
fade_up_shape   = slider8;
resonance       = slider9;
wet             = slider10;
dry             = 1 - wet;
phase_offset    = slider11 / 360;

// ===== PAN BLOCK SLIDER READ START =====
pan_enabled     = slider13;
pan_mode        = slider14;
pan_spread      = slider15;
pan_glide_ms    = slider16;
pan_cycle_steps = slider17;
pan_sweep_val   = slider18;
pan_sweep_mode  = slider19;
pan_sweep_ratio = slider20;

slider_show(slider14, pan_enabled);
slider_show(slider15, pan_enabled);
slider_show(slider16, pan_enabled);
slider_show(slider17, pan_enabled && pan_mode >= 1 && pan_mode <= 9);
slider_show(slider18, pan_enabled && (pan_mode == 10 || pan_mode == 11));
slider_show(slider19, pan_enabled && (pan_mode == 10 || pan_mode == 11));
slider_show(slider20, pan_enabled && pan_mode == 12);
// ===== PAN BLOCK SLIDER READ END =====

start_delay_sec = slider21;

// Play/Rest gate: integer cycle counts. Both must be > 0 for the
// gate to engage; 0 in either slider disables.
play_for_cycles = slider22;
rest_for_cycles = slider23;
new_pr_enabled  = (play_for_cycles > 0 && rest_for_cycles > 0);
// Defensive reset: if user disables the gate mid-rest, snap pr_resting
// back to 0 and zero the progress counter. effect_mix will smoothly
// ramp back to 1 via the @sample smoother.
!new_pr_enabled && pr_resting ? (
  pr_resting = 0;
  pr_cycle_progress = 0;
);
pr_enabled       = new_pr_enabled;
rest_lfo_mode    = slider24;
rest_output_mode = slider25;

// Speed ramp engage-edge.
slider28 && !speed_ramp_engaged_last ? (
  speed_scale_start = speed_scale_current;
  speed_ramp_t      = 0.0;
);
speed_ramp_engaged_last = slider28;


@sample

// Re-arm Start Delay on every transport stop/start. During the delay
// window the filter state stays frozen and spl0/spl1 pass through
// unchanged.
play_state > 0 && last_play_state == 0 ? (
  start_delay_elapsed = 0;
);
last_play_state = play_state;

start_delay_elapsed < start_delay_sec ? (
  start_delay_elapsed += 1 / srate;
  // No-op — spl0 and spl1 pass through unchanged.
) : (

freq_lo         = min(slider1, slider2);
freq_hi         = max(slider1, slider2);
high_secs       = slider3;
low_secs        = slider4;
fade_down_secs  = slider5;
fade_down_shape = slider6;
fade_up_secs    = slider7;
fade_up_shape   = slider8;
resonance       = slider9;
wet             = slider10;
dry             = 1 - wet;
phase_offset    = slider11 / 360;

// ===== PAN BLOCK SAMPLE READ START =====
pan_enabled     = slider13;
pan_mode        = slider14;
pan_spread      = slider15;
pan_glide_ms    = slider16;
pan_cycle_steps = slider17;
pan_sweep_val   = slider18;
pan_sweep_mode  = slider19;
pan_sweep_ratio = slider20;
// ===== PAN BLOCK SAMPLE READ END =====

period = high_secs + fade_down_secs + low_secs + fade_up_secs;
freq   = 1 / max(period, 0.00001);

// Advance speed ramp and scale freq by the resulting multiplier so
// the whole dwell pattern stretches/compresses smoothly. The cut
// smoother below absorbs any per-sample step change. Wobble layers
// on top, multiplying freq again when a slot is assigned.
slider28 && slider27 > 0 ? (
  speed_ramp_t += 1.0 / (srate * slider27 * 60);
  speed_ramp_t = min(speed_ramp_t, 1.0);
  speed_scale_current = speed_scale_start + (slider26 - speed_scale_start) * speed_ramp_t;
);
wobble_mult = 1.0;
slider29 > 0 ? (
  raw_wobble = gmem[WOBBLE_BASE + slider29];
  raw_wobble > 0 ? wobble_mult = raw_wobble;
);
freq = freq * speed_scale_current * wobble_mult;

// Smoother coefficient — used for cut_smooth below and effect_mix
// just below that. Moved up so both can share the same value.
smooth = exp(-1 / (srate * 0.003));

// Play/Rest gate state machine. pr_cycle_progress accumulates
// fractional cycles at the dwell-pattern frequency (1 / total
// period); when it crosses the threshold for the current state,
// pr_resting flips and the counter resets.
pr_enabled ? (
  pr_cycle_progress += freq / srate;
  !pr_resting ? (
    pr_cycle_progress >= play_for_cycles ? (
      pr_resting = 1;
      pr_cycle_progress = 0;
    );
  ) : (
    pr_cycle_progress >= rest_for_cycles ? (
      pr_resting = 0;
      pr_cycle_progress = 0;
    );
  );
);

// LFO at rest = Freeze → in_frozen_rest gates phase_l/r and
// pan_phase advancement during rest.
in_frozen_rest = pr_enabled && pr_resting && rest_lfo_mode == 1;

// effect_mix smoothly transitions between 1 (effect fully on) and
// 0 (rest target) at rest boundaries. The rest target depends on
// Output at rest: dry_l/r (pass-through) for Pass-through, 0
// (silence) for Silence. Below, the play-mode wet/dry mix and the
// rest target are interpolated by effect_mix to produce the final
// spl0/spl1 — soft fade between effect-on and whichever rest
// state was chosen.
target_effect_mix = pr_enabled && pr_resting ? 0 : 1;
effect_mix        = effect_mix * smooth + target_effect_mix * (1 - smooth);
silence_mode      = (rest_output_mode == 1);

// Advance dwell-pattern LFO phases unless Freeze rest is pinning them.
!in_frozen_rest ? (
  phase_l += freq / srate;
  phase_l >= 1 ? phase_l -= 1;

  slider12 == 0 ? (
    phase_r += freq / srate;
    phase_r >= 1 ? phase_r -= 1;
  ) : (
    phase_r = phase_l + phase_offset;
    phase_r >= 1 ? phase_r -= 1;
    phase_r < 0  ? phase_r += 1;
  );
);

lfo_l = calc_lfo(phase_l, high_secs, low_secs, fade_down_secs, fade_up_secs, fade_down_shape, fade_up_shape);
lfo_r = calc_lfo(phase_r, high_secs, low_secs, fade_down_secs, fade_up_secs, fade_down_shape, fade_up_shape);

target_freq_l = freq_lo + lfo_l * (freq_hi - freq_lo);
target_freq_r = freq_lo + lfo_r * (freq_hi - freq_lo);

cut_target_l = target_freq_l * 2 / srate;
cut_target_r = target_freq_r * 2 / srate;

cut_smooth_l = cut_smooth_l * smooth + cut_target_l * (1 - smooth);
cut_smooth_r = cut_smooth_r * smooth + cut_target_r * (1 - smooth);

dry_l = spl0;
dry_r = spl1;

fb_l = resonance + resonance / (1 - cut_smooth_l);
n3   = n3  + cut_smooth_l * (spl0 - n3  + fb_l * (n3  - n4));
n4   = n4  + cut_smooth_l * (n3   - n4);
out_l = n4;

fb_r = resonance + resonance / (1 - cut_smooth_r);
rn3  = rn3 + cut_smooth_r * (spl1 - rn3 + fb_r * (rn3 - rn4));
rn4  = rn4 + cut_smooth_r * (rn3  - rn4);
out_r = rn4;

// Compute play-mode output (normal wet/dry mix), then blend with
// the rest target via effect_mix. Rest target: dry_l/r for
// Pass-through, 0 for Silence. Filter state (n3/n4/rn3/rn4) and
// cut_smooth keep running through rest so the filter is "warm"
// and re-engages cleanly on rest exit.
play_spl0 = dry * dry_l + wet * out_l;
play_spl1 = dry * dry_r + wet * out_r;
rest_spl0 = silence_mode ? 0 : dry_l;
rest_spl1 = silence_mode ? 0 : dry_r;
spl0 = effect_mix * play_spl0 + (1 - effect_mix) * rest_spl0;
spl1 = effect_mix * play_spl1 + (1 - effect_mix) * rest_spl1;

// ===== PAN BLOCK SAMPLE LOGIC START =====
pan_enabled ? (
  // Per-cycle pan modes (0-9) advance pan_cycle_index on dwell LFO
  // phase wraps. Since the dwell phase_l advancement above is
  // gated by !in_frozen_rest, cycle_fired never triggers during
  // Freeze rest — pan_cycle_index naturally pauses too.
  cycle_fired  = (phase_l < last_phase_l);
  last_phase_l = phase_l;

  pan_mode <= 9 ? (
    cycle_fired ? (
      pan_mode == 5 || pan_mode == 7 || pan_mode == 9 ? (
        pan_cycle_index += pan_cycle_dir;
        (pan_cycle_index >= pan_cycle_steps - 1 || pan_cycle_index <= 0) ?
          pan_cycle_dir = -pan_cycle_dir;
      ) : (
        pan_cycle_index = (pan_cycle_index + 1) % pan_cycle_steps;
      );
    );
    cur_pan = percycle_pan(pan_cycle_index, pan_cycle_steps);
    pan_l = cur_pan;

  ) : pan_mode == 10 ? (
    // Pan Sweep — gate phase advance for Freeze mode.
    pan_sweep_mode == 0 ? (pan_freq = pan_sweep_val) :
    pan_sweep_mode == 1 ? (pan_freq = 1 / max(pan_sweep_val, 0.001)) :
                          (pan_freq = pan_sweep_val / 60);
    !in_frozen_rest ? (
      pan_phase += pan_freq / srate;
      pan_phase >= 1 ? pan_phase -= 1;
    );
    cur_pan = (pan_phase * 2.0 - 1.0) * pan_spread;
    pan_l = cur_pan;

  ) : pan_mode == 11 ? (
    // Pan Sweep Flipped — gate phase advance for Freeze mode.
    pan_sweep_mode == 0 ? (pan_freq = pan_sweep_val) :
    pan_sweep_mode == 1 ? (pan_freq = 1 / max(pan_sweep_val, 0.001)) :
                          (pan_freq = pan_sweep_val / 60);
    !in_frozen_rest ? (
      pan_phase += pan_freq / srate;
      pan_phase >= 1 ? pan_phase -= 1;
    );
    cur_pan = (1.0 - pan_phase * 2.0) * pan_spread;
    pan_l = cur_pan;

  ) : (
    // Linked Sweep — gate phase advance for Freeze mode.
    !in_frozen_rest ? (
      pan_phase += (freq * pan_sweep_ratio) / srate;
      pan_phase >= 1 ? pan_phase -= 1;
    );
    cur_pan = (pan_phase * 2.0 - 1.0) * pan_spread;
    pan_l = cur_pan;
  );

  pan_glide_coeff = pan_glide_ms > 0 ? exp(-1 / (srate * pan_glide_ms * 0.001)) : 0;
  pan_l_smooth = pan_l_smooth * pan_glide_coeff + pan_l * (1 - pan_glide_coeff);

  // Apply the pan, then blend with the un-panned signal via
  // effect_mix. During rest, effect_mix → 0 means the output is
  // whatever spl0 was BEFORE the pan block ran — which already
  // reflects the rest target (dry pass-through OR silence)
  // because the wet/dry blend above used effect_mix.
  pan_pos = (pan_l_smooth + 1.0) * 0.5;
  mono = (spl0 + spl1) * 0.5;
  spl0_panned = mono * cos(pan_pos * $pi * 0.5);
  spl1_panned = mono * sin(pan_pos * $pi * 0.5);
  spl0 = spl0 * (1 - effect_mix) + spl0_panned * effect_mix;
  spl1 = spl1 * (1 - effect_mix) + spl1_panned * effect_mix;
);
// ===== PAN BLOCK SAMPLE LOGIC END =====

);  // close start-delay else branch