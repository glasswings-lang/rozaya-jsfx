desc: Binaural Polyrhythm Oscillator v2
// Designed by Rozaya, developed with Claude (Anthropic)
//
// This work is dedicated to the public domain under CC0 1.0 Universal.
// https://creativecommons.org/publicdomain/zero/1.0/
//
// v2 adds Play/Rest gating (sliders 63, 64) on top of the v1 feature
// set. Per-voice cycle counting means V8 (fast drift) paces ahead of
// V1 in real time. On the final cycle of each play period the always-
// on Depth floor is cancelled during the release portion of the LFO
// so the voice glides to actual silence before the rest freeze,
// regardless of the user's Depth setting. With the new sliders at
// their defaults (both 0), the gate is disabled and the plugin is
// functionally identical to v1 — existing project files keep working
// without modification.

// ===== GLOBAL CONTROLS =====
slider1:0<0,1,1{Drift,Independent}>Tremolo Mode
slider2:0<0,2,1{BPM,Seconds,Hz}>Rate Mode
slider3:60<0.001,1000,0.001>Rate Value (Drift only)
slider4:4<0,100,0.1>Binaural Beat Hz (L/R offset)
slider5:100<0,100,0.1>On Duration % of Cycle
slider6:0<0,100,0.1>Attack % of Cycle
slider7:100<0,100,0.1>Release % of Cycle
slider8:1<0,3,1{Linear,Cosine,Logarithmic,Exponential}>Attack Shape
slider9:1<0,3,1{Linear,Cosine,Logarithmic,Exponential}>Release Shape
slider10:-6<-60,0,0.1>Depth dB
slider11:440<400,480,0.1>Tuning Reference Hz

// ===== BASE PITCH =====
slider12:0<0,11,1{C,C#,D,D#,E,F,F#,G,G#,A,A#,B}>Base Note
slider13:4<0,8,1>Center Octave

// ===== WAVEFORM =====
slider14:0<0,13,1{Sine,Triangle,Saw,Golden TS,Golden SG,Golden GS,Bell,Wavefold,Half-sine,Phi-cascade,Phi Triangle,Phi Sine,Square,Pulse}>Waveform

// ===== PAN =====
slider15:0<0,1,1{Off,On}>Pan Enabled
slider16:0<0,3,1{Tremolo,Increment,Spread,Spread Reversed}>Pan Mode
slider17:100<0,100,0.1>Pan Spread %
slider18:60<0.001,1000,0.001>Pan Base Rate
slider19:0<-1000,1000,0.001>Pan Increment per Voice

// ===== VOICE 1 =====
// Note: Active toggles bypass oscillator computation entirely.
// On modern hardware this makes no audible difference; on older machines,
// disabling unused voices reduces CPU load. Gain at -60 dB is effectively
// silent but still costs CPU. Use Active=Off to fully cut a voice.
//
// Phase Offset unit follows Rate Mode: BPM = beats, Seconds = seconds, Hz = cycles.
// Values wrap freely — there is no clamping. Voice 1 default is 0 (no offset).
slider20:-6<-60,6,0.1>V1 Gain dB
slider21:0<-1000,1000,1>V1 Semitones
slider22:0<-1000,1000,0.001>V1 Drift / Rate
slider23:0<-1000,1000,0.001>V1 Phase Offset
slider24:1<0,1,1{Off,On}>V1 Active (Off = no CPU cost)

// ===== VOICE 2 =====
slider25:-60<-60,6,0.1>V2 Gain dB
slider26:0<-1000,1000,1>V2 Semitones
slider27:0<-1000,1000,0.001>V2 Drift / Rate
slider28:0<-1000,1000,0.001>V2 Phase Offset
slider29:1<0,1,1{Off,On}>V2 Active (Off = no CPU cost)

// ===== VOICE 3 =====
slider30:-60<-60,6,0.1>V3 Gain dB
slider31:0<-1000,1000,1>V3 Semitones
slider32:0<-1000,1000,0.001>V3 Drift / Rate
slider33:0<-1000,1000,0.001>V3 Phase Offset
slider34:0<0,1,1{Off,On}>V3 Active (Off = no CPU cost)

// ===== VOICE 4 =====
slider35:-60<-60,6,0.1>V4 Gain dB
slider36:0<-1000,1000,1>V4 Semitones
slider37:0<-1000,1000,0.001>V4 Drift / Rate
slider38:0<-1000,1000,0.001>V4 Phase Offset
slider39:0<0,1,1{Off,On}>V4 Active (Off = no CPU cost)

// ===== VOICE 5 =====
slider40:-60<-60,6,0.1>V5 Gain dB
slider41:0<-1000,1000,1>V5 Semitones
slider42:0<-1000,1000,0.001>V5 Drift / Rate
slider43:0<-1000,1000,0.001>V5 Phase Offset
slider44:0<0,1,1{Off,On}>V5 Active (Off = no CPU cost)

// ===== VOICE 6 =====
slider45:-60<-60,6,0.1>V6 Gain dB
slider46:0<-1000,1000,1>V6 Semitones
slider47:0<-1000,1000,0.001>V6 Drift / Rate
slider48:0<-1000,1000,0.001>V6 Phase Offset
slider49:0<0,1,1{Off,On}>V6 Active (Off = no CPU cost)

// ===== VOICE 7 =====
slider50:-60<-60,6,0.1>V7 Gain dB
slider51:0<-1000,1000,1>V7 Semitones
slider52:0<-1000,1000,0.001>V7 Drift / Rate
slider53:0<-1000,1000,0.001>V7 Phase Offset
slider54:0<0,1,1{Off,On}>V7 Active (Off = no CPU cost)

// ===== VOICE 8 =====
slider55:-60<-60,6,0.1>V8 Gain dB
slider56:0<-1000,1000,1>V8 Semitones
slider57:0<-1000,1000,0.001>V8 Drift / Rate
slider58:0<-1000,1000,0.001>V8 Phase Offset
slider59:0<0,1,1{Off,On}>V8 Active (Off = no CPU cost)

// ===== DIRECTION & REVERSE =====
// Forward            — 8 voices, current behavior.
// Reverse — permute  — 8 voices. Drift values mirrored V1↔V8, V2↔V7,
//                       V3↔V6, V4↔V5; notes, gains, phase offsets,
//                       active flags stay in place. The low note now
//                       fires at the highest cadence and vice versa.
//                       (Permuting every setting together is a no-op
//                       on the audio sum — slot order doesn't change
//                       what gets added. Mirroring just drift is what
//                       produces an audible reordering.)
// Reverse — time     — 8 voices, tremolo phase decrements instead of
//                       increments. The on/off pattern (and any
//                       asymmetric attack/release envelope) plays
//                       backwards.
// Both — permute     — 16 voices. Forward layer (slots 0-7) unchanged.
//                       Reverse layer (slots 8-15) is the forward layer
//                       with drift values mirrored — each note plays at
//                       TWO different cadences across the two layers,
//                       creating harmonic-pair pulses at the fast end
//                       and offset solo pulses at the slow end.
// Both — time        — 16 voices. Forward layer (slots 0-7) unchanged.
//                       Reverse layer (slots 8-15) has the same drift
//                       as the forward layer but the tremolo phase
//                       advances backward, so the asymmetric envelope
//                       fades in where the forward layer fades out —
//                       the pulsing cancels into a continuous drone.
slider60:0<0,4,1{Forward,Reverse — permute,Reverse — time,Both — permute,Both — time}>Direction & Reverse

// Added to every drift/rate value in the reverse layer (slots 8-15) in
// Both modes. With a non-zero offset the two layers no longer run at
// matched cadences — the reverse layer's drift range shifts away from
// the forward layer's, so each voice in the reverse layer fires at a
// genuinely different cadence than its forward counterpart. This
// replaces the multi-track-per-scene stacking workflow where each
// track of a "drift pair" sat at a different rate range. Hidden by
// slider_show in single-layer modes (Forward / Reverse — permute /
// Reverse — time) where it would only duplicate the global Rate Value.
slider61:0<-1000,1000,0.001>Reverse Drift Offset

// ===== START DELAY =====
// Plugin sits silent for this many units after playback starts, then
// resumes normally. Units match Rate Mode (BPM beats / Seconds /
// Hz cycles), interpreted against the global Rate Value (slider3) for
// beats and cycles. 0 (default) = no delay. Re-arms on every transport
// stop/start. During the delay window the voice loop is skipped
// entirely so the per-voice phase counters stay at their play-start
// reset positions — when the delay ends, voices begin cleanly from
// phase 0 (or their phase offsets) rather than mid-fade.
slider62:0<0,1000,0.001>Start Delay

// ===== PLAY / REST GATING =====
// Per-voice cyclic gate. Each voice plays for `Play for` cycles of
// its OWN tremolo rate (global rate + per-voice drift), then is silent
// for `Rest for` cycles of the same per-voice rate, then resumes.
// Because counting is per-voice, V8 (high drift, fast cadence) reaches
// its play threshold sooner in real time than V1 (drift 0, slow
// cadence) and enters rest first — and wakes first too, since the
// rest counter also advances at the voice's own rate. The "loop" the
// listener hears is per-voice; the global rhythmic identity comes
// from how the voices' independent play/rest cycles interlock.
//
// Reaching actual silence before rest. On the FINAL cycle of each
// play period, the always-on Depth floor (`amount`) is cancelled
// during the release portion of the LFO — so the release tail decays
// to genuine 0 instead of bottoming at the Depth setting. With
// default Depth = -6 dB the voice tremolos between ~50% and ~75%
// gain during normal play, so without this override the rest freeze
// would catch the voice at ~50% and the 3 ms smoother would thud on
// the way down. With the override, the voice naturally glides to 0
// over the final release and the freeze is silent. Cycles 1 through
// (Play for - 1) play with the normal formula — only the last
// release shape changes.
//
// This requires a non-zero Release setting to do anything audible.
// With Release = 0% the release zone has zero width, the override
// never fires, and you get the sharp cutoff that Release = 0 implies.
//
// Feature disabled if either slider is 0 — the voice loop runs
// continuously then with no resting and no Depth-floor override.
//
// Transport. Stop/play does NOT preserve gate state — pressing play
// re-initializes everything (voice phases, Start Delay counter,
// per-voice cycle counters all reset). Conventional Reaper behavior;
// the gate begins a fresh play period from voice cycle 0 on every
// play press.
slider63:0<0,1000,1>Play for (cycles)
slider64:0<0,1000,1>Rest for (cycles)

// Speed ramp: in-plugin slowdown/speedup over time. Scales every
// voice's tremolo + pan + per-voice-cycle-counter advance by
// speed_scale_current per sample, so the entire polyrhythm stretches
// or compresses while preserving the rate RELATIONSHIPS between
// voices. 0.5 = whole polyrhythm at half speed (every voice slows
// proportionally — V1's 60 BPM and V2's 60.5 BPM both halve to 30
// and 30.25 BPM, preserving the slow beat between them); 2.0 =
// double. Tuning and binaural beat are unaffected — only the
// modulation rates scale.
slider65:1.0<0.1,4.0,0.01>Speed ramp target (multiplier)
slider66:0<0,60,0.1>Speed ramp duration (minutes)
slider67:0<0,1,1{Off,On}>Speed ramp engage

// ===== CHARACTER (global post-effects) =====
// Four sliders that adjust the character of WHATEVER waveform is
// selected. Applied to the summed output of all voices after all
// per-voice processing — so they shape the overall sound, not each
// individual voice. Defaults are all neutral (Tone=0, Edge=0,
// Movement=0, Body=0), so loading the plugin sounds identical to
// the v2.x release until you push one.
//
// Tone (-100 to +100): tilt EQ. Negative = warmer/darker (boost
// lows, attenuate highs); positive = brighter/airier (boost highs,
// attenuate lows). One slider that covers the warmth ↔ brightness
// axis. Crossover ~700 Hz, max boost ±~9 dB at the extremes.
//
// Edge (0-100): soft-clip drive on the summed signal. At 0 = clean;
// higher values progressively add harmonic grit. A sine + Edge gets
// a saw-flavored character; a triangle + Edge gets more bite. Uses
// tanh saturation with gain compensation so the level stays roughly
// constant as you push it.
//
// Movement (0-100): chorus on the output. Mono input fed through a
// modulated delay line read at two LFO-offset points (one for each
// output channel) to give stereo shimmer and motion. At 0 = no
// effect; higher values increase the wet mix.
//
// Body (0-100): peaking EQ at the Base Note + Center Octave
// frequency. Boosts the root note's fundamental region by up to
// +12 dB. Pitch-tracking — as you change Base Note or Center
// Octave, the body peak moves with it. Useful for the Golden /
// Phi waves which can sound thin in the low end.
slider69:0<-100,100,0.1>Tone (Warm <-> Bright)
slider70:0<0,100,0.1>Edge
slider71:0<0,100,0.1>Movement
slider72:0<0,100,0.1>Body

// ===== PULSE WIDTH (Waveform slot 13 only) =====
// Duty cycle for the Pulse waveform: the fraction of each cycle the
// wave spends "high" before snapping low. 50% is a square wave (and
// equals the Square slot); narrower values get thinner and more nasal,
// wider values mirror the same back the other way. Only meaningful when
// Waveform is set to Pulse (slot 13); hidden via slider_show otherwise.
// Default 25% so Pulse sounds audibly distinct from the Square slot on
// first selection. Range stops short of 0/100 (which would be silence/DC).
slider73:25<1,99,0.1>Pulse Width % (50 = square)

// ===== DRIFT (per-plugin, built-in) =====
// Two independent drift sources that perturb the global rate. Both are
// applied polyrhythm-wide (added to every voice's effective rate via
// v_dr offset), preserving the rate RELATIONSHIPS between voices —
// the whole pattern breathes together. Output is in the plugin's
// natural rate unit (BPM when Rate Mode = BPM; the magnitudes below
// assume BPM as the most common default — values still apply in
// Seconds / Hz modes but the perceptual amount differs).
//
// Musical drift scales with Speed Ramp (when Speed Ramp slows the
// rate, musical drift slows with it). Slow drift is wall-clock —
// independent of Speed Ramp.
//
// Shape applies to both drift sources.
//
// Defensive: if both Up by and Down by are 0, that source's math is
// skipped entirely (zero CPU cost when unused).
slider74:0<0,20,0.1>Musical drift: Up by
slider75:0<0,20,0.1>Musical drift: Down by
slider76:8<1,1000,1>Musical drift: Period (cycles)
slider77:0<0,20,0.1>Slow drift: Up by
slider78:0<0,20,0.1>Slow drift: Down by
slider79:5<0.1,60,0.1>Slow drift: Period (minutes)
slider80:0<0,2,1{Sine,Triangle,Random}>Drift shape


@init
// Conventional Reaper behavior: @init runs on plugin load AND on every
// transport play. That re-zeros all the slot memory below, so stop/play
// gives a clean restart — voice phases reset, Start Delay re-arms,
// per-voice Play/Rest counters reset. No `ext_noinit = 1` here.

PHI = 1.6180339887;

// Memory layout — 16 slots each
osc_phase_l  = 0;
osc_phase_r  = 16;
trem_phase   = 32;
gain_l       = 48;
gain_r       = 64;
v_freq_l     = 80;
v_freq_r     = 96;
v_trem_freq  = 112;
v_active     = 128;
v_semitones  = 144;
v_dr         = 160;  // Drift (Drift mode) or Rate (Independent mode)
pan_phase    = 176;
pan_smooth   = 192;
v_pan_freq   = 208;
v_gain       = 224;
v_phase_off      = 240;  // Phase offset, stored as raw slider value (unit = Rate Mode unit)
v_phase_off_last = 256;  // Last known offset per voice — used to detect live changes
v_pan_static     = 272;  // Static pan target per voice (-1..+1) for Spread modes
v_resting        = 288;  // Per-voice Play/Rest flag: 1 = frozen (rest), 0 = playing
v_pr_cycle       = 304;  // Per-voice Play/Rest cycle counter — accumulates at the
                         //   voice's own v_trem_freq[i] regardless of play/rest
                         //   state. Compared against play_for_cycles (when playing)
                         //   or rest_for_cycles (when resting); reset to 0 on each
                         //   state flip. This is what makes V8 (fast drift) pause
                         //   sooner in real time than V1 (slow drift) — and wake
                         //   sooner too, since the rest counter also advances at
                         //   the voice's own rate. Symmetric per-voice semantic.

// Character chain state (post-voice-sum DSP, sliders 69-72).
// Tone:  one-pole lowpass state per channel for the tilt EQ.
// Edge:  stateless (tanh) — no state needed.
// Body:  biquad peaking EQ per channel — last 2 in / last 2 out samples each.
tone_lp_l   = 0;
tone_lp_r   = 0;
body_x1_l   = 0;
body_x2_l   = 0;
body_y1_l   = 0;
body_y2_l   = 0;
body_x1_r   = 0;
body_x2_r   = 0;
body_y1_r   = 0;
body_y2_r   = 0;

// Movement: mono delay buffer at slot 320, 8192 samples (enough for ~85 ms
// at 96 kHz, ~170 ms at 48 kHz). Two LFO-offset read taps drive L/R output
// for stereo chorus motion.
chorus_buf       = 320;   // 320..8511 (8192 slots)
chorus_buf_size  = 8192;
chorus_write_pos = 0;
chorus_lfo_phase = 0;

// Initialize 16 slots — slots 0-7 always used; slots 8-15 hold the
// reverse layer in Both modes and stay zeroed otherwise.
i = 0;
loop(16,
  osc_phase_l[i] = 0;
  osc_phase_r[i] = 0;
  trem_phase[i]  = 0;
  gain_l[i]      = 1;
  gain_r[i]      = 1;
  pan_smooth[i]  = 0;
  v_gain[i]      = 1;
  v_phase_off[i]      = 0;
  v_phase_off_last[i] = 0;
  v_resting[i]        = 0;
  v_pr_cycle[i]       = 0;
  i += 1;
);

smooth = exp(-1 / (srate * 0.003));

// Counts up from 0 at each play start until it reaches start_delay_sec,
// then the voice loop runs normally. start_delay_sec is computed in
// @slider from the user-facing units; initialized to 0 here so the
// default behavior (no delay) doesn't gate the first sample.
start_delay_elapsed = 0;
start_delay_sec     = 0;

// Play/Rest gating state. play_for_cycles / rest_for_cycles are read
// from sliders 63/64 in @slider. Each voice has its own cycle counter
// (v_pr_cycle[i]) advancing at its own v_trem_freq[i] — no global
// counter needed. v_resting and v_pr_cycle are zeroed in the slot-init
// loop above, so all voices start in the "playing" state on every
// transport play (since @init re-runs on play).
play_for_cycles = 0;
rest_for_cycles = 0;

// Speed ramp state.
speed_ramp_engaged_last = 0;
speed_scale_current     = 1.0;
speed_scale_start       = 1.0;
speed_ramp_t            = 0.0;

// Drift state. Two independent phase accumulators (musical = scales
// with Speed Ramp, slow = wall-clock). prev/curr targets feed the
// Random shape's linear interpolation between successive random
// targets at each wrap. @init re-runs on transport play so phases
// reset cleanly on every play press, matching Speed Ramp behavior.
musical_drift_phase = 0;
slow_drift_phase    = 0;
musical_drift_prev_target = 0;
musical_drift_curr_target = 0;
slow_drift_prev_target    = 0;
slow_drift_curr_target    = 0;

function semitones_to_hz(base_note, center_octave, semitones) (
  tuning_ref * pow(2, ((center_octave + 1) * 12 + base_note + semitones - 69) / 12.0)
);

function apply_curve(t, shape) (
  shape == 0 ? t :
  shape == 1 ? (0.5 - 0.5 * cos(t * $pi)) :
  shape == 2 ? (log(1 + 9*t) / log(10)) :
               ((pow(10, t) - 1) / 9)
);

function calc_lfo(ph, on_frac, att_frac, rel_frac, att_shape, rel_shape)
local(aw, rw, hold_w, re_start, t, result, total) (
  aw = att_frac;
  rw = rel_frac;
  aw + rw > on_frac ? (
    total = aw + rw;
    aw = aw / total * on_frac;
    rw = rw / total * on_frac;
  );
  hold_w   = on_frac - aw - rw;
  re_start = aw + hold_w;
  ph < aw ? (
    aw > 0.0001 ? (
      t = ph / aw;
      result = apply_curve(t, att_shape);
    ) : (result = 1);
  ) :
  ph < re_start ? (
    result = 1;
  ) :
  ph < on_frac ? (
    rw > 0.0001 ? (
      t = 1 - (ph - re_start) / rw;
      result = apply_curve(t, rel_shape);
    ) : (result = 0);
  ) : (
    result = 0;
  );
  result
);

function rate_to_hz(raw_rate, rmode) (
  rmode == 0 ? max(raw_rate, 0.001) / 60 :
  rmode == 1 ? 1 / max(raw_rate, 0.001) :
               max(raw_rate, 0.001)
);

// Hyperbolic tangent — not built into eel2, so define it here. Used
// by the Edge character slider for soft-clip saturation. Clamps the
// exp() input above |x| > 7 to avoid overflow on extreme inputs
// (tanh saturates to ±1 well before that anyway).
function tanh(x) local(e2x) (
  abs(x) > 7 ? sign(x) : (
    e2x = exp(2 * x);
    (e2x - 1) / (e2x + 1)
  )
);

// PolyBLEP correction for a step discontinuity. Returns a small
// corrective bump in the samples immediately before AND after t = 0/1.
// Caller ADDs it at an upward step (-1 → +1) or SUBTRACTs at a downward
// step (+1 → -1) to band-limit the corner over ~2 samples. Used by the
// Square (slot 12) and Pulse (slot 13) waveforms.
//   t  = phase position relative to the edge (0..1)
//   dt = phase increment per sample at this voice's frequency
function polyblep(t, dt) local(s) (
  t < dt ? (
    s = t / dt;
    s + s - s * s - 1;
  ) : t > 1 - dt ? (
    s = (t - 1) / dt;
    s * s + s + s + 1;
  ) : (
    0;
  );
);

@slider

trem_mode     = slider1;
rate_mode     = slider2;
rate_val      = slider3;
bin_beat_hz   = slider4;
on_dur_pct    = slider5;
att_pct       = slider6;
rel_pct       = slider7;
att_shape     = slider8;
rel_shape     = slider9;
depth_db      = slider10;
tuning_ref    = slider11;
base_note     = slider12;
center_octave = slider13;
waveform      = slider14;
pan_enabled   = slider15;
pan_mode      = slider16;
pan_spread    = slider17 / 100.0;
pan_base_rate = slider18;
pan_increment = slider19;

v_gain[0] = slider20; v_semitones[0] = slider21; v_dr[0] = slider22; v_phase_off[0] = slider23; v_active[0] = slider24;
v_gain[1] = slider25; v_semitones[1] = slider26; v_dr[1] = slider27; v_phase_off[1] = slider28; v_active[1] = slider29;
v_gain[2] = slider30; v_semitones[2] = slider31; v_dr[2] = slider32; v_phase_off[2] = slider33; v_active[2] = slider34;
v_gain[3] = slider35; v_semitones[3] = slider36; v_dr[3] = slider37; v_phase_off[3] = slider38; v_active[3] = slider39;
v_gain[4] = slider40; v_semitones[4] = slider41; v_dr[4] = slider42; v_phase_off[4] = slider43; v_active[4] = slider44;
v_gain[5] = slider45; v_semitones[5] = slider46; v_dr[5] = slider47; v_phase_off[5] = slider48; v_active[5] = slider49;
v_gain[6] = slider50; v_semitones[6] = slider51; v_dr[6] = slider52; v_phase_off[6] = slider53; v_active[6] = slider54;
v_gain[7] = slider55; v_semitones[7] = slider56; v_dr[7] = slider57; v_phase_off[7] = slider58; v_active[7] = slider59;

direction_reverse     = slider60;
reverse_drift_offset  = slider61;
slot0_7_permute       = (direction_reverse == 1);
slot8_15_permute      = (direction_reverse == 3);
slot0_7_reverse_time  = (direction_reverse == 2);
slot8_15_reverse_time = (direction_reverse == 4);
is_both               = (direction_reverse == 3 || direction_reverse == 4);
n_voices              = is_both ? 16 : 8;

// Start delay — convert the user-facing units to seconds based on Rate
// Mode. BPM beats and Hz cycles are interpreted against the global
// Rate Value (slider3), which is what "1 beat" or "1 cycle" means.
// Seconds mode is literal seconds regardless of Rate Value.
start_delay_units = slider62;
rate_mode == 0 ? start_delay_sec = start_delay_units * 60 / max(rate_val, 0.001) :
rate_mode == 1 ? start_delay_sec = start_delay_units :
                 start_delay_sec = start_delay_units / max(rate_val, 0.001);

// Play/Rest gating — slider values are integer voice-cycle counts.
// Each voice counts ITS OWN cycles (advancing at v_trem_freq[i],
// which is the voice's tremolo Hz after global rate + per-voice drift
// are applied). Per-voice counting + thresholding lives in the voice
// loop in @sample; nothing global to compute here.
play_for_cycles = slider63;
rest_for_cycles = slider64;

// Speed ramp engage-edge.
slider67 && !speed_ramp_engaged_last ? (
  speed_scale_start = speed_scale_current;
  speed_ramp_t      = 0.0;
);
speed_ramp_engaged_last = slider67;

// Reverse — permute (single layer, option 1): mirror the per-voice
// drift/rate values V1↔V8, V2↔V7, V3↔V6, V4↔V5. Notes, gains, phase
// offsets, and active flags stay in place — only the cadences swap.
// The audio sum is commutative across voice slots, so swapping a
// voice's COMPLETE identity is a no-op; mirroring just drift means
// V1's note now fires at V8's cadence and vice versa, which is the
// audible effect modders expect from this slider.
slot0_7_permute ? (
  i = 0;
  loop(4,
    j = 7 - i;
    tmp = v_dr[i]; v_dr[i] = v_dr[j]; v_dr[j] = tmp;
    i += 1;
  );
);

// Both modes (options 3, 4): copy slots 0-7 to slots 8-15. Slots 0-7
// keep the forward-layer settings; slots 8-15 hold the reverse-layer
// settings. v_phase_off_last is intentionally NOT copied — leaving it
// at slot 8-15's prior value (0 from @init, or stale) means the
// @sample live-offset-change detector fires when entering Both mode,
// cleanly initializing trem_phase[8..15] from the offset.
is_both ? (
  i = 0;
  loop(8,
    v_gain[i + 8]      = v_gain[i];
    v_semitones[i + 8] = v_semitones[i];
    v_dr[i + 8]        = v_dr[i];
    v_phase_off[i + 8] = v_phase_off[i];
    v_active[i + 8]    = v_active[i];
    i += 1;
  );
  // Both — permute: mirror the drift values inside the reverse layer
  // (slots 8↔15, 9↔14, 10↔13, 11↔12), keeping notes/gains/offsets in
  // place. Result: slot 8 plays V1's note at V8's cadence, slot 15
  // plays V8's note at V1's cadence. Each note now fires at TWO
  // different cadences across the two layers — harmonic pairs at the
  // fast cadences, separate notes at the slow ones. Both — time skips
  // the swap (slots 8-15 keep V1..V8's drift unchanged) so the two
  // layers run at matched cadences in opposite time directions, which
  // cancels asymmetric envelope pulses into a continuous drone.
  slot8_15_permute ? (
    i = 0;
    loop(4,
      k = 8 + i;
      j = 15 - i;
      tmp = v_dr[k]; v_dr[k] = v_dr[j]; v_dr[j] = tmp;
      i += 1;
    );
  );

  // Shift every drift value in the reverse layer by the offset. Applied
  // AFTER the optional mirror so the post-mirror values are what get
  // shifted (mirror and offset commute mathematically since mirror is
  // just reordering and offset is a uniform add, but keeping the order
  // "mirror then offset" matches how the manual describes it).
  reverse_drift_offset != 0 ? (
    i = 0;
    loop(8,
      v_dr[i + 8] += reverse_drift_offset;
      i += 1;
    );
  );
);

// Rate Value only shown in Drift mode; Rate Mode always visible
slider_show(slider3, trem_mode == 0);

// Reverse Drift Offset only meaningful in Both modes — in single-layer
// modes it would duplicate the global Rate Value's effect on tremolo
// rate, so hide to avoid the confusion of two sliders doing the same
// thing.
slider_show(slider61, is_both);

// Show/hide pan controls
slider_show(slider16, pan_enabled);
slider_show(slider17, pan_enabled);
slider_show(slider18, pan_enabled && pan_mode == 1);
slider_show(slider19, pan_enabled && pan_mode == 1);

// Pulse duty cycle (slider73) → 0..1 fraction for the Pulse waveform.
// Only relevant when Waveform == 13 (Pulse); shown/hidden accordingly.
pulse_duty = slider73 / 100.0;
slider_show(slider73, waveform == 13);

// ===== CHARACTER CHAIN PARAMETERS =====
// Normalize all four character sliders into useful internal forms.

// Tone: -1..+1 range. Tilt EQ uses a one-pole lowpass to split lows
// from highs; the tilt is a symmetric boost-one-cut-the-other (so the
// overall level stays roughly constant — no loudness jump as you push
// the slider). Cutoff ~700 Hz, max tilt ±6 dB.
//   At tone_norm = 0:  both gains = 1.0  (pass-through, lp + hi = original)
//   At tone_norm = +1: highs ×2.0 (+6 dB), lows ×0.5 (-6 dB)  →  bright
//   At tone_norm = -1: lows  ×2.0 (+6 dB), highs ×0.5 (-6 dB) →  warm
tone_norm    = slider69 / 100.0;
tone_lp_a    = exp(-2 * $pi * 700 / srate);
tone_lp_b    = 1 - tone_lp_a;
tone_hi_gain = pow(2, tone_norm);
tone_lo_gain = pow(2, -tone_norm);

// Edge: 0..1 range. Drive scales 1..1.7x; wet mix scales 0..0.5.
// Tuned for "tasteful saturation" — pushing the slider to max adds
// noticeable harmonic character without sounding like clipping or a
// guitar fuzz pedal. Matches the suite's gentle-by-default ethos.
// (Earlier version went 1..3x drive with 0..0.8 wet, which crossed
// into obvious soft-clip territory; rolled back here.)
edge_norm  = slider70 / 100.0;
edge_drive = 1 + edge_norm * 0.7;
edge_wet   = edge_norm * 0.5;

// Movement: 0..1 range. LFO rate fixed at 0.5 Hz (slow shimmer);
// delay base 15 ms, modulation depth ±5 ms. Wet mix 0..0.5 so even
// at maximum the dry signal stays present.
movement_norm    = slider71 / 100.0;
chorus_lfo_inc   = 0.5 / srate;
chorus_base_ms   = 0.015;
chorus_depth_ms  = 0.005;
chorus_wet       = movement_norm * 0.5;
chorus_active    = movement_norm > 0.001;

// Body: 0..1 range. Peaking EQ at the Base Note + Center Octave
// fundamental, max +6 dB at that peak (was +12 in v0; halved here so
// pushing Body up doesn't crater the headroom). Plus a -3 dB makeup
// attenuation scaled by body_norm so the OVERALL level stays roughly
// constant — Body re-balances energy toward the fundamental rather
// than just adding it. Q = 1 for a musically-wide peak.
body_norm    = slider72 / 100.0;
body_active  = body_norm > 0.001;
body_makeup  = pow(10, -body_norm * 3 / 20);  // 1.0 at body=0; ~0.71 at body=100 (-3 dB)
body_active ? (
  body_freq  = semitones_to_hz(base_note, center_octave, 0);
  body_gain  = body_norm * 6;
  body_A     = pow(10, body_gain / 40);
  body_omega = 2 * $pi * body_freq / srate;
  body_cos   = cos(body_omega);
  body_alpha = sin(body_omega) / 2;          // Q = 1
  body_a0    = 1 + body_alpha / body_A;
  body_b0    = (1 + body_alpha * body_A) / body_a0;
  body_b1    = -2 * body_cos / body_a0;
  body_b2    = (1 - body_alpha * body_A) / body_a0;
  body_a1    = -2 * body_cos / body_a0;
  body_a2    = (1 - body_alpha / body_A) / body_a0;
);

amount = pow(2, depth_db / 6);
sc     = 0.5 * amount;
amount = 1 - amount;

i = 0;
loop(n_voices,
  hz = semitones_to_hz(base_note, center_octave, v_semitones[i]);
  v_freq_l[i] = hz;
  v_freq_r[i] = hz + bin_beat_hz;

  trem_mode == 0 ? (
    // Drift mode: global rate + per-voice drift offset
    v_trem_freq[i] = rate_to_hz(rate_val + v_dr[i], rate_mode);
  ) : (
    // Independent mode: per-voice rate in whatever unit Rate Mode specifies
    v_trem_freq[i] = rate_to_hz(v_dr[i], rate_mode);
  );

  // Convert per-voice gain dB to linear scalar
  v_gain[i] = pow(10, v_gain[i] / 20.0);

  i += 1;
);

// Static pan positions for Spread / Spread Reversed modes.
// Rank active voices and place evenly across the stereo field. In Both
// modes the reverse layer's voices participate in the ranking too, so
// 16 voices spread evenly across the field rather than 8 + 8 stacked.
total_active = 0;
i = 0; loop(n_voices, v_active[i] ? total_active += 1; i += 1;);

pan_mode >= 2 ? (
  rank = 0;
  i = 0;
  loop(n_voices,
    v_active[i] ? (
      total_active > 1 ? (
        pos = -1.0 + 2.0 * rank / (total_active - 1);
      ) : (
        pos = 0;
      );
      pan_mode == 3 ? pos = -pos;  // Spread Reversed: flip
      v_pan_static[i] = pos;
      rank += 1;
    ) : (
      v_pan_static[i] = 0;
    );
    i += 1;
  );
);

// Pan frequencies — Increment mode always uses Pan Base Rate as foundation
i = 0;
loop(n_voices,
  pan_mode == 0 ? (
    // Tremolo mode: pan at each voice's own tremolo rate
    v_pan_freq[i] = v_trem_freq[i];
  ) : (
    // Increment mode: Pan Base Rate + increment * voice index. In Both
    // modes voice index runs 0..15, so the reverse layer's voices keep
    // extending the pan-rate ramp past slot 7 rather than restarting.
    pan_rate_i = pan_base_rate + pan_increment * i;
    v_pan_freq[i] = rate_to_hz(pan_rate_i, rate_mode);
  );
  i += 1;
);

on_frac  = on_dur_pct / 100.0;
att_frac = att_pct    / 100.0;
rel_frac = rel_pct    / 100.0;

// Effective attack / release widths (after the calc_lfo "if aw+rw > on_frac,
// scale both down to fit" normalization), and the trem_phase value at which
// the release segment begins. Voice loop uses re_start to detect whether
// a sample falls in the release portion of the LFO — needed to "cancel the
// Depth floor for the last release of the play period" in Play/Rest mode.
aw_eff = att_frac;
rw_eff = rel_frac;
aw_eff + rw_eff > on_frac ? (
  rt_total = aw_eff + rw_eff;
  aw_eff = aw_eff / rt_total * on_frac;
  rw_eff = rw_eff / rt_total * on_frac;
);
re_start = on_frac - rw_eff;

@sample

// Advance speed ramp every sample (runs through Start Delay too).
// combined_scale multiplies every voice's tremolo + pan + cycle
// counter advance below, so the whole polyrhythm stretches as one
// piece and rate RELATIONSHIPS between voices stay intact.
slider67 && slider66 > 0 ? (
  speed_ramp_t += 1.0 / (srate * slider66 * 60);
  speed_ramp_t = min(speed_ramp_t, 1.0);
  speed_scale_current = speed_scale_start + (slider65 - speed_scale_start) * speed_ramp_t;
);
combined_scale = speed_scale_current;

// ===== DRIFT (per-plugin, built-in) =====
// Compute the current drift offset (in the plugin's natural rate
// unit — BPM in default Rate Mode) by advancing two independent
// phases and reading their shape. The offset is then converted to
// an Hz delta against the global rate and applied additively to
// each voice's effective tremolo freq below.
//
// Musical drift advances scaled by combined_scale (Speed Ramp slows
// it with the rest of the polyrhythm). Slow drift is wall-clock.
//
// "One primary cycle" for Polyrhythm Phase = V1's tremolo period
// (the global rate, rate_val in BPM-or-equivalent). That's why the
// musical period samples_per_primary_cycle uses rate_val_hz below.
//
// One-armed conditionals around the up==0 && down==0 guards: an
// empty () branch from a two-armed ternary breaks JSFX compilation.
musical_drift_up     = slider74;
musical_drift_down   = slider75;
musical_drift_period = slider76;
slow_drift_up        = slider77;
slow_drift_down      = slider78;
slow_drift_period    = max(slider79, 0.1);
drift_shape          = slider80;

// Base rate in Hz — used both as the divisor for "one V1 cycle" and
// to convert drift-in-natural-units back into an Hz delta.
rate_val_hz = rate_to_hz(rate_val, rate_mode);

drift_offset_natural = 0;

// ----- Musical drift -----
(musical_drift_up > 0 || musical_drift_down > 0) ? (
  // Phase increments by 1 / (period_cycles * samples_per_primary_cycle).
  // samples_per_primary_cycle = srate / rate_val_hz. So increment is
  // rate_val_hz / (period_cycles * srate), scaled by combined_scale so
  // Speed Ramp pulls musical drift along with the rest of the rhythm.
  musical_drift_phase += (rate_val_hz * combined_scale) / (musical_drift_period * srate);
  musical_drift_phase >= 1 ? (
    musical_drift_phase -= 1;
    // Random shape: pick a new target at every wrap, uniform in [-1, +1].
    drift_shape == 2 ? (
      musical_drift_prev_target = musical_drift_curr_target;
      musical_drift_curr_target = (rand(2) - 1);
    );
  );

  drift_shape == 0 ? (
    musical_shape_val = sin(2 * $pi * musical_drift_phase);
  ) : drift_shape == 1 ? (
    // Triangle: 0 at phase=0, +1 at 0.25, 0 at 0.5, -1 at 0.75, 0 at 1.
    musical_shape_val = musical_drift_phase < 0.25 ? (4 * musical_drift_phase) :
                        musical_drift_phase < 0.75 ? (2 - 4 * musical_drift_phase) :
                                                     (4 * musical_drift_phase - 4);
  ) : (
    // Random: linear interp prev → curr across one full period.
    musical_shape_val = musical_drift_prev_target +
                        (musical_drift_curr_target - musical_drift_prev_target) * musical_drift_phase;
  );

  musical_drift_offset = musical_shape_val > 0 ? musical_shape_val * musical_drift_up
                                         : musical_shape_val * musical_drift_down;
  drift_offset_natural += musical_drift_offset;
);

// ----- Slow drift -----
(slow_drift_up > 0 || slow_drift_down > 0) ? (
  // Wall-clock — no combined_scale here.
  slow_drift_phase += 1 / (slow_drift_period * 60 * srate);
  slow_drift_phase >= 1 ? (
    slow_drift_phase -= 1;
    drift_shape == 2 ? (
      slow_drift_prev_target = slow_drift_curr_target;
      slow_drift_curr_target = (rand(2) - 1);
    );
  );

  drift_shape == 0 ? (
    slow_shape_val = sin(2 * $pi * slow_drift_phase);
  ) : drift_shape == 1 ? (
    slow_shape_val = slow_drift_phase < 0.25 ? (4 * slow_drift_phase) :
                     slow_drift_phase < 0.75 ? (2 - 4 * slow_drift_phase) :
                                               (4 * slow_drift_phase - 4);
  ) : (
    slow_shape_val = slow_drift_prev_target +
                     (slow_drift_curr_target - slow_drift_prev_target) * slow_drift_phase;
  );

  slow_drift_offset = slow_shape_val > 0 ? slow_shape_val * slow_drift_up
                                   : slow_shape_val * slow_drift_down;
  drift_offset_natural += slow_drift_offset;
);

// Convert the natural-unit drift offset to an Hz delta that gets
// added uniformly to every voice's tremolo freq below (preserving
// inter-voice relationships). For BPM: drift_hz_delta = drift_bpm / 60.
// For Seconds: the conversion is nonlinear, so we approximate as
// (new_hz - base_hz) where new = rate_val + drift in natural units.
// Clamp the resulting effective rate so an over-aggressive Down-by
// can't silence or break the plugin (min 10 BPM equivalent).
drift_hz_delta = 0;
drift_offset_natural != 0 ? (
  effective_rate_natural = rate_val + drift_offset_natural;
  // Clamp to a sensible minimum in natural units.
  rate_mode == 0 ? effective_rate_natural = max(effective_rate_natural, 10) :   // BPM ≥ 10
  rate_mode == 1 ? effective_rate_natural = max(effective_rate_natural, 0.1) :  // Seconds ≥ 0.1
                   effective_rate_natural = max(effective_rate_natural, 0.1);   // Hz ≥ 0.1
  drift_hz_delta = rate_to_hz(effective_rate_natural, rate_mode) - rate_val_hz;
);

// Live phase offset update — fires when an offset slider is moved during
// playback. Runs over n_voices so the reverse layer's slots 8-15 also
// respond when v_phase_off there changes (entry into Both mode, toggle
// between Both — permute and Both — time, etc.).
i = 0;
loop(n_voices,
  v_phase_off[i] != v_phase_off_last[i] ? (
    // Offset means "when does this voice become audible" — so we set the phase
    // such that the on-window leading edge lands at offset seconds/beats/cycles.
    // Subtracting from 1 means: the phase clock is that far *before* phase zero,
    // so it arrives at the on-window start exactly at the requested offset time.
    frac = v_phase_off[i] * v_trem_freq[i];
    frac = frac - floor(frac);
    trem_phase[i] = frac > 0 ? 1.0 - frac : 0;
    v_phase_off_last[i] = v_phase_off[i];
  );
  i += 1;
);

// Whether Play/Rest gating is engaged this sample. Used by the voice
// loop's gate logic and by the "cancel Depth floor on the last
// release" branch. No transport gymnastics — @init runs on every
// play and re-zeros all per-voice state, so stop/play gives a clean
// restart automatically (conventional Reaper behavior).
pr_enabled = (play_for_cycles > 0 && rest_for_cycles > 0);

// Start Delay — gate the voice processing. In the delay window the
// output is zeroed and the elapsed counter advances; the voice loop is
// skipped entirely so phases stay at their play-start reset positions.
// When the delay ends, voices begin cleanly from phase 0 (or their
// phase offsets) rather than from a mid-cycle position.
start_delay_elapsed < start_delay_sec ? (
  start_delay_elapsed += 1 / srate;
  spl0 = 0;
  spl1 = 0;
) : (

// Per-voice Play/Rest gating runs inside the voice loop below
// (search for "v_pr_cycle"). Each voice keeps its own cycle counter
// advancing at its own v_trem_freq, flips v_resting[i] independently
// when its threshold is hit, and freezes in place at whatever phase
// it was at — so drift relationships persist across rest. The rest
// counter advances off the same per-voice rate, so V8 (fast) wakes
// before V1 (slow), preserving the per-voice symmetry. pr_enabled
// was computed earlier (above the play_state transition check) so
// the reset-on-play behavior can also see whether PR is engaged; the
// voice loop references it directly.

out_l = 0;
out_r = 0;

i = 0;
loop(n_voices,
  v_active[i] ? (
    // Effective per-voice tremolo Hz this sample = precomputed
    // v_trem_freq[i] (global rate + per-voice drift offset) plus the
    // uniform drift Hz delta (musical + slow). Adding the same delta
    // to every voice preserves the rate RELATIONSHIPS between voices
    // while shifting the whole pattern up or down together. Clamp to
    // a tiny minimum so an over-aggressive Drift Down can't drive the
    // freq to ≤0 (which would freeze trem_phase or run it backward).
    effective_trem_freq = max(v_trem_freq[i] + drift_hz_delta, 0.001);

    // Per-voice Play/Rest cycle counting. Each voice has its own
    // counter that advances at the voice's own tremolo rate, so V8
    // (fast drift) reaches play_for_cycles in less wall-clock time
    // than V1 (slow drift) and enters rest first. The same per-voice
    // rate drives the rest counter, so V8 also wakes first —
    // preserving the per-voice cadence symmetry through both halves
    // of the loop. Counter advances regardless of v_resting state;
    // the threshold comparison just picks which target to check.
    pr_enabled ? (
      v_pr_cycle[i] += effective_trem_freq * combined_scale / srate;
      !v_resting[i] ? (
        v_pr_cycle[i] >= play_for_cycles ? (
          v_resting[i]  = 1;
          v_pr_cycle[i] = 0;
        );
      ) : (
        v_pr_cycle[i] >= rest_for_cycles ? (
          v_resting[i]  = 0;
          v_pr_cycle[i] = 0;
        );
      );
    );

    // Tremolo phase advances forward by default; in any reverse-time
    // mode it decrements so the envelope shape is traced backwards.
    // Direction is per-slot: slots 0-7 advance backward only in
    // single-layer Reverse — time (option 2). Slots 8-15 advance
    // backward only in Both — time (option 4). Both — permute (option 3)
    // is forward in both layers; the "reverse" there is slot-mirroring,
    // not time. Phase wrap handled in both directions.
    //
    // Phase only advances while !v_resting; once this voice's PR
    // counter flips v_resting[i] to 1 (above), trem_phase stays put
    // until the rest counter expires and v_resting clears. Each voice
    // freezes at WHATEVER phase it was at the rest trigger — not at a
    // cycle boundary — so drift relationships persist across rest.
    !v_resting[i] ? (
      voice_reverse_time = (i < 8) ? slot0_7_reverse_time : slot8_15_reverse_time;
      voice_reverse_time ? (
        trem_phase[i] -= effective_trem_freq * combined_scale / srate;
        trem_phase[i] < 0 ? trem_phase[i] += 1;
      ) : (
        trem_phase[i] += effective_trem_freq * combined_scale / srate;
        trem_phase[i] >= 1 ? trem_phase[i] -= 1;
      );
    );

    // Target gain. Three regimes:
    //
    // 1) Resting: target_gain = 0. By the time v_resting flips, the
    //    depth-cancel branch below has already decayed gain to 0 via
    //    the natural release, so there's almost nothing for the gain
    //    smoother to do here.
    //
    // 2) Playing, NOT in the final cycle's release / silent portion:
    //    target_gain = lfo_val * sc + amount  (normal Polyrhythm Phase).
    //
    // 3) Playing, at or past re_start within the FINAL cycle of the
    //    play period: target_gain = lfo_val * (sc + amount). This drops
    //    the always-on Depth floor (`amount`) and lets the release tail
    //    decay all the way to 0 — so the voice actually reaches silence
    //    before the rest freeze, regardless of Depth dB setting.
    //
    //    Peak of release (lfo_val = 1, at re_start): gain = sc + amount,
    //    same as the normal peak. So no discontinuity entering release.
    //    End of release (lfo_val = 0): gain = 0. The override extends
    //    through the silent zone (re_start..1, not re_start..on_frac)
    //    so when On Duration < 100% the silent tail of the final cycle
    //    also stays at 0 — otherwise gain would snap back to `amount`
    //    in the silent zone and need the smoother to bring it down.
    //
    //    Only the final cycle is touched; cycles 1 through (play_for - 1)
    //    play with the normal formula. Release = 0% has zero release
    //    width, so the override never fires and you get a sharp cutoff
    //    at the rest boundary — use a non-zero Release for clean rest
    //    entry.
    //
    // Wake side: when v_resting flips back to 0, target_gain jumps from
    // 0 to whatever the LFO says at the resumed phase. The same 3 ms
    // gain_l/r smoother that already prevents Attack=0% from clicking
    // at normal cycle wraps handles this transition — gain_l ramps from
    // 0 to the new target over ~3 ms, perceptually a clean attack rather
    // than a click. No separate wake-fade machinery needed.
    v_resting[i] ? (
      target_gain = 0;
    ) : (
      lfo_val = calc_lfo(trem_phase[i], on_frac, att_frac, rel_frac, att_shape, rel_shape);
      in_last_cycle  = pr_enabled && (v_pr_cycle[i] >= play_for_cycles - 1);
      (in_last_cycle && trem_phase[i] >= re_start) ? (
        target_gain = lfo_val * (sc + amount);
      ) : (
        target_gain = lfo_val * sc + amount;
      );
    );
    gain_l[i] = gain_l[i] * smooth + target_gain * (1 - smooth);
    gain_r[i] = gain_r[i] * smooth + target_gain * (1 - smooth);

    // CPU-saver skip: when fully decayed in rest, bypass osc +
    // waveform + pan computation (voice would contribute ~0 anyway).
    // The gain smoother keeps running above this, so the catch-up
    // ramp is ready the moment v_resting flips back to 0. The
    // divisor (total_active, set in @slider) is NOT decremented when
    // we skip — that level-jump-on-rest was the "sounds louder after
    // rest" bug fixed 2026-05-25.
    v_resting[i] && gain_l[i] < 0.001 ? 0 : (
    osc_phase_l[i] += v_freq_l[i] / srate;
    osc_phase_l[i] >= 1 ? osc_phase_l[i] -= 1;
    osc_phase_r[i] += v_freq_r[i] / srate;
    osc_phase_r[i] >= 1 ? osc_phase_r[i] -= 1;

    waveform == 0 ? (
      osc_l = sin(osc_phase_l[i] * 2 * $pi) * gain_l[i] * v_gain[i];
      osc_r = sin(osc_phase_r[i] * 2 * $pi) * gain_r[i] * v_gain[i];
    ) : waveform == 1 ? (
      ph_l = osc_phase_l[i];
      ph_r = osc_phase_r[i];
      osc_l = (ph_l < 0.25 ? ph_l * 4 :
               ph_l < 0.75 ? 2 - ph_l * 4 :
                             ph_l * 4 - 4) * gain_l[i] * v_gain[i];
      osc_r = (ph_r < 0.25 ? ph_r * 4 :
               ph_r < 0.75 ? 2 - ph_r * 4 :
                             ph_r * 4 - 4) * gain_r[i] * v_gain[i];
    ) : waveform == 2 ? (
      ph_l = osc_phase_l[i] + 0.5;
      ph_l = ph_l - floor(ph_l);
      ph_r = osc_phase_r[i] + 0.5;
      ph_r = ph_r - floor(ph_r);
      osc_l = (ph_l * 2 - 1) * gain_l[i] * v_gain[i];
      osc_r = (ph_r * 2 - 1) * gain_r[i] * v_gain[i];
    ) : waveform == 3 ? (
      ph_l = osc_phase_l[i];
      ph_r = osc_phase_r[i];
      ph_l = ph_l < (1/PHI) ? ph_l * PHI * 0.5 : 0.5 + (ph_l - 1/PHI) / (1 - 1/PHI) * 0.5;
      ph_r = ph_r < (1/PHI) ? ph_r * PHI * 0.5 : 0.5 + (ph_r - 1/PHI) / (1 - 1/PHI) * 0.5;
      osc_l = sin(ph_l * 2 * $pi) * gain_l[i] * v_gain[i];
      osc_r = sin(ph_r * 2 * $pi) * gain_r[i] * v_gain[i];
    ) : waveform == 4 ? (
      ph_l = osc_phase_l[i];
      ph_r = osc_phase_r[i];
      ph_l = (sin((ph_l - 0.25) * 2 * $pi) + 1) * 0.5;
      ph_r = (sin((ph_r - 0.25) * 2 * $pi) + 1) * 0.5;
      ph_l = ph_l < (1/PHI) ? ph_l * PHI * 0.5 : 0.5 + (ph_l - 1/PHI) / (1 - 1/PHI) * 0.5;
      ph_r = ph_r < (1/PHI) ? ph_r * PHI * 0.5 : 0.5 + (ph_r - 1/PHI) / (1 - 1/PHI) * 0.5;
      osc_l = sin(ph_l * 2 * $pi) * gain_l[i] * v_gain[i];
      osc_r = sin(ph_r * 2 * $pi) * gain_r[i] * v_gain[i];
    ) : waveform == 5 ? (
      ph_l = osc_phase_l[i];
      ph_r = osc_phase_r[i];
      ph_l = ph_l + (1/PHI) * sin(ph_l * 2 * $pi) / (2 * $pi);
      ph_r = ph_r + (1/PHI) * sin(ph_r * 2 * $pi) / (2 * $pi);
      ph_l = ph_l - floor(ph_l);
      ph_r = ph_r - floor(ph_r);
      osc_l = sin(ph_l * 2 * $pi) * gain_l[i] * v_gain[i];
      osc_r = sin(ph_r * 2 * $pi) * gain_r[i] * v_gain[i];
    ) : waveform == 6 ? (
      // Bell: additive partials at integer harmonics with bell-leaning
      // amplitude weights. Real bells have inharmonic partials (2.4, 4.5,
      // ...) but those create discontinuities at each phase wrap; integer
      // partials wrap cleanly. Result is a tonal-rich additive voice that
      // shimmers nicely under tremolo even if it isn't a true singing-bowl.
      ph_l = osc_phase_l[i];
      ph_r = osc_phase_r[i];
      osc_l = (
        sin(ph_l * 1 * 2 * $pi) +
        0.5  * sin(ph_l * 2 * 2 * $pi) +
        0.3  * sin(ph_l * 3 * 2 * $pi) +
        0.4  * sin(ph_l * 4 * 2 * $pi) +
        0.15 * sin(ph_l * 6 * 2 * $pi)
      ) * 0.43 * gain_l[i] * v_gain[i];
      osc_r = (
        sin(ph_r * 1 * 2 * $pi) +
        0.5  * sin(ph_r * 2 * 2 * $pi) +
        0.3  * sin(ph_r * 3 * 2 * $pi) +
        0.4  * sin(ph_r * 4 * 2 * $pi) +
        0.15 * sin(ph_r * 6 * 2 * $pi)
      ) * 0.43 * gain_r[i] * v_gain[i];
    ) : waveform == 7 ? (
      // Wavefold: sine-of-sine with index 2. Soft, gentle harmonic
      // enrichment — like a sine that's been "warmed" without any harsh
      // edges. Stays in [-1, +1] naturally; no clipping artifacts.
      osc_l = sin(2 * sin(osc_phase_l[i] * 2 * $pi)) * gain_l[i] * v_gain[i];
      osc_r = sin(2 * sin(osc_phase_r[i] * 2 * $pi)) * gain_r[i] * v_gain[i];
    ) : waveform == 8 ? (
      // Half-sine: full-wave rectified sine remapped to bipolar. Even
      // harmonics only — gives a hollow, vaguely-reedy character distinct
      // from any of the other waveforms. Has a small DC offset (mean ≈ 0.27)
      // which speakers won't reproduce; tremolo and pan attenuate it further.
      osc_l = (2 * abs(sin(osc_phase_l[i] * 2 * $pi)) - 1) * gain_l[i] * v_gain[i];
      osc_r = (2 * abs(sin(osc_phase_r[i] * 2 * $pi)) - 1) * gain_r[i] * v_gain[i];
    ) : waveform == 9 ? (
      // Phi-cascade: additive harmonics with golden-ratio-decreasing
      // amplitudes — fundamental + (1/φ)*2nd + (1/φ²)*3rd. On theme with
      // the Golden TS/SG/GS family but uses pure additive synthesis rather
      // than phase warping. Continuous across phase wraps (integer harmonic
      // multipliers) so no discontinuity artifacts.
      ph_l = osc_phase_l[i];
      ph_r = osc_phase_r[i];
      osc_l = (
        sin(ph_l * 2 * $pi) +
        (1/PHI)       * sin(ph_l * 2 * 2 * $pi) +
        (1/(PHI*PHI)) * sin(ph_l * 3 * 2 * $pi)
      ) * 0.5 * gain_l[i] * v_gain[i];
      osc_r = (
        sin(ph_r * 2 * $pi) +
        (1/PHI)       * sin(ph_r * 2 * 2 * $pi) +
        (1/(PHI*PHI)) * sin(ph_r * 3 * 2 * $pi)
      ) * 0.5 * gain_r[i] * v_gain[i];
    ) : waveform == 10 ? (
      // Phi Triangle: golden-ratio phase warp → TRIANGLE output. This is
      // what the manual originally described as "Golden TS" — but the
      // original polyrhythm slot 3 actually fed the warped phase into a
      // sine, not a triangle. Rather than silently changing slot 3 and
      // breaking existing project files that relied on the sine sound,
      // the triangle-output variant lives here at the end of the list.
      // Matches the corresponding "Phi Triangle" slot in Melody Phase.
      ph_l = osc_phase_l[i];
      ph_r = osc_phase_r[i];
      ph_l = ph_l < (1/PHI) ? ph_l * PHI * 0.5 : 0.5 + (ph_l - 1/PHI) / (1 - 1/PHI) * 0.5;
      ph_r = ph_r < (1/PHI) ? ph_r * PHI * 0.5 : 0.5 + (ph_r - 1/PHI) / (1 - 1/PHI) * 0.5;
      osc_l = (ph_l < 0.5 ? 4 * ph_l - 1 : 3 - 4 * ph_l) * gain_l[i] * v_gain[i];
      osc_r = (ph_r < 0.5 ? 4 * ph_r - 1 : 3 - 4 * ph_r) * gain_r[i] * v_gain[i];
    ) : waveform == 11 ? (
      // Phi Sine: golden-ratio phase warp → sine output, with no extra
      // pre-warp. The "clean" version of what the manual described as
      // "Golden SG" — the original polyrhythm slot 4 had an additional
      // sine-prewarp stage before the golden warp that added harmonics
      // the docs didn't describe. Slot 4 keeps the original (bright)
      // sound for back-compat; this slot is the no-prewarp version.
      // Matches the corresponding "Phi Sine" slot in Melody Phase.
      ph_l = osc_phase_l[i];
      ph_r = osc_phase_r[i];
      ph_l = ph_l < (1/PHI) ? ph_l * PHI * 0.5 : 0.5 + (ph_l - 1/PHI) / (1 - 1/PHI) * 0.5;
      ph_r = ph_r < (1/PHI) ? ph_r * PHI * 0.5 : 0.5 + (ph_r - 1/PHI) / (1 - 1/PHI) * 0.5;
      osc_l = sin(ph_l * 2 * $pi) * gain_l[i] * v_gain[i];
      osc_r = sin(ph_r * 2 * $pi) * gain_r[i] * v_gain[i];
    ) : waveform == 12 ? (
      // Square: +1 for the first half of the cycle, -1 for the second.
      // PolyBLEP-corrected at both discontinuities — the rising edge at
      // the phase wrap (0) and the falling edge at mid-cycle (0.5) — so
      // it stays clean at high fundamentals. dt is each channel's phase
      // increment per sample (left/right differ by the binaural offset).
      dt_l = v_freq_l[i] / srate;
      dt_r = v_freq_r[i] / srate;
      ph_l = osc_phase_l[i];
      ph_r = osc_phase_r[i];
      // Left: naive square + rising-edge BLEP - falling-edge BLEP.
      // td is the phase distance from the mid-cycle falling edge.
      sq_l = ph_l < 0.5 ? 1 : -1;
      td_l = ph_l - 0.5; td_l < 0 ? td_l += 1;
      sq_l = sq_l + polyblep(ph_l, dt_l) - polyblep(td_l, dt_l);
      osc_l = sq_l * gain_l[i] * v_gain[i];
      // Right
      sq_r = ph_r < 0.5 ? 1 : -1;
      td_r = ph_r - 0.5; td_r < 0 ? td_r += 1;
      sq_r = sq_r + polyblep(ph_r, dt_r) - polyblep(td_r, dt_r);
      osc_r = sq_r * gain_r[i] * v_gain[i];
    ) : (
      // Pulse: +1 while phase < pulse_duty, -1 otherwise. pulse_duty
      // (0..1) comes from slider73. At duty 0.5 this is identical to the
      // Square slot; narrower duty gets thinner and more nasal. PolyBLEP
      // at the rising edge (phase 0) and the falling edge (phase = duty).
      // A non-50% duty introduces a DC offset, which is inaudible on
      // speakers and attenuated by tremolo/master — same accepted
      // tradeoff as the Half-sine waveform.
      dt_l = v_freq_l[i] / srate;
      dt_r = v_freq_r[i] / srate;
      ph_l = osc_phase_l[i];
      ph_r = osc_phase_r[i];
      // Left: naive pulse + rising-edge BLEP - falling-edge BLEP.
      // td is the phase distance from the falling edge at `pulse_duty`.
      pu_l = ph_l < pulse_duty ? 1 : -1;
      td_l = ph_l - pulse_duty; td_l < 0 ? td_l += 1;
      pu_l = pu_l + polyblep(ph_l, dt_l) - polyblep(td_l, dt_l);
      osc_l = pu_l * gain_l[i] * v_gain[i];
      // Right
      pu_r = ph_r < pulse_duty ? 1 : -1;
      td_r = ph_r - pulse_duty; td_r < 0 ? td_r += 1;
      pu_r = pu_r + polyblep(ph_r, dt_r) - polyblep(td_r, dt_r);
      osc_r = pu_r * gain_r[i] * v_gain[i];
    );

    pan_enabled ? (
      pan_mode < 2 ? (
        // Tremolo / Increment: oscillating LFO drives raw_pan
        pan_phase[i] += v_pan_freq[i] * combined_scale / srate;
        pan_phase[i] >= 1 ? pan_phase[i] -= 1;
        raw_pan = sin(pan_phase[i] * 2 * $pi) * pan_spread;
      ) : (
        // Spread / Spread Reversed: static target, smoother handles transitions
        raw_pan = v_pan_static[i] * pan_spread;
      );

      pan_smooth_coeff = exp(-1 / (srate * 0.010));
      pan_smooth[i] = pan_smooth[i] * pan_smooth_coeff + raw_pan * (1 - pan_smooth_coeff);

      // Apply pan as separate L/R multipliers — keeps osc_l and osc_r independent
      // so the binaural beat (frequency difference between channels) is preserved.
      // Collapsing to mono before panning would sum the channels and destroy it.
      pan_pos   = (pan_smooth[i] + 1.0) * 0.5;
      pan_l_mul = cos(pan_pos * $pi * 0.5);
      pan_r_mul = sin(pan_pos * $pi * 0.5);
      out_l += osc_l * pan_l_mul;
      out_r += osc_r * pan_r_mul;
    ) : (
      out_l += osc_l;
      out_r += osc_r;
    );
    );  // close "fully silent skip" ternary
  );
  i += 1;
);

// Normalize by the count of v_active voices — NOT by how many are
// currently audible. Counting only currently-audible voices makes the
// normalizer drop (and remaining voices get louder) every time a
// voice enters rest, then spike back up on wake. Stable divisor =
// stable level. total_active is precomputed in @slider, updated only
// when the user toggles a voice's Active state.
total_active > 0 ? (
  norm = 1.0 / total_active;
  spl0 = out_l * norm;
  spl1 = out_r * norm;
) : (
  spl0 = 0;
  spl1 = 0;
);

// ===== CHARACTER CHAIN =====
// Apply post-voice-sum character processing (Tone, Edge, Movement,
// Body). Runs only when there's audio (total_active > 0); during
// start delay or all-voices-off it stays bypassed since spl0/spl1
// would be 0 anyway.

// --- Tone (symmetric tilt EQ via one-pole lowpass split) ---
// Split into low + high using a one-pole lowpass at ~700 Hz, then
// apply symmetric boost/cut so the overall level stays neutral as
// the slider moves. tone_lo_gain and tone_hi_gain are precomputed
// in @slider — see the comments there for the gain mapping.
tone_lp_l = tone_lp_l * tone_lp_a + spl0 * tone_lp_b;
tone_lp_r = tone_lp_r * tone_lp_a + spl1 * tone_lp_b;
tone_hi_l = spl0 - tone_lp_l;
tone_hi_r = spl1 - tone_lp_r;
spl0 = tone_lp_l * tone_lo_gain + tone_hi_l * tone_hi_gain;
spl1 = tone_lp_r * tone_lo_gain + tone_hi_r * tone_hi_gain;

// --- Edge (soft-clip drive) ---
// Tanh saturation with gain compensation. Wet/dry mix prevents the
// distortion from taking over completely even at max setting.
edge_wet > 0 ? (
  spl0 = spl0 * (1 - edge_wet) + tanh(spl0 * edge_drive) / edge_drive * edge_wet;
  spl1 = spl1 * (1 - edge_wet) + tanh(spl1 * edge_drive) / edge_drive * edge_wet;
);

// --- Movement (stereo chorus from one delay buffer, two LFO taps) ---
// Write the dry signal (L+R averaged) into the circular buffer; read
// it back at two LFO-modulated positions for L and R. The two LFOs
// are phase-offset by 180° so the stereo motion is "out of phase"
// between channels — gives a wide swirling shimmer.
chorus_active ? (
  // Advance LFO
  chorus_lfo_phase += chorus_lfo_inc;
  chorus_lfo_phase >= 1 ? chorus_lfo_phase -= 1;
  chorus_lfo_l = sin(chorus_lfo_phase * 2 * $pi);
  chorus_lfo_r = sin((chorus_lfo_phase + 0.5) * 2 * $pi);  // 180° offset

  // Compute delay times in samples and read positions
  delay_l = (chorus_base_ms + chorus_depth_ms * chorus_lfo_l) * srate;
  delay_r = (chorus_base_ms + chorus_depth_ms * chorus_lfo_r) * srate;
  read_pos_l = chorus_write_pos - delay_l;
  read_pos_r = chorus_write_pos - delay_r;
  read_pos_l < 0 ? read_pos_l += chorus_buf_size;
  read_pos_r < 0 ? read_pos_r += chorus_buf_size;

  // Linear-interp read for L
  read_int_l  = floor(read_pos_l);
  read_frac_l = read_pos_l - read_int_l;
  read_int2_l = read_int_l + 1;
  read_int2_l >= chorus_buf_size ? read_int2_l -= chorus_buf_size;
  chorus_out_l = chorus_buf[read_int_l] * (1 - read_frac_l)
               + chorus_buf[read_int2_l] * read_frac_l;

  // Linear-interp read for R
  read_int_r  = floor(read_pos_r);
  read_frac_r = read_pos_r - read_int_r;
  read_int2_r = read_int_r + 1;
  read_int2_r >= chorus_buf_size ? read_int2_r -= chorus_buf_size;
  chorus_out_r = chorus_buf[read_int_r] * (1 - read_frac_r)
               + chorus_buf[read_int2_r] * read_frac_r;

  // Write the mono mix into the buffer, advance the write head
  chorus_buf[chorus_write_pos] = (spl0 + spl1) * 0.5;
  chorus_write_pos += 1;
  chorus_write_pos >= chorus_buf_size ? chorus_write_pos = 0;

  // Mix dry + delayed
  spl0 = spl0 * (1 - chorus_wet) + chorus_out_l * chorus_wet;
  spl1 = spl1 * (1 - chorus_wet) + chorus_out_r * chorus_wet;
);

// --- Body (peaking EQ at the root note frequency + makeup gain) ---
// Standard biquad direct-form-I. Per-channel state so L and R filter
// independently (preserves stereo image at the boost frequency). The
// makeup attenuation applied after the filter compensates for the
// peak's energy injection so overall loudness stays roughly neutral
// across the slider's range.
body_active ? (
  body_out_l = body_b0 * spl0 + body_b1 * body_x1_l + body_b2 * body_x2_l
             - body_a1 * body_y1_l - body_a2 * body_y2_l;
  body_x2_l = body_x1_l;  body_x1_l = spl0;
  body_y2_l = body_y1_l;  body_y1_l = body_out_l;
  spl0 = body_out_l * body_makeup;

  body_out_r = body_b0 * spl1 + body_b1 * body_x1_r + body_b2 * body_x2_r
             - body_a1 * body_y1_r - body_a2 * body_y2_r;
  body_x2_r = body_x1_r;  body_x1_r = spl1;
  body_y2_r = body_y1_r;  body_y1_r = body_out_r;
  spl1 = body_out_r * body_makeup;
);

);  // close start-delay else branch
