desc: FFT Roundtrip Test (DIAGNOSTIC) - three tones isolate the spectral failure
// =====================================================================
// Disposable diagnostic for the Spectral Vowel Morpher silence bug.
// Put it on a track and PLAY (or arm+monitor). You will hear up to 3 tones
// stacked. Each tone is a checkpoint -- listen for which are PRESENT:
//
//   LOW   220 Hz  -- ALWAYS on. Proves @sample runs at all. If you don't
//                    even hear this, the plugin isn't processing audio
//                    (transport/routing), nothing to do with FFT.
//   MID   440 Hz  -- on if fft() produced a real magnitude spectrum.
//   HIGH  880 Hz  -- on if the fft -> ifft round-trip produced energy back.
//
// Then flip "FFT size" between 16384 and 32768 and listen again. If MID/HIGH
// drop out at 32768 but are present at 16384, the bug is the FFT size, full
// stop -- and the fix is to drop the Spectral Vowel Morpher to a 16384 FFT.
// =====================================================================

slider1:0<0,1,1{16384,32768}>FFT size

@init
TWOPI = 6.283185307179586;
buf = 0;        // FFT work buffer (needs 2 * 32768 = 65536 slots)
gr  = 70000;    // round-trip grain output
phA = 0; phB = 0; phC = 0;
lastN = -1;
dbg_mx = 0; dbg_rms = 0;   // cleared every load so a recompile can't lie

@block
N = slider1 < 0.5 ? 16384 : 32768;
N != lastN ? (
  lastN = N;
  NB = N/2 + 1;
  // fill with a Hann-windowed 220 Hz sine, imag = 0
  i = 0;
  loop(N,
    w = 0.5 - 0.5*cos(TWOPI*i/(N-1));
    buf[2*i] = 0.5*sin(TWOPI*220*i/srate)*w; buf[2*i+1] = 0;
    i += 1;
  );
  fft(buf, N); fft_permute(buf, N);
  // peak magnitude -> did fft() produce a spectrum?
  mx = 0; i = 0;
  loop(NB,
    m = sqrt(buf[2*i]*buf[2*i] + buf[2*i+1]*buf[2*i+1]);
    m > mx ? mx = m;
    i += 1;
  );
  dbg_mx = mx;
  // rebuild Hermitian-correct with random phase, then invert
  i = 0;
  loop(NB,
    mag = sqrt(buf[2*i]*buf[2*i] + buf[2*i+1]*buf[2*i+1]);
    p = rand(1)*TWOPI;
    buf[2*i] = mag*cos(p); buf[2*i+1] = mag*sin(p);
    (i > 0 && i < N/2) ? ( buf[2*(N-i)] = mag*cos(p); buf[2*(N-i)+1] = -mag*sin(p); );
    i += 1;
  );
  fft_ipermute(buf, N); ifft(buf, N);
  rms = 0; i = 0;
  loop(N, s = buf[2*i]; gr[i] = s; rms += s*s; i += 1; );
  dbg_rms = sqrt(rms / N);
);

@sample
phA += TWOPI*220/srate; phA >= TWOPI ? phA -= TWOPI;
phB += TWOPI*440/srate; phB >= TWOPI ? phB -= TWOPI;
phC += TWOPI*880/srate; phC >= TWOPI ? phC -= TWOPI;
a = 0.15*sin(phA);                                   // ALWAYS: @sample runs
b = dbg_mx  > 0.0001     ? 0.15*sin(phB) : 0;        // fft() made a spectrum
c = dbg_rms > 0.0000001  ? 0.15*sin(phC) : 0;        // fft->ifft round-trip works
spl0 = a + b + c;
spl1 = a + b + c;
