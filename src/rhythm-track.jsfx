desc: Rhythm Track
// Designed by Rozaya, developed with Claude (Anthropic)
//
// This work is dedicated to the public domain under CC0 1.0 Universal.
// https://creativecommons.org/publicdomain/zero/1.0/

slider1:120<30,300,1>Tempo (BPM)
slider2:4<1,20,1>Beats per bar
slider3:0<-1,1,0.01>Swing amount
slider4:880<20,2000,1>Strong beat frequency (Hz)
slider5:440<20,2000,1>Weak beat frequency (Hz)
slider6:1.5<0.5,8,0.1>Tone resonance (Q)
slider7:0.75<0,1,0.01>Strong beat volume
slider8:0.5<0,1,0.01>Weak beat volume
slider9:0.04<0.001,1,0.001>Strong beat decay (seconds)
slider10:0.02<0.001,1,0.001>Weak beat decay (seconds)
slider11:1<0,1,0.01>Pan spread (0=mono, 1=full L/R)
slider12:0<0,5,1{Mono,Accent L / Weak R,Alternating,Distributed,Converging,Diverging}>Pan mode
slider13:0<0,1,1{Normal,Flipped}>Pan direction

// Sit silent for N beats after playback starts, then resume normally.
// Counted at the current Tempo. 0 disables the delay. Re-arms on every
// transport stop/start.
slider14:0<0,1000,0.01>Start Delay (beats)

// Per-beat Play/Rest gate. Plays N ticks normally, then suppresses
// the next M tick triggers (silent), then resumes — repeats forever.
// Useful as a practice tool ("4 ticks, 4 silent, 4 ticks, 4 silent").
// The previous tick's decay tail continues through the start of the
// rest period — gate is "don't trigger new ticks," not a hard cut.
// The bar grid (beat_index, accent placement) keeps marching during
// rest, so the accent stays locked to Beats per bar regardless of
// where the rest periods fall. If you want the accent to always land
// on beat 1 of every play period, set Play for to a multiple of
// Beats per bar. 0 in either slider disables the gate. Resets on
// every transport stop/start.
slider15:0<0,1000,1>Play for (beats)
slider16:0<0,1000,1>Rest for (beats)

// Speed ramp: in-plugin slowdown/speedup. beat_phase advance is
// scaled by speed_scale_current per sample (was 1/samples_per_beat,
// now speed_scale_current/samples_per_beat). 0.5 = half speed (BPM
// effectively halved without changing the slider), 2.0 = double.
slider17:1.0<0.1,4.0,0.01>Speed ramp target (multiplier)
slider18:0<0,60,0.1>Speed ramp duration (minutes)
slider19:0<0,1,1{Off,On}>Speed ramp engage

// Musical drift: organic up/down wander on tempo, paced in beats.
// Scales with Speed Ramp — slow the tempo down, drift slows with it.
// Up by / Down by are in BPM; Period is how many beats per one full
// drift cycle. 0 amplitudes disable.
slider21:0<0,20,0.1>Musical drift: Up by
slider22:0<0,20,0.1>Musical drift: Down by
slider23:8<1,1000,1>Musical drift: Period (cycles)

// Slow drift: wall-clock wander on tempo. Independent of Speed Ramp.
// Up by / Down by are in BPM; Period is in wall-clock minutes.
slider24:0<0,20,0.1>Slow drift: Up by
slider25:0<0,20,0.1>Slow drift: Down by
slider26:5<0.1,60,0.1>Slow drift: Period (minutes)

// Drift shape applies to BOTH musical and slow drift.
slider27:0<0,2,1{Sine,Triangle,Random}>Drift shape

@init

tick_buf_len = 65536;

strong_buf    = 0;
weak_buf      = strong_buf + tick_buf_len;
noise_scratch = weak_buf   + tick_buf_len;
// swing_offset needs its own memory region. Eel2 defaults any
// undeclared variable to 0; without an explicit base address here,
// swing_offset[i] would alias strong_buf[i] and the per-beat swing
// writes in @slider would corrupt the first `timesig` samples of
// the rendered strong-beat audio (~tiny click at the very start of
// the strong beat). 32 slots is generous — slider max is 20.
noise_len    = 300;
swing_offset = noise_scratch + noise_len;

strong_len = 0;
weak_len   = 0;

tick_playing = 0;
tick_pos     = 0;
tick_src     = 0;
tick_len     = 0;
tick_pan     = 0;

// Start beat_phase at 1.0 so the very first @sample call triggers
// the downbeat. With beat_phase=0 the first beat doesn't fire until
// samples_per_beat samples have elapsed — a full beat of silence
// before the metronome actually starts ticking. (Bug pre-dated the
// initial public release; reported by ear.)
beat_phase       = 1.0;
beat_index       = 0;
samples_per_beat = (60.0 / 120.0) * srate;

// Start Delay state. start_delay_elapsed counts up from 0 at each
// play start; while it's below start_delay_sec the @sample work is
// gated and output is silent.
last_play_state     = 0;
start_delay_elapsed = 0;
start_delay_sec     = 0;

// Play/Rest gate state. pr_beat counts ticks elapsed in the current
// play (or rest) period; threshold compare flips the period. Init
// to 0 because rhythm-track has no init pre-fire — the first tick
// fires via the normal beat_phase >= 1.0 trigger path on sample 1.
pr_resting     = 0;
pr_beat        = 0;
play_for_beats = 0;
rest_for_beats = 0;
pr_enabled     = 0;

// Speed ramp state.
speed_ramp_engaged_last = 0;
speed_scale_current     = 1.0;
speed_scale_start       = 1.0;
speed_ramp_t            = 0.0;

// Drift state. Phases advance per sample and wrap [0,1). For Random
// shape we interpolate between prev_target → curr_target over one
// full period; new target is drawn from uniform [-1, +1] on each wrap.
musical_drift_phase       = 0;
slow_drift_phase          = 0;
musical_drift_prev_target = 0;
musical_drift_curr_target = 0;
slow_drift_prev_target    = 0;
slow_drift_curr_target    = 0;

nx = 1;
i = 0;
loop(noise_len,
  nx = (479 * nx) % 997;
  noise_scratch[i] = (nx / 500.0) - 1.0;
  i += 1;
);


function render_tick(buf, hz, gain, decay_sec, tone_q)
local(i, len, env, raw, lp_out, peak_val, norm,
      lp_w0, lp_alpha, lp_cos, lp_b0, lp_b1, lp_b2, lp_a1, lp_a2,
      lp_x1, lp_x2, lp_y1, lp_y2,
      hp_w0, hp_alpha, hp_cos, hp_b0, hp_b1, hp_b2, hp_a1, hp_a2,
      hpx1, hpx2, hpy1, hpy2,
      hp2x1, hp2x2, hp2y1, hp2y2,
      hp3x1, hp3x2, hp3y1, hp3y2,
      hp4x1, hp4x2, hp4y1, hp4y2,
      hp_out) (

  // Dynamic length: 5 time constants captures tail to ~1% of peak
  len = min(ceil(decay_sec * srate * 5) + noise_len, tick_buf_len - 1);

  // Resonant lowpass at 2*hz, Q controlled by slider
  lp_w0    = 2.0 * $pi * min(srate * 0.45, 2.0 * hz) / srate;
  lp_alpha = sin(lp_w0) / (2.0 * tone_q);
  lp_cos   = cos(lp_w0);
  lp_b0    = (1 - lp_cos) / 2 / (1 + lp_alpha);
  lp_b1    = (1 - lp_cos)     / (1 + lp_alpha);
  lp_b2    = lp_b0;
  lp_a1    = -2 * lp_cos      / (1 + lp_alpha);
  lp_a2    = (1 - lp_alpha)   / (1 + lp_alpha);

  // 4-stage biquad highpass at hz (approximates 8-pole slope)
  hp_w0    = 2.0 * $pi * hz / srate;
  hp_alpha = sin(hp_w0) / (2.0 * 0.707);
  hp_cos   = cos(hp_w0);
  hp_b0    =  (1 + hp_cos) / 2 / (1 + hp_alpha);
  hp_b1    = -(1 + hp_cos)     / (1 + hp_alpha);
  hp_b2    =  hp_b0;
  hp_a1    = -2 * hp_cos       / (1 + hp_alpha);
  hp_a2    =  (1 - hp_alpha)   / (1 + hp_alpha);

  lp_x1 = 0; lp_x2 = 0; lp_y1 = 0; lp_y2 = 0;
  hpx1 = 0; hpx2 = 0; hpy1 = 0; hpy2 = 0;
  hp2x1 = 0; hp2x2 = 0; hp2y1 = 0; hp2y2 = 0;
  hp3x1 = 0; hp3x2 = 0; hp3y1 = 0; hp3y2 = 0;
  hp4x1 = 0; hp4x2 = 0; hp4y1 = 0; hp4y2 = 0;

  peak_val = 0.0001;
  i = 0;
  loop(len,
    // Envelope: short attack ramp, then exponential decay
    // Use noise_scratch for the first noise_len samples, silence after
    raw = (i < noise_len) ? noise_scratch[i] : 0;
    env = (i < 5) ? (i / 5.0) : exp(-i / (decay_sec * srate));
    raw = raw * env;

    // Resonant lowpass
    lp_out = lp_b0*raw + lp_b1*lp_x1 + lp_b2*lp_x2 - lp_a1*lp_y1 - lp_a2*lp_y2;
    lp_x2 = lp_x1; lp_x1 = raw;
    lp_y2 = lp_y1; lp_y1 = lp_out;

    // 4-stage highpass - each stage input is previous stage output
    hp_out = hp_b0*lp_out + hp_b1*hpx1 + hp_b2*hpx2 - hp_a1*hpy1 - hp_a2*hpy2;
    hpx2 = hpx1; hpx1 = lp_out; hpy2 = hpy1; hpy1 = hp_out;

    hp_out = hp_b0*hpy1 + hp_b1*hp2x1 + hp_b2*hp2x2 - hp_a1*hp2y1 - hp_a2*hp2y2;
    hp2x2 = hp2x1; hp2x1 = hpy1; hp2y2 = hp2y1; hp2y1 = hp_out;

    hp_out = hp_b0*hp2y1 + hp_b1*hp3x1 + hp_b2*hp3x2 - hp_a1*hp3y1 - hp_a2*hp3y2;
    hp3x2 = hp3x1; hp3x1 = hp2y1; hp3y2 = hp3y1; hp3y1 = hp_out;

    hp_out = hp_b0*hp3y1 + hp_b1*hp4x1 + hp_b2*hp4x2 - hp_a1*hp4y1 - hp_a2*hp4y2;
    hp4x2 = hp4x1; hp4x1 = hp3y1; hp4y2 = hp4y1; hp4y1 = hp_out;

    buf[i] = hp_out;
    abs(hp_out) > peak_val ? peak_val = abs(hp_out);
    i += 1;
  );

  norm = gain / peak_val;
  i = 0;
  loop(len,
    buf[i] = buf[i] * norm;
    i += 1;
  );

  len
);


function beat_pan(idx) local(n, non_accent, steps, step, pos, flip) (
  n          = max(timesig, 1);
  non_accent = n - 1;
  steps      = ceil(non_accent / 2.0); // number of distinct distances from anchor
  flip       = pan_flip ? -1.0 : 1.0;

  pan_mode == 0 ? (
    // Mono
    pos = 0;

  ) : pan_mode == 1 ? (
    // Accent L / Weak R
    pos = (idx == 0) ? -1 : 1;

  ) : pan_mode == 2 ? (
    // Alternating L/R/L/R
    pos = (idx % 2 == 0) ? -1 : 1;

  ) : pan_mode == 3 ? (
    // Distributed: evenly spaced left to right
    n > 1 ? (pos = (idx / (n - 1.0)) * 2.0 - 1.0) : (pos = 0);

  ) : pan_mode == 4 ? (
    // Converging: accent hard left, pairs walk inward toward center
    // beat 0 = -1, beat 1 = hard right, beat 2 = hard left - 1 step...
    idx == 0 ? (
      pos = -1.0;
    ) : (
      step = ceil((idx + 1) / 2); // 1,2,2,3,3,4... for idx 1,2,3,4,5,6
      pos = (idx % 2 == 1) ? (1.0 - (step - 1.0) / steps)
                            : -(1.0 - (step - 1.0) / steps);
      pos = max(-1.0, min(1.0, pos));
    );

  ) : (
    // Diverging: accent center, pairs walk outward symmetrically
    // beat 0 = 0, beat 1 = slight left, beat 2 = slight right...
    idx == 0 ? (
      pos = 0.0;
    ) : (
      step = floor((idx + 1) / 2); // 1,1,2,2,3,3...
      pos = (idx % 2 == 1) ? -(step / steps)
                            :  (step / steps);
      pos = max(-1.0, min(1.0, pos));
    );
  );

  pos * pan_spread * flip
);


@slider

tempo        = slider1;
timesig      = slider2;
swing        = slider3;
strong_hz    = slider4;
weak_hz      = slider5;
tone_q       = slider6;
strong_gain  = slider7;
weak_gain    = slider8;
strong_decay = slider9;
weak_decay   = slider10;
pan_spread   = slider11;
pan_mode     = slider12;
pan_flip     = slider13;

samples_per_beat = (60.0 / tempo) * srate;

// Start Delay — beats at the current Tempo.
start_delay_sec = slider14 * 60 / max(tempo, 1);

// Play/Rest gate: integer beat counts. Both must be > 0 for the
// gate to engage; 0 in either slider disables.
play_for_beats = slider15;
rest_for_beats = slider16;
pr_enabled     = (play_for_beats > 0 && rest_for_beats > 0);

// Speed ramp engage-edge.
slider19 && !speed_ramp_engaged_last ? (
  speed_scale_start = speed_scale_current;
  speed_ramp_t      = 0.0;
);
speed_ramp_engaged_last = slider19;

strong_len = render_tick(strong_buf, strong_hz, strong_gain, strong_decay, tone_q);
weak_len   = render_tick(weak_buf,   weak_hz,   weak_gain,   weak_decay,   tone_q);

i = 0;
loop(timesig,
  swing_offset[i] = swing * (1.0 / 3.0) * ((i + 1) % 2);
  i += 1;
);


@sample

// Advance speed ramp every sample, regardless of Start Delay.
slider19 && slider18 > 0 ? (
  speed_ramp_t += 1.0 / (srate * slider18 * 60);
  speed_ramp_t = min(speed_ramp_t, 1.0);
  speed_scale_current = speed_scale_start + (slider17 - speed_scale_start) * speed_ramp_t;
);

combined_scale = speed_scale_current;

// Drift: compute musical + slow offsets in BPM and apply to tempo.
// Musical drift advances by combined_scale (so it slows with Speed
// Ramp); slow drift advances by wall-clock. Each phase wraps [0,1).
musical_drift_up     = slider21;
musical_drift_down   = slider22;
musical_drift_period = slider23;
slow_drift_up        = slider24;
slow_drift_down      = slider25;
slow_drift_period    = max(slider26, 0.1);
drift_shape          = slider27;

musical_drift_offset = 0;
slow_drift_offset    = 0;

(musical_drift_up > 0 || musical_drift_down > 0) ? (
  musical_drift_phase += combined_scale / (musical_drift_period * samples_per_beat);
  musical_drift_phase >= 1.0 ? (
    musical_drift_phase -= 1.0;
    // On wrap, draw a fresh Random target. Shape-agnostic so the
    // value is ready if shape changes mid-cycle.
    musical_drift_prev_target = musical_drift_curr_target;
    musical_drift_curr_target = (rand(2) - 1);
  );
  drift_shape == 0 ? (
    drift_shape_val = sin(2 * $pi * musical_drift_phase);
  ) : drift_shape == 1 ? (
    drift_shape_val = musical_drift_phase < 0.25 ? (4 * musical_drift_phase)
                    : musical_drift_phase < 0.75 ? (2 - 4 * musical_drift_phase)
                    : (4 * musical_drift_phase - 4);
  ) : (
    drift_shape_val = musical_drift_prev_target
                    + (musical_drift_curr_target - musical_drift_prev_target) * musical_drift_phase;
  );
  musical_drift_offset = drift_shape_val > 0 ? drift_shape_val * musical_drift_up
                                              : drift_shape_val * musical_drift_down;
);

(slow_drift_up > 0 || slow_drift_down > 0) ? (
  slow_drift_phase += 1 / (slow_drift_period * 60 * srate);
  slow_drift_phase >= 1.0 ? (
    slow_drift_phase -= 1.0;
    slow_drift_prev_target = slow_drift_curr_target;
    slow_drift_curr_target = (rand(2) - 1);
  );
  drift_shape == 0 ? (
    drift_shape_val = sin(2 * $pi * slow_drift_phase);
  ) : drift_shape == 1 ? (
    drift_shape_val = slow_drift_phase < 0.25 ? (4 * slow_drift_phase)
                    : slow_drift_phase < 0.75 ? (2 - 4 * slow_drift_phase)
                    : (4 * slow_drift_phase - 4);
  ) : (
    drift_shape_val = slow_drift_prev_target
                    + (slow_drift_curr_target - slow_drift_prev_target) * slow_drift_phase;
  );
  slow_drift_offset = drift_shape_val > 0 ? drift_shape_val * slow_drift_up
                                          : drift_shape_val * slow_drift_down;
);

// Effective tempo with drift, clamped so over-aggressive Down-by
// can't silence or break the metronome. Recompute samples_per_beat
// each sample so beat_phase advances at the drifted rate.
effective_tempo = max(10, tempo + musical_drift_offset + slow_drift_offset);
effective_samples_per_beat = (60.0 / effective_tempo) * srate;

// Re-arm Start Delay on each transport stop/start.
play_state > 0 && last_play_state == 0 ? (
  start_delay_elapsed = 0;
);
last_play_state = play_state;

// Start Delay gate. During the silent window beat_phase and tick_pos
// don't advance, so when the delay elapses the metronome begins from
// the downbeat as expected.
start_delay_elapsed < start_delay_sec ? (
  start_delay_elapsed += 1 / srate;
  spl0 = 0;
  spl1 = 0;
) : (

beat_phase += combined_scale / effective_samples_per_beat;

beat_phase >= 1.0 ? (
  beat_phase -= 1.0;

  // Per-beat Play/Rest gate. Check first whether we've reached the
  // threshold for the current period — if so, flip play↔rest and
  // reset the counter. Then increment the counter for the beat we're
  // about to (maybe) fire. Tick fires only if !pr_resting (or gate
  // is off entirely). The previously-fired tick keeps playing through
  // its decay tail regardless — gate doesn't touch the audio buffer.
  pr_enabled ? (
    pr_beat >= (pr_resting ? rest_for_beats : play_for_beats) ? (
      pr_resting = 1 - pr_resting;
      pr_beat = 0;
    );
    pr_beat += 1;
  );

  (!pr_enabled || !pr_resting) ? (
    is_accent = (beat_index == 0) ? 1 : 0;
    tick_src  = is_accent ? strong_buf : weak_buf;
    tick_len  = is_accent ? strong_len : weak_len;
    tick_pan  = beat_pan(beat_index);
    tick_pos  = 0;
    tick_playing = 1;
  );

  // beat_index and swing always advance — preserves the bar grid
  // through rest periods so the accent stays locked to "every
  // timesig beats" regardless of where rest falls.
  beat_index  = (beat_index + 1) % timesig;
  beat_phase -= swing_offset[beat_index];
);

out = 0;
tick_playing ? (
  out = tick_src[tick_pos];
  tick_pos += 1;
  tick_pos >= tick_len ? tick_playing = 0;
);

pan_pos = (tick_pan + 1.0) * 0.5;
spl0 = out * cos(pan_pos * $pi * 0.5);
spl1 = out * sin(pan_pos * $pi * 0.5);

);  // close start-delay else branch