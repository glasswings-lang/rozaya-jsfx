desc: Rhythm Track
// Designed by Rozaya, developed with Claude (Anthropic)
//
// This work is dedicated to the public domain under CC0 1.0 Universal.
// https://creativecommons.org/publicdomain/zero/1.0/

slider1:120<10,300,0.1>Tempo (BPM)
slider2:4<1,20,1>Beats per bar
slider3:0<-1,1,0.01>Swing amount
slider4:880<20,2000,1>Strong beat frequency (Hz)
slider5:440<20,2000,1>Weak beat frequency (Hz)
slider6:1.5<0.5,8,0.1>Tone resonance (Q)
slider7:0.75<0,1,0.01>Strong beat volume
slider8:0.5<0,1,0.01>Weak beat volume
slider9:0.04<0.001,1,0.001>Strong beat decay (seconds)
slider10:0.02<0.001,1,0.001>Weak beat decay (seconds)
slider11:1<0,1,0.01>Pan spread (0=mono, 1=full L/R)
slider12:0<0,5,1{Mono,Accent L / Weak R,Alternating,Distributed,Converging,Diverging}>Pan mode
slider13:0<0,1,1{Normal,Flipped}>Pan direction

// Sit silent for N beats after playback starts, then resume normally.
// Counted at the current Tempo. 0 disables the delay. Re-arms on every
// transport stop/start.
slider14:0<0,1000,0.01>Start Delay (beats)

// Per-beat Play/Rest gate. Plays N ticks normally, then suppresses
// the next M tick triggers (silent), then resumes — repeats forever.
// Useful as a practice tool ("4 ticks, 4 silent, 4 ticks, 4 silent").
// The previous tick's decay tail continues through the start of the
// rest period — gate is "don't trigger new ticks," not a hard cut.
// The bar grid (beat_index, accent placement) keeps marching during
// rest, so the accent stays locked to Beats per bar regardless of
// where the rest periods fall. If you want the accent to always land
// on beat 1 of every play period, set Play for to a multiple of
// Beats per bar. 0 in either slider disables the gate. Resets on
// every transport stop/start.
slider15:0<0,1000,1>Play for (beats)
slider16:0<0,1000,1>Rest for (beats)

// Speed ramp: signed-delta on Tempo BPM. Single-target plugin (Tempo
// is the only meaningful rate), so no selector — slider 17 IS the
// `by` amount in BPM. effective_tempo = slider1 + ramp_t * slider17
// computed per sample. Engage (slider 19) is a freeze/resume gate
// (NOT a restart edge); only transport play resets ramp_t.
//
// Migration from v2.7: slider 17 changed from multiplier (0.1-4.0)
// to signed BPM delta (-270 to +180). Old projects' multiplier value
// gets interpreted as a tiny BPM delta — effectively "no Speed Ramp"
// until reconfigured. Default 0 = no change (safe on engage).
slider17:0<-270,180,0.1>Speed ramp by (BPM)
slider18:0<0,60,0.1>Speed ramp duration (minutes)
slider19:0<0,1,1{Off,On}>Speed ramp engage
slider20:0<0,60,0.1>Speed ramp start delay (minutes)

// Per-target drift: nested-selector pattern matching Womb v3 /
// breath gen v2.9 / heartbeat v2.9. Pick a target (slider21), then
// sliders 22-25 hold THAT target's drift config. Switching the
// selector saves current values to the old target's memory slot and
// loads the new target's values into the sliders. Both targets drift
// in parallel; the selector just chooses which one you're currently
// editing. Period unit is beats for both targets. For slow wall-clock
// feel, set a long period (~960 beats ≈ 8 min at 120 BPM).
//
// Note: Speed Ramp above is single-target (Tempo BPM only) because
// that's the only meaningful long-form wind-down here. Drift has 2
// targets because wandering Swing while the tempo stays put is a
// useful musical effect (it loosens the groove cycle-to-cycle).
//
// Migration from v2.8: the old flat drift block (musical_up/down/
// period, slow_up/down/period, drift_shape on sliders 21-27) was 7
// sliders covering Tempo only. v2.9 is 5 sliders covering 2 independent
// targets, reusing slider IDs 21-25; sliders 26 and 27 are no longer
// declared. Old projects' slider values get reinterpreted (selector
// defaults to Tempo BPM, sliders 22-23 become up/down BPM amounts).
// Reset drift sliders to defaults after upgrade and reconfigure.
slider21:0<0,1,1{Tempo BPM,Swing amount}>Drift target
slider22:0<0,50,0.1>Drift up amount (units match target)
slider23:0<0,50,0.1>Drift down amount (units match target)
slider24:8<1,1000,1>Drift period (beats)
slider25:0<0,2,1{Sine,Triangle,Random}>Drift shape

@init
ext_noinit = 1;   // preserve drift config bank across transport play (drift runtime + state machine still reset on play, see transport edge handler in @sample)

tick_buf_len = 65536;

strong_buf    = 0;
weak_buf      = strong_buf + tick_buf_len;
noise_scratch = weak_buf   + tick_buf_len;
// swing_offset needs its own memory region. Eel2 defaults any
// undeclared variable to 0; without an explicit base address here,
// swing_offset[i] would alias strong_buf[i] and the per-beat swing
// writes in @slider would corrupt the first `timesig` samples of
// the rendered strong-beat audio (~tiny click at the very start of
// the strong beat). 32 slots is generous — slider max is 20.
noise_len    = 300;
swing_offset = noise_scratch + noise_len;

strong_len = 0;
weak_len   = 0;

tick_playing = 0;
tick_pos     = 0;
tick_src     = 0;
tick_len     = 0;
tick_pan     = 0;

// Start beat_phase at 1.0 so the very first @sample call triggers
// the downbeat. With beat_phase=0 the first beat doesn't fire until
// samples_per_beat samples have elapsed — a full beat of silence
// before the metronome actually starts ticking. (Bug pre-dated the
// initial public release; reported by ear.)
beat_phase       = 1.0;
beat_index       = 0;

// Seed track_bpm from slider1 in @init so the first @sample call has
// a valid BPM available. With ext_noinit = 1, @init only runs on plugin
// load; this ensures effective_tempo computations have a defined
// baseline even if @sample touches them before @slider's first run.
// (NOTE: see @slider for the `tempo` vs `track_bpm` naming gotcha.)
track_bpm        = slider1;
samples_per_beat = (60.0 / max(slider1, 1)) * srate;

// Start Delay state. start_delay_elapsed counts up from 0 at each
// play start; while it's below start_delay_sec the @sample work is
// gated and output is silent.
last_play_state     = 0;
start_delay_elapsed = 0;
start_delay_sec     = 0;

// Play/Rest gate state. pr_beat counts ticks elapsed in the current
// play (or rest) period; threshold compare flips the period. Init
// to 0 because rhythm-track has no init pre-fire — the first tick
// fires via the normal beat_phase >= 1.0 trigger path on sample 1.
pr_resting     = 0;
pr_beat        = 0;
play_for_beats = 0;
rest_for_beats = 0;
pr_enabled     = 0;

// Speed ramp state.
// Speed Ramp state. Engage is a freeze/resume gate, not an edge;
// only transport play resets ramp_t.
speed_ramp_t             = 0.0;
speed_ramp_delay_elapsed = 0;

// --- v2.9 Drift target memory banks ---
//
// 2 targets × 8 fields = 16 slots. Arrays are 16-slot-spaced so
// targets can grow up to 16 later without re-laying-out. Placed right
// after swing_offset's reserved region (131404) at 131520 — no overlap
// with the tick render buffers below.
//
// Targets:
//   0 = Tempo BPM      (units: BPM)
//   1 = Swing amount   (units: 0-1 swing fraction, clamped at consumer)
N_TARGETS = 2;
target_drift_up     = 131520;
target_drift_down   = 131536;
target_drift_per    = 131552;
target_drift_shape  = 131568;
target_drift_phase  = 131584;
target_drift_prev   = 131600;
target_drift_curr   = 131616;
target_drift_offset = 131632;

i = 0;
loop(N_TARGETS,
  target_drift_up[i]     = 0;
  target_drift_down[i]   = 0;
  target_drift_per[i]    = 8;
  target_drift_shape[i]  = 0;
  target_drift_phase[i]  = 0;
  target_drift_prev[i]   = 0;
  target_drift_curr[i]   = 0;
  target_drift_offset[i] = 0;
  i += 1;
);

// Last-selected drift target tracker for save/restore on selector change.
last_target_select = 0;

nx = 1;
i = 0;
loop(noise_len,
  nx = (479 * nx) % 997;
  noise_scratch[i] = (nx / 500.0) - 1.0;
  i += 1;
);


function render_tick(buf, hz, gain, decay_sec, tone_q)
local(i, len, env, raw, lp_out, peak_val, norm,
      lp_w0, lp_alpha, lp_cos, lp_b0, lp_b1, lp_b2, lp_a1, lp_a2,
      lp_x1, lp_x2, lp_y1, lp_y2,
      hp_w0, hp_alpha, hp_cos, hp_b0, hp_b1, hp_b2, hp_a1, hp_a2,
      hpx1, hpx2, hpy1, hpy2,
      hp2x1, hp2x2, hp2y1, hp2y2,
      hp3x1, hp3x2, hp3y1, hp3y2,
      hp4x1, hp4x2, hp4y1, hp4y2,
      hp_out) (

  // Dynamic length: 5 time constants captures tail to ~1% of peak
  len = min(ceil(decay_sec * srate * 5) + noise_len, tick_buf_len - 1);

  // Resonant lowpass at 2*hz, Q controlled by slider
  lp_w0    = 2.0 * $pi * min(srate * 0.45, 2.0 * hz) / srate;
  lp_alpha = sin(lp_w0) / (2.0 * tone_q);
  lp_cos   = cos(lp_w0);
  lp_b0    = (1 - lp_cos) / 2 / (1 + lp_alpha);
  lp_b1    = (1 - lp_cos)     / (1 + lp_alpha);
  lp_b2    = lp_b0;
  lp_a1    = -2 * lp_cos      / (1 + lp_alpha);
  lp_a2    = (1 - lp_alpha)   / (1 + lp_alpha);

  // 4-stage biquad highpass at hz (approximates 8-pole slope)
  hp_w0    = 2.0 * $pi * hz / srate;
  hp_alpha = sin(hp_w0) / (2.0 * 0.707);
  hp_cos   = cos(hp_w0);
  hp_b0    =  (1 + hp_cos) / 2 / (1 + hp_alpha);
  hp_b1    = -(1 + hp_cos)     / (1 + hp_alpha);
  hp_b2    =  hp_b0;
  hp_a1    = -2 * hp_cos       / (1 + hp_alpha);
  hp_a2    =  (1 - hp_alpha)   / (1 + hp_alpha);

  lp_x1 = 0; lp_x2 = 0; lp_y1 = 0; lp_y2 = 0;
  hpx1 = 0; hpx2 = 0; hpy1 = 0; hpy2 = 0;
  hp2x1 = 0; hp2x2 = 0; hp2y1 = 0; hp2y2 = 0;
  hp3x1 = 0; hp3x2 = 0; hp3y1 = 0; hp3y2 = 0;
  hp4x1 = 0; hp4x2 = 0; hp4y1 = 0; hp4y2 = 0;

  peak_val = 0.0001;
  i = 0;
  loop(len,
    // Envelope: short attack ramp, then exponential decay
    // Use noise_scratch for the first noise_len samples, silence after
    raw = (i < noise_len) ? noise_scratch[i] : 0;
    env = (i < 5) ? (i / 5.0) : exp(-i / (decay_sec * srate));
    raw = raw * env;

    // Resonant lowpass
    lp_out = lp_b0*raw + lp_b1*lp_x1 + lp_b2*lp_x2 - lp_a1*lp_y1 - lp_a2*lp_y2;
    lp_x2 = lp_x1; lp_x1 = raw;
    lp_y2 = lp_y1; lp_y1 = lp_out;

    // 4-stage highpass - each stage input is previous stage output
    hp_out = hp_b0*lp_out + hp_b1*hpx1 + hp_b2*hpx2 - hp_a1*hpy1 - hp_a2*hpy2;
    hpx2 = hpx1; hpx1 = lp_out; hpy2 = hpy1; hpy1 = hp_out;

    hp_out = hp_b0*hpy1 + hp_b1*hp2x1 + hp_b2*hp2x2 - hp_a1*hp2y1 - hp_a2*hp2y2;
    hp2x2 = hp2x1; hp2x1 = hpy1; hp2y2 = hp2y1; hp2y1 = hp_out;

    hp_out = hp_b0*hp2y1 + hp_b1*hp3x1 + hp_b2*hp3x2 - hp_a1*hp3y1 - hp_a2*hp3y2;
    hp3x2 = hp3x1; hp3x1 = hp2y1; hp3y2 = hp3y1; hp3y1 = hp_out;

    hp_out = hp_b0*hp3y1 + hp_b1*hp4x1 + hp_b2*hp4x2 - hp_a1*hp4y1 - hp_a2*hp4y2;
    hp4x2 = hp4x1; hp4x1 = hp3y1; hp4y2 = hp4y1; hp4y1 = hp_out;

    buf[i] = hp_out;
    abs(hp_out) > peak_val ? peak_val = abs(hp_out);
    i += 1;
  );

  norm = gain / peak_val;
  i = 0;
  loop(len,
    buf[i] = buf[i] * norm;
    i += 1;
  );

  len
);


function beat_pan(idx) local(n, non_accent, steps, step, pos, flip) (
  n          = max(timesig, 1);
  non_accent = n - 1;
  steps      = ceil(non_accent / 2.0); // number of distinct distances from anchor
  flip       = pan_flip ? -1.0 : 1.0;

  pan_mode == 0 ? (
    // Mono
    pos = 0;

  ) : pan_mode == 1 ? (
    // Accent L / Weak R
    pos = (idx == 0) ? -1 : 1;

  ) : pan_mode == 2 ? (
    // Alternating L/R/L/R
    pos = (idx % 2 == 0) ? -1 : 1;

  ) : pan_mode == 3 ? (
    // Distributed: evenly spaced left to right
    n > 1 ? (pos = (idx / (n - 1.0)) * 2.0 - 1.0) : (pos = 0);

  ) : pan_mode == 4 ? (
    // Converging: accent hard left, pairs walk inward toward center
    // beat 0 = -1, beat 1 = hard right, beat 2 = hard left - 1 step...
    idx == 0 ? (
      pos = -1.0;
    ) : (
      step = ceil((idx + 1) / 2); // 1,2,2,3,3,4... for idx 1,2,3,4,5,6
      pos = (idx % 2 == 1) ? (1.0 - (step - 1.0) / steps)
                            : -(1.0 - (step - 1.0) / steps);
      pos = max(-1.0, min(1.0, pos));
    );

  ) : (
    // Diverging: accent center, pairs walk outward symmetrically
    // beat 0 = 0, beat 1 = slight left, beat 2 = slight right...
    idx == 0 ? (
      pos = 0.0;
    ) : (
      step = floor((idx + 1) / 2); // 1,1,2,2,3,3...
      pos = (idx % 2 == 1) ? -(step / steps)
                            :  (step / steps);
      pos = max(-1.0, min(1.0, pos));
    );
  );

  pos * pan_spread * flip
);


@slider

// NOTE: the variable name `tempo` is RESERVED in JSFX — it's a read-only
// system variable that returns REAPER's current project tempo. Assigning
// to `tempo` is silently ignored, which caused effective_tempo to be
// computed against the project tempo (always ~120 BPM by default) and
// completely ignore slider1. Renamed to `track_bpm` throughout to avoid
// the collision. See JSFX docs: https://www.reaper.fm/sdk/js/var.php
track_bpm    = slider1;
timesig      = slider2;
swing        = slider3;
strong_hz    = slider4;
weak_hz      = slider5;
tone_q       = slider6;
strong_gain  = slider7;
weak_gain    = slider8;
strong_decay = slider9;
weak_decay   = slider10;
pan_spread   = slider11;
pan_mode     = slider12;
pan_flip     = slider13;

samples_per_beat = (60.0 / track_bpm) * srate;

// Start Delay — beats at the current Tempo.
start_delay_sec = slider14 * 60 / max(track_bpm, 1);

// Play/Rest gate: integer beat counts. Both must be > 0 for the
// gate to engage; 0 in either slider disables.
play_for_beats = slider15;
rest_for_beats = slider16;
pr_enabled     = (play_for_beats > 0 && rest_for_beats > 0);

// Speed ramp engage-edge.
// No engage-edge logic. Engage is a freeze/resume gate handled in
// @sample. Only transport play resets ramp_t.

// Drift target selector save/restore (nested-selector pattern).
// Switching slider21 saves sliders 22-25 into the OLD target's slot,
// then loads the NEW target's stored config into sliders 22-25.
// Otherwise captures live edits to the current target's slot. Both
// targets drift in parallel from @sample regardless of selection.
sel_target = slider21;
sel_up     = slider22;
sel_down   = slider23;
sel_per    = slider24;
sel_shape  = slider25;

last_target_select != sel_target ? (
  target_drift_up[last_target_select]    = sel_up;
  target_drift_down[last_target_select]  = sel_down;
  target_drift_per[last_target_select]   = sel_per;
  target_drift_shape[last_target_select] = sel_shape;

  slider22 = target_drift_up[sel_target];
  slider23 = target_drift_down[sel_target];
  slider24 = target_drift_per[sel_target];
  slider25 = target_drift_shape[sel_target];
  slider_automate(slider22);
  slider_automate(slider23);
  slider_automate(slider24);
  slider_automate(slider25);

  last_target_select = sel_target;
) : (
  target_drift_up[sel_target]    = sel_up;
  target_drift_down[sel_target]  = sel_down;
  target_drift_per[sel_target]   = sel_per;
  target_drift_shape[sel_target] = sel_shape;
);

strong_len = render_tick(strong_buf, strong_hz, strong_gain, strong_decay, tone_q);
weak_len   = render_tick(weak_buf,   weak_hz,   weak_gain,   weak_decay,   tone_q);

// swing_offset[i] precompute removed in v2.9: swing now wanders per
// sample via target_drift_offset[1], so the offset for the current
// beat is computed inline in @sample on beat-wrap (see below).


@sample

// Transport play edge: fresh start. v2.9 uses ext_noinit = 1 so drift
// CONFIG bank survives across transport — but everything else needs
// explicit reset here so renders are deterministic (drift cycle at
// phase 0, first beat ready to fire immediately via beat_phase = 1.0
// init trick, no leftover tick decay). Matches breath_gen v2.9 / the
// suite rule.
play_state > 0 && last_play_state == 0 ? (
  // Start Delay + Speed Ramp progress.
  start_delay_elapsed      = 0;
  speed_ramp_t             = 0.0;
  speed_ramp_delay_elapsed = 0;

  // Drift runtime state (NOT the config bank).
  i = 0;
  loop(N_TARGETS,
    target_drift_phase[i]  = 0;
    target_drift_prev[i]   = 0;
    target_drift_curr[i]   = 0;
    target_drift_offset[i] = 0;
    i += 1;
  );

  // Beat clock: beat_phase = 1.0 so the very first @sample call after
  // delay fires the downbeat immediately (same trick as @init).
  beat_phase = 1.0;
  beat_index = 0;

  // Tick state: nothing playing.
  tick_playing = 0;
  tick_pos     = 0;
  tick_src     = 0;
  tick_len     = 0;
  tick_pan     = 0;

  // Play/Rest gate: beat 0, fully playing.
  pr_resting = 0;
  pr_beat    = 0;
);
last_play_state = play_state;

// Advance speed_ramp_t while engaged + duration > 0 + past start delay.
// Engage off freezes ramp_t; engaging on resumes from there.
slider19 && slider18 > 0 ? (
  speed_ramp_delay_samples = slider20 * 60 * srate;
  speed_ramp_delay_elapsed < speed_ramp_delay_samples ? (
    speed_ramp_delay_elapsed += 1;
  ) : (
    speed_ramp_t += 1.0 / (srate * slider18 * 60);
    speed_ramp_t = min(speed_ramp_t, 1.0);
  );
);

// Speed Ramp's BPM offset (signed delta). Applied additively to
// effective_tempo below alongside drift offsets. The drift wave's
// period needs to track Speed Ramp so the wave-per-beat relationship
// stays constant — but using effective_samples_per_beat would be
// circular (Tempo drift modifies it). Use a Speed-Ramp-adjusted
// samples_per_beat (track_bpm + speed_ramp_offset, no drift) as the
// stable reference for the drift wave's period.
speed_ramp_bpm_offset = speed_ramp_t * slider17;
sr_adjusted_tempo = max(10, track_bpm + speed_ramp_bpm_offset);
sr_adjusted_samples_per_beat = (60.0 / sr_adjusted_tempo) * srate;

// Per-target drift wave computation. 2 targets (0=Tempo BPM,
// 1=Swing amount). Each gets a phase counter advancing per sample
// at rate 1 / (period_beats * sr_adjusted_samples_per_beat) — both
// targets share the speed-ramp-adjusted beat as their period reference
// so drift on either target doesn't self-modulate the rate.
i = 0;
loop(N_TARGETS,
  up    = target_drift_up[i];
  down  = target_drift_down[i];
  per   = target_drift_per[i];
  shape = target_drift_shape[i];

  drift_offset_local = 0;
  (up > 0 || down > 0) && per > 0 ? (
    period_samples = max(per * max(sr_adjusted_samples_per_beat, 1), 1);
    new_phase = target_drift_phase[i] + 1.0 / period_samples;
    new_phase >= 1.0 ? (
      new_phase -= 1.0;
      shape == 2 ? (
        target_drift_prev[i] = target_drift_curr[i];
        target_drift_curr[i] = rand(2) - 1;
      );
    );
    target_drift_phase[i] = new_phase;

    shape == 0 ? (
      shape_val = sin(2 * $pi * new_phase);
    ) : shape == 1 ? (
      shape_val = new_phase < 0.25 ? (4 * new_phase) :
                  new_phase < 0.75 ? (2 - 4 * new_phase) :
                                     (4 * new_phase - 4);
    ) : (
      shape_val = target_drift_prev[i] +
        (target_drift_curr[i] - target_drift_prev[i]) * new_phase;
    );
    drift_offset_local = shape_val > 0 ? shape_val * up : shape_val * down;
  );
  target_drift_offset[i] = drift_offset_local;
  i += 1;
);

// Effective tempo with drift + Speed Ramp, clamped at 10 BPM (matches
// slider1's minimum) so over-aggressive Down amounts can't silence
// or invert the metronome.
effective_tempo = max(10, track_bpm + target_drift_offset[0] + speed_ramp_bpm_offset);
effective_samples_per_beat = (60.0 / effective_tempo) * srate;

// Effective swing: baseline + Swing drift, clamped to [-1, +1] so
// drift can't drive swing outside the meaningful range.
current_swing = max(-1.0, min(1.0, swing + target_drift_offset[1]));

// Start Delay gate. During the silent window beat_phase and tick_pos
// don't advance, so when the delay elapses the metronome begins from
// the downbeat as expected.
start_delay_elapsed < start_delay_sec ? (
  start_delay_elapsed += 1 / srate;
  spl0 = 0;
  spl1 = 0;
) : (

beat_phase += 1 / effective_samples_per_beat;

beat_phase >= 1.0 ? (
  beat_phase -= 1.0;

  // Per-beat Play/Rest gate. Check first whether we've reached the
  // threshold for the current period — if so, flip play↔rest and
  // reset the counter. Then increment the counter for the beat we're
  // about to (maybe) fire. Tick fires only if !pr_resting (or gate
  // is off entirely). The previously-fired tick keeps playing through
  // its decay tail regardless — gate doesn't touch the audio buffer.
  pr_enabled ? (
    pr_beat >= (pr_resting ? rest_for_beats : play_for_beats) ? (
      pr_resting = 1 - pr_resting;
      pr_beat = 0;
    );
    pr_beat += 1;
  );

  (!pr_enabled || !pr_resting) ? (
    is_accent = (beat_index == 0) ? 1 : 0;
    tick_src  = is_accent ? strong_buf : weak_buf;
    tick_len  = is_accent ? strong_len : weak_len;
    tick_pan  = beat_pan(beat_index);
    tick_pos  = 0;
    tick_playing = 1;
  );

  // beat_index and swing always advance — preserves the bar grid
  // through rest periods so the accent stays locked to "every
  // timesig beats" regardless of where rest falls.
  //
  // Swing offset is computed inline from current_swing (slider3 +
  // Swing drift, clamped). Pattern is "delay every 2nd beat by
  // swing * 1/3 of a beat" — alternates at beat_index parity.
  beat_index  = (beat_index + 1) % timesig;
  beat_phase -= current_swing * (1.0 / 3.0) * ((beat_index + 1) % 2);
);

out = 0;
tick_playing ? (
  out = tick_src[tick_pos];
  tick_pos += 1;
  tick_pos >= tick_len ? tick_playing = 0;
);

pan_pos = (tick_pan + 1.0) * 0.5;
spl0 = out * cos(pan_pos * $pi * 0.5);
spl1 = out * sin(pan_pos * $pi * 0.5);

);  // close start-delay else branch

@serialize
// Persist per-target drift configurations. Without this, only the
// most-recently-edited target's drift slider values survive a project
// save/load because sliders 22-25 hold whichever target was selected
// at save time. 2 targets × 4 config fields = 8 values; plus the
// selector.
file_mem(0, target_drift_up,    N_TARGETS);
file_mem(0, target_drift_down,  N_TARGETS);
file_mem(0, target_drift_per,   N_TARGETS);
file_mem(0, target_drift_shape, N_TARGETS);
file_var(0, last_target_select);
