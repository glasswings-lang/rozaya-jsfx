desc: Breath Generator
// Designed by Rozaya, developed with Claude (Anthropic)
//
// This work is dedicated to the public domain under CC0 1.0 Universal.
// https://creativecommons.org/publicdomain/zero/1.0/

slider1:4.0<0.5,20.0,0.1>Inhale Duration (sec)
slider2:0.3<0.0,5.0,0.1>Top Pause (sec)
slider3:4.0<0.5,20.0,0.1>Exhale Duration (sec)
slider4:0.3<0.0,5.0,0.1>Bottom Pause (sec)
slider5:800<50,2000,1>Inhale Frequency Hz
slider6:600<50,2000,1>Exhale Frequency Hz
slider7:0.3<0.0,1.0,0.01>Inhale Fade In
slider8:0.2<0.0,1.0,0.01>Inhale Fade Out
slider9:0.2<0.0,1.0,0.01>Exhale Fade In
slider10:0.3<0.0,1.0,0.01>Exhale Fade Out
slider11:2<1,4,1{Linear,Cosine,Exponential,Natural}>Fade Mode
slider12:0.5<0.0,1.0,0.01>Stereo Width
slider13:0<0,1,1{Normal,Flipped}>Stereo Flip

// Sit silent for N seconds after playback starts, then begin normally.
// Re-arms on every transport stop/start. 0 disables the delay.
slider14:0<0,1000,0.001>Start Delay (seconds)

// Per-breath Play/Rest gate. Runs N full breath cycles, then sits
// silent for M breath cycles' worth of time, then resumes — repeats
// forever. A "breath cycle" is one full inhale + top pause + exhale
// + bottom pause. During rest the state machine pauses on the
// bottom-pause state (already silent in normal operation), so the
// gate's silence is just an extended bottom pause — no extra fade
// logic needed. The breath in progress when the threshold hits
// finishes its natural envelope before the rest begins; the gate
// only stops the NEXT breath from starting. 0 in either slider
// disables the gate. Resets on every transport stop/start.
slider15:0<0,1000,1>Play for (breaths)
slider16:0<0,1000,1>Rest for (breaths)

// Speed ramp: nested-selector pattern matching Womb v3. Pick a target
// (slider17) and set a signed delta amount (slider20) in seconds; the
// selected target's segment length is shifted by ramp_t * amount as
// ramp_t advances 0->1 over the duration (slider18). All 4 targets'
// stored amounts ramp in parallel — switching the selector doesn't
// stop a running ramp, just changes which target's amount you're
// editing. Engage (slider19) is a freeze/resume gate (not a restart
// trigger). Only transport play resets ramp_t.
//
// Migration from v2.7: slider17 changed semantics from multiplier
// (0.1-4.0) to selector (integer 0-3). Existing projects will see
// slider17 hold a multiplier value, interpreted as a selector index
// (rounds down — e.g. 0.5 becomes 0 = Inhale). New slider20 (amount)
// defaults to 0, so Speed Ramp produces no effect on reload until
// re-configured.
slider17:0<0,3,1{Inhale,Top pause,Exhale,Bottom pause}>Speed ramp target
slider18:0<0,60,0.1>Speed ramp duration (minutes)
slider19:0<0,1,1{Off,On}>Speed ramp engage
slider20:0<-20,20,0.1>Speed ramp by

// Musical drift: cycles-per-drift-period, scales with Speed Ramp.
// Up/Down amplitudes in seconds added to the breath cycle.
// One "primary cycle" here is one full breath
// (inhale + top pause + exhale + bottom pause).
slider21:0<0,2,0.01>Musical drift: Up by
slider22:0<0,2,0.01>Musical drift: Down by
slider23:8<1,1000,1>Musical drift: Period (cycles)

// Slow drift: wall-clock minutes per drift cycle, does NOT scale with
// Speed Ramp. Up/Down amplitudes in seconds added to the breath cycle.
slider24:0<0,2,0.01>Slow drift: Up by
slider25:0<0,2,0.01>Slow drift: Down by
slider26:5<0.1,60,0.1>Slow drift: Period (minutes)

slider27:0<0,2,1{Sine,Triangle,Random}>Drift shape

// Speed ramp start delay: wait this many minutes after engage before
// ramp_t starts advancing. Lives at slider29 because the v2.7 layout
// already had Speed Ramp's first 3 sliders at 17-19 with the drift
// block claiming 21-27 immediately after, leaving no contiguous run.
slider29:0<0,60,0.1>Speed ramp start delay (minutes)

@init
srate_inv = 1.0 / srate;
two_pi = 2.0 * $pi;

// State machine
// 0 = inhale, 1 = top pause, 2 = exhale, 3 = bottom pause
breath_state = 0;
state_phase = 0.0; // 0..1 through current state

// Durations in samples
inhale_len  = floor(srate * 4.0);
top_len     = floor(srate * 0.3);
exhale_len  = floor(srate * 4.0);
bot_len     = floor(srate * 0.3);
state_len   = inhale_len;
state_pos   = 0;

// Filter state - two channels, each with inhale and exhale filter
// L channel
in_lp_l = 0; in_bp_l = 0;
ex_lp_l = 0; ex_bp_l = 0;
// R channel - slightly different to decorrelate
in_lp_r = 0; in_bp_r = 0;
ex_lp_r = 0; ex_bp_r = 0;



// Filter coefficients - initialized to defaults
in_f  = min(2.0 * sin($pi * 800.0 * srate_inv), 0.98);
in_f_r = min(2.0 * sin($pi * 760.0 * srate_inv), 0.98);
ex_f  = min(2.0 * sin($pi * 600.0 * srate_inv), 0.98);
ex_f_r = min(2.0 * sin($pi * 560.0 * srate_inv), 0.98);
lp_q  = 0.6;

fade_in_in   = 0.3;
fade_in_out  = 0.2;
fade_ex_in   = 0.2;
fade_ex_out  = 0.3;
fade_mode    = 2;
stereo_width = 0.5;

noise_seed  = 12345;
noise_seed2 = 67890;

function apply_fade(pos, fade_in, fade_out, mode) local(raw, t) (
  // pos = 0..1 through the sound
  // fade_in and fade_out are fractions of total duration
  raw = 1.0;

  // Fade in region
  pos < fade_in ? (
    t = pos / fade_in; // 0..1 within fade
    mode == 1 ? raw = t;                                    // Linear
    mode == 2 ? raw = 0.5 - 0.5 * cos(t * $pi);           // Cosine
    mode == 3 ? raw = t * t;                               // Exponential in
    mode == 4 ? raw = sin(t * $pi * 0.5);                  // Natural (sine curve)
  ) :

  // Fade out region
  pos > (1.0 - fade_out) ? (
    t = (pos - (1.0 - fade_out)) / fade_out; // 0..1 within fade
    mode == 1 ? raw = 1.0 - t;
    mode == 2 ? raw = 0.5 + 0.5 * cos(t * $pi);
    mode == 3 ? raw = (1.0 - t) * (1.0 - t);
    mode == 4 ? raw = cos(t * $pi * 0.5);
  );

  raw;
);

// Start Delay state.
last_play_state     = 0;
start_delay_elapsed = 0;
start_delay_sec     = 0;

// Play/Rest gate state. pr_breath counts breaths completed in the
// current play period (init to 0 because the first breath is still
// in progress at t=0). pr_rest_elapsed counts samples spent in rest
// — when it reaches rest_for_breaths * total_breath_samples, exit
// rest and start a fresh breath cycle from inhale.
pr_resting          = 0;
pr_breath           = 0;
pr_rest_elapsed     = 0;
play_for_breaths    = 0;
rest_for_breaths    = 0;
pr_enabled          = 0;
total_breath_samples = 0;

// Speed ramp state. Per-target memory bank holds the signed `by` delta
// for each of 4 targets (Inhale, Top pause, Exhale, Bottom pause).
// @sample reads all 4 in parallel; the selector just edits which slot
// slider20 currently reflects. ramp_t advances 0->1 over duration
// while engaged. Engage is a freeze/resume gate, NOT a restart edge —
// only transport play resets ramp_t.
N_SPEED_TARGETS              = 4;
speed_ramp_target_value_mem  = 4096;
i = 0;
loop(N_SPEED_TARGETS, speed_ramp_target_value_mem[i] = 0; i += 1;);
last_speed_target            = 0;
speed_ramp_t                 = 0.0;
speed_ramp_delay_elapsed     = 0;
// (last_play_state already initialized earlier in @init)

// Per-plugin drift state. Phases run 0..1, advancing each sample.
// Musical drift advances at a rate tied to one breath cycle (scaled
// by Speed Ramp); slow drift advances on wall-clock time.
musical_drift_phase = 0;
slow_drift_phase    = 0;
// Random-shape interpolation targets (uniform in [-1, +1]).
musical_drift_prev_target = 0;
musical_drift_curr_target = 0;
slow_drift_prev_target    = 0;
slow_drift_curr_target    = 0;

@slider
inhale_len = max(floor(srate * slider1), 1);
top_len    = max(floor(srate * slider2), 1);
exhale_len = max(floor(srate * slider3), 1);
bot_len    = max(floor(srate * slider4), 1);

// Clamp state_pos if durations shrank
breath_state == 0 ? state_len = inhale_len;
breath_state == 1 ? state_len = top_len;
breath_state == 2 ? state_len = exhale_len;
breath_state == 3 ? state_len = bot_len;
state_pos = min(state_pos, state_len - 1);

// Width spreads L and R filter frequencies apart from center
in_f   = min(2.0 * sin($pi * (slider5 * (1.0 + slider12 * 0.15)) * srate_inv), 0.98);
in_f_r = min(2.0 * sin($pi * (slider5 * (1.0 - slider12 * 0.15)) * srate_inv), 0.98);
ex_f   = min(2.0 * sin($pi * (slider6 * (1.0 + slider12 * 0.12)) * srate_inv), 0.98);
ex_f_r = min(2.0 * sin($pi * (slider6 * (1.0 - slider12 * 0.12)) * srate_inv), 0.98);

fade_in_in  = slider7;
fade_in_out = slider8;
fade_ex_in  = slider9;
fade_ex_out = slider10;
fade_mode   = slider11;
stereo_width = slider12;

start_delay_sec = slider14;

// Play/Rest gate: integer breath counts. Both must be > 0 for the
// gate to engage. total_breath_samples is the sample-count of one
// full breath cycle, used to time the rest period (which is a
// continuous sample counter, not a state-machine count).
total_breath_samples = inhale_len + top_len + exhale_len + bot_len;
play_for_breaths = slider15;
rest_for_breaths = slider16;
new_pr_enabled = (play_for_breaths > 0 && rest_for_breaths > 0);
// If the user disables the gate mid-rest, snap back to the start of
// a fresh inhale so the plugin doesn't stay stuck silent in state 3.
!new_pr_enabled && pr_resting ? (
  pr_resting = 0;
  breath_state = 0;
  state_len = inhale_len;
  state_pos = 0;
);
pr_enabled = new_pr_enabled;

// Speed ramp target selector: save/restore slider20 (amount) against
// the per-target memory bank. When the selector changes, save the
// current slider20 to the OLD target's slot, then load the NEW slot's
// stored amount into slider20. When the selector hasn't changed,
// capture live edits into the current target's slot.
sel_speed_target = slider17;
last_speed_target != sel_speed_target ? (
  speed_ramp_target_value_mem[last_speed_target] = slider20;
  slider20 = speed_ramp_target_value_mem[sel_speed_target];
  slider_automate(slider20);
  last_speed_target = sel_speed_target;
) : (
  speed_ramp_target_value_mem[sel_speed_target] = slider20;
);
// No engage-edge detection. Engage is a freeze/resume gate, handled
// in @sample via `slider19 && slider18 > 0` advancing speed_ramp_t.

@sample

// Transport play edge resets speed_ramp_t (and start-delay counter),
// so each play press starts a fresh ramp from 0. This is the ONLY
// thing that resets ramp_t — slider changes (selector switch, engage
// toggle, etc.) leave it alone.
play_state > 0 && last_play_state == 0 ? (
  start_delay_elapsed      = 0;
  speed_ramp_t             = 0.0;
  speed_ramp_delay_elapsed = 0;
);
last_play_state = play_state;

// Advance speed_ramp_t while engaged + duration > 0 + past start delay.
// Engage off freezes ramp_t at its current value; engaging on resumes
// from there.
slider19 && slider18 > 0 ? (
  speed_ramp_delay_samples = slider29 * 60 * srate;
  speed_ramp_delay_elapsed < speed_ramp_delay_samples ? (
    speed_ramp_delay_elapsed += 1;
  ) : (
    speed_ramp_t += 1.0 / (srate * slider18 * 60);
    speed_ramp_t = min(speed_ramp_t, 1.0);
  );
);

// Per-target Speed Ramp offsets (parallel — all 4 ramp regardless of
// which target the selector is currently showing). Each target gets
// `ramp_t * stored_amount` in its native unit (seconds for breath
// segments). The selector is NOT referenced here.
speed_ramp_inhale_offset = speed_ramp_t * speed_ramp_target_value_mem[0];
speed_ramp_top_offset    = speed_ramp_t * speed_ramp_target_value_mem[1];
speed_ramp_exhale_offset = speed_ramp_t * speed_ramp_target_value_mem[2];
speed_ramp_bot_offset    = speed_ramp_t * speed_ramp_target_value_mem[3];

// Effective per-segment lengths: baseline (from slider) + Speed Ramp
// offset. These OVERWRITE the @slider-set values each sample so that
// Speed Ramp's continuous progress is reflected in segment length
// at every sample.
inhale_len = max(floor(srate * max(slider1 + speed_ramp_inhale_offset, 0.1)), 1);
top_len    = max(floor(srate * max(slider2 + speed_ramp_top_offset,    0  )), 1);
exhale_len = max(floor(srate * max(slider3 + speed_ramp_exhale_offset, 0.1)), 1);
bot_len    = max(floor(srate * max(slider4 + speed_ramp_bot_offset,    0  )), 1);
total_breath_samples = inhale_len + top_len + exhale_len + bot_len;

// combined_scale is now driven only by drift (Speed Ramp lives in
// segment lengths, not in a scale multiplier). Starts at 1.0; the
// drift block below modifies it via drift_sec.
combined_scale = 1.0;

// Per-plugin drift. Two independent sources (musical + slow) sum into
// a seconds-offset on the breath cycle period, which is then converted
// back to a scale multiplier so it composes cleanly with Speed Ramp.
// Musical drift's phase advance scales with combined_scale so it tracks
// the kin's breath when Speed Ramp slows things down; slow drift is
// wall-clock and does not.
musical_drift_up     = slider21;
musical_drift_down   = slider22;
musical_drift_period = slider23;
slow_drift_up        = slider24;
slow_drift_down      = slider25;
slow_drift_period    = max(slider26, 0.1);
drift_shape          = slider27;

drift_sec = 0;
(musical_drift_up > 0 || musical_drift_down > 0) ? (
  // total_breath_samples is one full breath cycle. Phase wraps once
  // per (musical_drift_period) breaths.
  musical_period_samples = max(musical_drift_period, 1) * max(total_breath_samples, 1);
  musical_drift_phase_prev = musical_drift_phase;
  musical_drift_phase += combined_scale / musical_period_samples;
  musical_drift_phase >= 1.0 ? (
    musical_drift_phase -= floor(musical_drift_phase);
    drift_shape == 2 ? (
      musical_drift_prev_target = musical_drift_curr_target;
      musical_drift_curr_target = rand(2) - 1;
    );
  );
  drift_shape == 0 ? (
    musical_shape = sin(2 * $pi * musical_drift_phase);
  );
  drift_shape == 1 ? (
    musical_shape = musical_drift_phase < 0.25 ? (4 * musical_drift_phase) :
                    musical_drift_phase < 0.75 ? (2 - 4 * musical_drift_phase) :
                    (4 * musical_drift_phase - 4);
  );
  drift_shape == 2 ? (
    musical_shape = musical_drift_prev_target + (musical_drift_curr_target - musical_drift_prev_target) * musical_drift_phase;
  );
  musical_drift_offset = musical_shape > 0 ? (musical_shape * musical_drift_up) : (musical_shape * musical_drift_down);
  drift_sec += musical_drift_offset;
);

(slow_drift_up > 0 || slow_drift_down > 0) ? (
  slow_period_samples = slow_drift_period * 60 * srate;
  slow_drift_phase += 1.0 / slow_period_samples;
  slow_drift_phase >= 1.0 ? (
    slow_drift_phase -= floor(slow_drift_phase);
    drift_shape == 2 ? (
      slow_drift_prev_target = slow_drift_curr_target;
      slow_drift_curr_target = rand(2) - 1;
    );
  );
  drift_shape == 0 ? (
    slow_shape = sin(2 * $pi * slow_drift_phase);
  );
  drift_shape == 1 ? (
    slow_shape = slow_drift_phase < 0.25 ? (4 * slow_drift_phase) :
                 slow_drift_phase < 0.75 ? (2 - 4 * slow_drift_phase) :
                 (4 * slow_drift_phase - 4);
  );
  drift_shape == 2 ? (
    slow_shape = slow_drift_prev_target + (slow_drift_curr_target - slow_drift_prev_target) * slow_drift_phase;
  );
  slow_drift_offset = slow_shape > 0 ? (slow_shape * slow_drift_up) : (slow_shape * slow_drift_down);
  drift_sec += slow_drift_offset;
);

// Apply drift as a seconds offset on the breath cycle period, then
// convert to an effective scale multiplier. Clamp the resulting cycle
// to at least 0.2s so a heavy Down-by can't drive the rate to zero.
drift_sec != 0 ? (
  base_breath_sec = total_breath_samples / srate;
  combined_scale > 0 ? (
    effective_breath_sec = base_breath_sec / combined_scale + drift_sec;
    effective_breath_sec = max(effective_breath_sec, 0.2);
    combined_scale = base_breath_sec / effective_breath_sec;
  );
);

// (Transport edge handling is at the top of @sample now — it resets
// start_delay_elapsed AND speed_ramp_t/delay together. No second
// edge handler here.)

start_delay_elapsed < start_delay_sec ? (
  start_delay_elapsed += 1 / srate;
  spl0 = 0;
  spl1 = 0;
) : (

// Advance state machine. The 3→0 transition (end of bottom pause,
// start of a new breath cycle) is special-cased so the Play/Rest
// gate can decide whether to actually start a new breath or stay
// silent in state 3 for the rest of the rest period.
//
// Speed ramp + drift: increment by combined_scale instead of 1, so
// the whole breath cycle stretches/compresses smoothly with both the
// long-form ramp and the per-plugin drift layered together.
state_pos += combined_scale;
state_pos >= state_len ? (
  state_pos = 0;
  breath_state == 3 ? (
    // End of bottom pause — would normally start a new breath.
    // First: did the breath we JUST completed take us to the play
    // threshold? If so, flip to rest. (Only counts when actually
    // playing — during rest, repeated state-3 ends don't increment
    // the breath counter.)
    pr_enabled && !pr_resting ? (
      pr_breath += 1;
      pr_breath >= play_for_breaths ? (
        pr_resting = 1;
        pr_breath = 0;
        pr_rest_elapsed = 0;
      );
    );
    // Start a new breath cycle ONLY if not resting. If pr_resting is
    // true (either we just flipped to rest, or we've been resting),
    // leave breath_state at 3 and state_pos at 0 so the next pass
    // through the state-end check just re-enters the bottom pause
    // (already silent). The rest timer below is what eventually
    // exits rest and forces a fresh inhale.
    !pr_resting ? (
      breath_state = 0;
      state_len = inhale_len;
    );
  ) : (
    // Normal advance within a breath (0→1, 1→2, 2→3).
    breath_state = (breath_state + 1) % 4;
    breath_state == 1 ? state_len = top_len;
    breath_state == 2 ? state_len = exhale_len;
    breath_state == 3 ? state_len = bot_len;
  );
);

// Rest timer. While resting, count samples elapsed since rest
// began. When that reaches rest_for_breaths * total_breath_samples,
// exit rest and force a fresh inhale to start. total_breath_samples
// is recomputed in @slider whenever any phase-duration slider
// changes, so changing those mid-rest stretches/compresses the
// remaining rest accordingly.
pr_resting ? (
  // Rest timer also uses combined_scale so the play/rest ratio stays
  // consistent under both Speed Ramp and per-plugin drift.
  pr_rest_elapsed += combined_scale;
  pr_rest_elapsed >= rest_for_breaths * total_breath_samples ? (
    pr_resting = 0;
    pr_breath = 0;
    breath_state = 0;
    state_len = inhale_len;
    state_pos = 0;
  );
);

// Position within current state as 0..1
state_phase = state_pos / max(state_len - 1, 1);

// Independent noise per channel - naturally decorrelated stereo
noise_seed = (noise_seed * 1664525 + 1013904223) & 0xFFFFFFFF;
nl = (noise_seed - 0x80000000) * (1.0 / 2147483648.0);
noise_seed2 = (noise_seed2 * 22695477 + 1) & 0xFFFFFFFF;
nr = (noise_seed2 - 0x80000000) * (1.0 / 2147483648.0);

// Silence during pauses
(breath_state == 1 || breath_state == 3) ? (
  spl0 = 0;
  spl1 = 0;
) : (

  breath_state == 0 ? (
    // Inhale
    env = apply_fade(state_phase, fade_in_in, fade_in_out, fade_mode);

    // L
    in_lp_l += in_f * in_bp_l;
    in_hp_l = nl - in_lp_l - lp_q * in_bp_l;
    in_bp_l += in_f * in_hp_l;

    // R - different f coefficient for width
    in_lp_r += in_f_r * in_bp_r;
    in_hp_r = nr - in_lp_r - lp_q * in_bp_r;
    in_bp_r += in_f_r * in_hp_r;

    slider13 == 0 ? (
      spl0 = in_lp_l * env * 1.5;
      spl1 = in_lp_r * env * 1.5;
    ) : (
      spl0 = in_lp_r * env * 1.5;
      spl1 = in_lp_l * env * 1.5;
    );
  ) : (
    // Exhale
    env = apply_fade(state_phase, fade_ex_in, fade_ex_out, fade_mode);

    ex_lp_l += ex_f * ex_bp_l;
    ex_hp_l = nl - ex_lp_l - lp_q * ex_bp_l;
    ex_bp_l += ex_f * ex_hp_l;

    ex_lp_r += ex_f_r * ex_bp_r;
    ex_hp_r = nr - ex_lp_r - lp_q * ex_bp_r;
    ex_bp_r += ex_f_r * ex_hp_r;

    slider13 == 0 ? (
      spl0 = ex_lp_l * env * 1.5;
      spl1 = ex_lp_r * env * 1.5;
    ) : (
      spl0 = ex_lp_r * env * 1.5;
      spl1 = ex_lp_l * env * 1.5;
    );
  );
);

);  // close start-delay else branch

@serialize
// Persist per-target Speed Ramp amounts (signed deltas in seconds)
// and the last-selected target index. Without this, only the
// most-recently-edited target's amount survives a project save/load
// because slider20 holds whichever target was selected at save time.
file_mem(0, speed_ramp_target_value_mem, N_SPEED_TARGETS);
file_var(0, last_speed_target);
