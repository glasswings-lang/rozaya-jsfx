desc: Shepard Scale Generator
// Designed by Rozaya, developed with Claude (Anthropic)
//
// This work is dedicated to the public domain under CC0 1.0 Universal.
// https://creativecommons.org/publicdomain/zero/1.0/
//
// A Shepard scale sequencer. Steps through up to 12 chromatic notes (C-B).
// Each note triggers a stack of octave-spaced oscillators. The pitch window
// is exactly as wide as the Octave Count — so each layer is always exactly
// one octave apart and the bell shaping is always consistent. Together this
// creates the Shepard scale illusion — each note sounds higher than the last,
// but after 12 steps you're back where you started.
//
// SKIP vs REST:
//   Skip — inactive notes are skipped; sequence jumps to next active note.
//   Rest — inactive notes hold silence for their full beat duration.
//
// ENVELOPE:
//   Attack and Release shape each note's volume over its beat. The envelope
//   runs continuously from the beat phase — no abrupt resets, no clicks.
//
// CONTROLS:
//   BPM            — Tempo.
//   Direction      — Ascending (C to B) or descending (B to C).
//   Inactive Notes — Skip or Rest behavior.
//   Attack %       — Fraction of beat spent fading in.
//   Release %      — Fraction of beat spent fading out.
//   Note Length %  — How much of each beat the note occupies before silence.
//   Octave Count   — How many octave layers stack per note (2-12), and how
//                    wide the pitch window is. These are the same thing.
//   Center Octave  — Which octave sits at the middle of the stack.
//   Waveform       — Sine is cleanest for the illusion.
//   Binaural Beat  — Right channel Hz offset.
//   Tuning Ref     — A4 reference frequency.
//
// PER NOTE (C through B):
//   Active  — Always visible. Gain and Pan hide when off.
//   Gain dB — Volume of this note.
//   Pan     — Stereo position.

// ===== GLOBAL CONTROLS =====
slider1:120<10,300,0.1>BPM
slider2:0<0,1,1{Asc,Desc}>Direction
slider3:0<0,1,1{Skip,Rest}>Inactive Notes
slider4:10<0,100,0.1>Attack %
slider5:10<0,100,0.1>Release %
slider6:100<1,100,0.1>Note Length %
slider7:8<2,12,1>Octave Count
slider8:4<0,8,1>Center Octave
slider9:0<0,11,1{Sine,Triangle,Saw,Golden TS,Golden SG,Golden GS,Bell,Wavefold,Half-sine,Phi-cascade,Phi Triangle,Phi Sine}>Waveform
slider10:0<0,100,0.1>Binaural Beat Hz
slider11:440<400,480,0.1>Tuning Reference Hz

// ===== NOTES — C through B (3 sliders each: Active, Gain dB, Pan) =====
slider12:1<0,1,1{Off,On}>C Active
slider13:0<-60,6,0.1>C Gain dB
slider14:0<-100,100,0.1>C Pan

slider15:1<0,1,1{Off,On}>C# Active
slider16:0<-60,6,0.1>C# Gain dB
slider17:0<-100,100,0.1>C# Pan

slider18:1<0,1,1{Off,On}>D Active
slider19:0<-60,6,0.1>D Gain dB
slider20:0<-100,100,0.1>D Pan

slider21:1<0,1,1{Off,On}>D# Active
slider22:0<-60,6,0.1>D# Gain dB
slider23:0<-100,100,0.1>D# Pan

slider24:1<0,1,1{Off,On}>E Active
slider25:0<-60,6,0.1>E Gain dB
slider26:0<-100,100,0.1>E Pan

slider27:1<0,1,1{Off,On}>F Active
slider28:0<-60,6,0.1>F Gain dB
slider29:0<-100,100,0.1>F Pan

slider30:1<0,1,1{Off,On}>F# Active
slider31:0<-60,6,0.1>F# Gain dB
slider32:0<-100,100,0.1>F# Pan

slider33:1<0,1,1{Off,On}>G Active
slider34:0<-60,6,0.1>G Gain dB
slider35:0<-100,100,0.1>G Pan

slider36:1<0,1,1{Off,On}>G# Active
slider37:0<-60,6,0.1>G# Gain dB
slider38:0<-100,100,0.1>G# Pan

slider39:1<0,1,1{Off,On}>A Active
slider40:0<-60,6,0.1>A Gain dB
slider41:0<-100,100,0.1>A Pan

slider42:1<0,1,1{Off,On}>A# Active
slider43:0<-60,6,0.1>A# Gain dB
slider44:0<-100,100,0.1>A# Pan

slider45:1<0,1,1{Off,On}>B Active
slider46:0<-60,6,0.1>B Gain dB
slider47:0<-100,100,0.1>B Pan

// Sit silent for N beats after playback starts, then begin normally.
// Beats are counted at the current scale BPM (slider1) so a delay
// value of 4 at 60 BPM is 4 seconds; at 120 BPM it's 2 seconds.
// Re-arms on every transport stop/start. 0 disables the delay.
slider48:0<0,1000,0.01>Start Delay (beats)

// Per-beat Play/Rest gate. Plays N notes normally, then sits silent
// for M beats' worth of time, then resumes — repeats forever. The
// previously-firing note's envelope decays naturally via the existing
// per-note smoother during the start of the rest period, so rest is
// a clean tail-out rather than a hard cut. 0 in either slider
// disables the gate entirely. Resets on every transport stop/start.
// The Rest mode slider below picks between two different rest
// behaviors — see its comment for details.
slider49:0<0,1000,1>Play for (beats)
slider50:0<0,1000,1>Rest for (beats)

// How the sequencer behaves during the rest period.
//   Walk through (default) — the sequencer keeps advancing through
//     notes during rest. Each rest beat moves seq_pos forward
//     silently. If Play + Rest doesn't divide evenly into your
//     active-note count, the starting note of each play period
//     walks across the scale. Notes get "skipped" in the literal
//     sense (the sequencer walks past them silently); they reappear
//     in subsequent play periods at different positions.
//   Freeze in place — the sequencer pauses on the note that would
//     have fired when rest started. Rest duration is Rest for ×
//     one beat (60/BPM seconds). When rest ends, the frozen note
//     fires and the scale continues from there — every note plays
//     in order across multiple cycles, just with pauses between
//     phrases.
slider51:0<0,1,1{Walk through,Freeze in place}>Rest mode

// Speed ramp: in-plugin tempo morph over time. Scales seq_phase
// advancement (and the Freeze-mode rest timer) by speed_scale_current
// per sample, so the entire scale tempo stretches/compresses without
// touching the BPM slider. 0.5 = half tempo, 2.0 = double. Play/Rest
// timing stays internally consistent because both halves of the gate
// scale together.
slider52:1.0<0.1,4.0,0.01>Speed ramp target (multiplier)
slider53:0<0,60,0.1>Speed ramp duration (minutes)
slider54:0<0,1,1{Off,On}>Speed ramp engage

// Musical drift: per-plugin BPM drift scaled by Speed Ramp.
// Period is measured in beats — one drift cycle spans
// (Period (cycles)) beats at the current effective tempo.
// Up by / Down by are in BPM. Default 0 (off).
slider56:0<0,20,0.1>Musical drift: Up by
slider57:0<0,20,0.1>Musical drift: Down by
slider58:8<1,1000,1>Musical drift: Period (cycles)

// Slow drift: per-plugin BPM drift on a wall-clock period.
// Does NOT scale with Speed Ramp. Up by / Down by in BPM.
// Default 0 (off).
slider59:0<0,20,0.1>Slow drift: Up by
slider60:0<0,20,0.1>Slow drift: Down by
slider61:5<0.1,60,0.1>Slow drift: Period (minutes)

// Drift shape applies to BOTH drift sources.
slider62:0<0,2,1{Sine,Triangle,Random}>Drift shape


@init
PHI = 1.6180339887;
NUM_OSC = 12; // max octave layers per note

// Memory: note 0-11, osc 0-11 → index = note * NUM_OSC + osc (max 144 slots)
osc_freq    = 0;   // 0-143:   fixed frequency per oscillator
osc_phase_l = 144; // 144-287: oscillator phase left
osc_phase_r = 288; // 288-431: oscillator phase right
osc_gain    = 432; // 432-575: smoothed gain per oscillator

// Per-note (12 slots each)
n_active    = 576; // 576-587
n_gain_lin  = 588; // 588-599
n_pan       = 600; // 600-611
n_root      = 612; // 612-623: root Hz for each note
n_env       = 624; // 624-635: per-note envelope gain (smoothed)

// Sequencer state
seq_pos   = 0;   // current note index 0-11
seq_phase = 0.0; // position in current beat 0-1

smooth_gain = 0; // set in @slider
needs_init   = 1;
last_num_osc = 0;
last_center  = -1;
last_tuning  = -1;

i = 0;
loop(12, n_env[i] = 0; i += 1;);

i = 0;
loop(144,
  osc_freq[i]    = 1; // 1Hz placeholder — avoids log(0)
  osc_phase_l[i] = 0;
  osc_phase_r[i] = 0;
  osc_gain[i]    = 0;
  i += 1;
);

function note_to_hz(semitone, oct, tref) (
  // semitone 0=C ... 11=B, oct=octave number, tref=A4 Hz
  tref * pow(2, (oct * 12 + semitone - 57) / 12.0)
);

// Waveform dispatch — kept in sync with Polyrhythm Phase / Melody Phase
// so all four plugins offer the same palette. See those plugins' source
// for the canonical comment blocks on each waveform. Note that the
// Golden TS / SG slots are the polyrhythm-compatible (sine-output)
// versions, not the manual's strict reading — Phi Triangle / Phi Sine
// are the strict-reading variants. See rozaya-jsfx/CLAUDE.md for why.
function wave_sample(ph) (
  waveform == 0 ? sin(ph * 2 * $pi) :
  waveform == 1 ? (ph < 0.25 ? ph*4 : ph < 0.75 ? 2-ph*4 : ph*4-4) :
  waveform == 2 ? (ps = ph+0.5; ps-=floor(ps); ps*2-1) :
  waveform == 3 ? (
    pg = ph<(1/PHI) ? ph*PHI*0.5 : 0.5+(ph-1/PHI)/(1-1/PHI)*0.5;
    sin(pg*2*$pi)
  ) :
  waveform == 4 ? (
    pg = (sin((ph-0.25)*2*$pi)+1)*0.5;
    pg = pg<(1/PHI) ? pg*PHI*0.5 : 0.5+(pg-1/PHI)/(1-1/PHI)*0.5;
    sin(pg*2*$pi)
  ) :
  waveform == 5 ? (
    pg = ph+(1/PHI)*sin(ph*2*$pi)/(2*$pi); pg-=floor(pg); sin(pg*2*$pi)
  ) :
  waveform == 6 ? (
    // Bell — additive partials at 1, 2, 3, 4, 6
    0.55*sin(ph*2*$pi) + 0.25*sin(ph*4*$pi) + 0.10*sin(ph*6*$pi)
      + 0.07*sin(ph*8*$pi) + 0.03*sin(ph*12*$pi)
  ) :
  waveform == 7 ? sin(2 * sin(ph * 2 * $pi)) :          // Wavefold
  waveform == 8 ? (2 * abs(sin(ph * 2 * $pi)) - 1) :    // Half-sine (octave up; see Polyrhythm Phase docs)
  waveform == 9 ? (
    // Phi-cascade — fundamental + φ⁻¹·2nd + φ⁻²·3rd
    sin(ph*2*$pi) + (1/PHI)*sin(ph*4*$pi) + (1/(PHI*PHI))*sin(ph*6*$pi)
  ) :
  waveform == 10 ? (
    // Phi Triangle — manual-correct "Golden TS" (warp → triangle)
    pg = ph<(1/PHI) ? ph*PHI*0.5 : 0.5+(ph-1/PHI)/(1-1/PHI)*0.5;
    pg < 0.5 ? 4*pg - 1 : 3 - 4*pg
  ) : (
    // Phi Sine — manual-correct "Golden SG" (clean warp → sine, no prewarp)
    pg = ph<(1/PHI) ? ph*PHI*0.5 : 0.5+(ph-1/PHI)/(1-1/PHI)*0.5;
    sin(pg*2*$pi)
  )
);

// Bell gain: cosine rolloff centered on center_freq.
// half_width_oct is half the total window width in octaves (== num_osc / 2).
function bell_gain(f, f_center, half_width_oct) (
  dist = (log(f) - log(f_center)) / log(2);
  abs(dist) >= half_width_oct ? 0 :
  0.5 + 0.5 * cos(dist / half_width_oct * $pi)
);

// Beat envelope: cosine attack/release over beat phase 0-1
function beat_env(ph, att, rel) (
  att + rel > 1.0 ? (t = att+rel; att/=t; rel/=t;);
  ph < att ? (att > 0 ? 0.5 - 0.5*cos(ph/att*$pi) : 1) :
  ph > (1-rel) ? (rel > 0 ? 0.5 - 0.5*cos((1-ph)/rel*$pi) : 0) :
  1
);

// Initialize oscillator frequencies for all 12 notes.
// Window is exactly num_osc octaves wide centered on center_freq.
// Each note gets num_osc oscillators at exact octave steps, starting from
// the octave of the root nearest to center_freq.
function init_oscs() (
  n = 0;
  loop(12,
    root = n_root[n];
    // Find octave of root nearest to center_freq
    center_oct_offset = floor(log(center_freq / root) / log(2) + 0.5);
    root_near_center  = root * pow(2, center_oct_offset);

    // Place oscillators at exact octave steps above root_near_center,
    // wrapping back down when they exceed the window top.
    // Window == num_osc octaves wide, so wrap is always exact.
    o = 0;
    loop(NUM_OSC,
      oi = n * NUM_OSC + o;
      o < num_osc ? (
        f = root_near_center * pow(2, o);
        f > pitch_hi ? f *= pitch_lo / pitch_hi;
      ) : (
        f = root_near_center; // park extra slots — osc_gain stays 0
      );
      osc_freq[oi]    = f;
      osc_phase_l[oi] = 0;
      osc_phase_r[oi] = 0;
      osc_gain[oi]    = 0;
      o += 1;
    );
    n += 1;
  );
);

// Start Delay state.
last_play_state     = 0;
start_delay_elapsed = 0;
start_delay_sec     = 0;

// Play/Rest gate state. pr_step counts beats in the current play
// (or rest) period. Init to 1 because the first audible note (whatever
// seq_pos points at initially, default 0 = C) plays from sample 0
// without going through a beat boundary — so that note IS step 1 of
// the first play period. Subsequent beats increment pr_step at each
// boundary fire.
pr_resting               = 0;
pr_step                  = 1;
play_for_beats           = 0;
rest_for_beats           = 0;
pr_enabled               = 0;
rest_mode                = 0;
pr_rest_elapsed          = 0;
pr_rest_duration_samples = 0;

// Speed ramp state.
speed_ramp_engaged_last = 0;
speed_scale_current     = 1.0;
speed_scale_start       = 1.0;
speed_ramp_t            = 0.0;

// Per-plugin Drift state.
musical_drift_phase      = 0;
slow_drift_phase         = 0;
musical_drift_prev_target = 0;
musical_drift_curr_target = 0;
slow_drift_prev_target    = 0;
slow_drift_curr_target    = 0;


@slider

bpm           = slider1;
direction     = slider2;
skip_mode     = slider3;
attack_frac   = slider4 / 100.0;
release_frac  = slider5 / 100.0;
note_len_frac = slider6 / 100.0;
num_osc       = max(2, min(12, floor(slider7 + 0.5)));
center_oct    = floor(slider8 + 0.5);
waveform      = slider9;
binaural_hz   = slider10;
tuning_ref    = slider11;

// Pitch window: exactly num_osc octaves wide, centered on C in center_oct.
// Using C as anchor so the octave grid aligns with the chromatic root grid (C-B).
// Window width == num_osc means spacing is always exactly 1 octave.
center_freq = tuning_ref * pow(2, (center_oct * 12 - 57) / 12.0); // C4=261.63 at oct=4
half_width  = num_osc * 0.5;
pitch_lo    = center_freq * pow(2, -half_width);
pitch_hi    = center_freq * pow(2,  half_width);

beat_hz = bpm / 60.0;

// Smooth constant for osc gain changes (~5ms)
smooth_gain = exp(-1 / (srate * 0.005));

// Read per-note sliders
n = 0;
loop(12,
  base = 12 + n * 3;
  n_active[n]   = slider(base);
  n_gain_lin[n] = pow(10, slider(base + 1) / 20.0);
  n_pan[n]      = slider(base + 2);
  // Roots at octave 4 — bell centers on center_oct via center_freq
  n_root[n]     = note_to_hz(n, 4, tuning_ref);
  // Show gain and pan only when active
  slider_show(base + 1, n_active[n]);
  slider_show(base + 2, n_active[n]);
  n += 1;
);

// Reinit when oscillator layout needs to change
(num_osc != last_num_osc || center_oct != last_center || tuning_ref != last_tuning) ? (
  needs_init   = 1;
  last_num_osc = num_osc;
  last_center  = center_oct;
  last_tuning  = tuning_ref;
);

// Start Delay: convert beats to seconds at the current scale BPM.
start_delay_sec = slider48 * 60 / max(bpm, 1);

// Play/Rest gate: integer beat counts. Both must be > 0 for the
// gate to engage; 0 in either slider disables.
play_for_beats = slider49;
rest_for_beats = slider50;
pr_enabled     = (play_for_beats > 0 && rest_for_beats > 0);
rest_mode      = slider51;

// Speed ramp engage-edge.
slider54 && !speed_ramp_engaged_last ? (
  speed_scale_start = speed_scale_current;
  speed_ramp_t      = 0.0;
);
speed_ramp_engaged_last = slider54;


@sample

// Re-arm Start Delay on every transport stop/start, then gate the
// scale-generation work — oscillator phases and note state stay
// frozen during the silent window so the scale begins cleanly when
// the delay elapses.
play_state > 0 && last_play_state == 0 ? (
  start_delay_elapsed = 0;
);
last_play_state = play_state;

// Advance speed ramp every sample, regardless of Start Delay.
slider54 && slider53 > 0 ? (
  speed_ramp_t += 1.0 / (srate * slider53 * 60);
  speed_ramp_t = min(speed_ramp_t, 1.0);
  speed_scale_current = speed_scale_start + (slider52 - speed_scale_start) * speed_ramp_t;
);

combined_scale = speed_scale_current;

// Per-plugin Drift: musical (beat-period, Speed-Ramp-scaled) + slow
// (wall-clock). Both produce BPM offsets that sum into an effective
// beat_hz for this sample.
musical_drift_up     = slider56;
musical_drift_down   = slider57;
musical_drift_period = slider58;
slow_drift_up        = slider59;
slow_drift_down      = slider60;
slow_drift_period    = max(slider61, 0.1);
drift_shape          = slider62;

musical_drift_offset = 0;
slow_drift_offset    = 0;

// Musical drift — only run the math if amplitudes are non-zero.
(musical_drift_up > 0 || musical_drift_down > 0) ? (
  // samples_per_beat = srate / beat_hz; period_samples = cycles * samples_per_beat.
  // Phase advance per sample = combined_scale / period_samples,
  // so when Speed Ramp slows things down, musical drift slows too.
  musical_period_samples = musical_drift_period * srate / max(beat_hz, 0.0001);
  musical_drift_phase += combined_scale / max(musical_period_samples, 1);
  musical_drift_phase >= 1 ? (
    musical_drift_phase -= floor(musical_drift_phase);
    drift_shape == 2 ? (
      musical_drift_prev_target = musical_drift_curr_target;
      musical_drift_curr_target = rand(2) - 1;
    );
  );

  drift_shape == 0 ? (
    musical_shape_val = sin(2 * $pi * musical_drift_phase);
  );
  drift_shape == 1 ? (
    musical_shape_val = musical_drift_phase < 0.25 ? (4*musical_drift_phase) :
                        musical_drift_phase < 0.75 ? (2 - 4*musical_drift_phase) :
                        (4*musical_drift_phase - 4);
  );
  drift_shape == 2 ? (
    musical_shape_val = musical_drift_prev_target +
      (musical_drift_curr_target - musical_drift_prev_target) * musical_drift_phase;
  );

  musical_drift_offset = musical_shape_val > 0 ?
    musical_shape_val * musical_drift_up : musical_shape_val * musical_drift_down;
);

// Slow drift — wall-clock period, ignores Speed Ramp.
(slow_drift_up > 0 || slow_drift_down > 0) ? (
  slow_drift_phase += 1 / (slow_drift_period * 60 * srate);
  slow_drift_phase >= 1 ? (
    slow_drift_phase -= floor(slow_drift_phase);
    drift_shape == 2 ? (
      slow_drift_prev_target = slow_drift_curr_target;
      slow_drift_curr_target = rand(2) - 1;
    );
  );

  drift_shape == 0 ? (
    slow_shape_val = sin(2 * $pi * slow_drift_phase);
  );
  drift_shape == 1 ? (
    slow_shape_val = slow_drift_phase < 0.25 ? (4*slow_drift_phase) :
                     slow_drift_phase < 0.75 ? (2 - 4*slow_drift_phase) :
                     (4*slow_drift_phase - 4);
  );
  drift_shape == 2 ? (
    slow_shape_val = slow_drift_prev_target +
      (slow_drift_curr_target - slow_drift_prev_target) * slow_drift_phase;
  );

  slow_drift_offset = slow_shape_val > 0 ?
    slow_shape_val * slow_drift_up : slow_shape_val * slow_drift_down;
);

// Effective BPM for this sample (clamped to BPM >= 10).
effective_bpm = max(bpm + musical_drift_offset + slow_drift_offset, 10);
effective_beat_hz = effective_bpm / 60.0;

start_delay_elapsed < start_delay_sec ? (
  start_delay_elapsed += 1 / srate;
  spl0 = 0;
  spl1 = 0;
) : (

needs_init ? (
  init_oscs();
  needs_init = 0;
);

// Advance beat phase — unless we're in a Freeze-mode Play/Rest
// pause, in which case the sequencer is paused on the would-be-next
// note and seq_phase stays put until the rest timer (further down)
// fires us back into the play period. seq_phase advance scales by
// speed_scale_current so the entire scale tempo morphs with the ramp.
in_frozen_rest = pr_enabled && pr_resting && rest_mode == 1;
!in_frozen_rest ? seq_phase += effective_beat_hz * combined_scale / srate;

// On beat boundary: advance sequencer to next note
seq_phase >= 1.0 ? (
  seq_phase -= 1.0;

  direction == 0 ? (
    next = (seq_pos + 1) % 12;
    skip_mode == 0 ? (
      tries = 0;
      loop(12,
        tries < 12 && !n_active[next] ? (next = (next+1)%12; tries+=1;);
      );
    );
  ) : (
    next = (seq_pos + 11) % 12;
    skip_mode == 0 ? (
      tries = 0;
      loop(12,
        tries < 12 && !n_active[next] ? (next = (next+11)%12; tries+=1;);
      );
    );
  );

  // Play/Rest gate. Check whether the beat we just completed took us
  // to the threshold for the current period; if so, flip play↔rest
  // and reset the counter. Then increment for the beat we're about
  // to (maybe) play. In Walk mode, seq_pos always advances to `next`
  // regardless of pr_resting; the env_target gate further down
  // suppresses audio during rest. In Freeze mode, seq_pos also
  // advances to `next` at the rest-entry boundary (so the frozen
  // note is the would-be-next note), but seq_phase is then pinned
  // by in_frozen_rest above so no further boundary fires until
  // rest exits.
  pr_enabled ? (
    pr_step >= (pr_resting ? rest_for_beats : play_for_beats) ? (
      just_entered_rest = !pr_resting;
      pr_resting = 1 - pr_resting;
      pr_step    = 0;
      just_entered_rest && rest_mode == 1 ? (
        // Freeze-mode rest entry: compute rest duration in samples
        // based on one beat at the current BPM. Same formula every
        // cycle (BPM is global) — unlike Melody Phase where each
        // voice's Next voice in could vary.
        pr_rest_duration_samples = rest_for_beats * srate / effective_beat_hz;
        pr_rest_elapsed = 0;
      );
    );
    pr_step += 1;
  );

  seq_pos = next;
);

// Freeze-mode rest timer. While Rest mode = Freeze AND we're in
// the rest period, count samples elapsed. When the threshold hits,
// exit rest and reset pr_step to 1 so the next beat counts as step 1
// of the new play period. seq_phase is already ~0 (we last touched
// it at the boundary that triggered rest) so the frozen note's beat
// envelope starts cleanly from the beat origin on the next sample.
// The pr_rest_duration_samples > 0 guard handles the edge case where
// the user changes Rest mode mid-rest — without the duration being
// set, the comparison would fire immediately and snap out of rest
// with inconsistent state.
pr_enabled && pr_resting && rest_mode == 1 && pr_rest_duration_samples > 0 ? (
  // Scale rest accumulation by combined_scale so the rest duration
  // tracks the same effective tempo as the play period (Speed Ramp
  // applies; drift is already baked into pr_rest_duration_samples
  // via effective_beat_hz at rest entry).
  pr_rest_elapsed += combined_scale;
  pr_rest_elapsed >= pr_rest_duration_samples ? (
    pr_resting               = 0;
    pr_step                  = 1;
    pr_rest_duration_samples = 0;
  );
);

cur = seq_pos;
out_l = 0;
out_r = 0;

n = 0;
loop(12,
  // Envelope target: current active note gets beat shape, all others decay to 0.
  // During Play/Rest's rest period, force env_target = 0 for the current note
  // too — the per-note smoother (n_env) handles the natural tail-out of whatever
  // was playing when rest started.
  n == cur && n_active[cur] && (!pr_enabled || !pr_resting) ? (
    seq_phase < note_len_frac ? (
      env_target = beat_env(seq_phase / note_len_frac, attack_frac, release_frac);
    ) : (
      env_target = 0;
    );
  ) : (
    env_target = 0;
  );

  // Smooth envelope — no resets, no clicks
  n_env[n] = n_env[n] * smooth_gain + env_target * (1 - smooth_gain);

  n_env[n] > 0.0001 ? (
    pan_val   = n_pan[n] / 100.0;
    pan_l_amt = cos((pan_val + 1) * 0.25 * $pi);
    pan_r_amt = sin((pan_val + 1) * 0.25 * $pi);

    o = 0;
    loop(num_osc,
      oi = n * NUM_OSC + o;

      bg = bell_gain(osc_freq[oi], center_freq, half_width);
      target_gain = bg * n_gain_lin[n] * n_env[n];
      osc_gain[oi] = osc_gain[oi] * smooth_gain + target_gain * (1 - smooth_gain);

      osc_phase_l[oi] += osc_freq[oi] / srate;
      osc_phase_l[oi] >= 1 ? osc_phase_l[oi] -= 1;
      osc_phase_r[oi] += (osc_freq[oi] + binaural_hz) / srate;
      osc_phase_r[oi] >= 1 ? osc_phase_r[oi] -= 1;

      out_l += wave_sample(osc_phase_l[oi]) * osc_gain[oi] * pan_l_amt;
      out_r += wave_sample(osc_phase_r[oi]) * osc_gain[oi] * pan_r_amt;

      o += 1;
    );
  );

  n += 1;
);

// Normalize by oscillator count. Gain smoothing handles crossfade level.
norm = 1.0 / max(num_osc, 1);
spl0 = out_l * norm;
spl1 = out_r * norm;

);  // close start-delay else branch
