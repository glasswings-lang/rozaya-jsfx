desc: Heartbeat Generator
// Designed by Rozaya, developed with Claude (Anthropic)
//
// This work is dedicated to the public domain under CC0 1.0 Universal.
// https://creativecommons.org/publicdomain/zero/1.0/

slider1:70<20,200,1>BPM
slider2:120<50,400,1>Systole ms (S1->S2 gap)
slider3:1.0<0.0,1.0,0.01>S1 Volume
slider4:0.7<0.0,1.0,0.01>S2 Volume
slider5:0.3<0.0,1.0,0.01>Brightness
slider6:60<10,200,1>S1 Decay ms
slider7:25<5,100,1>S2 Decay ms
slider8:45<20,120,1>S1 Frequency Hz
slider9:120<60,300,1>S2 Frequency Hz
slider10:3.0<-15.0,15.0,0.1>Stereo Width ms (neg = heart right)
slider11:6.0<1.0,30.0,0.1>Breath Cycle Seconds
slider12:0.08<0.0,0.25,0.01>Breath HRV Depth
slider13:0.02<0.0,0.08,0.005>Random HRV Depth

// Sit silent for N heartbeats after playback starts, then begin
// normally. Beats are counted at the current BPM (slider1) so a delay
// value of 4 at 60 BPM is 4 seconds; at 120 BPM it's 2 seconds.
// Re-arms on every transport stop/start. 0 disables the delay.
slider14:0<0,1000,0.01>Start Delay (beats)

// Per-beat Play/Rest gate. Fires beats normally for N beats, then
// suppresses the next M beat triggers (silent), then resumes —
// repeats forever. Each beat counted is one full heartbeat at the
// current BPM (S1 + S2 with the systole interval). The previous
// beat's S1/S2 envelopes finish naturally during the silent gap,
// so "rest" here is "don't trigger new beats" rather than any kind
// of fade. 0 in either slider disables the gate entirely. Resets
// on every transport stop/start, same as Start Delay.
slider15:0<0,1000,1>Play for (beats)
slider16:0<0,1000,1>Rest for (beats)

// Speed ramp: nested-selector pattern matching Womb v3. Pick a target
// (slider17), set a signed delta `by` amount (slider20) in the
// target's natural unit. All 4 targets ramp in parallel; switching
// the selector doesn't stop a running ramp. Engage is a freeze/resume
// gate (NOT a restart edge); only transport play resets ramp_t.
//
// Migration from v2.7: slider17 changed from multiplier (0.1-4.0) to
// integer selector (0-3). Old projects' multiplier value rounds down
// to a selector index; slider20 (new amount) defaults to 0, so Speed
// Ramp produces no effect on reload until reconfigured.
slider17:0<0,3,1{Heart BPM,S1-S2 gap,Breath HRV depth,Random HRV depth}>Speed ramp target
slider18:0<0,60,0.1>Speed ramp duration (minutes)
slider19:0<0,1,1{Off,On}>Speed ramp engage
slider20:0<-400,400,0.01>Speed ramp by

// Per-target drift: nested-selector pattern matching Womb v3 / breath
// gen v2.9. Pick a target (slider21), then sliders 22-25 hold THAT
// target's drift config. Switching the selector saves current values
// to the old target's memory slot and loads the new target's values
// into the sliders. All 4 targets drift in parallel; the selector
// just chooses which one you're currently editing. Period unit is
// heartbeats for all 4 targets. For slow wall-clock-feel drift, set
// a long period (~360 heartbeats ≈ 5 min at 72 BPM).
//
// Target indices align with the Speed Ramp selector above — same
// selector value means the same parameter for both, which is a
// convenience for users coordinating drift and ramp on the same
// target.
//
// Migration from v2.8: the old flat drift block (musical_up,
// musical_down, musical_period, slow_up, slow_down, slow_period,
// drift_shape on sliders 21-27) was 7 sliders covering one target
// (Heart BPM only). This is 5 sliders covering 4 independent targets,
// reusing slider IDs 21-25; sliders 26 and 27 are no longer declared.
// Old projects' slider values get reinterpreted (selector defaults
// to Heart BPM, slider22-23 become up/down amounts in BPM). Reset
// drift sliders to defaults after upgrade and reconfigure if you'd
// used the old block.
slider21:0<0,3,1{Heart BPM,S1-S2 gap,Breath HRV depth,Random HRV depth}>Drift target
slider22:0<0,50,0.1>Drift up amount (units match target)
slider23:0<0,50,0.1>Drift down amount (units match target)
slider24:8<1,1000,1>Drift period (heartbeats)
slider25:0<0,2,1{Sine,Triangle,Random}>Drift shape

// Speed ramp start delay (lives here because slider20 took the gap
// between Speed Ramp and Drift; this one sits after the drift block).
slider28:0<0,60,0.1>Speed ramp start delay (minutes)

@init
ext_noinit = 1;   // preserve drift config bank across transport play (drift runtime + state machine still reset on play, see transport edge handler in @sample)

srate_inv = 1.0 / srate;
two_pi = 2.0 * $pi;

s1_freq = 45.0;
s2_freq = 120.0;
s1_phase_osc_near = 0; s1_phase_osc_far = 0;
s2_phase_osc_near = 0; s2_phase_osc_far = 0;

cycle_len_base = floor(srate * 60.0 / 70.0);
cycle_len = cycle_len_base;
systole_samples = floor(srate * 120.0 * 0.001);
s1_vol = 1.0;
s2_vol = 0.7;
s1_decay = exp(-srate_inv / 0.060);
s2_decay = exp(-srate_inv / 0.025);
s1_attack_rate = exp(-srate_inv / 0.008);
s2_attack_rate = exp(-srate_inv / 0.004);

delay_buf_size = 4096;
memset(0, 0, delay_buf_size);
delay_write = 0;
delay_samples = floor(srate * 0.003);
delay_sign = 1;

phase = 0;
s1_active = 1; s2_active = 0;
s1_env = 1.0; s2_env = 0;
s1_attack_phase = 0; s2_attack_phase = 0;

breath_phase = 0.0;
breath_rate = two_pi / (6.0 * srate);
breath_depth = 0.08;

rand_hrv = 0.0;
rand_hrv_target = 0.0;
rand_hrv_depth = 0.02;
rand_hrv_step = 0;
rand_hrv_step_len = floor(srate * 5.0);
rand_hrv_slew = exp(-srate_inv / 3.0);
hrv_seed = 99999;

s1_res_f_near = min(2.0 * sin($pi * 50.0 * srate_inv), 0.98);
s1_res_q_near = 2.8;
s1_res_low_near = 0; s1_res_band_near = 0;
s2_res_f_near = min(2.0 * sin($pi * 138.0 * srate_inv), 0.98);
s2_res_q_near = 2.0;
s2_res_low_near = 0; s2_res_band_near = 0;
lp_f_near = min(2.0 * sin($pi * 200.0 * srate_inv), 0.98);
lp_low_near = 0; lp_band_near = 0; lp_low2_near = 0; lp_band2_near = 0;

s1_res_f_far = min(2.0 * sin($pi * 58.0 * srate_inv), 0.98);
s1_res_q_far = 2.2;
s1_res_low_far = 0; s1_res_band_far = 0;
s2_res_f_far = min(2.0 * sin($pi * 150.0 * srate_inv), 0.98);
s2_res_q_far = 1.6;
s2_res_low_far = 0; s2_res_band_far = 0;
lp_f_far = min(2.0 * sin($pi * 175.0 * srate_inv), 0.98);
lp_low_far = 0; lp_band_far = 0; lp_low2_far = 0; lp_band2_far = 0;

lp_q = 0.5;

noise_seed = 12345;
noise_seed2 = 67890;

// Start Delay state.
last_play_state     = 0;
start_delay_elapsed = 0;
start_delay_sec     = 0;

// Play/Rest gate state. pr_beat counts heartbeats elapsed in the
// current play (or rest) period; threshold compare flips the period
// at each phase wrap. Init to 1 because @init's s1_active=1 already
// starts the first heartbeat firing — that pre-fire is beat 1 of
// the first play period, so the first phase wrap is beat 2.
pr_resting     = 0;
pr_beat        = 1;
play_for_beats = 0;
rest_for_beats = 0;
pr_enabled     = 0;

// Speed ramp + BPM smoother state.
// rate_smoother_coeff eases bpm_smoothed toward bpm_target with a
// ~100 ms time constant — short enough to feel responsive on manual
// tweaks, long enough to bury any per-sample discontinuity.
// Speed Ramp's BPM offset is ADDED to bpm_smoothed in @sample (not
// multiplied) so it composes additively with drift. Seeded from the
// current BPM slider so the first beat after transport-start isn't
// smoothed from a stale default.
rate_smoother_coeff      = 1.0 - exp(-1.0 / (srate * 0.1));
bpm_target               = slider1;
bpm_smoothed             = slider1;
// Speed Ramp state. Per-target memory bank for 4 targets' signed
// `by` amounts (Heart BPM, S1-S2 gap, Breath HRV depth, Random HRV
// depth). Engage is a freeze/resume gate, not an edge; only transport
// play resets ramp_t.
N_SPEED_TARGETS              = 4;
speed_ramp_target_value_mem  = 4096;
i = 0;
loop(N_SPEED_TARGETS, speed_ramp_target_value_mem[i] = 0; i += 1;);
last_speed_target            = 0;
speed_ramp_t                 = 0.0;
speed_ramp_delay_elapsed     = 0;

// --- v2.9 Drift target memory banks ---
//
// 4 targets × 8 fields = 32 slots. 16-slot-aligned per array so
// targets can grow up to 16 later without re-laying-out. Speed ramp
// bank uses 4 slots at 4096; drift banks start at 4112.
//
// Targets (align with Speed Ramp selector indices):
//   0 = Heart BPM         (units: BPM)
//   1 = S1-S2 gap         (units: ms)
//   2 = Breath HRV depth  (units: fractional depth, 0.0-0.25)
//   3 = Random HRV depth  (units: fractional depth, 0.0-0.08)
N_TARGETS = 4;
target_drift_up     = 4112;
target_drift_down   = 4128;
target_drift_per    = 4144;
target_drift_shape  = 4160;
target_drift_phase  = 4176;
target_drift_prev   = 4192;
target_drift_curr   = 4208;
target_drift_offset = 4224;

i = 0;
loop(N_TARGETS,
  target_drift_up[i]     = 0;
  target_drift_down[i]   = 0;
  target_drift_per[i]    = 8;
  target_drift_shape[i]  = 0;
  target_drift_phase[i]  = 0;   // transport play also resets this; @init seeds for first run
  target_drift_prev[i]   = 0;
  target_drift_curr[i]   = 0;
  target_drift_offset[i] = 0;
  i += 1;
);

// Last-selected drift target tracker for save/restore on selector change.
last_target_select = 0;

@slider
// bpm_target feeds the per-sample smoother; cycle_len_base is now
// recomputed each sample in @sample from the smoothed, speed-scaled
// value, so we don't compute it here anymore.
bpm_target = slider1;

// Speed ramp engage-edge: capture the in-flight scale so a re-engage
// starts a fresh ramp from wherever the previous one left off.
// Speed Ramp target selector save/restore (nested-selector pattern).
// When the selector changes, save current slider20 to the OLD slot,
// load NEW slot's amount into slider20. Otherwise capture live edits.
sel_speed_target = slider17;
last_speed_target != sel_speed_target ? (
  speed_ramp_target_value_mem[last_speed_target] = slider20;
  slider20 = speed_ramp_target_value_mem[sel_speed_target];
  slider_automate(slider20);
  last_speed_target = sel_speed_target;
) : (
  speed_ramp_target_value_mem[sel_speed_target] = slider20;
);
// No engage-edge detection. Engage is a freeze/resume gate handled
// in @sample. Only transport play resets ramp_t.

// Drift target selector save/restore (nested-selector pattern).
// Switching slider21 saves sliders 22-25 into the OLD target's slot,
// then loads the NEW target's stored config into sliders 22-25.
// Otherwise captures live edits to the current target's slot. All 4
// targets drift in parallel from @sample regardless of selection.
sel_target = slider21;
sel_up     = slider22;
sel_down   = slider23;
sel_per    = slider24;
sel_shape  = slider25;

last_target_select != sel_target ? (
  target_drift_up[last_target_select]    = sel_up;
  target_drift_down[last_target_select]  = sel_down;
  target_drift_per[last_target_select]   = sel_per;
  target_drift_shape[last_target_select] = sel_shape;

  slider22 = target_drift_up[sel_target];
  slider23 = target_drift_down[sel_target];
  slider24 = target_drift_per[sel_target];
  slider25 = target_drift_shape[sel_target];
  slider_automate(slider22);
  slider_automate(slider23);
  slider_automate(slider24);
  slider_automate(slider25);

  last_target_select = sel_target;
) : (
  target_drift_up[sel_target]    = sel_up;
  target_drift_down[sel_target]  = sel_down;
  target_drift_per[sel_target]   = sel_per;
  target_drift_shape[sel_target] = sel_shape;
);

systole_samples = floor(srate * slider2 * 0.001);
s1_vol = slider3;
s2_vol = slider4;
s1_freq = slider8;
s2_freq = slider9;

breath_rate = two_pi / (slider11 * srate);
breath_depth = slider12;
rand_hrv_depth = slider13;

s1_center_near = slider8 * 1.1;
s2_center_near = slider9 * 1.15;
s1_center_far = slider8 * 1.28;
s2_center_far = slider9 * 1.25;
lp_cutoff_near = 200.0 + slider5 * 250.0;
lp_cutoff_far = 175.0 + slider5 * 220.0;

s1_res_f_near = min(2.0 * sin($pi * s1_center_near * srate_inv), 0.98);
s2_res_f_near = min(2.0 * sin($pi * s2_center_near * srate_inv), 0.98);
lp_f_near = min(2.0 * sin($pi * lp_cutoff_near * srate_inv), 0.98);
s1_res_f_far = min(2.0 * sin($pi * s1_center_far * srate_inv), 0.98);
s2_res_f_far = min(2.0 * sin($pi * s2_center_far * srate_inv), 0.98);
lp_f_far = min(2.0 * sin($pi * lp_cutoff_far * srate_inv), 0.98);

s1_decay = exp(-srate_inv / (slider6 * 0.001));
s2_decay = exp(-srate_inv / (slider7 * 0.001));

delay_samples = floor(srate * abs(slider10) * 0.001);
delay_samples = min(delay_samples, delay_buf_size - 1);
new_sign = slider10 >= 0 ? 1 : -1;
new_sign != delay_sign ? (
  s1_res_low_near = 0; s1_res_band_near = 0;
  s2_res_low_near = 0; s2_res_band_near = 0;
  lp_low_near = 0; lp_band_near = 0; lp_low2_near = 0; lp_band2_near = 0;
  s1_res_low_far = 0; s1_res_band_far = 0;
  s2_res_low_far = 0; s2_res_band_far = 0;
  lp_low_far = 0; lp_band_far = 0; lp_low2_far = 0; lp_band2_far = 0;
  memset(0, 0, delay_buf_size);
);
delay_sign = new_sign;

// Start Delay: convert beats to seconds at the current BPM.
start_delay_sec = slider14 * 60 / max(slider1, 1);

// Play/Rest gate: integer beat counts. Both must be > 0 for the
// gate to engage; 0 in either slider disables.
play_for_beats = slider15;
rest_for_beats = slider16;
pr_enabled     = (play_for_beats > 0 && rest_for_beats > 0);

@sample

// Smooth BPM toward slider1's target.
bpm_smoothed += (bpm_target - bpm_smoothed) * rate_smoother_coeff;

// Advance speed_ramp_t while engaged + duration > 0 + past start
// delay. Engage off freezes ramp_t; engaging on resumes from there.
slider19 && slider18 > 0 ? (
  speed_ramp_delay_samples = slider28 * 60 * srate;
  speed_ramp_delay_elapsed < speed_ramp_delay_samples ? (
    speed_ramp_delay_elapsed += 1;
  ) : (
    speed_ramp_t += 1.0 / (srate * slider18 * 60);
    speed_ramp_t = min(speed_ramp_t, 1.0);
  );
);

// Per-target Speed Ramp offsets (parallel — all 4 ramp regardless
// of which target the selector is currently showing). Each target
// gets ramp_t * stored_amount in its native unit.
speed_ramp_heart_offset    = speed_ramp_t * speed_ramp_target_value_mem[0]; // BPM
speed_ramp_systole_offset  = speed_ramp_t * speed_ramp_target_value_mem[1]; // ms
speed_ramp_breath_offset   = speed_ramp_t * speed_ramp_target_value_mem[2]; // HRV depth
speed_ramp_rand_hrv_offset = speed_ramp_t * speed_ramp_target_value_mem[3]; // HRV depth

// Per-target drift wave computation. Each of 4 targets gets a phase
// counter advancing per sample at rate 1 / (period_heartbeats *
// cycle_len_base_samples). All 4 targets use heartbeats as period
// unit. Drift offset for each target is computed in target-native
// units and stored back into target_drift_offset[i], then consumed
// at the effective-value computations below. The drift loop uses
// cycle_len_base from the PREVIOUS sample (acoustically negligible
// 1-sample lag).
i = 0;
loop(N_TARGETS,
  up    = target_drift_up[i];
  down  = target_drift_down[i];
  per   = target_drift_per[i];
  shape = target_drift_shape[i];

  drift_offset_local = 0;
  (up > 0 || down > 0) && per > 0 ? (
    period_samples = max(per * max(cycle_len_base, 1), 1);
    new_phase = target_drift_phase[i] + 1.0 / period_samples;
    new_phase >= 1.0 ? (
      new_phase -= 1.0;
      shape == 2 ? (
        target_drift_prev[i] = target_drift_curr[i];
        target_drift_curr[i] = rand(2) - 1;
      );
    );
    target_drift_phase[i] = new_phase;

    shape == 0 ? (
      shape_val = sin(2 * $pi * new_phase);
    ) : shape == 1 ? (
      shape_val = new_phase < 0.25 ? (4 * new_phase) :
                  new_phase < 0.75 ? (2 - 4 * new_phase) :
                                     (4 * new_phase - 4);
    ) : (
      shape_val = target_drift_prev[i] +
        (target_drift_curr[i] - target_drift_prev[i]) * new_phase;
    );
    drift_offset_local = shape_val > 0 ? shape_val * up : shape_val * down;
  );
  target_drift_offset[i] = drift_offset_local;
  i += 1;
);

// Effective per-target values: baseline (from slider) + Speed Ramp
// offset + per-target drift offset. These OVERRIDE @slider-set values
// for the per-sample consumption sites.
effective_systole_ms = max(slider2  + speed_ramp_systole_offset  + target_drift_offset[1], 1);
systole_samples      = floor(srate * effective_systole_ms * 0.001);
breath_depth         = max(slider12 + speed_ramp_breath_offset   + target_drift_offset[2], 0);
rand_hrv_depth       = max(slider13 + speed_ramp_rand_hrv_offset + target_drift_offset[3], 0);

// Clamp effective BPM at 10 so an over-aggressive Down amount or
// Speed Ramp delta can't drag the heartbeat to a stop or invert it.
effective_bpm  = max(bpm_smoothed + speed_ramp_heart_offset + target_drift_offset[0], 10.0);
cycle_len_base = floor(srate * 60.0 / effective_bpm);

// Transport play edge: fresh start. v2.9 uses ext_noinit = 1 so drift
// CONFIG bank + Speed Ramp configs survive across transport — but
// everything else that v2.8's @init re-run used to reset needs to be
// explicitly reset here so a render starts fresh (drift cycle at
// phase 0, first heartbeat ready to fire, filters clean, deterministic
// noise). Matches breath_gen v2.9 and the suite rule.
play_state > 0 && last_play_state == 0 ? (
  // Start Delay + Speed Ramp progress.
  start_delay_elapsed      = 0;
  speed_ramp_t             = 0.0;
  speed_ramp_delay_elapsed = 0;

  // Drift runtime state (NOT the config bank).
  i = 0;
  loop(N_TARGETS,
    target_drift_phase[i]  = 0;
    target_drift_prev[i]   = 0;
    target_drift_curr[i]   = 0;
    target_drift_offset[i] = 0;
    i += 1;
  );

  // Heartbeat state machine: fresh first beat, S1 primed to fire.
  phase           = 0;
  s1_active       = 1; s2_active = 0;
  s1_env          = 1.0; s2_env  = 0;
  s1_attack_phase = 0; s2_attack_phase = 0;

  // Oscillator phases.
  s1_phase_osc_near = 0; s1_phase_osc_far = 0;
  s2_phase_osc_near = 0; s2_phase_osc_far = 0;

  // Filter state (near + far paths).
  s1_res_low_near = 0; s1_res_band_near = 0;
  s2_res_low_near = 0; s2_res_band_near = 0;
  lp_low_near = 0; lp_band_near = 0; lp_low2_near = 0; lp_band2_near = 0;
  s1_res_low_far = 0; s1_res_band_far = 0;
  s2_res_low_far = 0; s2_res_band_far = 0;
  lp_low_far = 0; lp_band_far = 0; lp_low2_far = 0; lp_band2_far = 0;

  // Delay buffer (stereo width).
  memset(0, 0, delay_buf_size);
  delay_write = 0;

  // Breath HRV + random HRV modulators.
  breath_phase    = 0.0;
  rand_hrv        = 0.0;
  rand_hrv_target = 0.0;
  rand_hrv_step   = 0;

  // Play/Rest gate: back to beat 1 (matches @init's "S1 pre-fire is
  // beat 1" semantics).
  pr_resting = 0;
  pr_beat    = 1;

  // BPM smoother seeds from current target so first sample uses the
  // saved BPM, not a stale value.
  bpm_smoothed = bpm_target;

  // Noise seeds reset to @init defaults so noise texture is
  // deterministic per play press.
  noise_seed  = 12345;
  noise_seed2 = 67890;
  hrv_seed    = 99999;
);
last_play_state = play_state;

start_delay_elapsed < start_delay_sec ? (
  start_delay_elapsed += 1 / srate;
  spl0 = 0;
  spl1 = 0;
) : (

breath_phase += breath_rate;
breath_phase > two_pi ? breath_phase -= two_pi;
breath_mod = sin(breath_phase) * breath_depth;

rand_hrv_step += 1;
rand_hrv_step >= rand_hrv_step_len ? (
  rand_hrv_step = 0;
  hrv_seed = (hrv_seed * 1664525 + 1013904223) & 0xFFFFFFFF;
  rand_hrv_target = ((hrv_seed - 0x80000000) * (1.0 / 2147483648.0)) * rand_hrv_depth;
);
rand_hrv += (rand_hrv_target - rand_hrv) * (1.0 - rand_hrv_slew);

cycle_len = floor(cycle_len_base * (1.0 - breath_mod + rand_hrv));
cycle_len = max(cycle_len, floor(srate * 60.0 / 200.0));

phase += 1;
phase >= cycle_len ? (
  phase = 0;
  // Per-beat Play/Rest gate. On each new heartbeat, advance the
  // period counter; if it reaches the threshold for the current
  // state, flip play↔rest and reset the counter. Then suppress the
  // S1 trigger (and the matching S2 trigger below) if we're in the
  // rest period. The previous beat's S1/S2 envelopes are still
  // decaying naturally — the gate only stops NEW triggers.
  pr_enabled ? (
    pr_beat >= (pr_resting ? rest_for_beats : play_for_beats) ? (
      pr_resting = 1 - pr_resting;
      pr_beat = 0;
    );
    pr_beat += 1;
  );
  (!pr_enabled || !pr_resting) ? (
    s1_active = 1;
    s1_env = 0.0;
    s1_attack_phase = 1;
  );
);

// S2 fires systole_samples into each cycle — matched to S1 above,
// so it's gated by the same pr_resting state. Within a single cycle
// pr_resting can't change (it only flips on phase wrap), so the S1
// and S2 of any given beat see consistent state.
phase == systole_samples && (!pr_enabled || !pr_resting) ? (
  s2_active = 1;
  s2_env = 0.0;
  s2_attack_phase = 1;
);

noise_seed = (noise_seed * 1664525 + 1013904223) & 0xFFFFFFFF;
n = (noise_seed - 0x80000000) * (1.0 / 2147483648.0);
noise_seed2 = (noise_seed2 * 22695477 + 1) & 0xFFFFFFFF;
n2 = (noise_seed2 - 0x80000000) * (1.0 / 2147483648.0);

s1_active ? (
  s1_attack_phase ? (
    s1_env += (1.0 - s1_env) * (1.0 - s1_attack_rate);
    s1_env >= 0.98 ? s1_attack_phase = 0;
  ) : (
    s1_env *= s1_decay;
    s1_env < 0.0001 ? s1_active = 0;
  );
) : 0;

s2_active ? (
  s2_attack_phase ? (
    s2_env += (1.0 - s2_env) * (1.0 - s2_attack_rate);
    s2_env >= 0.98 ? s2_attack_phase = 0;
  ) : (
    s2_env *= s2_decay;
    s2_env < 0.0001 ? s2_active = 0;
  );
) : 0;

s1_phase_osc_near += two_pi * s1_freq * srate_inv;
s1_phase_osc_near > two_pi ? s1_phase_osc_near -= two_pi;
s2_phase_osc_near += two_pi * s2_freq * srate_inv;
s2_phase_osc_near > two_pi ? s2_phase_osc_near -= two_pi;
s1_phase_osc_far += two_pi * (s1_freq * 1.003) * srate_inv;
s1_phase_osc_far > two_pi ? s1_phase_osc_far -= two_pi;
s2_phase_osc_far += two_pi * (s2_freq * 0.997) * srate_inv;
s2_phase_osc_far > two_pi ? s2_phase_osc_far -= two_pi;

s1_active ? (
  s1_res_low_near += s1_res_f_near * s1_res_band_near;
  s1_res_high_near = (sin(s1_phase_osc_near)*0.8 + n*0.2) - s1_res_low_near - s1_res_q_near * s1_res_band_near;
  s1_res_band_near += s1_res_f_near * s1_res_high_near;
  s1_out_near = s1_res_band_near * s1_env * s1_env * 2.0 * s1_vol;
) : s1_out_near = 0;

s2_active ? (
  s2_res_low_near += s2_res_f_near * s2_res_band_near;
  s2_res_high_near = (sin(s2_phase_osc_near)*0.5 + n*0.5) - s2_res_low_near - s2_res_q_near * s2_res_band_near;
  s2_res_band_near += s2_res_f_near * s2_res_high_near;
  s2_out_near = s2_res_band_near * s2_env * s2_env * s2_vol;
) : s2_out_near = 0;

raw_near = s1_out_near + s2_out_near;
lp_low_near += lp_f_near * lp_band_near;
lp_high_near = raw_near - lp_low_near - lp_q * lp_band_near;
lp_band_near += lp_f_near * lp_high_near;
lp_low2_near += lp_f_near * lp_band2_near;
lp_high2_near = lp_low_near - lp_low2_near - lp_q * lp_band2_near;
lp_band2_near += lp_f_near * lp_high2_near;
heart_near = lp_low2_near * 1.5;

s1_active ? (
  s1_res_low_far += s1_res_f_far * s1_res_band_far;
  s1_res_high_far = (sin(s1_phase_osc_far)*0.8 + n2*0.2) - s1_res_low_far - s1_res_q_far * s1_res_band_far;
  s1_res_band_far += s1_res_f_far * s1_res_high_far;
  s1_out_far = s1_res_band_far * s1_env * s1_env * 2.0 * s1_vol;
) : s1_out_far = 0;

s2_active ? (
  s2_res_low_far += s2_res_f_far * s2_res_band_far;
  s2_res_high_far = (sin(s2_phase_osc_far)*0.5 + n2*0.5) - s2_res_low_far - s2_res_q_far * s2_res_band_far;
  s2_res_band_far += s2_res_f_far * s2_res_high_far;
  s2_out_far = s2_res_band_far * s2_env * s2_env * s2_vol;
) : s2_out_far = 0;

raw_far = s1_out_far + s2_out_far;
lp_low_far += lp_f_far * lp_band_far;
lp_high_far = raw_far - lp_low_far - lp_q * lp_band_far;
lp_band_far += lp_f_far * lp_high_far;
lp_low2_far += lp_f_far * lp_band2_far;
lp_high2_far = lp_low_far - lp_low2_far - lp_q * lp_band2_far;
lp_band2_far += lp_f_far * lp_high2_far;
heart_far_now = lp_low2_far * 1.5;

delay_write_pos = delay_write & (delay_buf_size - 1);
delay_read_pos = (delay_write - delay_samples) & (delay_buf_size - 1);
delay_write_pos[0] = heart_far_now;
heart_far = delay_read_pos[0];
delay_write = (delay_write + 1) & (delay_buf_size - 1);

delay_sign == 1 ? (
  spl0 = heart_near;
  spl1 = heart_far;
) : (
  spl0 = heart_far;
  spl1 = heart_near;
);

);  // close start-delay else branch

@serialize
// Persist per-target Speed Ramp amounts + last-selected target so
// reloading a project restores all 4 targets' configured deltas,
// not just whichever was selected at save time.
file_mem(0, speed_ramp_target_value_mem, N_SPEED_TARGETS);
file_var(0, last_speed_target);

// Persist per-target drift configurations. Same story: without this,
// only the most-recently-edited target's drift slider values survive
// because sliders 22-25 hold whichever target was selected at save
// time. 4 targets × 4 config fields = 16 values; plus the selector.
file_mem(0, target_drift_up,    N_TARGETS);
file_mem(0, target_drift_down,  N_TARGETS);
file_mem(0, target_drift_per,   N_TARGETS);
file_mem(0, target_drift_shape, N_TARGETS);
file_var(0, last_target_select);
