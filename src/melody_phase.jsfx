desc:Melody Phase
// A step-sequencer melody synth, sibling to Polyrhythm Phase.
//
// Up to 8 voices. Each voice plays a single note (a configurable
// number of semitones from the root) for its own Step Length, then
// hands off to the next active voice. Each voice also has a Note
// Length controlling how long its note actually rings — when Note
// Length exceeds Step Length, the voice's release continues in
// parallel with the next voice's attack (overlap / phrasing). When
// Note Length is less than Step Length, there's silence between
// voices (rest). When equal, clean sequential handoff.
//
// Rate is global. Step Length and Note Length per voice are
// expressed in cycles of the global rate, so you can write
// rhythmic relationships like "V1 = 2 cycles, V2 = 1 cycle,
// V3 = 0.5 cycles" and they'll line up.
//
// Inactive voices (Active = Off) are skipped in the sequence
// entirely. To insert a rest in the sequence, leave a voice
// Active but set its Note Length to 0 — the voice contributes
// silence for its Step Length, then hands off.
//
// Free reuse of Polyrhythm Phase's 10 waveforms, envelope shapes,
// binaural beat, and tuning math.
//
// CC0 — public domain.

// --- Global sliders (1-14) ---
slider1:1<0,2,1{BPM,Seconds,Hz}>Rate Mode
slider2:1<0.001,1000,0.001>Rate Value
slider3:0<0,11,1{Sine,Triangle,Saw,Golden TS,Golden SG,Golden GS,Bell,Wavefold,Half-sine,Phi-cascade,Phi Triangle,Phi Sine}>Waveform
slider4:440<400,480,0.1>Tuning Reference Hz
slider5:0<0,11,1{C,C#,D,D#,E,F,F#,G,G#,A,A#,B}>Root Note
slider6:4<0,8,1>Center Octave
slider7:1<0,1,1{Off,On}>Loop
slider8:-6<-60,0,0.1>Master Gain dB
slider9:0<0,100,0.1>Binaural Beat Hz (L/R offset)
slider10:10<0,100,0.1>Attack % of Note duration
slider11:30<0,100,0.1>Release % of Note duration
slider12:1<0,3,1{Linear,Cosine,Logarithmic,Exponential}>Attack Shape
slider13:1<0,3,1{Linear,Cosine,Logarithmic,Exponential}>Release Shape
slider14:0<0,8,1{All Active,1,2,3,4,5,6,7,8}>Sequence Length

// --- Pan (sliders 15-19) — mirrors Polyrhythm Phase ---
slider15:0<0,1,1{Off,On}>Pan Enabled
slider16:2<0,3,1{Tremolo,Increment,Spread,Spread Reversed}>Pan Mode
slider17:100<0,100,0.1>Pan Spread %
slider18:1<0.001,1000,0.001>Pan Base Rate (Tremolo / Increment modes)
slider19:0<-1000,1000,0.001>Pan Increment per Voice (Increment mode)

// --- Glide / portamento (sliders 20-21) ---
// When Glide time > 0, each new voice's pitch starts at the previous
// voice's target frequency and slides to its own target over this many
// seconds. 0 = no glide; voices jump straight to their pitch.
// Legato glide changes how the new voice's envelope is triggered:
// see slider21 description for details.
slider20:0<0,5,0.001>Glide time (seconds; 0 = off)
slider21:0<0,1,1{Off,On}>Legato glide

// --- Per-voice sliders (5 each, V1=22-26 ... V8=57-61) ---
slider22:0<-24,24,1>V1 Semitones from root
slider23:1<0.01,16,0.01>V1 Next voice in (cycles)
slider24:1<0,16,0.01>V1 Note duration (cycles; 0 = silent)
slider25:-6<-60,6,0.1>V1 Gain dB
slider26:1<0,1,1{Off,On}>V1 Active

slider27:2<-24,24,1>V2 Semitones from root
slider28:1<0.01,16,0.01>V2 Next voice in (cycles)
slider29:1<0,16,0.01>V2 Note duration (cycles; 0 = silent)
slider30:-6<-60,6,0.1>V2 Gain dB
slider31:1<0,1,1{Off,On}>V2 Active

slider32:4<-24,24,1>V3 Semitones from root
slider33:1<0.01,16,0.01>V3 Next voice in (cycles)
slider34:1<0,16,0.01>V3 Note duration (cycles; 0 = silent)
slider35:-6<-60,6,0.1>V3 Gain dB
slider36:1<0,1,1{Off,On}>V3 Active

slider37:5<-24,24,1>V4 Semitones from root
slider38:1<0.01,16,0.01>V4 Next voice in (cycles)
slider39:1<0,16,0.01>V4 Note duration (cycles; 0 = silent)
slider40:-6<-60,6,0.1>V4 Gain dB
slider41:1<0,1,1{Off,On}>V4 Active

slider42:7<-24,24,1>V5 Semitones from root
slider43:1<0.01,16,0.01>V5 Next voice in (cycles)
slider44:1<0,16,0.01>V5 Note duration (cycles; 0 = silent)
slider45:-6<-60,6,0.1>V5 Gain dB
slider46:0<0,1,1{Off,On}>V5 Active

slider47:9<-24,24,1>V6 Semitones from root
slider48:1<0.01,16,0.01>V6 Next voice in (cycles)
slider49:1<0,16,0.01>V6 Note duration (cycles; 0 = silent)
slider50:-6<-60,6,0.1>V6 Gain dB
slider51:0<0,1,1{Off,On}>V6 Active

slider52:11<-24,24,1>V7 Semitones from root
slider53:1<0.01,16,0.01>V7 Next voice in (cycles)
slider54:1<0,16,0.01>V7 Note duration (cycles; 0 = silent)
slider55:-6<-60,6,0.1>V7 Gain dB
slider56:0<0,1,1{Off,On}>V7 Active

slider57:12<-24,24,1>V8 Semitones from root
slider58:1<0.01,16,0.01>V8 Next voice in (cycles)
slider59:1<0,16,0.01>V8 Note duration (cycles; 0 = silent)
slider60:-6<-60,6,0.1>V8 Gain dB
slider61:0<0,1,1{Off,On}>V8 Active

// --- Start Delay (slider 62) ---
// Sit silent for N units after playback starts, then resume normally.
// Units match Rate Mode (BPM beats / Seconds / Hz cycles, interpreted
// against Rate Value). 0 disables the delay. Re-arms on every
// transport stop/start. During the delay the @sample work is gated
// entirely so the sequencer state stays at its play-start position
// rather than advancing silently through the silent window.
slider62:0<0,1000,0.001>Start Delay

// --- Direction (slider 63) ---
// Walk order through the active voices in the pool (the first
// seq_length_eff slots). Inactive voices are skipped in all
// directions; bounce modes flip direction at the pool's edges.
// Repeat/no-repeat controls whether the boundary voice doubles when
// the direction flips:
//   Up                       1, 2, 3, 4, 1, 2, 3, 4, ... (current default)
//   Down                     4, 3, 2, 1, 4, 3, 2, 1, ...
//   Up-Down (repeat)         1, 2, 3, 4, 4, 3, 2, 1, 1, 2, 3, 4, ...
//   Up-Down (no repeat)      1, 2, 3, 4, 3, 2, 1, 2, 3, 4, ...
//   Down-Up (repeat)         4, 3, 2, 1, 1, 2, 3, 4, 4, ...
//   Down-Up (no repeat)      4, 3, 2, 1, 2, 3, 4, 3, ...
// Loop=Off + Up or Down: plays one pass, stops. Loop=Off + any
// bounce mode: plays one complete bounce cycle (back to starting
// edge), stops.
slider63:0<0,5,1{Up,Down,Up-Down (repeat),Up-Down (no repeat),Down-Up (repeat),Down-Up (no repeat)}>Direction

// --- Play/Rest gating (sliders 64-65) ---
// Per-step gate: the sequencer fires N notes normally, then walks
// silently through M more steps, then resumes — repeats forever. Each
// "step" is one voice's "Next voice in" period (regardless of whether
// that voice's Note duration is non-zero — programmed rests still
// count as steps). The previously-firing note finishes its natural
// envelope (sustain → release in non-Legato mode; forced into release
// at the rest boundary in Legato mode so it doesn't ring forever) so
// the rest is a clean tail-out, not a hard cut. Rest duration is
// variable: it's the sum of "Next voice in" for the M voices the
// sequencer walks through silently. 0 in either slider disables the
// gate. Resets on every transport stop/start.
slider64:0<0,1000,1>Play for (steps)
slider65:0<0,1000,1>Rest for (steps)

// --- Rest mode (slider 66) ---
// How the sequencer behaves during the rest period.
//   Walk through (default) — sequencer keeps advancing; rest steps
//     consume "Next voice in" seconds silently. Total cycle = Play
//     + Rest steps consumed from the underlying sequencer grid.
//     If Play + Rest doesn't divide evenly into your active voice
//     count, the starting voice of each play period walks across
//     the melody. Notes get "skipped" in the literal sense (the
//     sequencer walks past them silently); they reappear in
//     subsequent play periods at different positions.
//   Freeze in place — sequencer pauses on the voice that WOULD
//     have been triggered when rest started. Rest duration is
//     Rest for × that frozen voice's "Next voice in" seconds.
//     When rest ends, the frozen voice fires and the sequence
//     continues from there — every voice plays in order across
//     multiple cycles, just with pauses between phrases.
// Both modes do the same Legato force-release at rest entry so
// the previous voice doesn't ring forever in Legato mode.
slider66:0<0,1,1{Walk through,Freeze in place}>Rest mode

// Speed ramp: in-plugin slowdown/speedup over time. Scales the
// effective dt (the per-sample time the sequencer + voice envelopes
// see) by speed_scale_current, so the whole melody timeline stretches
// or compresses without touching the Rate Value or per-voice cycle
// counts. 0.5 = the melody takes twice as long; 2.0 = half the time.
// Voice envelope proportions (Attack %, Release %, Note duration)
// stay intact because they're percentages of the stretched step.
slider67:1.0<0.1,4.0,0.01>Speed ramp target (multiplier)
slider68:0<0,60,0.1>Speed ramp duration (minutes)
slider69:0<0,1,1{Off,On}>Speed ramp engage

// Wobble slot: read a slowly-wandering multiplier from a shared
// mailbox and apply it to the melody tempo (alongside Speed Ramp).
// 0 = no wobble.
slider70:0<0,16,1>Wobble slot (0 = no wobble)

@init
// Memory layout per voice (16 slots each — V0 starts at the
// labelled base, voice i offsets by i; e.g., V3's osc_phase_l is
// at osc_phase_l[3] = base + 3).
osc_phase_l       = 0;
osc_phase_r       = 16;
voice_state       = 32;   // 0 = silent, 1 = attack, 2 = sustain, 3 = release
state_elapsed     = 48;   // seconds elapsed in current state
v_envelope        = 64;   // current envelope output, 0..1 (raw state-machine value)
v_freq_l          = 80;
v_freq_r          = 96;
// 240 is the next free 16-slot bank — see CLAUDE.md for the
// Polyrhythm Phase layout; we follow the same per-voice 16-slot
// convention.
v_env_smoothed    = 240;  // amplitude after the click-prevention one-pole smoother
// Pan (sliders 15-19, mirrored from Polyrhythm Phase).
pan_phase         = 256;  // per-voice pan LFO phase (Tremolo / Increment modes)
pan_smooth        = 272;  // smoothed pan position, -1..+1
v_pan_freq        = 288;  // cached pan LFO frequency (Hz)
v_pan_static      = 304;  // static pan target for Spread / Spread Reversed modes
// Glide / portamento (slider 60). Each voice tracks its currently-
// playing frequency (slides toward v_freq_l/r[i] over glide_time);
// the oscillator phase increment uses v_freq_current_l/r instead
// of v_freq_l/r directly so the pitch slides smoothly.
v_freq_current_l  = 320;
v_freq_current_r  = 336;
v_active          = 112;
v_semitones       = 128;
v_step_seconds    = 144;  // computed at @slider: step_length_cycles * cycle_seconds
v_note_seconds    = 160;  // computed at @slider: note_length_cycles * cycle_seconds
v_attack_seconds  = 176;  // attack_pct * note_seconds (clamped if att+rel > 100%)
v_release_seconds = 192;  // release_pct * note_seconds (clamped)
v_sustain_seconds = 208;  // note_seconds - attack - release
v_gain            = 224;  // linear gain, from dB

// Initialise per-voice state. Phases start at 0; states start
// silent. The sequencer's first tick will trigger V0's attack.
i = 0;
loop(8,
  osc_phase_l[i]       = 0;
  osc_phase_r[i]       = 0;
  voice_state[i]       = 0;
  state_elapsed[i]     = 0;
  v_envelope[i]        = 0;
  v_env_smoothed[i]    = 0;
  v_freq_l[i]          = 440;
  v_freq_r[i]          = 440;
  v_active[i]          = 0;
  v_semitones[i]       = 0;
  v_step_seconds[i]    = 1;
  v_note_seconds[i]    = 1;
  v_attack_seconds[i]  = 0.1;
  v_release_seconds[i] = 0.3;
  v_sustain_seconds[i] = 0.6;
  v_gain[i]            = 1;
  pan_phase[i]         = 0;
  pan_smooth[i]        = 0;
  v_pan_freq[i]        = 1;
  v_pan_static[i]      = 0;
  v_freq_current_l[i]  = 440;
  v_freq_current_r[i]  = 440;
  i += 1;
);

// Glide / portamento state. Tracks the last triggered voice's
// target frequencies so the NEXT triggered voice can start its
// glide from there. have_prev_trigger guards the first-ever
// trigger (no previous voice to slide from — just snap so we
// don't sweep up from 0 Hz on the very first note).
// prev_seq_index also tracks WHICH voice was previously playing
// — needed for Legato glide to inherit envelope state and the
// oscillator phase from the previous voice on hand-off.
prev_trigger_freq_l = 440;
prev_trigger_freq_r = 440;
have_prev_trigger   = 0;
prev_seq_index      = -1;

// Sequencer global state. seq_index is the voice whose step is
// currently elapsing. seq_step_elapsed tracks how far into that
// step we are. seq_started=0 until we trigger the very first
// voice's attack; once started, the sequencer keeps advancing.
seq_index        = 0;
seq_step_elapsed = 0;
seq_started      = 0;
seq_finished     = 0;  // set when Loop=Off and we've walked off the end

// Direction state. seq_dir is +1 for Up walks, -1 for Down walks; it
// flips at pool boundaries in the bounce modes. bounce_count_total
// counts boundary crossings within a Loop=Off cycle so the sequence
// stops after a complete bounce (start → other end → back to start).
seq_dir            = 1;
bounce_count_total = 0;

// Start Delay state. start_delay_elapsed counts up from 0 at each
// play start; while it's below start_delay_sec the @sample work is
// gated and output is silent. start_delay_sec is computed in @slider
// from the user-facing units; default 0 means no delay.
last_play_state     = 0;
start_delay_elapsed = 0;
start_delay_sec     = 0;

// Play/Rest gate state. pr_step counts sequencer steps elapsed in
// the current play (or rest) period; threshold compare flips the
// period at each handoff. Init to 0 because the first trigger
// (inside seq_started == 0 branch) increments pr_step at the
// moment the first note fires — same "count notes that have fired"
// semantic as Heartbeat / Rhythm Track.
pr_resting     = 0;
pr_step        = 0;
play_for_steps = 0;
rest_for_steps = 0;
pr_enabled     = 0;

// Rest mode state. rest_mode = 0 → Walk through (sequencer advances
// during rest, current behavior). rest_mode = 1 → Freeze in place
// (sequencer pauses; rest is a sample-counted timer instead of a
// step counter). pr_frozen_prev_voice remembers the voice that was
// playing when Freeze rest started — used as the "prev_voice"
// argument to the trigger function when rest ends. The frozen
// "would-be-next" voice index lives in seq_index itself (we set it
// at the handoff above the PR check and never overwrite it during
// Freeze rest, since the sequencer advance is gated off).
rest_mode                = 0;
pr_rest_elapsed          = 0;
pr_rest_duration_samples = 0;
pr_frozen_prev_voice     = -1;

// Speed ramp state.
speed_ramp_engaged_last = 0;
speed_scale_current     = 1.0;
speed_scale_start       = 1.0;
speed_ramp_t            = 0.0;

// Wobble: shared mailbox base in gmem. Must match wobble_modulator.jsfx.
WOBBLE_BASE = 100000;

// One-pole exponential smoother coefficient for the envelope
// output. Polyrhythm Phase uses this exact pattern: the raw
// state-machine envelope value (which can step instantly when
// attack% or release% is 0) gets fed through a smoother before
// being applied to the oscillator, so the actual amplitude ramps
// up over ~3ms instead of jumping in a single sample. That's
// what eliminates the click on attack=0 / release=0 / rest
// transitions without forcing the user-set attack/release
// percentages to be non-zero. exp(-1/(srate * 0.003)) gives a
// ~3ms time constant: after 3ms, the smoother is ~63% of the
// way to the new target.
smooth_coeff = exp(-1 / (srate * 0.003));

function semitones_to_hz(base_note, center_octave, semitones) (
  tuning_ref * pow(2, ((center_octave + 1) * 12 + base_note + semitones - 69) / 12.0)
);

function apply_curve(t, shape) (
  shape == 0 ? t :
  shape == 1 ? (0.5 - 0.5 * cos(t * $pi)) :
  shape == 2 ? (log(1 + 9*t) / log(10)) :
               ((pow(10, t) - 1) / 9)
);

function rate_to_cycle_seconds(raw_rate, rmode) (
  // Convert the user's Rate Value + Rate Mode into seconds-per-cycle.
  // BPM:  60 / value     (60 BPM = 1 cycle/sec, so 1 sec/cycle)
  // Sec:  value          (literal seconds per cycle — default mode,
  //                      so per-voice "cycles" are directly seconds
  //                      when Rate Value is left at 1)
  // Hz:   1 / value      (cycles/sec inverted to sec/cycle)
  rmode == 0 ? 60 / max(raw_rate, 0.001) :
  rmode == 1 ? max(raw_rate, 0.001) :
               1 / max(raw_rate, 0.001)
);

function db_to_lin(db) (
  pow(10, db / 20)
);

function count_active_voices() local(n, j) (
  n = 0;
  j = 0;
  loop(8,
    v_active[j] ? n += 1;
    j += 1;
  );
  n
);

function next_active_voice(start, dir) local(j, tries) (
  // Walk from `start` (inclusive) in direction `dir` looking for
  // the next voice with v_active=1. Wraps around the pool
  // [0, seq_length_eff) if needed. Returns -1 if no active voice
  // exists anywhere in the pool.
  j = start;
  tries = 0;
  loop(8,
    j >= seq_length_eff ? j = 0;
    j < 0 ? j = seq_length_eff - 1;
    v_active[j] ? ( tries = 999; ); // sentinel to break out
    tries == 999 ? 0 : ( j += dir; tries += 1; );
  );
  tries == 999 ? j : -1
);

function step_in_dir_no_wrap(cur_idx, dir) local(j, found) (
  // Walk one step at a time in direction `dir` from cur_idx + dir,
  // looking for an active voice WITHIN the pool [0, seq_length_eff)
  // without wrapping. Returns the active voice's index, or -1 if we
  // crossed a pool boundary without finding one. Bounce modes use
  // the -1 return as the signal to flip direction.
  j = cur_idx + dir;
  found = -1;
  loop(8,
    found < 0 && j >= 0 && j < seq_length_eff && v_active[j] ? found = j;
    found < 0 ? j += dir;
  );
  found
);

function simulate_rest_duration_seconds(start_idx, num_steps)
local(saved_dir, saved_bounce, sim_idx, total_sec, ran_out, next_idx, wrap_start) (
  // Simulate exactly what Walk mode would do for the next num_steps
  // handoffs starting from start_idx, summing each visited voice's
  // "Next voice in" — returns the total wall-clock seconds. Used by
  // Freeze mode at rest entry so its rest duration matches the Walk
  // equivalent, instead of just being num_steps × the frozen voice's
  // step duration (which only matches when all active voices share
  // the same Next voice in).
  //
  // Mirrors the bounce_active / loop_enabled / bounce_is_repeat
  // branches from the real handoff logic. Temporarily mutates
  // seq_dir and bounce_count_total via step_in_dir_no_wrap calls
  // and the bounce flips below; saved at the top and restored at
  // the bottom so the actual sequencer state is untouched.
  //
  // If the simulated walk would hit a hard stop (Loop=Off bounce
  // completed, or Loop=Off Up/Down past the pool edge), ran_out is
  // set and the loop stops counting. The returned duration is the
  // partial sum — meaning Freeze mode's rest will end earlier than
  // num_steps × something in that case. That matches Walk mode's
  // actual behavior (Walk hits seq_finished and the gate stops
  // exiting rest), with the caveat that Freeze still cleanly resumes
  // when its timer expires while Walk would just stay finished.
  saved_dir = seq_dir;
  saved_bounce = bounce_count_total;
  sim_idx = start_idx;
  total_sec = 0;
  ran_out = 0;
  loop(num_steps,
    ran_out ? 0 : (
      total_sec += v_step_seconds[sim_idx];
      next_idx = step_in_dir_no_wrap(sim_idx, seq_dir);
      next_idx < 0 ? (
        bounce_active ? (
          seq_dir = -seq_dir;
          bounce_count_total += 1;
          !loop_enabled && bounce_count_total >= 2 ? (
            ran_out = 1;
          ) : (
            bounce_is_repeat ? (
              next_idx = sim_idx;
            ) : (
              next_idx = step_in_dir_no_wrap(sim_idx, seq_dir);
              next_idx < 0 ? ran_out = 1;
            );
            bounce_count_total >= 2 ? bounce_count_total = 0;
          );
        ) : (
          loop_enabled ? (
            wrap_start = seq_dir > 0 ? 0 : seq_length_eff - 1;
            next_idx = next_active_voice(wrap_start, seq_dir);
            next_idx < 0 ? ran_out = 1;
          ) : (
            ran_out = 1;
          );
        );
      );
      !ran_out ? sim_idx = next_idx;
    );
  );
  seq_dir = saved_dir;
  bounce_count_total = saved_bounce;
  total_sec
);

function trigger_seq_voice(prev_idx) (
  // Fire whatever voice seq_index points to. Shared by three call
  // sites: the first-ever trigger (seq_started == 0 branch, passes
  // prev_idx = -1), the normal handoff (passes the just-replaced
  // prev_seq_index), and Freeze-mode rest exit (passes the saved
  // pr_frozen_prev_voice). Encapsulates the Legato handoff branch,
  // the glide source setup, and the prev_trigger_freq bookkeeping
  // so all three sites stay in sync.
  v_note_seconds[seq_index] > 0.0001 ? (
    legato_enabled && prev_idx >= 0 && voice_state[prev_idx] != 0 ? (
      v_envelope[seq_index]     = v_envelope[prev_idx];
      v_env_smoothed[seq_index] = v_env_smoothed[prev_idx];
      osc_phase_l[seq_index]    = osc_phase_l[prev_idx];
      osc_phase_r[seq_index]    = osc_phase_r[prev_idx];
      pan_smooth[seq_index]     = pan_smooth[prev_idx];
      pan_phase[seq_index]      = pan_phase[prev_idx];
      voice_state[seq_index]    = 2;
      state_elapsed[seq_index]  = 0;
      voice_state[prev_idx]     = 0;
      v_envelope[prev_idx]      = 0;
      v_env_smoothed[prev_idx]  = 0;
    ) : (
      voice_state[seq_index]    = 1;
      state_elapsed[seq_index]  = 0;
    );
    have_prev_trigger ? (
      v_freq_current_l[seq_index] = prev_trigger_freq_l;
      v_freq_current_r[seq_index] = prev_trigger_freq_r;
    ) : (
      v_freq_current_l[seq_index] = v_freq_l[seq_index];
      v_freq_current_r[seq_index] = v_freq_r[seq_index];
      have_prev_trigger = 1;
    );
    prev_trigger_freq_l = v_freq_l[seq_index];
    prev_trigger_freq_r = v_freq_r[seq_index];
    prev_seq_index = seq_index;
  );
);

@slider
rate_mode     = slider1;
rate_value    = slider2;
waveform      = slider3;
tuning_ref    = slider4;
base_note     = slider5;
center_octave = slider6;
loop_enabled  = slider7;
master_gain   = db_to_lin(slider8);
binaural_hz   = slider9;
attack_pct    = slider10 / 100;
release_pct   = slider11 / 100;
attack_shape  = slider12;
release_shape = slider13;
seq_length_cfg = slider14;
pan_enabled    = slider15;
pan_mode       = slider16;
pan_spread     = slider17 / 100;
pan_base_rate  = slider18;
pan_increment  = slider19;
glide_time     = slider20;
legato_enabled = slider21;
// Glide coefficient: one-pole smoother applied per sample to
// v_freq_current_l/r, with glide_time as the time constant.
// When glide_time = 0 we just snap (handled inline at the
// @sample step), so glide_coeff doesn't need a safe value
// for the glide_time = 0 case; compute defensively anyway.
glide_coeff   = glide_time > 0.0001 ? exp(-1 / max(srate * glide_time, 1)) : 0;
// Pan smoother coefficient. Default 10ms for snappy-but-click-free
// pan transitions; matches Polyrhythm Phase. In Legato mode with
// Glide > 0, slow it down to match the glide time so pan moves
// at the same perceived speed as pitch — otherwise pan finishes
// its transition in 10-30ms while pitch is still gliding for
// hundreds of ms, which the listener hears as two separate
// transitions at different rates (the pan one feels like a
// sharp position change against the slower pitch slide). Tying
// them together makes the whole transition feel like one
// coherent slide. Floor stays at 10ms so non-Legato use and
// Glide-off still get the snappy-but-click-free behavior.
pan_smooth_time = (legato_enabled && glide_time > 0.0001) ? max(0.010, glide_time) : 0.010;
pan_smooth_coeff_global = exp(-1 / (srate * pan_smooth_time));

cycle_seconds = rate_to_cycle_seconds(rate_value, rate_mode);

// Effective sequence length: "All Active" (0) means walk all 8
// voice slots and skip the inactive ones; 1..8 truncates the
// sequence to the first N voice slots (still skipping inactives
// within that range).
seq_length_eff = seq_length_cfg == 0 ? 8 : seq_length_cfg;

// Cache per-voice values. Step / Note lengths convert from cycles
// to seconds via the global cycle_seconds.
i = 0;
loop(8,
  i == 0 ? ( v_semitones[i] = slider22; v_step_cycles = slider23; v_note_cycles = slider24; v_gain_db = slider25; v_active[i] = slider26; );
  i == 1 ? ( v_semitones[i] = slider27; v_step_cycles = slider28; v_note_cycles = slider29; v_gain_db = slider30; v_active[i] = slider31; );
  i == 2 ? ( v_semitones[i] = slider32; v_step_cycles = slider33; v_note_cycles = slider34; v_gain_db = slider35; v_active[i] = slider36; );
  i == 3 ? ( v_semitones[i] = slider37; v_step_cycles = slider38; v_note_cycles = slider39; v_gain_db = slider40; v_active[i] = slider41; );
  i == 4 ? ( v_semitones[i] = slider42; v_step_cycles = slider43; v_note_cycles = slider44; v_gain_db = slider45; v_active[i] = slider46; );
  i == 5 ? ( v_semitones[i] = slider47; v_step_cycles = slider48; v_note_cycles = slider49; v_gain_db = slider50; v_active[i] = slider51; );
  i == 6 ? ( v_semitones[i] = slider52; v_step_cycles = slider53; v_note_cycles = slider54; v_gain_db = slider55; v_active[i] = slider56; );
  i == 7 ? ( v_semitones[i] = slider57; v_step_cycles = slider58; v_note_cycles = slider59; v_gain_db = slider60; v_active[i] = slider61; );

  v_step_seconds[i] = max(v_step_cycles * cycle_seconds, 0.001);
  v_note_seconds[i] = max(v_note_cycles * cycle_seconds, 0);
  v_gain[i] = db_to_lin(v_gain_db);

  // Frequency: voice's note at the configured tuning.
  // L channel uses the base frequency; R channel adds the binaural
  // offset (in Hz, applied to R only). When binaural_hz=0, L and R
  // run at identical frequencies — same shape as Polyrhythm Phase.
  hz_base = semitones_to_hz(base_note, center_octave, v_semitones[i]);
  v_freq_l[i] = hz_base;
  v_freq_r[i] = hz_base + binaural_hz;

  // Recompute envelope segment durations from the new note length.
  // attack+release together can't exceed the note duration; if the
  // user set both high (90%+90%), scale them proportionally to fit.
  att_t = attack_pct * v_note_seconds[i];
  rel_t = release_pct * v_note_seconds[i];
  att_t + rel_t > v_note_seconds[i] ? (
    total = att_t + rel_t;
    total > 0 ? (
      att_t = att_t / total * v_note_seconds[i];
      rel_t = rel_t / total * v_note_seconds[i];
    );
  );
  // No anti-click floor here on purpose — the @sample loop runs
  // the raw envelope through a one-pole smoother (smooth_coeff)
  // before applying it to the oscillator, which handles the
  // 0-duration ramp case the same way Polyrhythm Phase does.
  // Forcing a minimum ramp here would let a user's "attack = 0"
  // setting silently become "attack = 3ms" — annoying when the
  // user actually wanted a percussive transient.
  v_attack_seconds[i]  = att_t;
  v_release_seconds[i] = rel_t;
  v_sustain_seconds[i] = max(0, v_note_seconds[i] - att_t - rel_t);

  i += 1;
);

// Pan: per-voice LFO frequency for Tremolo / Increment modes.
// Tremolo: every voice pans at Pan Base Rate (same as PRP's
// "use the voice's tremolo rate" idea, except this plugin has
// no per-voice tremolo rate — the sequencer IS the rhythm, so
// we collapse to a single shared pan rate here).
// Increment: voice i pans at Pan Base Rate + i * Pan Increment.
// Spread / Spread Reversed: pan position is static (computed
// below), pan frequency is unused.
i = 0;
loop(8,
  pan_mode == 1 ? (
    pan_rate_i = pan_base_rate + pan_increment * i;
    pan_cycle_sec = rate_to_cycle_seconds(pan_rate_i, rate_mode);
    v_pan_freq[i] = pan_cycle_sec > 0 ? 1 / pan_cycle_sec : 0;
  ) : (
    pan_cycle_sec = rate_to_cycle_seconds(pan_base_rate, rate_mode);
    v_pan_freq[i] = pan_cycle_sec > 0 ? 1 / pan_cycle_sec : 0;
  );
  i += 1;
);

// Static pan positions for Spread / Spread Reversed modes.
// Rank active voices and place evenly across the stereo field.
// Mirrors Polyrhythm Phase's implementation exactly.
total_active = 0;
i = 0;
loop(8,
  v_active[i] ? total_active += 1;
  i += 1;
);
pan_mode >= 2 ? (
  rank = 0;
  i = 0;
  loop(8,
    v_active[i] ? (
      total_active > 1 ? (
        pos = -1.0 + 2.0 * rank / (total_active - 1);
      ) : (
        pos = 0;
      );
      pan_mode == 3 ? pos = -pos;
      v_pan_static[i] = pos;
      rank += 1;
    ) : (
      v_pan_static[i] = 0;
    );
    i += 1;
  );
);

// Show pan sub-sliders only when pan is enabled, and only the
// ones relevant to the chosen mode (matches PRP's UX).
slider_show(slider16, pan_enabled);
slider_show(slider17, pan_enabled);
slider_show(slider18, pan_enabled && (pan_mode == 0 || pan_mode == 1));
slider_show(slider19, pan_enabled && pan_mode == 1);

// Start Delay — convert the user-facing value to seconds. BPM beats
// and Hz cycles are interpreted against Rate Value (so 1 beat at
// 60 BPM = 1 second). Seconds mode is literal seconds.
start_delay_units = slider62;
rate_mode == 0 ? start_delay_sec = start_delay_units * 60 / max(rate_value, 0.001) :
rate_mode == 1 ? start_delay_sec = start_delay_units :
                 start_delay_sec = start_delay_units / max(rate_value, 0.001);

// Direction mode + derived flags. For Up/Down (modes 0/1) we force
// seq_dir to the mode's natural direction every @slider so that
// switching from one to the other mid-playback flips the walk
// immediately. For bounce modes (2-5) we leave seq_dir alone — it's
// managed by the sequencer's bounce logic in @sample.
direction_mode   = slider63;
bounce_active    = (direction_mode >= 2);
bounce_is_repeat = (direction_mode == 2 || direction_mode == 4);
direction_mode == 0 ? seq_dir =  1;
direction_mode == 1 ? seq_dir = -1;

// Play/Rest gate: integer step counts. Both must be > 0 for the
// gate to engage; 0 in either slider disables.
play_for_steps = slider64;
rest_for_steps = slider65;
pr_enabled     = (play_for_steps > 0 && rest_for_steps > 0);
rest_mode      = slider66;

// Speed ramp engage-edge.
slider69 && !speed_ramp_engaged_last ? (
  speed_scale_start = speed_scale_current;
  speed_ramp_t      = 0.0;
);
speed_ramp_engaged_last = slider69;

@sample
// Advance speed ramp every sample, read wobble, scale dt by the
// resulting combined multiplier so the sequencer + voice envelopes
// + pan all stretch together. Note: dt is also used for
// state_elapsed (voice envelope time), so scaling here keeps
// Attack %, Release %, Note duration proportions intact across
// speed changes.
slider69 && slider68 > 0 ? (
  speed_ramp_t += 1.0 / (srate * slider68 * 60);
  speed_ramp_t = min(speed_ramp_t, 1.0);
  speed_scale_current = speed_scale_start + (slider67 - speed_scale_start) * speed_ramp_t;
);
wobble_mult = 1.0;
slider70 > 0 ? (
  raw_wobble = gmem[WOBBLE_BASE + slider70];
  raw_wobble > 0 ? wobble_mult = raw_wobble;
);
combined_scale = speed_scale_current * wobble_mult;
dt = combined_scale / srate;

// Re-arm Start Delay on each transport stop/start.
play_state > 0 && last_play_state == 0 ? (
  start_delay_elapsed = 0;
);
last_play_state = play_state;

// Start Delay gate. During the silent window the sequencer state
// (seq_started, voice envelopes, etc.) doesn't advance, so when the
// delay elapses the sequencer kicks in cleanly from V1 as if just
// loaded. After the gate releases the rest of @sample runs normally.
start_delay_elapsed < start_delay_sec ? (
  start_delay_elapsed += 1 / srate;
  spl0 = 0;
  spl1 = 0;
) : (

// === Sequencer advance ===
// On the very first sample, trigger the first active voice's attack
// — unless that voice is a rest (Note Length = 0), in which case it
// stays in state 0 (silent) and just consumes its Step Length
// before handing off. Triggering attack on a zero-length note used
// to click: envelope jumped from 0 to 1 to 0 in adjacent samples
// (no time for the ramp to actually ramp), so the listener heard
// the oscillator's sample value at full gain for one sample, then
// silence. Skipping the trigger for rest voices fixes that — a
// rest is now truly silent for its entire step.
seq_started == 0 ? (
  // Pick starting direction + first voice based on Direction mode.
  // Up / Up-Down: start at the first active voice walking forward
  // from index 0. Down / Down-Up: start at the last active voice
  // walking backward from the end of the pool.
  starts_down = (direction_mode == 1 || direction_mode == 4 || direction_mode == 5);
  seq_dir = starts_down ? -1 : 1;
  bounce_count_total = 0;
  first_idx = starts_down ? next_active_voice(seq_length_eff - 1, -1) : next_active_voice(0, 1);
  first_idx >= 0 ? (
    seq_index = first_idx;
    seq_step_elapsed = 0;
    // Fire the first voice via the shared trigger function. prev_idx
    // = -1 means "no previous voice exists"; the Legato handoff
    // branch needs prev_idx >= 0 so it won't fire, and the glide
    // branch hits the !have_prev_trigger path which snaps the
    // current frequency to this voice's own target.
    trigger_seq_voice(-1);
    seq_started = 1;
    // Count this step toward the play period. No threshold check on
    // the first step (pr_step is 0; threshold is always >= 1 when
    // pr_enabled, so it'd never fire here anyway).
    pr_enabled ? pr_step += 1;
  );
);

// Once started (and not finished), advance the per-step clock.
// When the current voice's step has elapsed, the sequencer hands
// off to the next active voice. The OUTGOING voice's envelope
// keeps progressing through its own (longer or shorter) note
// duration in parallel — that's where overlap comes from.
//
// Freeze-mode rest exception: when the Play/Rest gate is engaged
// AND we're in the rest period AND Rest mode = Freeze, the step
// clock does NOT advance. This is what keeps the sequencer paused
// at the would-be-next voice (seq_index already points to it from
// the handoff that triggered rest) — no new handoffs fire during
// the silent period. The rest timer block further down handles
// resuming with that frozen voice when the rest duration elapses.
seq_started && !seq_finished ? (
  in_frozen_rest = pr_enabled && pr_resting && rest_mode == 1;
  !in_frozen_rest ? seq_step_elapsed += dt;
  cur_step = v_step_seconds[seq_index];
  seq_step_elapsed >= cur_step ? (
    seq_step_elapsed -= cur_step;
    // === Compute next voice based on Direction mode ===
    // Try to step in the current direction WITHIN the pool. If we'd
    // cross a pool boundary (step_in_dir_no_wrap returns -1), handle
    // it according to mode: bounce modes flip direction; Up/Down
    // wrap or stop based on Loop. nxt = -1 at the end of this block
    // means "stop the sequence" (set seq_finished below).
    nxt = step_in_dir_no_wrap(seq_index, seq_dir);
    nxt < 0 ? (
      bounce_active ? (
        // Hit a pool edge — flip direction.
        seq_dir = -seq_dir;
        bounce_count_total += 1;
        // Loop=Off bounce: stop after two boundary crossings (one
        // complete bounce, back to the starting edge). Checked
        // BEFORE picking the next voice so the second bounce's
        // would-be note never plays.
        !loop_enabled && bounce_count_total >= 2 ? (
          nxt = -1;
        ) : (
          bounce_is_repeat ? (
            // Repeat-boundary modes: play the current voice once
            // more with the new direction queued for the next step.
            nxt = seq_index;
          ) : (
            // No-repeat modes: skip the would-be repeat, take one
            // step in the new direction immediately.
            nxt = step_in_dir_no_wrap(seq_index, seq_dir);
          );
          // Loop=On: keep bounce_count_total bounded by resetting
          // every complete cycle (two bounces).
          bounce_count_total >= 2 ? bounce_count_total = 0;
        );
      ) : (
        // Up or Down — wrap to the other end if looping, else stop.
        loop_enabled ? (
          wrap_start = seq_dir > 0 ? 0 : seq_length_eff - 1;
          nxt = next_active_voice(wrap_start, seq_dir);
        );
        // else: nxt stays -1, triggering the seq_finished branch below.
      );
    );
    nxt < 0 ? (
      // No next voice — finalize the sequence. Same Legato release
      // as the original logic so the last note doesn't ring forever.
      seq_finished = 1;
      legato_enabled && voice_state[seq_index] != 0 ? (
        voice_state[seq_index] = 3;
        state_elapsed[seq_index] = 0;
      );
    ) : (
      // Capture the previous (still-playing-or-just-released)
      // voice index BEFORE we advance seq_index. Used by the
      // Legato glide hand-off below — we need to know which
      // voice to inherit envelope + oscillator phase from.
      prev_voice = prev_seq_index;
      seq_index = nxt;

      // Play/Rest gate. Check first whether the step we just
      // completed took us to the threshold for the current period;
      // if so, flip play↔rest and reset the counter. Then increment
      // for the step we're about to (maybe) trigger. The note
      // trigger below is conditioned on !pr_resting so during rest
      // the sequencer walks silently in Walk mode (seq_index still
      // advances, pr_step still increments, just no new attack
      // fires). In Freeze mode the rest-entry block below saves
      // the would-be-next voice and sets up the sample-timed rest
      // window; the sequencer-advance gate higher up keeps
      // seq_step_elapsed pinned so this handoff doesn't re-fire.
      //
      // Legato edge case: in Legato mode the previous voice's
      // sustain doesn't auto-release (it normally only releases when
      // the next voice's Legato handoff inherits it). When PR flips
      // to rest, no handoff fires and the previous voice would ring
      // forever. Force it into release at the rest-entry moment —
      // same trick the seq_finished branch uses for Loop=Off.
      pr_enabled ? (
        pr_step >= (pr_resting ? rest_for_steps : play_for_steps) ? (
          just_entered_rest = !pr_resting;
          just_entered_rest && legato_enabled && voice_state[prev_voice] != 0 ? (
            voice_state[prev_voice]   = 3;
            state_elapsed[prev_voice] = 0;
          );
          pr_resting = 1 - pr_resting;
          pr_step    = 0;
          // Freeze-mode rest entry: remember the voice that was
          // playing (for the trigger function's prev_idx when we
          // resume), and compute the rest duration in samples by
          // simulating exactly what Walk mode would have done from
          // this point — sum the next rest_for_steps voices' Next
          // voice in durations. This makes the slider's wall-clock
          // meaning consistent across Walk and Freeze even when
          // voices have different per-step timings. The sequencer-
          // advance gate higher up keeps seq_index pointing at the
          // frozen voice for the entire rest.
          just_entered_rest && rest_mode == 1 ? (
            pr_frozen_prev_voice = prev_voice;
            pr_rest_duration_samples = simulate_rest_duration_seconds(seq_index, rest_for_steps) * srate;
            pr_rest_elapsed = 0;
          );
        );
        pr_step += 1;
      );

        // Re-trigger the new voice's envelope from attack — unless
        // the voice is a rest (Note Length = 0; the trigger
        // function handles that case internally) or PR is in its
        // rest period.
        !pr_enabled || !pr_resting ? trigger_seq_voice(prev_voice);
    );
  );
);

// Freeze-mode rest timer. When Rest mode = Freeze in place AND we
// entered a rest period, the sequencer-advance gate above keeps
// seq_step_elapsed pinned so no handoffs fire. This block counts
// samples of rest elapsed; when we hit the threshold (rest_for_steps
// × the frozen voice's "Next voice in" duration, in samples), exit
// rest and fire the frozen voice via the shared trigger function.
// pr_step is reset to 1 so the next handoff sees this fired voice
// as step 1 of the new play period — matching how Walk mode counts
// the first fired note of a new play period.
//
// The pr_rest_duration_samples > 0 guard handles the edge case where
// the user changes Rest mode mid-rest (Walk → Freeze): without the
// duration being set, the comparison would fire immediately and
// snap out of rest, leaving state inconsistent. With the guard we
// just sit until the user presses stop/play to reset cleanly.
pr_enabled && pr_resting && rest_mode == 1 && pr_rest_duration_samples > 0 ? (
  // Scale rest accumulation by combined_scale so rest duration tracks
  // the effective tempo set by Speed Ramp + Wobble (consistent with
  // how Walk-mode rest auto-tracks via the stretched dt).
  pr_rest_elapsed += combined_scale;
  pr_rest_elapsed >= pr_rest_duration_samples ? (
    pr_resting = 0;
    pr_step = 1;
    seq_step_elapsed = 0;
    trigger_seq_voice(pr_frozen_prev_voice);
  );
);

// === Per-voice envelope + oscillator + sum ===
// Walk every voice that's in a non-silent state; update its
// envelope based on its own elapsed-in-state, render its sample,
// sum to L/R. A voice can be ringing here even if it's not the
// "current" sequencer voice (overlap case).
//
// Click prevention: after the state machine produces a raw
// envelope value, that value goes through a one-pole smoother
// (smooth_coeff, ~3ms time constant) before being applied to
// the oscillator. So even when attack% = 0 or release% = 0
// would let the raw envelope jump instantly from 0 to 1 (or
// vice versa), the smoothed amplitude ramps over a few
// milliseconds and the listener hears a clean transition.
// This mirrors Polyrhythm Phase's gain_l[i] = gain_l[i] *
// smooth + target * (1 - smooth) pattern.
//
// Voices in state 0 (silent) still pass through the smoother
// so any tail from a previous note rings out gracefully if
// the voice was just released. We only skip the oscillator
// render once both the raw envelope AND the smoothed value
// are near zero — otherwise the smoothed tail would get cut
// off mid-fade.
out_l = 0;
out_r = 0;

i = 0;
loop(8,
  v_active[i] && (voice_state[i] != 0 || v_env_smoothed[i] > 0.0001) ? (
    // Advance the state machine ONLY when the voice is in a
    // non-silent state. A voice in state 0 with a non-zero
    // smoothed envelope is decaying its tail — the state machine
    // has nothing more to do; we just let the smoother converge
    // to 0 (v_envelope[i] is already 0, the smoother was set to
    // 0 by the release-end transition).
    voice_state[i] != 0 ? (
      state_elapsed[i] += dt;
      elapsed = state_elapsed[i];

      // State machine: attack → sustain → release → silent.
      // Note Length = 0 (rest voice) never enters here because
      // the sequencer-trigger code refuses to set state to 1
      // when v_note_seconds <= 0.0001 — rests stay silent.
      voice_state[i] == 1 ? (  // attack
        v_attack_seconds[i] > 0.0001 ? (
          t = elapsed / v_attack_seconds[i];
          t >= 1 ? (
            v_envelope[i] = 1;
            voice_state[i] = 2;
            state_elapsed[i] = 0;
          ) : (
            v_envelope[i] = apply_curve(t, attack_shape);
          );
        ) : (
          // attack% = 0 — jump straight to sustain. The smoother
          // below catches the 0→1 jump so no click reaches the
          // listener; this matches Polyrhythm Phase's behavior.
          v_envelope[i] = 1;
          voice_state[i] = 2;
          state_elapsed[i] = 0;
        );
      ) :
      voice_state[i] == 2 ? (  // sustain
        v_envelope[i] = 1;
        // Sustain → release on its own ONLY when Legato is off.
        // In Legato mode, each voice rings continuously until the
        // sequencer's next hand-off silences it via the legato
        // inheritance path — so the user's "Note duration"
        // effectively becomes "ring until the next note takes
        // over," giving a true continuous tone with pitch sliding
        // between voices. End-of-sequence (Loop=Off, walked past
        // the last active voice) is handled separately above by
        // forcing the current voice into release state so the
        // sound doesn't ring forever.
        !legato_enabled && elapsed >= v_sustain_seconds[i] ? (
          voice_state[i] = 3;
          state_elapsed[i] = 0;
        );
      ) :
      voice_state[i] == 3 ? (  // release
        v_release_seconds[i] > 0.0001 ? (
          t = elapsed / v_release_seconds[i];
          t >= 1 ? (
            v_envelope[i] = 0;
            voice_state[i] = 0;
            state_elapsed[i] = 0;
          ) : (
            v_envelope[i] = apply_curve(1 - t, release_shape);
          );
        ) : (
          // release% = 0 — drop to silent. Smoother handles the
          // 1→0 fade so no click reaches the listener.
          v_envelope[i] = 0;
          voice_state[i] = 0;
          state_elapsed[i] = 0;
        );
      );
    );

    // One-pole exponential smoother on the envelope output.
    // smooth_coeff = exp(-1/(srate * 0.003)), so the smoothed
    // value tracks the raw envelope with a ~3ms time constant.
    // This is what prevents clicks on the attack=0 and release=0
    // edge cases — the raw v_envelope[i] may step instantly
    // (0→1 on attack=0, 1→0 on release=0), but the smoother
    // ramps over a few milliseconds and the listener hears a
    // clean transition. Same pattern as Polyrhythm Phase.
    v_env_smoothed[i] = v_env_smoothed[i] * smooth_coeff + v_envelope[i] * (1 - smooth_coeff);

    // Always render the oscillator while the smoothed envelope
    // is non-trivial — covers both the active-state case and the
    // post-release tail-decay case.
    (
      // Glide step: slide v_freq_current_l/r toward this voice's
      // own target (v_freq_l/r[i]) over glide_time seconds via a
      // one-pole smoother. When glide_time = 0, just snap so the
      // pitch jumps cleanly to its target (the original behavior
      // before glide was added).
      glide_time > 0.0001 ? (
        v_freq_current_l[i] = v_freq_current_l[i] * glide_coeff + v_freq_l[i] * (1 - glide_coeff);
        v_freq_current_r[i] = v_freq_current_r[i] * glide_coeff + v_freq_r[i] * (1 - glide_coeff);
      ) : (
        v_freq_current_l[i] = v_freq_l[i];
        v_freq_current_r[i] = v_freq_r[i];
      );
      // Advance oscillator phases using the (possibly gliding)
      // current frequency. L and R are independent so the binaural
      // beat (Hz offset on R only) works cleanly.
      osc_phase_l[i] += v_freq_current_l[i] / srate;
      osc_phase_r[i] += v_freq_current_r[i] / srate;
      osc_phase_l[i] >= 1 ? osc_phase_l[i] -= 1;
      osc_phase_r[i] >= 1 ? osc_phase_r[i] -= 1;

      // Waveform chain — matches Polyrhythm Phase's 10 options.
      // Each branch computes osc_l from osc_phase_l[i] and osc_r
      // from osc_phase_r[i]. (Copy-pasted intentionally; JSFX has
      // no imports, and the alternative is a single sample worth
      // of function-call overhead per voice.)
      pl = osc_phase_l[i];
      pr = osc_phase_r[i];

      waveform == 0 ? (  // Sine
        osc_l = sin(2 * $pi * pl);
        osc_r = sin(2 * $pi * pr);
      ) :
      waveform == 1 ? (  // Triangle
        osc_l = (pl < 0.5 ? 4 * pl - 1 : 3 - 4 * pl);
        osc_r = (pr < 0.5 ? 4 * pr - 1 : 3 - 4 * pr);
      ) :
      waveform == 2 ? (  // Saw
        osc_l = 2 * pl - 1;
        osc_r = 2 * pr - 1;
      ) :
      waveform == 3 ? (  // Golden TS (Polyrhythm-Phase-compatible: golden
                         //   phase warp → SINE output. The originally-
                         //   shipped Melody Phase slot 3 fed the warp into
                         //   a triangle, which sounded different from the
                         //   same-named slot in Polyrhythm Phase. To make
                         //   the two plugins match — and to preserve the
                         //   sound of existing Polyrhythm Phase projects
                         //   that built on this — the triangle-output
                         //   variant moved to the "Phi Triangle" slot at
                         //   the end of this list. See docs for context.)
        inv_phi = 1 / 1.618033988749895;
        wl = pl < inv_phi ? pl / inv_phi * 0.5 : 0.5 + (pl - inv_phi) / (1 - inv_phi) * 0.5;
        wr = pr < inv_phi ? pr / inv_phi * 0.5 : 0.5 + (pr - inv_phi) / (1 - inv_phi) * 0.5;
        osc_l = sin(2 * $pi * wl);
        osc_r = sin(2 * $pi * wr);
      ) :
      waveform == 4 ? (  // Golden SG (Polyrhythm-Phase-compatible: sine
                         //   prewarp + golden phase warp → sine output.
                         //   The originally-shipped Melody Phase slot 4
                         //   was the no-prewarp "clean" version; the
                         //   prewarp version is what Polyrhythm Phase
                         //   has always shipped, and the prewarp adds
                         //   harmonic content. Clean (no-prewarp) version
                         //   moved to "Phi Sine" at the end of this list.)
        inv_phi = 1 / 1.618033988749895;
        pl_pre = (sin((pl - 0.25) * 2 * $pi) + 1) * 0.5;
        pr_pre = (sin((pr - 0.25) * 2 * $pi) + 1) * 0.5;
        wl = pl_pre < inv_phi ? pl_pre / inv_phi * 0.5 : 0.5 + (pl_pre - inv_phi) / (1 - inv_phi) * 0.5;
        wr = pr_pre < inv_phi ? pr_pre / inv_phi * 0.5 : 0.5 + (pr_pre - inv_phi) / (1 - inv_phi) * 0.5;
        osc_l = sin(2 * $pi * wl);
        osc_r = sin(2 * $pi * wr);
      ) :
      waveform == 5 ? (  // Golden GS
        inv_phi = 1 / 1.618033988749895;
        osc_l = sin(2 * $pi * pl + inv_phi * sin(2 * $pi * pl));
        osc_r = sin(2 * $pi * pr + inv_phi * sin(2 * $pi * pr));
      ) :
      waveform == 6 ? (  // Bell — additive partials at 1, 2, 3, 4, 6
        osc_l = 0.55 * sin(2 * $pi * pl)
              + 0.25 * sin(4 * $pi * pl)
              + 0.10 * sin(6 * $pi * pl)
              + 0.07 * sin(8 * $pi * pl)
              + 0.03 * sin(12 * $pi * pl);
        osc_r = 0.55 * sin(2 * $pi * pr)
              + 0.25 * sin(4 * $pi * pr)
              + 0.10 * sin(6 * $pi * pr)
              + 0.07 * sin(8 * $pi * pr)
              + 0.03 * sin(12 * $pi * pr);
      ) :
      waveform == 7 ? (  // Wavefold — sin(2 * sin(phase))
        osc_l = sin(2 * sin(2 * $pi * pl));
        osc_r = sin(2 * sin(2 * $pi * pr));
      ) :
      waveform == 8 ? (  // Half-sine — full-wave rectified, bipolar
        osc_l = 2 * abs(sin(2 * $pi * pl)) - 1;
        osc_r = 2 * abs(sin(2 * $pi * pr)) - 1;
      ) :
      waveform == 9 ? (  // Phi-cascade — fundamental + φ⁻¹·2nd + φ⁻²·3rd
        inv_phi = 1 / 1.618033988749895;
        inv_phi2 = inv_phi * inv_phi;
        osc_l = sin(2 * $pi * pl) + inv_phi * sin(4 * $pi * pl) + inv_phi2 * sin(6 * $pi * pl);
        osc_r = sin(2 * $pi * pr) + inv_phi * sin(4 * $pi * pr) + inv_phi2 * sin(6 * $pi * pr);
      ) :
      waveform == 10 ? (  // Phi Triangle — golden phase warp → TRIANGLE output.
                          //   This is the manual's documented "Golden TS"
                          //   behavior, and was Melody Phase's original
                          //   slot 3 implementation. Moved here so the
                          //   Polyrhythm-compatible sine-output Golden TS
                          //   can live at slot 3 in both plugins. Matches
                          //   the corresponding "Phi Triangle" slot in
                          //   Polyrhythm Phase.
        inv_phi = 1 / 1.618033988749895;
        wl = pl < inv_phi ? pl / inv_phi * 0.5 : 0.5 + (pl - inv_phi) / (1 - inv_phi) * 0.5;
        wr = pr < inv_phi ? pr / inv_phi * 0.5 : 0.5 + (pr - inv_phi) / (1 - inv_phi) * 0.5;
        osc_l = (wl < 0.5 ? 4 * wl - 1 : 3 - 4 * wl);
        osc_r = (wr < 0.5 ? 4 * wr - 1 : 3 - 4 * wr);
      ) :
      waveform == 11 ? (  // Phi Sine — golden phase warp → sine output, no
                          //   pre-warp. The manual's documented "Golden SG"
                          //   behavior, and was Melody Phase's original
                          //   slot 4 implementation. Cleaner / less bright
                          //   than the Polyrhythm-compatible Golden SG at
                          //   slot 4, which adds a sine prewarp. Matches
                          //   the corresponding "Phi Sine" slot in
                          //   Polyrhythm Phase.
        inv_phi = 1 / 1.618033988749895;
        wl = pl < inv_phi ? pl / inv_phi * 0.5 : 0.5 + (pl - inv_phi) / (1 - inv_phi) * 0.5;
        wr = pr < inv_phi ? pr / inv_phi * 0.5 : 0.5 + (pr - inv_phi) / (1 - inv_phi) * 0.5;
        osc_l = sin(2 * $pi * wl);
        osc_r = sin(2 * $pi * wr);
      );

      // Apply this voice's smoothed envelope, per-voice gain, and
      // master gain. Smoothed (not raw) so attack=0 / release=0
      // transitions don't click.
      amp = v_env_smoothed[i] * v_gain[i] * master_gain;

      // Pan — mirrors Polyrhythm Phase. When enabled, each voice's
      // L and R get separate amplitude multipliers based on the
      // pan position, instead of summing straight to out_l/out_r.
      // Pan is applied AFTER the osc/amp split so the binaural
      // beat (frequency difference between channels) is preserved
      // across the pan — collapsing osc_l + osc_r before panning
      // would destroy that.
      pan_enabled ? (
        pan_mode < 2 ? (
          // Tremolo / Increment: pan position oscillates via LFO
          pan_phase[i] += v_pan_freq[i] / srate;
          pan_phase[i] >= 1 ? pan_phase[i] -= 1;
          raw_pan = sin(pan_phase[i] * 2 * $pi) * pan_spread;
        ) : (
          // Spread / Spread Reversed: position is static; smoother
          // below handles transitions cleanly when the user flips
          // a voice's Active toggle or changes Pan Mode mid-play.
          raw_pan = v_pan_static[i] * pan_spread;
        );
        // pan_smooth_coeff_global is computed in @slider so we don't
        // call exp() 8 times per sample. Time constant follows
        // Glide time in Legato mode (so pan and pitch glide
        // together), 10ms otherwise.
        pan_smooth[i] = pan_smooth[i] * pan_smooth_coeff_global + raw_pan * (1 - pan_smooth_coeff_global);
        pan_pos   = (pan_smooth[i] + 1.0) * 0.5;
        pan_l_mul = cos(pan_pos * $pi * 0.5);
        pan_r_mul = sin(pan_pos * $pi * 0.5);
        out_l += osc_l * amp * pan_l_mul;
        out_r += osc_r * amp * pan_r_mul;
      ) : (
        out_l += osc_l * amp;
        out_r += osc_r * amp;
      );
    );
  );
  i += 1;
);

spl0 = out_l;
spl1 = out_r;

);  // close start-delay else branch
