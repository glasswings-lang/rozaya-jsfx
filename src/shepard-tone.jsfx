desc: Shepard Tone Generator
// Designed by Rozaya, developed with Claude (Anthropic)
//
// This work is dedicated to the public domain under CC0 1.0 Universal.
// https://creativecommons.org/publicdomain/zero/1.0/
//
// A Shepard-Risset glissando generator — an auditory illusion of pitch that
// sweeps upward (or downward) continuously without ever actually getting higher.
//
// HOW IT WORKS:
// Each voice is rooted at a musical note. Inside that voice, multiple oscillators
// are stacked at exact octave intervals from the root. The pitch window is exactly
// as wide as the Octave Count — so spacing is always 1 octave and handoffs are
// always clean. All oscillators sweep continuously in the same direction. Each
// oscillator's volume is shaped by the Fade In/Out controls — loud near the center
// of the window, silent at the edges. When an oscillator exits the top of the window
// it wraps silently to the bottom and begins fading in again, producing seamless
// continuous motion.
//
// VOICES:
// Up to 8 independent voices, each rooted at a different note. Use multiple
// voices to create Shepard chords (e.g. C+E+G), counterpoint (one ascending,
// one descending), or polyrhythmic textures (Independent drift mode with
// different rates per voice).
//
// CONTROLS:
//   Drift Mode       — Synced: all voices share Rate Value; each voice's Drift
//                      slider is a cents detune offset on its oscillators.
//                      Independent: each voice's Drift slider is its own rate
//                      in the current Rate Mode units.
//   Rate Mode/Value  — How fast the sweep cycles: BPM, cycle length in seconds,
//                      or direct Hz.
//   Octave Count     — How many oscillators run per voice (2-12), and how many
//                      octaves wide the pitch window is. These are the same thing.
//   Center Octave    — Which octave sits at the middle of the pitch window.
//   Fade In/Out %    — What fraction of each sweep cycle is spent fading in or
//                      out. Lower values = longer hold at full volume, shorter
//                      crossfades. 20/20 is a good starting point for ambient use.
//   Waveform         — Sine is cleanest for the illusion. Other waveforms add
//                      harmonic color.
//   Binaural Beat    — Offsets the right channel frequency by this many Hz,
//                      producing a binaural beat at the specified frequency.
//   Root Note        — Global tonic. Per-voice Note sliders offset from this.
//   Tuning Ref       — Reference frequency for A4 (default 440Hz).
//
// PER-VOICE:
//   Note             — Pitch class of this voice, relative to Root Note.
//   Pan              — Stereo position. Negative = left, positive = right. 0 = center.
//   Direction        — Ascending or descending sweep.
//   Drift            — Cents detune (Synced) or independent rate (Independent).
//   Gain dB          — Volume of this voice.
//   Active           — Enables the voice. Controls hide when inactive.

// ===== GLOBAL CONTROLS =====
slider1:0<0,1,1{Synced,Independent}>Drift Mode
slider2:0<0,2,1{BPM,Seconds,Hz}>Rate Mode
slider3:0.5<0.001,1000,0.001>Rate Value
slider4:8<2,16,1>Octave Count
slider5:3<0,8,1>Center Octave
slider6:20<0,100,0.1>Fade In %
slider7:20<0,100,0.1>Fade Out %
slider8:0<0,11,1{Sine,Triangle,Saw,Golden TS,Golden SG,Golden GS,Bell,Wavefold,Half-sine,Phi-cascade,Phi Triangle,Phi Sine}>Waveform
slider9:0<0,100,0.1>Binaural Beat Hz
slider10:0<0,11,1{C,C#,D,D#,E,F,F#,G,G#,A,A#,B}>Root Note
slider11:440<400,480,0.1>Tuning Reference Hz

// ===== VOICE 1 =====
slider12:9<0,11,1{C,C#,D,D#,E,F,F#,G,G#,A,A#,B}>V1 Note
slider13:0<-100,100,0.1>V1 Pan (neg=left, pos=right)
slider14:0<0,1,1{Asc,Desc}>V1 Direction
slider15:0<-1000,1000,0.001>V1 Drift (Synced: cents) / Rate (Indep)
slider16:0<-60,6,0.1>V1 Gain dB
slider17:1<0,1,1{Off,On}>V1 Active

// ===== VOICE 2 =====
slider18:0<0,11,1{C,C#,D,D#,E,F,F#,G,G#,A,A#,B}>V2 Note
slider19:0<-100,100,0.1>V2 Pan (neg=left, pos=right)
slider20:0<0,1,1{Asc,Desc}>V2 Direction
slider21:0<-1000,1000,0.001>V2 Drift (Synced: cents) / Rate (Indep)
slider22:0<-60,6,0.1>V2 Gain dB
slider23:0<0,1,1{Off,On}>V2 Active

// ===== VOICE 3 =====
slider24:4<0,11,1{C,C#,D,D#,E,F,F#,G,G#,A,A#,B}>V3 Note
slider25:0<-100,100,0.1>V3 Pan (neg=left, pos=right)
slider26:0<0,1,1{Asc,Desc}>V3 Direction
slider27:0<-1000,1000,0.001>V3 Drift (Synced: cents) / Rate (Indep)
slider28:0<-60,6,0.1>V3 Gain dB
slider29:0<0,1,1{Off,On}>V3 Active

// ===== VOICE 4 =====
slider30:7<0,11,1{C,C#,D,D#,E,F,F#,G,G#,A,A#,B}>V4 Note
slider31:0<-100,100,0.1>V4 Pan (neg=left, pos=right)
slider32:0<0,1,1{Asc,Desc}>V4 Direction
slider33:0<-1000,1000,0.001>V4 Drift (Synced: cents) / Rate (Indep)
slider34:0<-60,6,0.1>V4 Gain dB
slider35:0<0,1,1{Off,On}>V4 Active

// ===== VOICE 5 =====
slider36:0<0,11,1{C,C#,D,D#,E,F,F#,G,G#,A,A#,B}>V5 Note
slider37:0<-100,100,0.1>V5 Pan (neg=left, pos=right)
slider38:0<0,1,1{Asc,Desc}>V5 Direction
slider39:0<-1000,1000,0.001>V5 Drift (Synced: cents) / Rate (Indep)
slider40:0<-60,6,0.1>V5 Gain dB
slider41:0<0,1,1{Off,On}>V5 Active

// ===== VOICE 6 =====
slider42:4<0,11,1{C,C#,D,D#,E,F,F#,G,G#,A,A#,B}>V6 Note
slider43:0<-100,100,0.1>V6 Pan (neg=left, pos=right)
slider44:0<0,1,1{Asc,Desc}>V6 Direction
slider45:0<-1000,1000,0.001>V6 Drift (Synced: cents) / Rate (Indep)
slider46:0<-60,6,0.1>V6 Gain dB
slider47:0<0,1,1{Off,On}>V6 Active

// ===== VOICE 7 =====
slider48:7<0,11,1{C,C#,D,D#,E,F,F#,G,G#,A,A#,B}>V7 Note
slider49:0<-100,100,0.1>V7 Pan (neg=left, pos=right)
slider50:0<0,1,1{Asc,Desc}>V7 Direction
slider51:0<-1000,1000,0.001>V7 Drift (Synced: cents) / Rate (Indep)
slider52:0<-60,6,0.1>V7 Gain dB
slider53:0<0,1,1{Off,On}>V7 Active

// ===== VOICE 8 =====
slider54:0<0,11,1{C,C#,D,D#,E,F,F#,G,G#,A,A#,B}>V8 Note
slider55:0<-100,100,0.1>V8 Pan (neg=left, pos=right)
slider56:0<0,1,1{Asc,Desc}>V8 Direction
slider57:0<-1000,1000,0.001>V8 Drift (Synced: cents) / Rate (Indep)
slider58:0<-60,6,0.1>V8 Gain dB
slider59:0<0,1,1{Off,On}>V8 Active

// Sit silent for N units after playback starts, then begin normally.
// Units match Rate Mode (BPM beats / Seconds / Hz cycles), interpreted
// against Rate Value. Re-arms on every transport stop/start. 0
// disables the delay.
slider60:0<0,1000,0.001>Start Delay

// Per-cycle Play/Rest gate over the continuous glissando. Voices
// play normally for N cycles of the master Rate Value, then go
// silent for M cycles, then resume — repeats forever. Cycle unit
// matches Start Delay (Rate Mode units against Rate Value): at
// Rate Value = 0.5 Hz, 4 cycles = 8 seconds; at 120 BPM, 4 cycles
// = 2 seconds. 0 in either slider disables the gate entirely.
// Resets on every transport stop/start. The Rest mode slider below
// picks between two different rest behaviors — see its comment.
slider61:0<0,1000,1>Play for (cycles)
slider62:0<0,1000,1>Rest for (cycles)

// How the oscillators behave during the rest period.
//   Walk through (default) — oscillators keep sweeping during rest,
//     just silently. When rest ends, you hear the tone wherever
//     the sweep happened to be — the position has shifted during
//     the silent stretch. Preserves the "the glissando is always
//     running, the gate just controls output" feel.
//   Freeze in place — oscillators stop sweeping during rest, frozen
//     at their current frequencies and phases. When rest ends, the
//     tone resumes from exactly where it left off. Preserves the
//     "pause and resume continuous motion" feel.
// For short rests the difference is subtle; for long rests (or fast
// sweep rates) Walk noticeably re-positions the harmonics while
// Freeze always resumes at the pre-rest position.
slider63:0<0,1,1{Walk through,Freeze in place}>Rest mode

// Speed ramp: signed-delta on Rate Value, expressed in the rate's
// current unit (BPM if Rate Mode = BPM, seconds if = Seconds, Hz if
// = Hz). The effective rate value = slider3 + ramp_t * slider64,
// then converted to Hz the same way slider3 is converted.
//
// In BPM mode at 60 BPM, slider64 = -30 ramps the sweep rate from
// 60 → 30 BPM (slower). In Hz mode at 0.5 Hz, slider64 = -0.25 ramps
// from 0.5 → 0.25 Hz. In Seconds mode (period units), positive
// slider64 lengthens the period (slower).
//
// Engage is a freeze/resume gate (NOT a restart edge); only transport
// play resets ramp_t. Migration from v2.7: slider64 changed from
// multiplier (0.1-4.0) to signed delta. Old projects' multiplier
// value is interpreted as a tiny delta — Speed Ramp effectively
// "off" until reconfigured.
slider64:0<-1000,1000,0.001>Speed ramp by (in rate's current unit)
slider65:0<0,60,0.1>Speed ramp duration (minutes)
slider66:0<0,1,1{Off,On}>Speed ramp engage
slider67:0<0,60,0.1>Speed ramp start delay (minutes)

// Per-target drift: nested-selector pattern matching Womb v3 / the
// rest of the v2.9 sweep. Pick a target (slider68), then sliders 69-72
// hold THAT target's drift config. Switching the selector saves
// current values to the old target's memory slot and loads the new
// target's values into the sliders. All 11 targets drift in parallel;
// the selector just chooses which one you're currently editing.
//
// Targets:
//   Rate Value  — wanders the master sweep rate (all voices, like the
//                 old musical drift). Multiplicative on base_rate_hz.
//   V1-V8 Rate  — wanders each voice's own sweep rate independently.
//                 In Synced mode the reference is Rate Value; in
//                 Independent mode it's that voice's Drift/Rate slider.
//   Fade In %   — wanders the window fade-in fraction.
//   Fade Out %  — wanders the window fade-out fraction.
//
// Period unit is glissando cycles (scaled by Speed Ramp) for ALL
// targets — including Fade %, which is paced by the sweep clock. For
// slow wall-clock-feel drift, set a long period.
//
// Up/Down amount is in the target's natural unit: the rate's current
// unit (BPM / Seconds / Hz) for Rate Value + per-voice targets, and
// percent for Fade In/Out. The 0-100 range covers Fade fully and BPM-
// mode rate drift; in Hz mode you'll use the low end (e.g. 0.1-0.5),
// in Seconds mode small period offsets.
//
// Migration from v2.8: the old flat drift block (musical_up/down/
// period, slow_up/down/period, drift_shape on sliders 68-74) was 7
// sliders covering Rate Value only. v2.9 is 5 sliders covering 11
// independent targets, reusing slider IDs 68-72; sliders 73 and 74
// are no longer declared. Old projects' slider values get reinterpreted
// (selector defaults to Rate Value; non-zero amounts on 69-70 produce
// drift on Rate Value). Reset drift sliders to defaults after upgrade
// and reconfigure.
slider68:0<0,10,1{Rate Value,V1 Rate,V2 Rate,V3 Rate,V4 Rate,V5 Rate,V6 Rate,V7 Rate,V8 Rate,Fade In %,Fade Out %}>Drift target
slider69:0<0,100,0.01>Drift up amount (units match target)
slider70:0<0,100,0.01>Drift down amount (units match target)
slider71:8<1,1000,1>Drift period (cycles)
slider72:0<0,2,1{Sine,Triangle,Random}>Drift shape


@init
ext_noinit = 1;   // preserve drift config bank across transport play (drift runtime + oscillator/gate state still reset on play, see transport edge handler in @sample)

PHI = 1.6180339887;
NUM_OSC = 16; // max oscillators per voice

// Memory layout — voice * NUM_OSC + osc = index, max 8*16 = 128 slots
osc_freq    = 0;   // 0-127
osc_phase_l = 128; // 128-255
osc_phase_r = 256; // 256-383
osc_gain    = 384; // 384-511

// Per-voice (8 slots each)
v_active    = 512;
v_gain_lin  = 520;
v_dir       = 528;
v_root      = 536; // root frequency in Hz
v_note      = 544;
v_pan       = 552; // pan position -100 to 100
shep_rate   = 560; // octaves per second
drifts      = 568;

smooth = exp(-1 / (srate * 0.008)); // one-pole smoothing ~8ms — prevents clicks on gain changes
needs_init = 1; // true first-load only — places oscillators before any @sample runs

i = 0;
loop(128,
  osc_freq[i]    = 0;
  osc_phase_l[i] = 0;
  osc_phase_r[i] = 0;
  osc_gain[i]    = 0;
  i += 1;
);

function rate_to_hz(raw_rate, rmode) (
  rmode == 0 ? max(raw_rate, 0.001) / 60 :
  rmode == 1 ? 1 / max(raw_rate, 0.001) :
               max(raw_rate, 0.001)
);

function note_to_hz(note, oct, tref) (
  tref * pow(2, ((oct + 1) * 12 + note - 69) / 12.0)
);

// Waveform dispatch — kept in sync with Polyrhythm Phase / Melody Phase
// so all four plugins offer the same palette. See those plugins' source
// for the canonical comment blocks on each waveform. Note that the
// Golden TS / SG slots are the polyrhythm-compatible (sine-output)
// versions, not the manual's strict reading — Phi Triangle / Phi Sine
// are the strict-reading variants. See rozaya-jsfx/CLAUDE.md for why.
function wave_sample(ph) (
  waveform == 0 ? sin(ph * 2 * $pi) :
  waveform == 1 ? (ph < 0.25 ? ph * 4 : ph < 0.75 ? 2 - ph * 4 : ph * 4 - 4) :
  waveform == 2 ? (
    ps = ph + 0.5; ps -= floor(ps); ps * 2 - 1
  ) :
  waveform == 3 ? (
    pg = ph < (1/PHI) ? ph * PHI * 0.5 : 0.5 + (ph - 1/PHI) / (1 - 1/PHI) * 0.5;
    sin(pg * 2 * $pi)
  ) :
  waveform == 4 ? (
    pg = (sin((ph - 0.25) * 2 * $pi) + 1) * 0.5;
    pg = pg < (1/PHI) ? pg * PHI * 0.5 : 0.5 + (pg - 1/PHI) / (1 - 1/PHI) * 0.5;
    sin(pg * 2 * $pi)
  ) :
  waveform == 5 ? (
    pg = ph + (1/PHI) * sin(ph * 2 * $pi) / (2 * $pi);
    pg -= floor(pg);
    sin(pg * 2 * $pi)
  ) :
  waveform == 6 ? (
    // Bell — additive partials at 1, 2, 3, 4, 6
    0.55 * sin(ph * 2 * $pi) + 0.25 * sin(ph * 4 * $pi)
      + 0.10 * sin(ph * 6 * $pi) + 0.07 * sin(ph * 8 * $pi)
      + 0.03 * sin(ph * 12 * $pi)
  ) :
  waveform == 7 ? sin(2 * sin(ph * 2 * $pi)) :          // Wavefold
  waveform == 8 ? (2 * abs(sin(ph * 2 * $pi)) - 1) :    // Half-sine (octave up; see Polyrhythm Phase docs)
  waveform == 9 ? (
    // Phi-cascade — fundamental + φ⁻¹·2nd + φ⁻²·3rd
    sin(ph * 2 * $pi) + (1/PHI) * sin(ph * 4 * $pi)
      + (1/(PHI*PHI)) * sin(ph * 6 * $pi)
  ) :
  waveform == 10 ? (
    // Phi Triangle — manual-correct "Golden TS" (warp → triangle)
    pg = ph < (1/PHI) ? ph * PHI * 0.5 : 0.5 + (ph - 1/PHI) / (1 - 1/PHI) * 0.5;
    pg < 0.5 ? 4 * pg - 1 : 3 - 4 * pg
  ) : (
    // Phi Sine — manual-correct "Golden SG" (clean warp → sine, no prewarp)
    pg = ph < (1/PHI) ? ph * PHI * 0.5 : 0.5 + (ph - 1/PHI) / (1 - 1/PHI) * 0.5;
    sin(pg * 2 * $pi)
  )
);

// window_gain: returns 0-1 gain for an oscillator at log-frequency lf.
// pos=0 is the bottom of the pitch window, pos=1 is the top.
// Fade in over the bottom fi fraction, hold at 1, fade out over the top fo fraction.
// Oscillators outside the window (pos<=0 or pos>=1) return 0 — silent wrap zone.
function window_gain(lf, log_lo, log_range, fi, fo) (
  pos = (lf - log_lo) / log_range;
  pos <= 0 || pos >= 1 ? 0 :
  pos < fi ? (fi > 0 ? 0.5 - 0.5 * cos(pos / fi * $pi) : 1) :
  pos > (1 - fo) ? (fo > 0 ? 0.5 - 0.5 * cos((1 - pos) / fo * $pi) : 0) :
  1
);

// Start Delay state.
last_play_state     = 0;
start_delay_elapsed = 0;
start_delay_sec     = 0;

// Play/Rest gate state. pr_cycle_progress is a continuous counter
// (fractional cycles elapsed in the current play or rest period)
// that flips pr_resting and resets when it crosses the relevant
// threshold. Always uses base_rate_hz as the clock, same as
// Start Delay — Rate Value is the master cycle unit regardless of
// drift_mode.
pr_resting        = 0;
pr_cycle_progress = 0;
play_for_cycles   = 0;
rest_for_cycles   = 0;
pr_enabled        = 0;
rest_mode         = 0;

// Speed ramp state.
// Speed Ramp state. Engage is a freeze/resume gate, not an edge;
// only transport play resets ramp_t.
speed_scale_current      = 1.0;
speed_ramp_t             = 0.0;
speed_ramp_delay_elapsed = 0;

// --- v2.9 Drift target memory banks ---
//
// 11 targets × 8 fields. Each array is 16-slot-spaced so targets can
// grow to 16 later without re-laying-out. Placed at 576 — right after
// drifts[] (per-voice array ending at 575), no overlap with osc / v
// arrays below.
//
// Targets:
//   0      = Rate Value        (units: rate's current unit)
//   1..8   = V1..V8 Rate        (units: rate's current unit)
//   9      = Fade In %          (units: %)
//   10     = Fade Out %         (units: %)
N_TARGETS = 11;
target_drift_up     = 576;
target_drift_down   = 592;
target_drift_per    = 608;
target_drift_shape  = 624;
target_drift_phase  = 640;
target_drift_prev   = 656;
target_drift_curr   = 672;
target_drift_offset = 688;

i = 0;
loop(N_TARGETS,
  target_drift_up[i]     = 0;
  target_drift_down[i]   = 0;
  target_drift_per[i]    = 8;
  target_drift_shape[i]  = 0;
  target_drift_phase[i]  = 0;
  target_drift_prev[i]   = 0;
  target_drift_curr[i]   = 0;
  target_drift_offset[i] = 0;
  i += 1;
);

// Last-selected drift target tracker for save/restore on selector change.
last_target_select = 0;


@slider

drift_mode   = slider1;
rate_mode    = slider2;
rate_val     = slider3;
num_osc      = max(2, min(16, floor(slider4 + 0.5)));
center_oct   = floor(slider5 + 0.5);
fade_in_pct  = slider6;
fade_out_pct = slider7;
waveform     = slider8;
binaural_hz  = slider9;
root_note    = floor(slider10 + 0.5);
tuning_ref   = slider11;

// Pitch window: exactly num_osc octaves wide, centered on center_oct.
// Window width == octave count means spacing is always exactly 1 octave,
// so oscillators always land on exact octave intervals of the root.
center_freq     = tuning_ref * pow(2, center_oct - 4); // A in center octave
pitch_lo        = center_freq * pow(2, -num_osc * 0.5);
pitch_hi        = center_freq * pow(2,  num_osc * 0.5);
log_pitch_lo    = log(pitch_lo);
log_pitch_hi    = log(pitch_hi);
log_pitch_range = log_pitch_hi - log_pitch_lo;

base_rate_hz = rate_to_hz(rate_val, rate_mode);
oct_range    = num_osc; // window is exactly num_osc octaves wide

// Read per-voice sliders and recompute derived values — like polyrhythm, no reinit needed.
// Oscillators keep sweeping; note changes simply update v_root and the @sample loop
// brings each oscillator into the new window on its next wrap.
i = 0;
loop(8,
  base = 12 + i * 6;
  v_note[i]     = slider(base);
  v_pan[i]      = slider(base + 1);
  v_dir[i]      = slider(base + 2);
  drifts[i]     = slider(base + 3);
  v_gain_lin[i] = pow(10, slider(base + 4) / 20.0);
  v_active[i]   = slider(base + 5);
  v_root[i]     = note_to_hz(v_note[i] + root_note, 4, tuning_ref);

  drift_mode == 0 ? (
    shep_rate[i] = base_rate_hz * oct_range;
  ) : (
    // Independent mode: a rate of 0 (or below) means "this voice does
    // not sweep" — it holds its pitch. The old code clamped via
    // max(drifts[i], 0.001), which produced a slow creep in BPM/Hz
    // mode and a wild 1000 Hz sweep in Seconds mode (1/0.001) — so a
    // voice whose Rate slider read 0 was still moving behind the
    // scenes. Guard explicitly: rate > 0 sweeps at that rate;
    // rate <= 0 freezes the voice (shep_rate = 0 → freq_mul = 1).
    drifts[i] > 0 ? (
      shep_rate[i] = rate_to_hz(drifts[i], rate_mode) * oct_range;
    ) : (
      shep_rate[i] = 0;
    );
  );

  i += 1;
);

// Fade fractions are now computed per-sample in @sample as eff_fade_*
// (baseline fade_in_pct/fade_out_pct + Fade % drift offset, clamped +
// renormalized). The old @slider fade_in_frac/fade_out_frac precompute
// was removed in v2.9 — fade_in_pct / fade_out_pct carry the baseline.

// Show/hide per-voice controls based on active state.
// Must use actual sliderN variables — slider_show() takes slider variable
// references or bitmasks, NOT integer indices.
// Active toggle always visible; other controls hide when voice is inactive;
// drift additionally requires Independent mode.
slider_show(slider12, slider17); slider_show(slider13, slider17); slider_show(slider14, slider17);
slider_show(slider15, slider17 && drift_mode == 1); slider_show(slider16, slider17);
slider_show(slider18, slider23); slider_show(slider19, slider23); slider_show(slider20, slider23);
slider_show(slider21, slider23 && drift_mode == 1); slider_show(slider22, slider23);
slider_show(slider24, slider29); slider_show(slider25, slider29); slider_show(slider26, slider29);
slider_show(slider27, slider29 && drift_mode == 1); slider_show(slider28, slider29);
slider_show(slider30, slider35); slider_show(slider31, slider35); slider_show(slider32, slider35);
slider_show(slider33, slider35 && drift_mode == 1); slider_show(slider34, slider35);
slider_show(slider36, slider41); slider_show(slider37, slider41); slider_show(slider38, slider41);
slider_show(slider39, slider41 && drift_mode == 1); slider_show(slider40, slider41);
slider_show(slider42, slider47); slider_show(slider43, slider47); slider_show(slider44, slider47);
slider_show(slider45, slider47 && drift_mode == 1); slider_show(slider46, slider47);
slider_show(slider48, slider53); slider_show(slider49, slider53); slider_show(slider50, slider53);
slider_show(slider51, slider53 && drift_mode == 1); slider_show(slider52, slider53);
slider_show(slider54, slider59); slider_show(slider55, slider59); slider_show(slider56, slider59);
slider_show(slider57, slider59 && drift_mode == 1); slider_show(slider58, slider59);

// Start Delay: convert to seconds based on Rate Mode. BPM beats and
// Hz cycles are interpreted against Rate Value; Seconds is literal.
start_delay_units = slider60;
rate_mode == 0 ? start_delay_sec = start_delay_units * 60 / max(rate_val, 0.001) :
rate_mode == 1 ? start_delay_sec = start_delay_units :
                 start_delay_sec = start_delay_units / max(rate_val, 0.001);

// Play/Rest gate: integer cycle counts. Both must be > 0 for the
// gate to engage; 0 in either slider disables.
play_for_cycles = slider61;
rest_for_cycles = slider62;
new_pr_enabled  = (play_for_cycles > 0 && rest_for_cycles > 0);
// Defensive reset: if user disables the gate (sets either slider to
// 0), drop pr_resting back to play and zero the progress counter so
// the gate doesn't carry stuck state into a future re-enable.
!new_pr_enabled && pr_resting ? (
  pr_resting = 0;
  pr_cycle_progress = 0;
);
pr_enabled = new_pr_enabled;
rest_mode  = slider63;

// Speed ramp engage-edge.
// No engage-edge detection. Engage is a freeze/resume gate handled
// in @sample. Only transport play resets ramp_t.

// Drift target selector save/restore (nested-selector pattern).
// Switching slider68 saves sliders 69-72 into the OLD target's slot,
// then loads the NEW target's stored config into sliders 69-72.
// Otherwise captures live edits to the current target's slot. All 11
// targets drift in parallel from @sample regardless of selection.
sel_target = slider68;
sel_up     = slider69;
sel_down   = slider70;
sel_per    = slider71;
sel_shape  = slider72;

last_target_select != sel_target ? (
  target_drift_up[last_target_select]    = sel_up;
  target_drift_down[last_target_select]  = sel_down;
  target_drift_per[last_target_select]   = sel_per;
  target_drift_shape[last_target_select] = sel_shape;

  slider69 = target_drift_up[sel_target];
  slider70 = target_drift_down[sel_target];
  slider71 = target_drift_per[sel_target];
  slider72 = target_drift_shape[sel_target];
  slider_automate(slider69);
  slider_automate(slider70);
  slider_automate(slider71);
  slider_automate(slider72);

  last_target_select = sel_target;
) : (
  target_drift_up[sel_target]    = sel_up;
  target_drift_down[sel_target]  = sel_down;
  target_drift_per[sel_target]   = sel_per;
  target_drift_shape[sel_target] = sel_shape;
);


@sample

// Transport play edge: fresh start. v2.9 uses ext_noinit = 1 so drift
// CONFIG bank survives across transport — but everything else needs
// explicit reset here so renders are deterministic (drift cycle at
// phase 0, oscillators re-placed, gate state clean). Matches breath_gen
// v2.9 / the suite rule.
play_state > 0 && last_play_state == 0 ? (
  // Start Delay + Speed Ramp progress.
  start_delay_elapsed      = 0;
  speed_ramp_t             = 0.0;
  speed_ramp_delay_elapsed = 0;

  // Drift runtime state (NOT the config bank).
  i = 0;
  loop(N_TARGETS,
    target_drift_phase[i]  = 0;
    target_drift_prev[i]   = 0;
    target_drift_curr[i]   = 0;
    target_drift_offset[i] = 0;
    i += 1;
  );

  // Force oscillator re-placement on the first sample (rebuilds osc
  // frequencies + phases + gains from the current window).
  needs_init = 1;

  // Play/Rest gate state.
  pr_resting        = 0;
  pr_cycle_progress = 0;
);
last_play_state = play_state;

// Advance speed_ramp_t while engaged + duration > 0 + past start
// delay. Engage off freezes ramp_t; engaging on resumes from there.
slider66 && slider65 > 0 ? (
  speed_ramp_delay_samples = slider67 * 60 * srate;
  speed_ramp_delay_elapsed < speed_ramp_delay_samples ? (
    speed_ramp_delay_elapsed += 1;
  ) : (
    speed_ramp_t += 1.0 / (srate * slider65 * 60);
    speed_ramp_t = min(speed_ramp_t, 1.0);
  );
);

// Signed-delta Speed Ramp: effective rate value = slider3 + ramp_t *
// slider64 (both in the rate's current unit). Convert to Hz the same
// way base_rate_hz is converted from slider3, then express the speed
// ramp's effect as a multiplicative factor (effective / base) so the
// existing combined_scale-based audio path keeps working. No
// "snapshot at engage" — live edits adjust trajectory.
effective_rate_val  = slider3 + speed_ramp_t * slider64;
effective_rate_hz   = rate_to_hz(effective_rate_val, rate_mode);
speed_scale_current = effective_rate_hz / max(base_rate_hz, 0.001);

// Per-target drift wave computation. 11 targets (0=Rate Value, 1-8=
// V1-V8 Rate, 9=Fade In %, 10=Fade Out %). Each gets a phase counter
// advancing per sample. Period unit is glissando cycles for ALL
// targets, referenced against base_rate_hz * speed_scale_current
// (cycle rate scaled by Speed Ramp but NOT by drift, to avoid a
// self-modulating feedback loop).
drift_cycle_rate = base_rate_hz * speed_scale_current;
i = 0;
loop(N_TARGETS,
  up    = target_drift_up[i];
  down  = target_drift_down[i];
  per   = target_drift_per[i];
  shape = target_drift_shape[i];

  drift_offset_local = 0;
  (up > 0 || down > 0) && per > 0 ? (
    period_samples = max(per * srate / max(drift_cycle_rate, 0.0001), 1);
    new_phase = target_drift_phase[i] + 1.0 / period_samples;
    new_phase >= 1.0 ? (
      new_phase -= 1.0;
      shape == 2 ? (
        target_drift_prev[i] = target_drift_curr[i];
        target_drift_curr[i] = rand(2) - 1;
      );
    );
    target_drift_phase[i] = new_phase;

    shape == 0 ? (
      shape_val = sin(2 * $pi * new_phase);
    ) : shape == 1 ? (
      shape_val = new_phase < 0.25 ? (4 * new_phase) :
                  new_phase < 0.75 ? (2 - 4 * new_phase) :
                                     (4 * new_phase - 4);
    ) : (
      shape_val = target_drift_prev[i] +
        (target_drift_curr[i] - target_drift_prev[i]) * new_phase;
    );
    drift_offset_local = shape_val > 0 ? shape_val * up : shape_val * down;
  );
  target_drift_offset[i] = drift_offset_local;
  i += 1;
);

// Rate Value drift (target 0) → global multiplier on base_rate_hz via
// the rate_to_hz ratio (so BPM/Hz/Seconds mode-direction is handled —
// e.g. in Seconds mode a positive offset lengthens the period =
// slower). Folds into combined_scale alongside Speed Ramp. Per-voice
// rate drift (targets 1-8) is applied inside the voice loop below.
rate_value_drift_mult = rate_to_hz(rate_val + target_drift_offset[0], rate_mode) / max(base_rate_hz, 0.001);
combined_scale = speed_scale_current * rate_value_drift_mult;

// Fade In / Out drift (targets 9, 10) → effective fade fractions for
// this sample, clamped to [0,1] and renormalized if they'd sum past 1
// (same guard as @slider's static fractions).
eff_fade_in_frac  = max(0, min(1, (fade_in_pct  + target_drift_offset[9])  / 100.0));
eff_fade_out_frac = max(0, min(1, (fade_out_pct + target_drift_offset[10]) / 100.0));
eff_fade_in_frac + eff_fade_out_frac > 1.0 ? (
  tf = eff_fade_in_frac + eff_fade_out_frac;
  eff_fade_in_frac  /= tf;
  eff_fade_out_frac /= tf;
);

start_delay_elapsed < start_delay_sec ? (
  start_delay_elapsed += 1 / srate;
  spl0 = 0;
  spl1 = 0;
) : (

// First-load init: place oscillators before any sweeping begins.
// Never triggered by slider changes — oscillators keep running through all parameter edits.
needs_init ? (
  i = 0;
  loop(8,
    root_in_window = v_root[i];
    root_in_window < pitch_lo ? root_in_window *= pow(2, ceil(log(pitch_lo / root_in_window) / log(2)));
    root_in_window > pitch_hi ? root_in_window *= pow(2, -ceil(log(root_in_window / pitch_hi) / log(2)));

    o = 0;
    loop(NUM_OSC,
      oi = i * NUM_OSC + o;
      o < num_osc ? (
        f = root_in_window * pow(2, o);
        f > pitch_hi ? f *= pitch_lo / pitch_hi;
      ) : (
        f = pitch_lo; // park extra slots at bottom — gain=0 there, silent
      );
      osc_freq[oi]    = f;
      osc_phase_l[oi] = 0;
      osc_phase_r[oi] = 0;
      osc_gain[oi]    = 0;
      o += 1;
    );
    i += 1;
  );
  needs_init = 0;
);

// Play/Rest gate: advance the cycle counter and flip pr_resting at
// thresholds. base_rate_hz / srate is fractional cycles per sample,
// using the master Rate Value clock regardless of drift_mode (so
// the gate timing matches what Start Delay would do at the same
// Rate Value setting).
pr_enabled ? (
  pr_cycle_progress += base_rate_hz * combined_scale / srate;
  !pr_resting ? (
    pr_cycle_progress >= play_for_cycles ? (
      pr_resting = 1;
      pr_cycle_progress = 0;
    );
  ) : (
    pr_cycle_progress >= rest_for_cycles ? (
      pr_resting = 0;
      pr_cycle_progress = 0;
    );
  );
);

// in_frozen_rest is the Freeze-mode-and-resting condition. Used
// below to gate oscillator frequency and phase advancement, so
// Freeze mode literally pauses the glissando. In Walk mode this
// stays false and oscillators keep sweeping during rest (just
// silently, via the target_gain = 0 branch).
in_frozen_rest = pr_enabled && pr_resting && rest_mode == 1;

out_l = 0;
out_r = 0;
active_count = 0;

i = 0;
loop(8,
  v_active[i] ? (
    active_count += 1;

    // Per-voice rate drift (targets 1-8). Offset is in the rate's
    // current unit, relative to the voice's OWN reference rate: Rate
    // Value in Synced mode, the voice's Drift/Rate slider in Independent
    // mode. Converted to a multiplier via the rate_to_hz ratio so
    // mode-direction asymmetry is handled. 1.0 when this voice has no
    // rate drift configured. Composes multiplicatively with the global
    // combined_scale (which carries Speed Ramp + Rate Value drift).
    voff = target_drift_offset[1 + i];
    voff != 0 ? (
      vbase = drift_mode == 0 ? rate_val : max(drifts[i], 0.001);
      v_rate_mult = rate_to_hz(vbase + voff, rate_mode) / max(rate_to_hz(vbase, rate_mode), 0.0001);
    ) : (
      v_rate_mult = 1.0;
    );

    freq_mul = pow(2, shep_rate[i] * combined_scale * v_rate_mult / srate);

    // Cosine-law pan: negative = left, positive = right
    pan_pos = (v_pan[i] / 100.0 + 1.0) * 0.5; // 0=full left, 0.5=center, 1=full right
    pan_l   = cos(pan_pos * $pi * 0.5);
    pan_r   = sin(pan_pos * $pi * 0.5);

    o = 0;
    loop(num_osc,
      oi = i * NUM_OSC + o;

      // Sweep oscillator frequency along the glissando, unless we
      // are in Freeze-mode rest — in that case the frequency stays
      // pinned so the tone resumes from the exact same position.
      !in_frozen_rest ? (
        v_dir[i] == 0 ? (
          osc_freq[oi] *= freq_mul;
          osc_freq[oi] > pitch_hi ? osc_freq[oi] *= pitch_lo / pitch_hi;
        ) : (
          osc_freq[oi] /= freq_mul;
          osc_freq[oi] < pitch_lo ? osc_freq[oi] *= pitch_hi / pitch_lo;
        );
      );

      // Drift detune (synced mode only — cents offset)
      drift_mode == 0 ? (
        freq_l = osc_freq[oi] * pow(2, drifts[i] / 1200.0);
      ) : (
        freq_l = osc_freq[oi];
      );
      freq_r = freq_l + binaural_hz;

      // Target gain — bell window position, unless Play/Rest is
      // resting (Walk OR Freeze mode), in which case force 0 and
      // let the existing smoother fade audio out.
      pr_enabled && pr_resting ? (
        target_gain = 0;
      ) : (
        lf = log(osc_freq[oi]);
        target_gain = window_gain(lf, log_pitch_lo, log_pitch_range, eff_fade_in_frac, eff_fade_out_frac) * v_gain_lin[i];
      );
      osc_gain[oi] = osc_gain[oi] * smooth + target_gain * (1 - smooth);

      // Advance phases, unless Freeze-mode rest is pinning them so
      // the waveform resumes at the same phase on rest exit.
      !in_frozen_rest ? (
        osc_phase_l[oi] += freq_l / srate;
        osc_phase_l[oi] >= 1 ? osc_phase_l[oi] -= 1;
        osc_phase_r[oi] += freq_r / srate;
        osc_phase_r[oi] >= 1 ? osc_phase_r[oi] -= 1;
      );

      out_l += wave_sample(osc_phase_l[oi]) * osc_gain[oi] * pan_l;
      out_r += wave_sample(osc_phase_r[oi]) * osc_gain[oi] * pan_r;

      o += 1;
    );
  );
  i += 1;
);

active_count > 0 ? (
  norm = 1.0 / (active_count * num_osc);
  spl0 = out_l * norm;
  spl1 = out_r * norm;
) : (
  spl0 = 0;
  spl1 = 0;
);

);  // close start-delay else branch


@serialize
// Persist per-target drift configurations. Without this, only the
// most-recently-edited target's drift slider values survive a project
// save/load because sliders 69-72 hold whichever target was selected
// at save time. 11 targets × 4 config fields = 44 values; plus the
// selector.
file_mem(0, target_drift_up,    N_TARGETS);
file_mem(0, target_drift_down,  N_TARGETS);
file_mem(0, target_drift_per,   N_TARGETS);
file_mem(0, target_drift_shape, N_TARGETS);
file_var(0, last_target_select);


@gfx 0 0
// Empty — present only to fix REAPER 7.x FX dialog slider display regression
// where sliders 1-5 are hidden when a plugin has no @gfx block.
