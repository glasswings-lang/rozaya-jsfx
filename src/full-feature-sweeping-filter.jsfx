desc: Resonant Sweeping Filter with Shaped LFO and Pan Modes
// Designed by Rozaya, developed with Claude (Anthropic)
//
// This work is dedicated to the public domain under CC0 1.0 Universal.
// https://creativecommons.org/publicdomain/zero/1.0/

slider1:500<20,20000,1>Frequency Low Hz
slider2:5000<20,20000,1>Frequency High Hz
slider3:2<0.001,1000,0.001>Rate Value
slider4:0<0,2,1{Hz,Seconds,BPM}>Rate Mode
slider5:0<-180,180,0.1>LFO Start Phase (degrees)
slider6:50<0,100,0.1>On Duration % of Cycle
slider7:100<0,100,0.1>Depth %
slider8:0<0,100,0.1>Attack %
slider9:0<0,100,0.1>Release %
slider10:1<0,3,1{Linear,Cosine,Logarithmic,Exponential}>Attack Shape
slider11:1<0,3,1{Linear,Cosine,Logarithmic,Exponential}>Release Shape
slider12:0.7<0,1,0.01>Resonance
slider13:0<-180,180,0.1>R Channel Phase Offset degrees
slider14:0<0,1,1{Independent L+R,Offset from L}>Phase Mode
slider15:1<0,1,0.01>Wet/Dry Mix
// ===== PAN BLOCK SLIDERS START =====
slider16:0<0,1,1{Off,On}>Pan Enabled
slider17:0<0,12,1{Mono,Alternating,Alternating (Flipped),Distributed,Distributed (Flipped),Distributed (Ping-pong),Converging,Converging (Ping-pong),Diverging,Diverging (Ping-pong),Pan Sweep,Pan Sweep (Flipped),Linked Sweep}>Pan Mode
slider18:1<0,1,0.01>Pan Spread (0=mono, 1=full)
slider19:5<0,100,0.1>Pan Glide ms (0=instant)
slider20:8<2,32,1>Cycle Steps (per-cycle modes)
slider21:2<0.001,1000,0.001>Pan Sweep Rate
slider22:0<0,2,1{Hz,Seconds,BPM}>Pan Sweep Rate Unit
slider23:1<0.125,8,0.125>Filter Speed Multiplier (Linked Sweep)
// ===== PAN BLOCK SLIDERS END =====

// Pass-through for N units after playback starts, then apply the
// filter sweep + pan effect normally. Units match Rate Mode (BPM
// beats / Seconds / Hz cycles), interpreted against Rate Value. As an
// EFFECT plugin the dry signal passes through during the delay. Re-
// arms on every transport stop/start. 0 disables the delay.
slider24:0<0,1000,0.001>Start Delay

// Per-cycle Play/Rest gate. Effect is applied normally for N cycles
// of the Rate Value, then bypassed (dry signal passes through
// unchanged) for M cycles, then resumes — repeats forever. Cycle
// unit matches Start Delay. As an EFFECT plugin, "rest" means dry
// pass-through (NOT silence) — silencing the input would mute the
// upstream track. The transition between effect-on and dry uses a
// ~3 ms fade. 0 in either slider disables the gate. Resets on
// every transport stop/start.
slider25:0<0,1000,1>Play for (cycles)
slider26:0<0,1000,1>Rest for (cycles)

// What the LFOs do during the rest period.
//   Walk through (default) — filter sweep LFO and pan LFOs keep
//     cycling during rest. When the effect resumes, the cutoff has
//     swept to a different position.
//   Freeze in place — LFO phases pause, frozen at their values at
//     rest entry. When the effect resumes, the cutoff picks up
//     from the same position. The rhythmic sweep pauses and
//     resumes in lockstep with the gate.
slider27:0<0,1,1{Walk through,Freeze in place}>LFO at rest

// What the output does during the rest period.
//   Pass-through (default) — dry signal passes through unchanged
//     (matches Start Delay's behavior). Effect plugins normally
//     don't silence their input.
//   Silence — wet+dry mix smooths to 0; the audio drops out during
//     rest instead of passing dry. Useful when you want the gate
//     to act like a hard mute rather than a filter bypass.
//     Combines cleanly with either Rest LFO setting.
slider28:0<0,1,1{Pass-through,Silence}>Output at rest

// Speed ramp: signed-delta on Sweep Rate (slider3), in the rate's
// currently-displayed unit (BPM if Rate Mode = BPM, seconds if
// Seconds, Hz if Hz). Effective rate = slider3 + ramp_t * slider29.
// In BPM/Hz modes negative slider29 = slower; in Seconds mode
// (period) positive slider29 = slower (longer period).
//
// A ~100 ms smoother on freq removes clicks from manual Rate
// adjustment too. Linked Sweep pan mode (12) scales with this since
// it derives its rate from the sweep frequency; the two pan-sweep
// modes (10, 11) have their own independent rate and are untouched.
//
// Engage is a freeze/resume gate (NOT a restart edge); only
// transport play resets ramp_t.
//
// Migration from v2.7: slider 29 changed from multiplier (0.1-4.0)
// to signed delta in rate-units. Old projects' multiplier value
// interprets as a tiny delta — Speed Ramp effectively "off" until
// reconfigured.
slider29:0<-1000,1000,0.001>Speed ramp by (in rate's current unit)
slider30:0<0,60,0.1>Speed ramp duration (minutes)
slider31:0<0,1,1{Off,On}>Speed ramp engage
slider32:0<0,60,0.1>Speed ramp start delay (minutes)

// Per-plugin drift: two independent drift sources (musical and slow)
// modulate the effective sweep rate (in Hz) with asymmetric up/down
// amplitudes. Musical drift is measured in cycles of the filter LFO
// itself and scales with Speed Ramp. Slow drift is wall-clock minutes
// and does NOT scale with Speed Ramp. Shape applies to both.
slider33:0<0,5,0.01>Musical drift: Up by
slider34:0<0,5,0.01>Musical drift: Down by
slider35:8<1,1000,1>Musical drift: Period (cycles)
slider36:0<0,5,0.01>Slow drift: Up by
slider37:0<0,5,0.01>Slow drift: Down by
slider38:5<0.1,60,0.1>Slow drift: Period (minutes)
slider39:0<0,2,1{Sine,Triangle,Random}>Drift shape

in_pin:left input
in_pin:right input
out_pin:left output
out_pin:right output

@init
phase_l = 0;
phase_r = 0;
n3 = n4 = rn3 = rn4 = 0;
cut_smooth_l = cut_smooth_r = 0.1;
last_start_phase = -999;

// ===== PAN BLOCK INIT START =====
pan_l           = 0;
pan_l_smooth    = 0;
pan_cycle_index = 0;
pan_cycle_dir   = 1;
last_phase_l    = 0;
pan_phase       = 0;
// ===== PAN BLOCK INIT END =====


function apply_curve(t, shape) (
  shape == 0 ? t :
  shape == 1 ? (0.5 - 0.5 * cos(t * $pi)) :
  shape == 2 ? (log(1 + 9*t) / log(10)) :
               ((10^t - 1) / 9)
);

function calc_lfo(ph, on_secs, att_secs, rel_secs, period, att_shape, rel_shape)
local(on_frac, aw, rw, hold_w, re_start, t, result, total) (
  on_secs = min(on_secs, period);
  on_frac = on_secs / period;

  aw = att_secs / period;
  rw = rel_secs / period;

  aw + rw > on_frac ? (
    total = aw + rw;
    aw = aw / total * on_frac;
    rw = rw / total * on_frac;
  );

  hold_w   = on_frac - aw - rw;
  re_start = aw + hold_w;

  ph < aw ? (
    aw > 0.0001 ? (
      t = ph / aw;
      result = apply_curve(t, att_shape);
    ) : (result = 1);
  ) :
  ph < re_start ? (
    result = 1;
  ) :
  ph < on_frac ? (
    rw > 0.0001 ? (
      t = 1 - (ph - re_start) / rw;
      result = apply_curve(t, rel_shape);
    ) : (result = 0);
  ) : (
    result = 0;
  );
  result
);

// ===== PAN BLOCK FUNCTIONS START =====
function percycle_pan(idx, n_steps) local(steps, step, pos) (
  n_steps = max(n_steps, 1);
  steps   = max(ceil((n_steps - 1) / 2.0), 1);

  pan_mode == 0 ? (
    pos = 0;
  ) : pan_mode == 1 ? (
    pos = (idx % 2 == 0) ? -1 : 1;
  ) : pan_mode == 2 ? (
    pos = (idx % 2 == 0) ? 1 : -1;
  ) : pan_mode == 3 ? (
    n_steps > 1 ? (pos = (idx % n_steps) / (n_steps - 1.0) * 2.0 - 1.0) : (pos = 0);
  ) : pan_mode == 4 ? (
    n_steps > 1 ? (pos = 1.0 - (idx % n_steps) / (n_steps - 1.0) * 2.0) : (pos = 0);
  ) : pan_mode == 5 ? (
    n_steps > 1 ? (pos = idx / (n_steps - 1.0) * 2.0 - 1.0) : (pos = 0);
  ) : pan_mode == 6 ? (
    idx = idx % n_steps;
    idx == 0 ? (
      pos = -1.0;
    ) : (
      step = ceil((idx + 1) / 2);
      pos = (idx % 2 == 1) ?  (1.0 - (step - 1.0) / steps)
                            : -(1.0 - (step - 1.0) / steps);
      pos = max(-1.0, min(1.0, pos));
    );
  ) : pan_mode == 7 ? (
    idx = idx % n_steps;
    idx == 0 ? (
      pos = -1.0;
    ) : (
      step = ceil((idx + 1) / 2);
      pos = (idx % 2 == 1) ?  (1.0 - (step - 1.0) / steps)
                            : -(1.0 - (step - 1.0) / steps);
      pos = max(-1.0, min(1.0, pos));
    );
  ) : pan_mode == 8 ? (
    idx = idx % n_steps;
    idx == 0 ? (
      pos = 0.0;
    ) : (
      step = floor((idx + 1) / 2);
      pos = (idx % 2 == 1) ? -(step / steps)
                            :  (step / steps);
      pos = max(-1.0, min(1.0, pos));
    );
  ) : pan_mode == 9 ? (
    idx = idx % n_steps;
    idx == 0 ? (
      pos = 0.0;
    ) : (
      step = floor((idx + 1) / 2);
      pos = (idx % 2 == 1) ? -(step / steps)
                            :  (step / steps);
      pos = max(-1.0, min(1.0, pos));
    );
  ) : (
    pos = 0;
  );

  pos * pan_spread
);
// ===== PAN BLOCK FUNCTIONS END =====

// Start Delay state.
last_play_state     = 0;
start_delay_elapsed = 0;
start_delay_sec     = 0;

// Play/Rest gate state. pr_cycle_progress is a continuous fractional
// counter (cycles elapsed in the current play or rest period).
// effect_mix smoothly transitions between 1 (effect fully on) and
// 0 (full dry pass-through) at rest boundaries — the wet mix and
// pan blend with their dry equivalents via this mix, so the gate
// is a soft fade rather than an abrupt switch.
pr_resting        = 0;
pr_cycle_progress = 0;
play_for_cycles   = 0;
rest_for_cycles   = 0;
pr_enabled        = 0;
rest_lfo_mode     = 0;
rest_output_mode  = 0;
effect_mix        = 1;

// Speed ramp + rate smoother state. Seeded from current slider values
// in @init so the first sample after transport-start uses the saved
// rate, not a default — same pattern as Tremolo.
rate_smoother_coeff      = 1.0 - exp(-1.0 / (srate * 0.1));
slider4 == 0 ? (freq_smoothed = slider3) :
slider4 == 1 ? (freq_smoothed = 1 / max(slider3, 0.001)) :
               (freq_smoothed = slider3 / 60);
// Speed Ramp state. Engage is a freeze/resume gate, not an edge;
// only transport play resets ramp_t.
speed_scale_current      = 1.0;
speed_ramp_t             = 0.0;
speed_ramp_delay_elapsed = 0;

// Per-plugin drift state. Phases advance per sample; on each wrap the
// Random shape latches a new target in [-1, +1] and interpolates from
// the previous target across the next cycle.
musical_drift_phase       = 0;
slow_drift_phase          = 0;
musical_drift_prev_target = 0;
musical_drift_curr_target = 0;
slow_drift_prev_target    = 0;
slow_drift_curr_target    = 0;


@slider

freq_lo      = min(slider1, slider2);
freq_hi      = max(slider1, slider2);
rate_val     = slider3;
rate_mode    = slider4;
dur_pct      = slider6;
depth_pct    = slider7 * 0.01;
att_pct      = slider8;
rel_pct      = slider9;
att_shape    = slider10;
rel_shape    = slider11;
resonance    = slider12;
phase_offset = slider13 / 360;
wet          = slider15;
dry          = 1 - wet;

slider5 != last_start_phase ? (
  phase_l = slider5 / 360.0;
  phase_l < 0 ? phase_l += 1;
  phase_r = phase_l;
  last_start_phase = slider5;
);

// ===== PAN BLOCK SLIDER READ START =====
pan_enabled     = slider16;
pan_mode        = slider17;
pan_spread      = slider18;
pan_glide_ms    = slider19;
pan_cycle_steps = slider20;
pan_sweep_val   = slider21;
pan_sweep_mode  = slider22;
pan_sweep_ratio = slider23;

slider_show(slider17, pan_enabled);
slider_show(slider18, pan_enabled);
slider_show(slider19, pan_enabled);
slider_show(slider20, pan_enabled && pan_mode >= 1 && pan_mode <= 9);
slider_show(slider21, pan_enabled && (pan_mode == 10 || pan_mode == 11));
slider_show(slider22, pan_enabled && (pan_mode == 10 || pan_mode == 11));
slider_show(slider23, pan_enabled && pan_mode == 12);
// ===== PAN BLOCK SLIDER READ END =====

// Start Delay: convert to seconds based on Rate Mode. BPM beats and
// Hz cycles are interpreted against Rate Value; Seconds is literal.
start_delay_units = slider24;
slider4 == 0 ? start_delay_sec = start_delay_units * 60 / max(slider3, 0.001) :
slider4 == 1 ? start_delay_sec = start_delay_units :
               start_delay_sec = start_delay_units / max(slider3, 0.001);

// Play/Rest gate: integer cycle counts. Both must be > 0 for the
// gate to engage; 0 in either slider disables.
play_for_cycles = slider25;
rest_for_cycles = slider26;
new_pr_enabled  = (play_for_cycles > 0 && rest_for_cycles > 0);
!new_pr_enabled && pr_resting ? (
  pr_resting = 0;
  pr_cycle_progress = 0;
);
pr_enabled       = new_pr_enabled;
rest_lfo_mode    = slider27;
rest_output_mode = slider28;

// Speed ramp engage-edge.
// No engage-edge detection. Engage is a freeze/resume gate handled
// in @sample. Only transport play resets ramp_t.


@sample

// Transport play edge resets EVERYTHING tied to "this play session":
// Start Delay counter, Speed Ramp progress, Speed Ramp start-delay
// counter. ONLY thing that resets ramp_t — slider changes don't.
play_state > 0 && last_play_state == 0 ? (
  start_delay_elapsed      = 0;
  speed_ramp_t             = 0.0;
  speed_ramp_delay_elapsed = 0;
);
last_play_state = play_state;

start_delay_elapsed < start_delay_sec ? (
  start_delay_elapsed += 1 / srate;
  // No-op — spl0 and spl1 pass through unchanged.
) : (

freq_lo      = min(slider1, slider2);
freq_hi      = max(slider1, slider2);
rate_val     = slider3;
rate_mode    = slider4;
dur_pct      = slider6;
depth_pct    = slider7 * 0.01;
att_pct      = slider8;
rel_pct      = slider9;
att_shape    = slider10;
rel_shape    = slider11;
resonance    = slider12;
phase_offset = slider13 / 360;
wet          = slider15;
dry          = 1 - wet;

// ===== PAN BLOCK SAMPLE READ START =====
pan_enabled     = slider16;
pan_mode        = slider17;
pan_spread      = slider18;
pan_glide_ms    = slider19;
pan_cycle_steps = slider20;
pan_sweep_val   = slider21;
pan_sweep_mode  = slider22;
pan_sweep_ratio = slider23;
// ===== PAN BLOCK SAMPLE READ END =====

rate_mode == 0 ? (freq_raw = rate_val) :
rate_mode == 1 ? (freq_raw = 1 / max(rate_val, 0.001)) :
                 (freq_raw = rate_val / 60);

// Smooth the rate slider, advance the speed ramp, apply per-plugin
// drift, then derive the effective freq used downstream by the LFO
// phase advance and the cycle counter.
freq_smoothed += (freq_raw - freq_smoothed) * rate_smoother_coeff;

// Advance speed_ramp_t while engaged + duration > 0 + past start
// delay. Engage off freezes ramp_t; engaging on resumes from there.
slider31 && slider30 > 0 ? (
  speed_ramp_delay_samples = slider32 * 60 * srate;
  speed_ramp_delay_elapsed < speed_ramp_delay_samples ? (
    speed_ramp_delay_elapsed += 1;
  ) : (
    speed_ramp_t += 1.0 / (srate * slider30 * 60);
    speed_ramp_t = min(speed_ramp_t, 1.0);
  );
);

// Signed-delta Speed Ramp: effective rate value = rate_val + ramp_t *
// slider29 (both in rate's current unit). Convert to Hz the same way
// freq_raw is computed above, then express as a multiplicative factor
// on freq_smoothed so the existing combined_scale-based audio path
// keeps working. No "snapshot at engage" — live edits adjust trajectory.
effective_rate_val = rate_val + speed_ramp_t * slider29;
rate_mode == 0 ? (effective_rate_hz = effective_rate_val) :
rate_mode == 1 ? (effective_rate_hz = 1 / max(effective_rate_val, 0.001)) :
                 (effective_rate_hz = effective_rate_val / 60);
speed_scale_current = effective_rate_hz / max(freq_raw, 0.001);

// Per-plugin drift. Musical drift's "primary cycle" is one LFO cycle
// (one full filter sweep). freq_base is the current Speed-Ramp-scaled
// sweep frequency; musical drift's phase advance scales with this so
// the wave's period in LFO cycles stays roughly constant as Speed Ramp
// slows the metronome. Slow drift advances on wall clock and ignores
// Speed Ramp.
freq_base = freq_smoothed * speed_scale_current;

musical_drift_up     = slider33;
musical_drift_down   = slider34;
musical_drift_period = slider35;
slow_drift_up        = slider36;
slow_drift_down      = slider37;
slow_drift_period    = max(slider38, 0.1);
drift_shape          = slider39;

musical_drift_offset = 0;
(musical_drift_up > 0 || musical_drift_down > 0) ? (
  musical_period_samples = (musical_drift_period / max(freq_base, 0.00001)) * srate;
  musical_drift_phase += 1 / max(musical_period_samples, 1);
  musical_drift_phase >= 1 ? (
    musical_drift_phase -= 1;
    drift_shape == 2 ? (
      musical_drift_prev_target = musical_drift_curr_target;
      musical_drift_curr_target = rand(2) - 1;
    );
  );
  drift_shape == 0 ? (
    m_shape_val = sin(2 * $pi * musical_drift_phase);
  ) : drift_shape == 1 ? (
    m_shape_val = musical_drift_phase < 0.25 ? (4 * musical_drift_phase) :
                  musical_drift_phase < 0.75 ? (2 - 4 * musical_drift_phase) :
                                               (4 * musical_drift_phase - 4);
  ) : (
    m_shape_val = musical_drift_prev_target +
                  (musical_drift_curr_target - musical_drift_prev_target) * musical_drift_phase;
  );
  musical_drift_offset = m_shape_val > 0 ? m_shape_val * musical_drift_up : m_shape_val * musical_drift_down;
);

slow_drift_offset = 0;
(slow_drift_up > 0 || slow_drift_down > 0) ? (
  slow_drift_phase += 1 / (slow_drift_period * 60 * srate);
  slow_drift_phase >= 1 ? (
    slow_drift_phase -= 1;
    drift_shape == 2 ? (
      slow_drift_prev_target = slow_drift_curr_target;
      slow_drift_curr_target = rand(2) - 1;
    );
  );
  drift_shape == 0 ? (
    s_shape_val = sin(2 * $pi * slow_drift_phase);
  ) : drift_shape == 1 ? (
    s_shape_val = slow_drift_phase < 0.25 ? (4 * slow_drift_phase) :
                  slow_drift_phase < 0.75 ? (2 - 4 * slow_drift_phase) :
                                            (4 * slow_drift_phase - 4);
  ) : (
    s_shape_val = slow_drift_prev_target +
                  (slow_drift_curr_target - slow_drift_prev_target) * slow_drift_phase;
  );
  slow_drift_offset = s_shape_val > 0 ? s_shape_val * slow_drift_up : s_shape_val * slow_drift_down;
);

freq = max(freq_base + musical_drift_offset + slow_drift_offset, 0.001);

period   = 1 / max(freq, 0.00001);
on_secs  = (dur_pct / 100.0) * period;
att_secs = (att_pct / 100.0) * period;
rel_secs = (rel_pct / 100.0) * period;

// Smoother coefficient — moved up from the cut_smooth section so
// effect_mix can reuse it for the rest-boundary fade.
smooth = exp(-1 / (srate * 0.003));

// Play/Rest gate state machine. pr_cycle_progress accumulates
// fractional cycles at the LFO rate; when it crosses the
// threshold for the current state, pr_resting flips and the
// counter resets.
pr_enabled ? (
  pr_cycle_progress += freq / srate;
  !pr_resting ? (
    pr_cycle_progress >= play_for_cycles ? (
      pr_resting = 1;
      pr_cycle_progress = 0;
    );
  ) : (
    pr_cycle_progress >= rest_for_cycles ? (
      pr_resting = 0;
      pr_cycle_progress = 0;
    );
  );
);

// in_frozen_rest gates LFO phase advancement (filter sweep LFO and
// pan_phase) so Freeze pauses the modulation during rest. Walk
// leaves it false. Independent of Rest output, so all four
// LFO×output combinations work.
in_frozen_rest = pr_enabled && pr_resting && rest_lfo_mode == 1;

// effect_mix smoothly transitions between 1 (effect fully on) and
// 0 (rest target) at rest boundaries. The rest target depends on
// Rest output: dry_l/r (pass-through) for Pass-through, 0 (full
// silence) for Silence. Below, the play-mode wet/dry mix output
// and the rest target are interpolated by effect_mix to produce
// the final spl0/spl1 — soft fade between effect-on and the rest
// state, regardless of which rest target was chosen.
target_effect_mix = pr_enabled && pr_resting ? 0 : 1;
effect_mix        = effect_mix * smooth + target_effect_mix * (1 - smooth);
silence_mode      = (rest_output_mode == 1);

// Advance filter sweep LFO phases unless Freeze rest is pinning them.
!in_frozen_rest ? (
  phase_l += freq / srate;
  phase_l >= 1 ? phase_l -= 1;

  slider14 == 0 ? (
    phase_r += freq / srate;
    phase_r >= 1 ? phase_r -= 1;
  ) : (
    phase_r = phase_l + phase_offset;
    phase_r >= 1 ? phase_r -= 1;
    phase_r < 0  ? phase_r += 1;
  );
);

lfo_l = calc_lfo(phase_l, on_secs, att_secs, rel_secs, period, att_shape, rel_shape);
lfo_r = calc_lfo(phase_r, on_secs, att_secs, rel_secs, period, att_shape, rel_shape);

fcenter = (freq_lo + freq_hi) * 0.5;
fsize   = (freq_hi - freq_lo) * 0.5 * depth_pct;

target_freq_l = fcenter + (lfo_l * 2 - 1) * fsize;
target_freq_r = fcenter + (lfo_r * 2 - 1) * fsize;

cut_target_l = target_freq_l * 2 / srate;
cut_target_r = target_freq_r * 2 / srate;

cut_smooth_l = cut_smooth_l * smooth + cut_target_l * (1 - smooth);
cut_smooth_r = cut_smooth_r * smooth + cut_target_r * (1 - smooth);

dry_l = spl0;
dry_r = spl1;

fb_l = resonance + resonance / (1 - cut_smooth_l);
n3   = n3  + cut_smooth_l * (spl0 - n3  + fb_l * (n3  - n4));
n4   = n4  + cut_smooth_l * (n3   - n4);
out_l = n4;

fb_r = resonance + resonance / (1 - cut_smooth_r);
rn3  = rn3 + cut_smooth_r * (spl1 - rn3 + fb_r * (rn3 - rn4));
rn4  = rn4 + cut_smooth_r * (rn3  - rn4);
out_r = rn4;

// Compute the play-mode output (normal wet/dry mix), then blend
// with the rest target via effect_mix. Rest target depends on
// Rest mode: dry_l/r (pass-through) for Walk and Freeze, 0 for
// Silence. The cut_smooth and filter state (n3/n4/rn3/rn4) keep
// running through the filter math even during rest, so the filter
// is "warm" and re-engages cleanly when the gate exits rest.
play_spl0 = dry * dry_l + wet * out_l;
play_spl1 = dry * dry_r + wet * out_r;
rest_spl0 = silence_mode ? 0 : dry_l;
rest_spl1 = silence_mode ? 0 : dry_r;
spl0 = effect_mix * play_spl0 + (1 - effect_mix) * rest_spl0;
spl1 = effect_mix * play_spl1 + (1 - effect_mix) * rest_spl1;

// ===== PAN BLOCK SAMPLE LOGIC START =====
pan_enabled ? (
  // Per-cycle pan modes (0-9) advance pan_cycle_index on filter LFO
  // phase wraps. Since the filter LFO advancement above is gated by
  // !in_frozen_rest, cycle_fired never triggers during Freeze rest
  // — pan_cycle_index naturally pauses without needing its own gate.
  cycle_fired  = (phase_l < last_phase_l);
  last_phase_l = phase_l;

  pan_mode <= 9 ? (
    cycle_fired ? (
      pan_mode == 5 || pan_mode == 7 || pan_mode == 9 ? (
        pan_cycle_index += pan_cycle_dir;
        (pan_cycle_index >= pan_cycle_steps - 1 || pan_cycle_index <= 0) ?
          pan_cycle_dir = -pan_cycle_dir;
      ) : (
        pan_cycle_index = (pan_cycle_index + 1) % pan_cycle_steps;
      );
    );
    cur_pan = percycle_pan(pan_cycle_index, pan_cycle_steps);
    pan_l = cur_pan;

  ) : pan_mode == 10 ? (
    // Pan Sweep — gate phase advance for Freeze mode.
    pan_sweep_mode == 0 ? (pan_freq = pan_sweep_val) :
    pan_sweep_mode == 1 ? (pan_freq = 1 / max(pan_sweep_val, 0.001)) :
                          (pan_freq = pan_sweep_val / 60);
    !in_frozen_rest ? (
      pan_phase += pan_freq / srate;
      pan_phase >= 1 ? pan_phase -= 1;
    );
    cur_pan = (pan_phase * 2.0 - 1.0) * pan_spread;
    pan_l = cur_pan;

  ) : pan_mode == 11 ? (
    // Pan Sweep Flipped — gate phase advance for Freeze mode.
    pan_sweep_mode == 0 ? (pan_freq = pan_sweep_val) :
    pan_sweep_mode == 1 ? (pan_freq = 1 / max(pan_sweep_val, 0.001)) :
                          (pan_freq = pan_sweep_val / 60);
    !in_frozen_rest ? (
      pan_phase += pan_freq / srate;
      pan_phase >= 1 ? pan_phase -= 1;
    );
    cur_pan = (1.0 - pan_phase * 2.0) * pan_spread;
    pan_l = cur_pan;

  ) : (
    // Linked Sweep — gate phase advance for Freeze mode.
    !in_frozen_rest ? (
      pan_phase += (freq * pan_sweep_ratio) / srate;
      pan_phase >= 1 ? pan_phase -= 1;
    );
    cur_pan = (pan_phase * 2.0 - 1.0) * pan_spread;
    pan_l = cur_pan;
  );

  // Glide smoothing — runs always; with phases frozen pan_l stays
  // constant so the smoother converges to it.
  pan_glide_coeff = pan_glide_ms > 0 ? exp(-1 / (srate * pan_glide_ms * 0.001)) : 0;
  pan_l_smooth = pan_l_smooth * pan_glide_coeff + pan_l * (1 - pan_glide_coeff);

  // Apply the pan, then blend with the un-panned signal via
  // effect_mix. During rest, effect_mix → 0 means the output is the
  // un-panned (already dry, since wet was scaled to 0 above) signal.
  pan_pos = (pan_l_smooth + 1.0) * 0.5;
  mono = (spl0 + spl1) * 0.5;
  spl0_panned = mono * cos(pan_pos * $pi * 0.5);
  spl1_panned = mono * sin(pan_pos * $pi * 0.5);
  spl0 = spl0 * (1 - effect_mix) + spl0_panned * effect_mix;
  spl1 = spl1 * (1 - effect_mix) + spl1_panned * effect_mix;
);
// ===== PAN BLOCK SAMPLE LOGIC END =====

);  // close start-delay else branch
