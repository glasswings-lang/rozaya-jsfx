desc: Womb Sound Generator v2
// Designed by Rozaya, developed with Claude (Anthropic)
//
// This work is dedicated to the public domain under CC0 1.0 Universal.
// https://creativecommons.org/publicdomain/zero/1.0/

// --- GLOBAL ---
slider1:70<20,200,1>BPM
slider2:0<0,1,1{Normal,Flipped}>Master Stereo Flip

// --- HEARTBEAT ---
slider3:1.0<0.0,1.0,0.01>HB Master Volume
slider4:0<0,1,1{Off,Solo}>Heartbeat Solo
slider5:120<50,400,1>Systole ms (S1->S2 gap)
slider6:1.0<0.0,1.0,0.01>S1 Volume
slider7:0.7<0.0,1.0,0.01>S2 Volume
slider8:0.3<0.0,1.0,0.01>Brightness
slider9:60<10,200,1>S1 Decay ms
slider10:25<5,100,1>S2 Decay ms
slider11:45<20,120,1>S1 Frequency Hz
slider12:120<60,300,1>S2 Frequency Hz
slider13:3.0<-15.0,15.0,0.1>HB Stereo Width ms (neg = heart right)

// --- BREATH ---
slider14:0.8<0.0,1.0,0.01>Breath Volume
slider15:0<0,1,1{Off,Solo}>Breath Solo
slider16:4.0<0.5,20.0,0.1>Inhale Duration sec
slider17:0.3<0.0,5.0,0.1>Top Pause sec
slider18:4.0<0.5,20.0,0.1>Exhale Duration sec
slider19:0.3<0.0,5.0,0.1>Bottom Pause sec
slider20:800<50,2000,1>Inhale Frequency Hz
slider21:600<50,2000,1>Exhale Frequency Hz
slider22:200<20,800,1>Breath High-pass Hz
slider23:0.3<0.0,1.0,0.01>Inhale Fade In
slider24:0.2<0.0,1.0,0.01>Inhale Fade Out
slider25:0.2<0.0,1.0,0.01>Exhale Fade In
slider26:0.3<0.0,1.0,0.01>Exhale Fade Out
slider27:2<1,4,1{Linear,Cosine,Exponential,Natural}>Fade Mode
slider28:0.5<0.0,1.0,0.01>Breath Stereo Width

// --- BLOODFLOW ---
slider29:0.5<0.0,1.0,0.01>Bloodflow Volume
slider30:0<0,1,1{Off,Solo}>Bloodflow Solo
slider31:250<20,2000,1>Bloodflow Filter Hz
slider32:0.3<0,1,0.01>Bloodflow Dicrotic Level
slider33:0.2<0.0,0.95,0.01>Bloodflow Resonance
slider34:0.05<0.005,0.5,0.005>Bloodflow Attack (proportion of cycle)
slider35:0.35<0.05,0.95,0.01>Bloodflow Decay (proportion of cycle)
slider36:0.5<0.0,1.0,0.01>Bloodflow Stereo Width

// (slider37, slider38 were Breath HRV Depth and Random HRV Depth in v1;
// removed in v2 in favor of explicit direct controls — breath drift now
// modulates the Breath cycle scaler directly, which is more controllable
// than the old depth-knob-over-hidden-algorithm shape.)

// --- BREATH POST FILTER ---
slider39:2000<50,4000,1>Breath Post-filter Hz
slider40:1.5<0.5,8.0,0.1>Breath Post-filter Q

// Sit silent for N heartbeats after playback starts, then begin
// normally. Beats are counted at the current Heartbeat BPM (slider1)
// so a delay value of 4 at 60 BPM is 4 seconds; at 120 BPM it's 2.
// Re-arms on every transport stop/start. 0 disables the delay.
slider41:0<0,1000,0.01>Start Delay (beats)

// --- PLAY/REST GATES (per-layer, independent) ---
// Each layer (Heartbeat, Breath, Bloodflow) has its own Play/Rest
// gate so you can run e.g. continuous bloodflow + breathing under
// a heartbeat that pulses in patterns of N beats with M rest. All
// three gates work on the same model used by the standalone plugins
// of each type: play N events, then rest M events' worth of time,
// repeat. 0 in either slider of a layer disables that layer's gate.

slider42:0<0,1000,1>HB: Play for (beats)
slider43:0<0,1000,1>HB: Rest for (beats)

slider44:0<0,1000,1>Breath: Play for (breaths)
slider45:0<0,1000,1>Breath: Rest for (breaths)

slider46:0<0,1000,1>Bloodflow: Play for (heartbeats)
slider47:0<0,1000,1>Bloodflow: Rest for (heartbeats)

// Speed ramp: a single in-plugin slowdown/speedup that scales ALL
// THREE layers together — heartbeat, breath, and bloodflow (which
// is locked to heartbeat and follows automatically). Designed for
// sleep wind-down: 0.5 over 15 minutes takes the whole womb down
// to half tempo gradually. A ~100 ms smoother on BPM kills clicks
// from manual BPM tweaks too. Speed_scale_current is shared by HB
// (multiplies BPM) and breath (multiplies state_pos and rest timer
// advance), so the three layers stay coherent at any speed.
slider48:1.0<0.1,4.0,0.01>Speed ramp target (multiplier)
slider49:0<0,60,0.1>Speed ramp duration (minutes)
slider50:0<0,1,1{Off,On}>Speed ramp engage

// Speed ramp start delay: when Speed Ramp engage flips on, wait this
// long at base rate before the ramp begins. Default 0 = ramp starts
// immediately (preserves v1-era Speed Ramp behavior).
slider51:0<0,60,0.1>Speed ramp start delay (minutes)

// Breaths per minute: optional master rate control for the breath
// cycle. Default 0 = inert (the four duration sliders 16-19 control
// the breath rate directly). Set to nonzero and the four durations
// rescale ONCE to fit the target (60/BPM seconds total cycle),
// preserving their inhale/exhale/pause ratios. Subsequent duration
// edits don't update BPM back — this is a one-way "rescale tool,"
// not a bidirectional sync. Each new BPM value triggers a new rescale,
// so you can sweep the breath cycle longer by sliding BPM down.
// Return BPM to 0 to release the durations back to manual control.
slider52:0<0,30,0.1>Breaths per minute (0=off; rescales durations 16-19)

// Heart drift — slow organic wander of heart rate around its baseline.
// Independent of breath drift below; the two represent two real
// biological rates that drift on their own timescales. Asymmetric
// up/down amplitudes match the bio-feel convention of the suite-wide
// per-plugin drift (real heart rate variability is famously asymmetric
// around its mean). Set both Up by and Down by to 0 to disable.
slider53:0<0,50,0.1>Heart drift: Up by (BPM)
slider54:0<0,50,0.1>Heart drift: Down by (BPM)
slider55:8<1,1000,1>Heart drift: Period (heartbeats)

// Heart with breath — the RSA layer. Heart rate swings PEAK-TO-PEAK
// around baseline, coupled to breath phase. A value of 6 means HR
// climbs ~3 above baseline at top of inhale, descends ~3 below at
// bottom of exhale. The natural top-pause and bottom-pause of the
// breath cycle give the peak and trough their dwell time (operator-
// observed: 1-2 beats of slowing at the bottom before climbing back,
// matching real RSA physiology). Set to 0 to disable.
slider56:0<0,30,0.1>Heart with breath (BPM peak-to-peak)

// Breath drift — slow organic wander of breath rate, independent of
// heart drift. Unit is breaths/min, parallel to Heart drift's BPM.
// Set both Up by and Down by to 0 to disable.
slider57:0<0,15,0.1>Breath drift: Up by (breaths/min)
slider58:0<0,15,0.1>Breath drift: Down by (breaths/min)
slider59:8<1,1000,1>Breath drift: Period (breath cycles)

// Drift shape shared by both heart and breath drift waves. (Heart with
// breath has its own shape — coupled to breath phase — and is not
// affected by this setting.)
slider60:0<0,2,1{Sine,Triangle,Random}>Drift shape

@init
srate_inv = 1.0 / srate;
two_pi = 2.0 * $pi;
israte2 = 2.0 / srate;

// --- HEARTBEAT INIT ---
s1_freq = 45.0; s2_freq = 120.0;
s1_phase_osc_near = 0; s1_phase_osc_far = 0;
s2_phase_osc_near = 0; s2_phase_osc_far = 0;

cycle_len_base = floor(srate * 60.0 / 70.0);
cycle_len = cycle_len_base;
systole_samples = floor(srate * 120.0 * 0.001);
s1_vol = 1.0;
s2_vol = 0.7;
s1_decay = exp(-srate_inv / 0.060);
s2_decay = exp(-srate_inv / 0.025);
s1_attack_rate = exp(-srate_inv / 0.008);
s2_attack_rate = exp(-srate_inv / 0.004);

hb_delay_buf_size = 4096;
memset(0, 0, hb_delay_buf_size);
hb_delay_write = 0;
hb_delay_samples = floor(srate * 0.003);
hb_delay_sign = 1;

hb_phase = 0;
s1_active = 1; s2_active = 0;
s1_env = 1.0; s2_env = 0;
s1_attack_phase = 0; s2_attack_phase = 0;

s1_res_f_near = min(2.0 * sin($pi * 50.0 * srate_inv), 0.98);
s1_res_q_near = 2.8; s1_res_low_near = 0; s1_res_band_near = 0;
s2_res_f_near = min(2.0 * sin($pi * 138.0 * srate_inv), 0.98);
s2_res_q_near = 2.0; s2_res_low_near = 0; s2_res_band_near = 0;
lp_f_near = min(2.0 * sin($pi * 200.0 * srate_inv), 0.98);
lp_low_near = 0; lp_band_near = 0; lp_low2_near = 0; lp_band2_near = 0;

s1_res_f_far = min(2.0 * sin($pi * 58.0 * srate_inv), 0.98);
s1_res_q_far = 2.2; s1_res_low_far = 0; s1_res_band_far = 0;
s2_res_f_far = min(2.0 * sin($pi * 150.0 * srate_inv), 0.98);
s2_res_q_far = 1.6; s2_res_low_far = 0; s2_res_band_far = 0;
lp_f_far = min(2.0 * sin($pi * 175.0 * srate_inv), 0.98);
lp_low_far = 0; lp_band_far = 0; lp_low2_far = 0; lp_band2_far = 0;
lp_q = 0.5;

// --- BREATH INIT ---
breath_state = 0;
breath_state_pos = 0;
breath_state_len = floor(srate * 4.0);

in_lp_l = 0; in_bp_l = 0; in_lp_r = 0; in_bp_r = 0;
ex_lp_l = 0; ex_bp_l = 0; ex_lp_r = 0; ex_bp_r = 0;
hp_lp_l = 0; hp_lp_r = 0;

bpf_low_l = 0; bpf_band_l = 0;
bpf_low_r = 0; bpf_band_r = 0;
bpf_f = min(2.0 * sin($pi * 2000.0 * srate_inv), 0.98);
bpf_q = 0.5;

in_f_l = min(2.0 * sin($pi * 800.0 * srate_inv), 0.98);
in_f_r = min(2.0 * sin($pi * 760.0 * srate_inv), 0.98);
ex_f_l = min(2.0 * sin($pi * 600.0 * srate_inv), 0.98);
ex_f_r = min(2.0 * sin($pi * 560.0 * srate_inv), 0.98);
hp_f   = min(2.0 * sin($pi * 200.0 * srate_inv), 0.98);
breath_lp_q = 0.6;

inhale_len = floor(srate * 4.0);
top_len    = floor(srate * 0.3);
exhale_len = floor(srate * 4.0);
bot_len    = floor(srate * 0.3);

// --- BLOODFLOW INIT ---
bf_n3_l = 0; bf_n4_l = 0;
bf_n3_r = 0; bf_n4_r = 0;
bf_filter_hz      = 250.0;
bf_dicrotic_level = 0.3;
bf_res            = 0.2;
bf_attack         = 0.05;
bf_decay          = 0.35;
bf_stereo_width   = 0.5;

// --- NOISE SEEDS ---
ns1 = 12345; ns2 = 67890; ns3 = 54321;
ns4 = 11111; ns5 = 22222; ns6 = 33333;

function apply_fade(pos, fade_in, fade_out, mode) local(raw, t) (
  raw = 1.0;
  pos < fade_in ? (
    t = pos / fade_in;
    mode == 1 ? raw = t :
    mode == 2 ? raw = 0.5 - 0.5 * cos(t * $pi) :
    mode == 3 ? raw = t * t :
    raw = sin(t * $pi * 0.5);
  ) : pos > (1.0 - fade_out) ? (
    t = (pos - (1.0 - fade_out)) / fade_out;
    mode == 1 ? raw = 1.0 - t :
    mode == 2 ? raw = 0.5 + 0.5 * cos(t * $pi) :
    mode == 3 ? raw = (1.0 - t) * (1.0 - t) :
    raw = cos(t * $pi * 0.5);
  );
  raw;
);

// Start Delay state.
last_play_state     = 0;
start_delay_elapsed = 0;
start_delay_sec     = 0;

// --- Play/Rest state (per-layer, independent) ---
// Heartbeat layer (mirrors standalone Heartbeat plugin's gate):
//   pr_hb_beat counts beats elapsed in the current play (or rest)
//   period. Init to 1 because the @init s1_active=1 pre-fire counts
//   as beat 1 of the first play period. this_hb_has_beat carries
//   "did THIS heartbeat get triggered?" from the s1 site to the
//   s2 site so they stay paired.
pr_hb_resting    = 0;
pr_hb_beat       = 1;
play_for_hb      = 0;
rest_for_hb      = 0;
pr_hb_enabled    = 0;
this_hb_has_beat = 1;
// Breath layer (mirrors standalone Breath plugin's gate):
//   pr_br_breath counts completed breath cycles. pr_br_rest_elapsed
//   counts samples spent in rest; when it reaches the threshold
//   (rest_for_breaths * total_breath_samples), exit rest and force
//   a fresh inhale.
pr_br_resting            = 0;
pr_br_breath             = 0;
pr_br_rest_elapsed       = 0;
pr_br_rest_duration_samples = 0;
play_for_br              = 0;
rest_for_br              = 0;
pr_br_enabled            = 0;
total_breath_samples     = 0;
// Bloodflow layer (continuous LFO locked to heartbeat phase):
//   pr_bf_beat counts heartbeats (uses hb_phase wraps as its tick).
//   Gate fades bf_l/bf_r output to 0 via the bf_output_mix smoother
//   — the bloodflow filter state keeps running so it's "warm" on
//   rest exit and doesn't transient when un-muted.
pr_bf_resting    = 0;
pr_bf_beat       = 0;
play_for_bf      = 0;
rest_for_bf      = 0;
pr_bf_enabled    = 0;
bf_output_mix    = 1;
// One-pole smoother coefficient (3 ms) shared by the bloodflow
// output mix; matches the smoother used in the other plugins.
pr_smooth = exp(-1 / (srate * 0.003));

// Speed ramp + BPM smoother state. Seeded from slider1 so the first
// heartbeat after transport-start uses the saved BPM, not a default.
rate_smoother_coeff      = 1.0 - exp(-1.0 / (srate * 0.1));
bpm_target               = slider1;
bpm_smoothed             = slider1;
speed_ramp_engaged_last  = 0;
speed_scale_current      = 1.0;
speed_scale_start        = 1.0;
speed_ramp_t             = 0.0;
speed_ramp_delay_elapsed = 0;

// Per-plugin Drift state.
//
// Heart drift and breath drift each have their own phase variable
// that advances per sample. Phases wrap at 1.0; Random shape uses
// prev_target -> curr_target linear interp across one drift period.
// Heart-with-breath (RSA) has no phase of its own — it's coupled
// directly to breath_state and breath_state_pos.
heart_drift_phase        = 0;
heart_drift_prev_target  = 0;
heart_drift_curr_target  = 0;
breath_drift_phase       = 0;
breath_drift_prev_target = 0;
breath_drift_curr_target = 0;

// One-way BPM rescale state. We snapshot the last-seen BPM slider
// value so @slider can detect when it changed and trigger a single
// rescale of the four phase duration sliders. Duration changes do
// NOT update BPM back — this is one-way, not bidirectional.
last_bpm = slider52;

@slider
// Heartbeat — bpm_target feeds the per-sample smoother; cycle_len_base
// is recomputed per sample in @sample using the smoothed + speed-ramped
// value, so we don't compute it from slider1 here anymore.
bpm_target = slider1;
systole_samples = floor(srate * slider5 * 0.001);
s1_vol = slider6;
s2_vol = slider7;
s1_freq = slider11; s2_freq = slider12;

s1_center_near = slider11 * 1.1; s2_center_near = slider12 * 1.15;
s1_center_far  = slider11 * 1.28; s2_center_far = slider12 * 1.25;
lp_cutoff_near = 200.0 + slider8 * 250.0;
lp_cutoff_far  = 175.0 + slider8 * 220.0;

s1_res_f_near = min(2.0 * sin($pi * s1_center_near * srate_inv), 0.98);
s2_res_f_near = min(2.0 * sin($pi * s2_center_near * srate_inv), 0.98);
lp_f_near = min(2.0 * sin($pi * lp_cutoff_near * srate_inv), 0.98);
s1_res_f_far = min(2.0 * sin($pi * s1_center_far * srate_inv), 0.98);
s2_res_f_far = min(2.0 * sin($pi * s2_center_far * srate_inv), 0.98);
lp_f_far = min(2.0 * sin($pi * lp_cutoff_far * srate_inv), 0.98);

s1_decay = exp(-srate_inv / (slider9 * 0.001));
s2_decay = exp(-srate_inv / (slider10 * 0.001));

hb_delay_samples = floor(srate * abs(slider13) * 0.001);
hb_delay_samples = min(hb_delay_samples, hb_delay_buf_size - 1);
new_hb_sign = slider13 >= 0 ? 1 : -1;
new_hb_sign != hb_delay_sign ? (
  s1_res_low_near = 0; s1_res_band_near = 0;
  s2_res_low_near = 0; s2_res_band_near = 0;
  lp_low_near = 0; lp_band_near = 0; lp_low2_near = 0; lp_band2_near = 0;
  s1_res_low_far = 0; s1_res_band_far = 0;
  s2_res_low_far = 0; s2_res_band_far = 0;
  lp_low_far = 0; lp_band_far = 0; lp_low2_far = 0; lp_band2_far = 0;
  memset(0, 0, hb_delay_buf_size);
);
hb_delay_sign = new_hb_sign;

// Breath: one-way BPM rescale of the four phase duration sliders.
//
// When slider52 (Breaths per minute) changes AND is nonzero, rescale
// the four durations proportionally to fit the new target total
// (60/BPM seconds), preserving their inhale/exhale/pause ratios.
// When BPM is at 0, nothing happens — the durations control the
// breath rate directly. Duration tweaks NEVER update BPM back.
slider52 != last_bpm && slider52 > 0 ? (
  current_total_sec = slider16 + slider17 + slider18 + slider19;
  current_total_sec > 0.1 ? (
    target_total_sec = 60.0 / slider52;
    rescale_ratio    = target_total_sec / current_total_sec;
    slider16 *= rescale_ratio; slider_automate(slider16);
    slider17 *= rescale_ratio; slider_automate(slider17);
    slider18 *= rescale_ratio; slider_automate(slider18);
    slider19 *= rescale_ratio; slider_automate(slider19);
  );
);
last_bpm = slider52;

inhale_len = max(floor(srate * slider16), 1);
top_len    = max(floor(srate * slider17), 1);
exhale_len = max(floor(srate * slider18), 1);
bot_len    = max(floor(srate * slider19), 1);

breath_state == 0 ? breath_state_len = inhale_len;
breath_state == 1 ? breath_state_len = top_len;
breath_state == 2 ? breath_state_len = exhale_len;
breath_state == 3 ? breath_state_len = bot_len;
breath_state_pos = min(breath_state_pos, breath_state_len - 1);

in_f_l = min(2.0 * sin($pi * (slider20 * (1.0 + slider28 * 0.15)) * srate_inv), 0.98);
in_f_r = min(2.0 * sin($pi * (slider20 * (1.0 - slider28 * 0.15)) * srate_inv), 0.98);
ex_f_l = min(2.0 * sin($pi * (slider21 * (1.0 + slider28 * 0.12)) * srate_inv), 0.98);
ex_f_r = min(2.0 * sin($pi * (slider21 * (1.0 - slider28 * 0.12)) * srate_inv), 0.98);
hp_f   = min(2.0 * sin($pi * slider22 * srate_inv), 0.98);

// Bloodflow
bf_filter_hz      = slider31;
bf_dicrotic_level = slider32;
bf_res            = slider33;
bf_attack         = max(slider34, 0.001);
bf_decay          = max(slider35, 0.001);
bf_stereo_width   = slider36;

// If attack + decay exceed one cycle, normalize so they fit. Defends
// against user-set extreme values and against old projects whose
// Fade In + Fade Out sliders summed >1.0 under the old design.
bf_attack + bf_decay > 1.0 ? (
  bf_attack = slider34 / (slider34 + slider35);
  bf_decay  = slider35 / (slider34 + slider35);
);

// Breath post-filter
bpf_f = min(2.0 * sin($pi * slider39 * srate_inv), 0.98);
bpf_q = 1.0 / slider40;

// Start Delay: convert heartbeats to seconds at the current Heartbeat BPM.
start_delay_sec = slider41 * 60 / max(slider1, 1);

// Play/Rest reads. Each layer's gate engages iff both its sliders > 0.
play_for_hb   = slider42;
rest_for_hb   = slider43;
pr_hb_enabled = (play_for_hb > 0 && rest_for_hb > 0);

play_for_br      = slider44;
rest_for_br      = slider45;
new_pr_br_enabled = (play_for_br > 0 && rest_for_br > 0);
// Total breath cycle duration in samples, used to time Breath's
// freeze-style rest period. Recomputed whenever any phase duration
// changes — affects the IN-PROGRESS rest period too (stretches/
// compresses to match the new total), same as standalone Breath.
total_breath_samples = inhale_len + top_len + exhale_len + bot_len;
// Defensive reset: disabling Breath gate mid-rest snaps the state
// machine back to inhale start so it doesn't stay stuck in state 3.
!new_pr_br_enabled && pr_br_resting ? (
  pr_br_resting    = 0;
  breath_state     = 0;
  breath_state_len = inhale_len;
  breath_state_pos = 0;
);
pr_br_enabled = new_pr_br_enabled;

play_for_bf   = slider46;
rest_for_bf   = slider47;
pr_bf_enabled = (play_for_bf > 0 && rest_for_bf > 0);

// Speed ramp engage-edge. Reset BOTH the ramp progress and the
// start-delay counter so flipping engage Off then On restarts cleanly.
slider50 && !speed_ramp_engaged_last ? (
  speed_scale_start        = speed_scale_current;
  speed_ramp_t             = 0.0;
  speed_ramp_delay_elapsed = 0;
);
speed_ramp_engaged_last = slider50;

// Drift sliders read directly per sample in @sample (no @slider
// indirection needed — they're plain reads).

@sample

// Smooth BPM toward bpm_target, advance the speed ramp, then run
// per-plugin Drift. combined_scale (Speed Ramp) applies to all three
// layers (HB BPM, breath state_pos, breath rest timer) so the whole
// womb stays coherent. Drift offsets add on top of bpm_smoothed in
// the plugin's natural unit (BPM here).
bpm_smoothed += (bpm_target - bpm_smoothed) * rate_smoother_coeff;
slider50 && slider49 > 0 ? (
  // Honor the start delay first: tick the delay counter until it
  // elapses, then begin the actual ramp. During the delay window
  // speed_scale_current stays at speed_scale_start, so combined_scale
  // is whatever it was when engage flipped on.
  speed_ramp_delay_samples = slider51 * 60 * srate;
  speed_ramp_delay_elapsed < speed_ramp_delay_samples ? (
    speed_ramp_delay_elapsed += 1;
  ) : (
    speed_ramp_t += 1.0 / (srate * slider49 * 60);
    speed_ramp_t = min(speed_ramp_t, 1.0);
    speed_scale_current = speed_scale_start + (slider48 - speed_scale_start) * speed_ramp_t;
  );
);
combined_scale = speed_scale_current;

// --- Per-plugin Drift ---
// Read drift parameters directly from sliders. Each Up/Down value is
// a peak amplitude in BPM (heart) or breaths/min (breath) — the
// relevant rate can swing up to that much above/below baseline.
heart_drift_up_bpm     = slider53;
heart_drift_down_bpm   = slider54;
heart_drift_period     = slider55;
heart_with_breath_bpm  = slider56;
breath_drift_up_bpm    = slider57;
breath_drift_down_bpm  = slider58;
breath_drift_period    = slider59;
drift_shape            = slider60;

// Helper: advance a phase variable by `inc` per sample, wrap at 1.0,
// re-roll Random target on wrap, and return shape_val in [-1, +1].
// (Inlined per source below — JSFX has no functions, so this is the
// repeated pattern.)

// Heart drift wave. Period in heartbeats: one drift cycle takes
// heart_drift_period heartbeats. Advance scales with combined_scale
// so it tracks Speed Ramp.
heart_drift_offset = 0;
(heart_drift_up_bpm > 0 || heart_drift_down_bpm > 0) ? (
  heart_period_samples = max(heart_drift_period * cycle_len_base, 1);
  heart_drift_phase += combined_scale / heart_period_samples;
  heart_drift_phase >= 1.0 ? (
    heart_drift_phase -= 1.0;
    drift_shape == 2 ? (
      heart_drift_prev_target = heart_drift_curr_target;
      heart_drift_curr_target = rand(2) - 1;
    );
  );
  drift_shape == 0 ? (
    heart_shape_val = sin(2 * $pi * heart_drift_phase);
  ) : drift_shape == 1 ? (
    heart_shape_val = heart_drift_phase < 0.25 ? (4 * heart_drift_phase) :
                      heart_drift_phase < 0.75 ? (2 - 4 * heart_drift_phase) :
                                                 (4 * heart_drift_phase - 4);
  ) : (
    heart_shape_val = heart_drift_prev_target +
      (heart_drift_curr_target - heart_drift_prev_target) * heart_drift_phase;
  );
  heart_drift_offset = heart_shape_val > 0 ? heart_shape_val * heart_drift_up_bpm
                                           : heart_shape_val * heart_drift_down_bpm;
);

// Heart-with-breath modulation (RSA, peak-to-peak in BPM).
//
// Bidirectional, centered on baseline. Setting slider56 to 6 means
// HR swings between -3 (trough at bottom pause) and +3 (peak at top
// pause) around bpm_smoothed. Real RSA physiology: HR rises during
// inhale, peaks at top, descends past baseline to the trough during
// exhale, holds at trough during bottom pause for 1-2 beats before
// the next inhale climbs again.
//
// Half-amplitude = peak-to-peak / 2 = the swing above and below.
// During inhale (state 0): linear ramp from -half (trough) to +half (peak).
// At top pause   (state 1): hold at +half (peak).
// During exhale (state 2): linear ramp from +half (peak) to -half (trough).
// At bottom pause (state 3): hold at -half (trough).
heart_with_breath_offset = 0;
heart_with_breath_bpm > 0 ? (
  rsa_half = heart_with_breath_bpm * 0.5;
  breath_phase_pos_for_rsa = breath_state_pos / max(breath_state_len - 1, 1);
  breath_state == 0 ? heart_with_breath_offset = (breath_phase_pos_for_rsa - 0.5) * heart_with_breath_bpm :
  breath_state == 1 ? heart_with_breath_offset = rsa_half :
  breath_state == 2 ? heart_with_breath_offset = (0.5 - breath_phase_pos_for_rsa) * heart_with_breath_bpm :
                      heart_with_breath_offset = -rsa_half;
);

// Breath drift wave. Period in breath cycles: one drift cycle takes
// breath_drift_period breath cycles. Advance scales with combined_scale
// so it tracks Speed Ramp.
breath_drift_offset_bpm = 0;
(breath_drift_up_bpm > 0 || breath_drift_down_bpm > 0) ? (
  // total_breath_samples is one full breath cycle at the user's
  // current durations; period_samples = period_cycles * one_cycle.
  breath_period_samples = max(breath_drift_period * max(total_breath_samples, 1), 1);
  breath_drift_phase += combined_scale / breath_period_samples;
  breath_drift_phase >= 1.0 ? (
    breath_drift_phase -= 1.0;
    drift_shape == 2 ? (
      breath_drift_prev_target = breath_drift_curr_target;
      breath_drift_curr_target = rand(2) - 1;
    );
  );
  drift_shape == 0 ? (
    breath_shape_val = sin(2 * $pi * breath_drift_phase);
  ) : drift_shape == 1 ? (
    breath_shape_val = breath_drift_phase < 0.25 ? (4 * breath_drift_phase) :
                       breath_drift_phase < 0.75 ? (2 - 4 * breath_drift_phase) :
                                                   (4 * breath_drift_phase - 4);
  ) : (
    breath_shape_val = breath_drift_prev_target +
      (breath_drift_curr_target - breath_drift_prev_target) * breath_drift_phase;
  );
  breath_drift_offset_bpm = breath_shape_val > 0 ? breath_shape_val * breath_drift_up_bpm
                                                 : breath_shape_val * breath_drift_down_bpm;
);

// Apply heart-side modulation: heart drift + heart-with-breath.
effective_bpm  = max(bpm_smoothed * combined_scale + heart_drift_offset + heart_with_breath_offset, 20.0);
cycle_len_base = floor(srate * 60.0 / effective_bpm);

// Apply breath-side drift: baseline breaths/min plus the per-sample
// breath drift offset gives the effective breath rate. Baseline is
// slider52 when nonzero (operator set the rate explicitly), else
// implied from the four phase durations (their summed seconds give
// a natural BPM). Convert effective/baseline to a per-sample state-
// advance multiplier so the breath state machine cycles at the
// drifted rate without recomputing per-phase lengths each sample.
baseline_breath_bpm   = slider52 > 0 ? slider52
                                     : 60.0 / max(slider16 + slider17 + slider18 + slider19, 0.1);
effective_breath_bpm  = max(baseline_breath_bpm + breath_drift_offset_bpm, 0.1);
breath_combined_scale = combined_scale * (effective_breath_bpm / max(baseline_breath_bpm, 0.1));

// Re-arm Start Delay on every transport stop/start, then gate the
// whole @sample work — all internal state (heartbeat phase, breath
// state, post-filter buffers) stays frozen during the silent window
// so the womb soundscape begins cleanly when the delay elapses.
play_state > 0 && last_play_state == 0 ? (
  start_delay_elapsed = 0;
);
last_play_state = play_state;

start_delay_elapsed < start_delay_sec ? (
  start_delay_elapsed += 1 / srate;
  spl0 = 0;
  spl1 = 0;
) : (

// --- NOISE ---
ns1 = (ns1 * 1664525 + 1013904223) & 0xFFFFFFFF;
n1 = (ns1 - 0x80000000) * (1.0 / 2147483648.0);
ns2 = (ns2 * 22695477 + 1) & 0xFFFFFFFF;
n2 = (ns2 - 0x80000000) * (1.0 / 2147483648.0);
ns3 = (ns3 * 1664525 + 1013904223) & 0xFFFFFFFF;
n3 = (ns3 - 0x80000000) * (1.0 / 2147483648.0);
ns4 = (ns4 * 22695477 + 1) & 0xFFFFFFFF;
n4 = (ns4 - 0x80000000) * (1.0 / 2147483648.0);
ns5 = (ns5 * 1664525 + 1013904223) & 0xFFFFFFFF;
n5 = (ns5 - 0x80000000) * (1.0 / 2147483648.0);
ns6 = (ns6 * 22695477 + 1) & 0xFFFFFFFF;
n6 = (ns6 - 0x80000000) * (1.0 / 2147483648.0);

// --- HEARTBEAT CYCLE LENGTH ---
// In v1 this was modulated by breath-coupled HRV and a random jitter
// (the "Breath HRV Depth" / "Random HRV Depth" sliders). v2 drops both
// in favor of direct controllable variation via per-plugin Drift on
// the BPM slider — the operator dials in exactly the wobble they want
// rather than handing depth knobs to a hidden algorithm.
cycle_len = max(cycle_len_base, floor(srate * 60.0 / 200.0));

// --- HEARTBEAT ---
hb_phase += 1;
hb_phase >= cycle_len ? (
  hb_phase = 0;
  // Per-beat Play/Rest gate (independent of Breath and Bloodflow).
  // Advance pr_hb_beat at each phase wrap; on threshold, flip
  // pr_hb_resting and reset. Then trigger s1 only when not resting.
  // The bloodflow gate below uses the SAME phase wrap as its tick,
  // so pr_bf_beat also advances here.
  pr_hb_enabled ? (
    pr_hb_beat >= (pr_hb_resting ? rest_for_hb : play_for_hb) ? (
      pr_hb_resting = 1 - pr_hb_resting;
      pr_hb_beat = 0;
    );
    pr_hb_beat += 1;
  );
  pr_bf_enabled ? (
    pr_bf_beat >= (pr_bf_resting ? rest_for_bf : play_for_bf) ? (
      pr_bf_resting = 1 - pr_bf_resting;
      pr_bf_beat = 0;
    );
    pr_bf_beat += 1;
  );
  // Beat fires only if HB gate isn't gating this beat out. Carry
  // the same decision to the s2 site below so S1 and S2 of a given
  // beat always stay paired.
  this_hb_has_beat = !pr_hb_enabled || !pr_hb_resting;
  this_hb_has_beat ? (
    s1_active = 1; s1_env = 0.0; s1_attack_phase = 1;
  );
);
hb_phase == systole_samples && this_hb_has_beat ? (
  s2_active = 1; s2_env = 0.0; s2_attack_phase = 1;
);

s1_active ? (
  s1_attack_phase ? (
    s1_env += (1.0 - s1_env) * (1.0 - s1_attack_rate);
    s1_env >= 0.98 ? s1_attack_phase = 0;
  ) : (
    s1_env *= s1_decay;
    s1_env < 0.0001 ? s1_active = 0;
  );
) : 0;

s2_active ? (
  s2_attack_phase ? (
    s2_env += (1.0 - s2_env) * (1.0 - s2_attack_rate);
    s2_env >= 0.98 ? s2_attack_phase = 0;
  ) : (
    s2_env *= s2_decay;
    s2_env < 0.0001 ? s2_active = 0;
  );
) : 0;

s1_phase_osc_near += two_pi * s1_freq * srate_inv;
s1_phase_osc_near > two_pi ? s1_phase_osc_near -= two_pi;
s2_phase_osc_near += two_pi * s2_freq * srate_inv;
s2_phase_osc_near > two_pi ? s2_phase_osc_near -= two_pi;
s1_phase_osc_far += two_pi * (s1_freq * 1.003) * srate_inv;
s1_phase_osc_far > two_pi ? s1_phase_osc_far -= two_pi;
s2_phase_osc_far += two_pi * (s2_freq * 0.997) * srate_inv;
s2_phase_osc_far > two_pi ? s2_phase_osc_far -= two_pi;

s1_active ? (
  s1_res_low_near += s1_res_f_near * s1_res_band_near;
  s1_res_high_near = (sin(s1_phase_osc_near)*0.8 + n1*0.2) - s1_res_low_near - s1_res_q_near * s1_res_band_near;
  s1_res_band_near += s1_res_f_near * s1_res_high_near;
  s1_out_near = s1_res_band_near * s1_env * s1_env * 2.0 * s1_vol;
) : s1_out_near = 0;
s2_active ? (
  s2_res_low_near += s2_res_f_near * s2_res_band_near;
  s2_res_high_near = (sin(s2_phase_osc_near)*0.5 + n1*0.5) - s2_res_low_near - s2_res_q_near * s2_res_band_near;
  s2_res_band_near += s2_res_f_near * s2_res_high_near;
  s2_out_near = s2_res_band_near * s2_env * s2_env * s2_vol;
) : s2_out_near = 0;

raw_near = s1_out_near + s2_out_near;
lp_low_near += lp_f_near * lp_band_near;
lp_high_near = raw_near - lp_low_near - lp_q * lp_band_near;
lp_band_near += lp_f_near * lp_high_near;
lp_low2_near += lp_f_near * lp_band2_near;
lp_high2_near = lp_low_near - lp_low2_near - lp_q * lp_band2_near;
lp_band2_near += lp_f_near * lp_high2_near;
heart_near = lp_low2_near * 1.5;

s1_active ? (
  s1_res_low_far += s1_res_f_far * s1_res_band_far;
  s1_res_high_far = (sin(s1_phase_osc_far)*0.8 + n2*0.2) - s1_res_low_far - s1_res_q_far * s1_res_band_far;
  s1_res_band_far += s1_res_f_far * s1_res_high_far;
  s1_out_far = s1_res_band_far * s1_env * s1_env * 2.0 * s1_vol;
) : s1_out_far = 0;
s2_active ? (
  s2_res_low_far += s2_res_f_far * s2_res_band_far;
  s2_res_high_far = (sin(s2_phase_osc_far)*0.5 + n2*0.5) - s2_res_low_far - s2_res_q_far * s2_res_band_far;
  s2_res_band_far += s2_res_f_far * s2_res_high_far;
  s2_out_far = s2_res_band_far * s2_env * s2_env * s2_vol;
) : s2_out_far = 0;

raw_far = s1_out_far + s2_out_far;
lp_low_far += lp_f_far * lp_band_far;
lp_high_far = raw_far - lp_low_far - lp_q * lp_band_far;
lp_band_far += lp_f_far * lp_high_far;
lp_low2_far += lp_f_far * lp_band2_far;
lp_high2_far = lp_low_far - lp_low2_far - lp_q * lp_band2_far;
lp_band2_far += lp_f_far * lp_high2_far;
heart_far_now = lp_low2_far * 1.5;

hb_dw = hb_delay_write & (hb_delay_buf_size - 1);
hb_dr = (hb_delay_write - hb_delay_samples) & (hb_delay_buf_size - 1);
hb_dw[0] = heart_far_now;
heart_far = hb_dr[0];
hb_delay_write = (hb_delay_write + 1) & (hb_delay_buf_size - 1);

hb_delay_sign == 1 ? (
  hb_l = heart_near; hb_r = heart_far;
) : (
  hb_l = heart_far; hb_r = heart_near;
);
hb_l *= slider3; hb_r *= slider3;

// --- BREATH ---
// State advance. The 3→0 transition (end of bottom pause, start of
// new breath cycle) is special-cased so the Breath Play/Rest gate
// can decide whether to actually start a new breath or stay silent
// in state 3 for the rest period. Mirrors the standalone Breath
// plugin's gate exactly. state_pos advances by breath_combined_scale
// per sample — that variable bakes in Speed Ramp and breath drift
// (linked or independent), computed earlier this @sample.
breath_state_pos += breath_combined_scale;
breath_state_pos >= breath_state_len ? (
  breath_state_pos = 0;
  breath_state == 3 ? (
    // End of bottom pause — would normally start a new breath.
    pr_br_enabled && !pr_br_resting ? (
      pr_br_breath += 1;
      pr_br_breath >= play_for_br ? (
        pr_br_resting = 1;
        pr_br_breath = 0;
        pr_br_rest_elapsed = 0;
      );
    );
    // Start a new breath only if not resting. If resting, stay in
    // state 3 (already silent); the rest timer below will exit
    // rest and force a fresh inhale when time elapses.
    !pr_br_resting ? (
      breath_state     = 0;
      breath_state_len = inhale_len;
    );
  ) : (
    breath_state = (breath_state + 1) % 4;
    breath_state == 1 ? breath_state_len = top_len;
    breath_state == 2 ? breath_state_len = exhale_len;
    breath_state == 3 ? breath_state_len = bot_len;
  );
);

// Breath rest timer (Freeze-style: state machine pauses on bottom
// pause, sample counter measures the rest duration).
pr_br_resting ? (
  pr_br_rest_duration_samples = rest_for_br * total_breath_samples;
  // Scale rest accumulation by combined_scale so breath rest stretches
  // in lockstep with the rest of the breath cycle (Speed Ramp).
  pr_br_rest_elapsed += breath_combined_scale;
  pr_br_rest_elapsed >= pr_br_rest_duration_samples ? (
    pr_br_resting    = 0;
    pr_br_breath     = 0;
    breath_state     = 0;
    breath_state_len = inhale_len;
    breath_state_pos = 0;
  );
);

breath_phase_pos = breath_state_pos / max(breath_state_len - 1, 1);

(breath_state == 1 || breath_state == 3) ? (
  br_l = 0; br_r = 0;
) : (
  breath_state == 0 ? (
    br_env = apply_fade(breath_phase_pos, slider23, slider24, slider27);
    hp_lp_l += hp_f * (n3 - hp_lp_l);
    br_hp_l = n3 - hp_lp_l;
    in_lp_l += in_f_l * in_bp_l;
    in_hp2_l = br_hp_l - in_lp_l - breath_lp_q * in_bp_l;
    in_bp_l += in_f_l * in_hp2_l;
    hp_lp_r += hp_f * (n4 - hp_lp_r);
    br_hp_r = n4 - hp_lp_r;
    in_lp_r += in_f_r * in_bp_r;
    in_hp2_r = br_hp_r - in_lp_r - breath_lp_q * in_bp_r;
    in_bp_r += in_f_r * in_hp2_r;
    br_l = in_bp_l * br_env * 1.5;
    br_r = in_bp_r * br_env * 1.5;
  ) : (
    br_env = apply_fade(breath_phase_pos, slider25, slider26, slider27);
    hp_lp_l += hp_f * (n3 - hp_lp_l);
    br_hp_l = n3 - hp_lp_l;
    ex_lp_l += ex_f_l * ex_bp_l;
    ex_hp2_l = br_hp_l - ex_lp_l - breath_lp_q * ex_bp_l;
    ex_bp_l += ex_f_l * ex_hp2_l;
    hp_lp_r += hp_f * (n4 - hp_lp_r);
    br_hp_r = n4 - hp_lp_r;
    ex_lp_r += ex_f_r * ex_bp_r;
    ex_hp2_r = br_hp_r - ex_lp_r - breath_lp_q * ex_bp_r;
    ex_bp_r += ex_f_r * ex_hp2_r;
    br_l = ex_bp_l * br_env * 1.5;
    br_r = ex_bp_r * br_env * 1.5;
  );
);
br_l *= slider14; br_r *= slider14;

// Breath post-filter
bpf_low_l += bpf_f * bpf_band_l;
bpf_high_l = br_l - bpf_low_l - bpf_q * bpf_band_l;
bpf_band_l += bpf_f * bpf_high_l;
br_l = bpf_low_l;

bpf_low_r += bpf_f * bpf_band_r;
bpf_high_r = br_r - bpf_low_r - bpf_q * bpf_band_r;
bpf_band_r += bpf_f * bpf_high_r;
br_r = bpf_low_r;

// --- BLOODFLOW ---
// Cardiac pressure envelope locked to heartbeat phase.
//
// Real arterial blood-sound is amplitude-modulated noise — sharp
// upstroke at systole, exponential decay through diastole, with a
// small secondary bump (the dicrotic notch, from aortic-valve
// closure reflecting back into the arterial tree), then quiet until
// the next beat. NOT a frequency sweep, which was the v1 mistake;
// that sounded like a wah pedal triggered by a heart, not like a
// pulse. The filter Hz is FIXED now and what shapes the per-beat
// pulse is amplitude.
bf_cycle_pos = hb_phase / max(cycle_len, 1);

// Main pulse: cosine upstroke during systole, exponential decay
// during diastole. bf_attack + bf_decay <= 1.0 (clamped in @slider).
bf_cycle_pos < bf_attack ? (
  bf_t = bf_cycle_pos / bf_attack;
  bf_env_main = 0.5 - 0.5 * cos(bf_t * $pi);
) : bf_cycle_pos < (bf_attack + bf_decay) ? (
  bf_t = (bf_cycle_pos - bf_attack) / bf_decay;
  bf_env_main = exp(-bf_t * 3.5);
) : (
  bf_env_main = 0;
);

// Dicrotic bump: small secondary pulse ~70% of the way through the
// decay phase. Anatomically this is the reflection from aortic-valve
// closure; perceptually it's what gives the pulse its "thump-tick"
// character rather than a plain decaying noise burst.
bf_dicrotic_center     = bf_attack + bf_decay * 0.7;
bf_dicrotic_half_width = bf_decay * 0.12;
bf_dicrotic_distance   = abs(bf_cycle_pos - bf_dicrotic_center);
bf_dicrotic_distance < bf_dicrotic_half_width ? (
  bf_dt = bf_dicrotic_distance / bf_dicrotic_half_width;
  bf_env_dicrotic = bf_dicrotic_level * (0.5 + 0.5 * cos(bf_dt * $pi));
) : (
  bf_env_dicrotic = 0;
);

bf_env = bf_env_main + bf_env_dicrotic;

// Fixed-frequency filter. Stereo Width gives a small L/R cutoff
// offset so the two channels are decorrelated, matching the old
// design's spatial behavior.
bf_cut   = bf_filter_hz * israte2;
bf_cut_l = (bf_cut * (1.0 + bf_stereo_width * 0.08));
bf_cut_r = (bf_cut * (1.0 - bf_stereo_width * 0.08));

// Cockos resonant lowpass on white noise. With moderate Resonance
// the filter peaks near cutoff, giving bandpass-like character.
bf_fb_l = bf_res + bf_res / (1.0 - bf_cut_l);
bf_n3_l = bf_n3_l + bf_cut_l * (n5 - bf_n3_l + bf_fb_l * (bf_n3_l - bf_n4_l));
bf_n4_l = bf_n4_l + bf_cut_l * (bf_n3_l - bf_n4_l);

bf_fb_r = bf_res + bf_res / (1.0 - bf_cut_r);
bf_n3_r = bf_n3_r + bf_cut_r * (n6 - bf_n3_r + bf_fb_r * (bf_n3_r - bf_n4_r));
bf_n4_r = bf_n4_r + bf_cut_r * (bf_n3_r - bf_n4_r);

// Amplitude modulation: filtered noise shaped by the pressure
// envelope. Gain factor is 8 here (bumped from the old 4) because
// envelope-modulated output has lower RMS than the old continuous-
// filter design — without the bump the same Volume slider value
// produced a perceptually quieter result.
bf_l = bf_n4_l * bf_env * slider29 * 8.0;
bf_r = bf_n4_r * bf_env * slider29 * 8.0;

// Bloodflow Play/Rest gate. Counter (pr_bf_beat) advances on each
// hb_phase wrap above; the gate state is set there too. Here we
// just fade the output to 0 via bf_output_mix during rest so the
// transition is click-free. The bloodflow filter state and LFO
// keep running so the filter is "warm" and re-engages cleanly on
// rest exit.
target_bf_mix = pr_bf_enabled && pr_bf_resting ? 0 : 1;
bf_output_mix = bf_output_mix * pr_smooth + target_bf_mix * (1 - pr_smooth);
bf_l *= bf_output_mix;
bf_r *= bf_output_mix;

// --- SOLO LOGIC ---
any_solo = (slider4 > 0) || (slider15 > 0) || (slider30 > 0);
any_solo ? (
  hb_l = slider4  > 0 ? hb_l : 0;
  hb_r = slider4  > 0 ? hb_r : 0;
  br_l = slider15 > 0 ? br_l : 0;
  br_r = slider15 > 0 ? br_r : 0;
  bf_l = slider30 > 0 ? bf_l : 0;
  bf_r = slider30 > 0 ? bf_r : 0;
) : 0;

out_l = hb_l + br_l + bf_l;
out_r = hb_r + br_r + bf_r;

slider2 == 0 ? (
  spl0 = out_l; spl1 = out_r;
) : (
  spl0 = out_r; spl1 = out_l;
);

);  // close start-delay else branch
