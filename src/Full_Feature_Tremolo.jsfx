desc: Tremolo with Shaped Envelope, Stereo Phase, and Pan Modulation
// Designed by Rozaya, developed with Claude (Anthropic)
//
// This work is dedicated to the public domain under CC0 1.0 Universal.
// https://creativecommons.org/publicdomain/zero/1.0/

slider1:2<0.001,1000,0.001>Rate Value
slider2:0<0,2,1{Hz,Seconds,BPM}>Rate Mode
slider3:50<0,100,0.1>On Duration % of Cycle
slider4:-6<-60,0,0.1>Depth dB
slider5:0<0,100,0.1>Attack %
slider6:0<0,100,0.1>Release %
slider7:1<0,3,1{Linear,Cosine,Logarithmic,Exponential}>Attack Shape
slider8:1<0,3,1{Linear,Cosine,Logarithmic,Exponential}>Release Shape
slider9:0<-180,180,0.1>Stereo Phase Offset degrees
slider10:0<0,1,1{Independent L+R,Offset from L}>Phase Mode
// ===== PAN BLOCK SLIDERS START =====
slider11:0<0,1,1{Off,On}>Pan Enabled
slider12:0<0,11,1{Mono,Alternating,Distributed,Distributed (Flipped),Distributed (Ping-pong),Converging,Converging (Ping-pong),Diverging,Diverging (Ping-pong),Pan Sweep,Pan Sweep (Flipped),Linked Sweep}>Pan Mode
slider13:1<0,1,0.01>Pan Spread (0=mono, 1=full)
slider14:5<0,100,0.1>Pan Glide ms (0=instant)
slider15:8<2,32,1>Cycle Steps (per-cycle modes)
slider16:2<0.001,1000,0.001>Pan Sweep Rate
slider17:0<0,2,1{Hz,Seconds,BPM}>Pan Sweep Rate Unit
slider18:1<0.125,8,0.125>Filter Speed Multiplier (Linked Sweep)
// ===== PAN BLOCK SLIDERS END =====

// Pass-through for N units after playback starts, then apply the
// tremolo + pan effect normally. Units match Rate Mode (BPM beats /
// Seconds / Hz cycles), interpreted against Rate Value. As an EFFECT
// plugin (not a generator) the dry signal passes through during the
// delay rather than being silenced — silence-during-delay would mute
// the dry track too, which is rarely what you want. Re-arms on every
// transport stop/start. 0 disables the delay.
slider19:0<0,1000,0.001>Start Delay

// Per-cycle Play/Rest gate. Effect is applied normally for N cycles
// of the Rate Value, then bypassed (dry signal passes through
// unchanged) for M cycles, then resumes — repeats forever. Cycle
// unit matches Start Delay (Rate Mode units against Rate Value).
// As with Start Delay, "rest" here means dry pass-through, NOT
// silence — silencing the input would mute the upstream track.
// The transition between effect-on and dry uses a ~3 ms fade so
// the gate is click-free. 0 in either slider disables the gate.
// Resets on every transport stop/start.
slider20:0<0,1000,1>Play for (cycles)
slider21:0<0,1000,1>Rest for (cycles)

// What the LFOs do during the rest period.
//   Walk through (default) — tremolo + pan LFOs keep cycling
//     during rest. When the effect resumes, the LFOs are at new
//     phase positions reflecting wall-clock time passed. The
//     rhythmic cycle keeps running silently.
//   Freeze in place — LFO phases pause, frozen at their values at
//     rest entry. When the effect resumes, the LFOs pick up from
//     the same phase. The rhythmic cycle pauses and resumes in
//     lockstep with the gate.
slider22:0<0,1,1{Walk through,Freeze in place}>LFO at rest

// What the output does during the rest period.
//   Pass-through (default) — dry signal passes through unchanged.
//     Effect plugins normally don't silence their input (silencing
//     would mute the upstream track in the FX chain), so this
//     matches Start Delay's pass-through-during-delay behavior.
//   Silence — gain target smooths to 0; the audio drops out during
//     rest instead of passing dry. Useful when you want the gate
//     to act like a hard mute rather than an effect bypass — e.g.,
//     for rhythmic drop-outs in an arrangement. Combines cleanly
//     with either Rest LFO setting.
slider23:0<0,1,1{Pass-through,Silence}>Output at rest

// Speed ramp: in-plugin slowdown/speedup over time. The effective
// Speed ramp: signed-delta on Rate Value, expressed in the rate's
// current unit (BPM if Rate Mode = BPM, seconds if Seconds, Hz if
// Hz). Effective rate = slider1 + ramp_t * slider24; converted to
// Hz the same way the base rate is.
//
// In BPM/Hz modes negative slider24 = slower. In Seconds mode
// (period) positive slider24 = slower (longer period).
//
// Engage is a freeze/resume gate (NOT a restart edge); only
// transport play resets ramp_t. A ~100 ms smoother sits between
// the Rate slider and freq so manual Rate tweaks don't click.
//
// Migration from v2.7: slider24 changed from multiplier (0.1-4.0)
// to signed delta. Old projects' multiplier value interprets as a
// tiny delta — Speed Ramp effectively "off" until reconfigured.
slider24:0<-1000,1000,0.001>Speed ramp by (in rate's current unit)
slider25:0<0,60,0.1>Speed ramp duration (minutes)
slider26:0<0,1,1{Off,On}>Speed ramp engage
slider27:0<0,60,0.1>Speed ramp start delay (minutes)

// Per-target drift: nested-selector pattern matching Womb v3 / the
// rest of the v2.9 sweep. Pick a target (slider28), then sliders 29-32
// hold THAT target's drift config. Switching the selector saves
// current values to the old target's memory slot and loads the new
// target's values into the sliders. All 6 targets drift in parallel;
// the selector just chooses which one you're currently editing.
//
// Targets:
//   Rate Value      — wanders the tremolo rate (the old drift target).
//   Depth dB        — wanders the modulation depth.
//   Pan Sweep Rate  — wanders the Pan Sweep Rate (pan modes 9/10 only).
//   On Duration %   — wanders the on-portion of each cycle.
//   Attack %        — wanders the attack ramp length.
//   Release %       — wanders the release ramp length.
//
// Period unit is tremolo cycles for ALL targets, scaled by Speed Ramp
// (so the wave-per-cycle relationship stays constant under wind-down).
// For slow wall-clock-feel drift, set a long period.
//
// Up/Down amount is in the target's natural unit: the rate's current
// unit (BPM / Seconds / Hz) for Rate Value, dB for Depth, the Pan
// Sweep Rate's unit for Pan Sweep Rate, percent for the three %
// targets. The 0-100 range covers all of them; rate/pan-rate targets
// in Hz mode use the low end.
//
// Migration from v2.8: the old flat drift block (musical_up/down/
// period, slow_up/down/period, drift_shape on sliders 28-34) was 7
// sliders covering Rate Value only. v2.9 is 5 sliders covering 6
// independent targets, reusing slider IDs 28-32; sliders 33 and 34
// are no longer declared. Old projects' slider values get reinterpreted
// (selector defaults to Rate Value; non-zero amounts on 29-30 produce
// drift on Rate Value). Reset drift sliders to defaults after upgrade
// and reconfigure.
slider28:0<0,5,1{Rate Value,Depth dB,Pan Sweep Rate,On Duration %,Attack %,Release %}>Drift target
slider29:0<0,100,0.01>Drift up amount (units match target)
slider30:0<0,100,0.01>Drift down amount (units match target)
slider31:8<1,1000,1>Drift period (cycles)
slider32:0<0,2,1{Sine,Triangle,Random}>Drift shape

@init
// v2.10 render-state fix (Path A — see docs/v2.9-render-state-bug.md).
// NO ext_noinit: REAPER re-runs @init on every transport play / render
// start, resetting all runtime for free (LFO phases/gains, pan state,
// rate smoother re-seeded from the slider, drift runtime, Speed Ramp,
// Start Delay, Play/Rest + effect mix). Only the drift CONFIG bank must
// survive the re-run; it's guarded by drift_cfg_inited below.

phase_l = 0;
phase_r = 0;
gain_l  = 1;
gain_r  = 1;

// ===== PAN BLOCK INIT START =====
pan_l           = 0;
pan_l_smooth    = 0;
pan_cycle_index = 0;
pan_cycle_dir   = 1;
last_phase_l    = 0;
pan_phase       = 0;
// ===== PAN BLOCK INIT END =====


function apply_curve(t, shape) (
  shape == 0 ? t :
  shape == 1 ? (0.5 - 0.5 * cos(t * $pi)) :
  shape == 2 ? (log(1 + 9*t) / log(10)) :
               ((10^t - 1) / 9)
);

function calc_lfo(ph, on_secs, att_secs, rel_secs, period, att_shape, rel_shape)
local(on_frac, aw, rw, hold_w, re_start, t, result, total) (
  on_secs = min(on_secs, period);
  on_frac = on_secs / period;

  aw = att_secs / period;
  rw = rel_secs / period;

  // Scale attack+release down if they exceed on-time
  aw + rw > on_frac ? (
    total = aw + rw;
    aw = aw / total * on_frac;
    rw = rw / total * on_frac;
  );

  hold_w   = on_frac - aw - rw;  // hold-high portion (may be zero)
  re_start = aw + hold_w;        // phase point where release begins

  ph < aw ? (
    // Attack: ramp up from 0 to 1
    aw > 0.0001 ? (
      t = ph / aw;
      result = apply_curve(t, att_shape);
    ) : (result = 1);
  ) :
  ph < re_start ? (
    // Hold high
    result = 1;
  ) :
  ph < on_frac ? (
    // Release: ramp down from 1 to 0
    rw > 0.0001 ? (
      t = 1 - (ph - re_start) / rw;
      result = apply_curve(t, rel_shape);
    ) : (result = 0);
  ) : (
    // Hold low (off-time)
    result = 0;
  );
  result
);

// ===== PAN BLOCK FUNCTIONS START =====
function percycle_pan(idx, n_steps) local(steps, step, pos) (
  n_steps = max(n_steps, 1);
  steps   = max(ceil((n_steps - 1) / 2.0), 1);

  pan_mode == 0 ? (
    pos = 0;
  ) : pan_mode == 1 ? (
    pos = (idx % 2 == 0) ? -1 : 1;
  ) : pan_mode == 2 ? (
    n_steps > 1 ? (pos = (idx % n_steps) / (n_steps - 1.0) * 2.0 - 1.0) : (pos = 0);
  ) : pan_mode == 3 ? (
    n_steps > 1 ? (pos = 1.0 - (idx % n_steps) / (n_steps - 1.0) * 2.0) : (pos = 0);
  ) : pan_mode == 4 ? (
    n_steps > 1 ? (pos = idx / (n_steps - 1.0) * 2.0 - 1.0) : (pos = 0);
  ) : pan_mode == 5 ? (
    idx = idx % n_steps;
    idx == 0 ? (
      pos = -1.0;
    ) : (
      step = ceil((idx + 1) / 2);
      pos = (idx % 2 == 1) ?  (1.0 - (step - 1.0) / steps)
                            : -(1.0 - (step - 1.0) / steps);
      pos = max(-1.0, min(1.0, pos));
    );
  ) : pan_mode == 6 ? (
    idx = idx % n_steps;
    idx == 0 ? (
      pos = -1.0;
    ) : (
      step = ceil((idx + 1) / 2);
      pos = (idx % 2 == 1) ?  (1.0 - (step - 1.0) / steps)
                            : -(1.0 - (step - 1.0) / steps);
      pos = max(-1.0, min(1.0, pos));
    );
  ) : pan_mode == 7 ? (
    idx = idx % n_steps;
    idx == 0 ? (
      pos = 0.0;
    ) : (
      step = floor((idx + 1) / 2);
      pos = (idx % 2 == 1) ? -(step / steps)
                            :  (step / steps);
      pos = max(-1.0, min(1.0, pos));
    );
  ) : pan_mode == 8 ? (
    idx = idx % n_steps;
    idx == 0 ? (
      pos = 0.0;
    ) : (
      step = floor((idx + 1) / 2);
      pos = (idx % 2 == 1) ? -(step / steps)
                            :  (step / steps);
      pos = max(-1.0, min(1.0, pos));
    );
  ) : (
    pos = 0;
  );

  pos * pan_spread
);
// ===== PAN BLOCK FUNCTIONS END =====

// Start Delay state.
last_play_state     = 0;
start_delay_elapsed = 0;
start_delay_sec     = 0;

// Play/Rest gate state. pr_cycle_progress is a continuous fractional
// counter (cycles elapsed in the current play or rest period) that
// flips pr_resting and resets when it crosses the threshold for the
// current state. effect_mix smoothes between 1 (effect fully on) and
// 0 (full dry pass-through) — the tremolo gain target blends with
// 1.0 via this mix, and the pan output blends with the un-panned
// signal the same way, so the transition between play and rest is
// a soft fade rather than an abrupt switch.
pr_resting        = 0;
pr_cycle_progress = 0;
play_for_cycles   = 0;
rest_for_cycles   = 0;
pr_enabled        = 0;
rest_lfo_mode     = 0;
rest_output_mode  = 0;
effect_mix        = 1;

// Speed ramp + rate smoother state.
// freq_smoothed is the per-sample-smoothed tremolo frequency; the
// speed ramp's multiplier is applied on top to produce the effective
// freq used by phase advance + LFO calculations. Seeded from the
// current slider values so the first audio sample isn't smoothed up
// from 0 (would otherwise produce ~100 ms of wrong-rate modulation at
// every transport start since @init re-runs on play).
rate_smoother_coeff      = 1.0 - exp(-1.0 / (srate * 0.1));
slider2 == 0 ? (freq_smoothed = slider1) :
slider2 == 1 ? (freq_smoothed = 1 / max(slider1, 0.001)) :
               (freq_smoothed = slider1 / 60);
// Speed Ramp state. Engage is a freeze/resume gate, not an edge;
// only transport play resets ramp_t.
speed_scale_current      = 1.0;
speed_ramp_t             = 0.0;
speed_ramp_delay_elapsed = 0;

// --- v2.9 Drift target memory banks ---
//
// 6 targets × 8 fields. Each array is 16-slot-spaced so targets can
// grow to 16 later. This plugin uses no other memory arrays (all
// scalar state), so the bank lives at 1024 with plenty of headroom.
//
// Targets:
//   0 = Rate Value      (units: rate's current unit)
//   1 = Depth dB        (units: dB)
//   2 = Pan Sweep Rate  (units: Pan Sweep Rate's unit; modes 9/10 only)
//   3 = On Duration %   (units: %)
//   4 = Attack %        (units: %)
//   5 = Release %       (units: %)
N_TARGETS = 6;
target_drift_up     = 1024;
target_drift_down   = 1040;
target_drift_per    = 1056;
target_drift_shape  = 1072;
target_drift_phase  = 1088;
target_drift_prev   = 1104;
target_drift_curr   = 1120;
target_drift_offset = 1136;

// CONFIG bank (drift up/down/period/shape + selector tracker) — guarded
// by drift_cfg_inited so the @init re-run on every transport play (Path A
// render fix, no ext_noinit) does NOT wipe the user's setup. @serialize
// restores saved configs on project reload.
drift_cfg_inited != 1 ? (
  i = 0;
  loop(N_TARGETS,
    target_drift_up[i]    = 0;
    target_drift_down[i]  = 0;
    target_drift_per[i]   = 8;
    target_drift_shape[i] = 0;
    i += 1;
  );
  last_target_select = 0;
  drift_cfg_inited = 1;
);

// Drift RUNTIME resets on EVERY @init (every transport play) — phase 0.
i = 0;
loop(N_TARGETS,
  target_drift_phase[i]  = 0;
  target_drift_prev[i]   = 0;
  target_drift_curr[i]   = 0;
  target_drift_offset[i] = 0;
  i += 1;
);


@slider

rate_val     = slider1;
rate_mode    = slider2;
dur_pct      = slider3;
depth        = slider4;
att_pct      = slider5;
rel_pct      = slider6;
att_shape    = slider7;
rel_shape    = slider8;
phase_offset = slider9 / 360;

amount = 2 ^ (depth / 6);
sc     = 0.5 * amount;
amount = 1 - amount;

// ===== PAN BLOCK SLIDER READ START =====
pan_enabled     = slider11;
pan_mode        = slider12;
pan_spread      = slider13;
pan_glide_ms    = slider14;
pan_cycle_steps = slider15;
pan_sweep_val   = slider16;
pan_sweep_mode  = slider17;
pan_sweep_ratio = slider18;

slider_show(slider12, pan_enabled);
slider_show(slider13, pan_enabled);
slider_show(slider14, pan_enabled);
slider_show(slider15, pan_enabled && pan_mode >= 1 && pan_mode <= 8);
slider_show(slider16, pan_enabled && (pan_mode == 9 || pan_mode == 10));
slider_show(slider17, pan_enabled && (pan_mode == 9 || pan_mode == 10));
slider_show(slider18, pan_enabled && pan_mode == 11);
// ===== PAN BLOCK SLIDER READ END =====

// Start Delay: convert to seconds based on Rate Mode. BPM beats and
// Hz cycles are interpreted against Rate Value; Seconds is literal.
start_delay_units = slider19;
slider2 == 0 ? start_delay_sec = start_delay_units * 60 / max(slider1, 0.001) :
slider2 == 1 ? start_delay_sec = start_delay_units :
               start_delay_sec = start_delay_units / max(slider1, 0.001);

// Play/Rest gate: integer cycle counts. Both must be > 0 for the
// gate to engage; 0 in either slider disables.
play_for_cycles = slider20;
rest_for_cycles = slider21;
new_pr_enabled  = (play_for_cycles > 0 && rest_for_cycles > 0);
// Defensive reset: if user disables the gate mid-rest, snap pr_resting
// back to 0 and zero the progress counter. effect_mix will smoothly
// ramp back to 1 via the @sample smoother.
!new_pr_enabled && pr_resting ? (
  pr_resting = 0;
  pr_cycle_progress = 0;
);
pr_enabled       = new_pr_enabled;
rest_lfo_mode    = slider22;
rest_output_mode = slider23;

// No engage-edge detection. Engage is a freeze/resume gate handled
// in @sample. Only transport play resets ramp_t.

// Drift target selector save/restore (nested-selector pattern).
// Switching slider28 saves sliders 29-32 into the OLD target's slot,
// then loads the NEW target's stored config into sliders 29-32.
// Otherwise captures live edits to the current target's slot. All 6
// targets drift in parallel from @sample regardless of selection.
sel_target = slider28;
sel_up     = slider29;
sel_down   = slider30;
sel_per    = slider31;
sel_shape  = slider32;

last_target_select != sel_target ? (
  target_drift_up[last_target_select]    = sel_up;
  target_drift_down[last_target_select]  = sel_down;
  target_drift_per[last_target_select]   = sel_per;
  target_drift_shape[last_target_select] = sel_shape;

  slider29 = target_drift_up[sel_target];
  slider30 = target_drift_down[sel_target];
  slider31 = target_drift_per[sel_target];
  slider32 = target_drift_shape[sel_target];
  slider_automate(slider29);
  slider_automate(slider30);
  slider_automate(slider31);
  slider_automate(slider32);

  last_target_select = sel_target;
) : (
  target_drift_up[sel_target]    = sel_up;
  target_drift_down[sel_target]  = sel_down;
  target_drift_per[sel_target]   = sel_per;
  target_drift_shape[sel_target] = sel_shape;
);


@sample

// (No transport-edge reset here — Path A. REAPER re-runs @init on every
// transport play / render start, which resets all runtime state — LFO
// phases/gains, pan state, rate smoother (re-seeded from slider1), drift
// runtime, Speed Ramp, Start Delay, Play/Rest + effect mix; the drift
// CONFIG bank is preserved across those re-runs by the drift_cfg_inited
// guard in @init. See docs/v2.9-render-state-bug.md.)

start_delay_elapsed < start_delay_sec ? (
  start_delay_elapsed += 1 / srate;
  // No-op — spl0 and spl1 pass through unchanged.
) : (

rate_val     = slider1;
rate_mode    = slider2;
dur_pct      = slider3;
depth        = slider4;
att_pct      = slider5;
rel_pct      = slider6;
att_shape    = slider7;
rel_shape    = slider8;
phase_offset = slider9 / 360;

// ===== PAN BLOCK SAMPLE READ START =====
pan_enabled     = slider11;
pan_mode        = slider12;
pan_spread      = slider13;
pan_glide_ms    = slider14;
pan_cycle_steps = slider15;
pan_sweep_val   = slider16;
pan_sweep_mode  = slider17;
pan_sweep_ratio = slider18;
// ===== PAN BLOCK SAMPLE READ END =====

// (amount / sc are computed AFTER the drift block below, so the Depth
// dB drift target can fold into depth first.)

rate_mode == 0 ? (freq_raw = rate_val) :
rate_mode == 1 ? (freq_raw = 1 / max(rate_val, 0.001)) :
                 (freq_raw = rate_val / 60);

// Smooth the rate slider so manual tweaks don't click, then advance
// the speed ramp. Drift offsets are added below.
freq_smoothed += (freq_raw - freq_smoothed) * rate_smoother_coeff;

// Advance speed_ramp_t while engaged + duration > 0 + past start
// delay. Engage off freezes ramp_t; engaging on resumes from there.
slider26 && slider25 > 0 ? (
  speed_ramp_delay_samples = slider27 * 60 * srate;
  speed_ramp_delay_elapsed < speed_ramp_delay_samples ? (
    speed_ramp_delay_elapsed += 1;
  ) : (
    speed_ramp_t += 1.0 / (srate * slider25 * 60);
    speed_ramp_t = min(speed_ramp_t, 1.0);
  );
);

// Signed-delta Speed Ramp: effective rate value = slider1 + ramp_t *
// slider24 (both in the rate's current unit). Convert to Hz the same
// way freq_raw is computed from slider1 above, then express as a
// multiplicative factor on freq so the existing combined_scale-based
// audio path keeps working. No "snapshot at engage" — live edits
// adjust trajectory.
effective_rate_val = rate_val + speed_ramp_t * slider24;
rate_mode == 0 ? (effective_rate_hz = effective_rate_val) :
rate_mode == 1 ? (effective_rate_hz = 1 / max(effective_rate_val, 0.001)) :
                 (effective_rate_hz = effective_rate_val / 60);
speed_scale_current = effective_rate_hz / max(freq_raw, 0.001);
combined_scale = speed_scale_current;
freq = freq_smoothed * combined_scale;

// ===== DRIFT BLOCK START =====
// Per-target drift wave computation. 6 targets (0=Rate Value, 1=Depth
// dB, 2=Pan Sweep Rate, 3=On Duration %, 4=Attack %, 5=Release %).
// Each gets a phase counter advancing per sample. Period unit is
// tremolo cycles for ALL targets, referenced against drift_ref_freq
// (the Speed-Ramp-adjusted rate BEFORE drift, captured here) so drift
// on Rate Value doesn't self-modulate its own period.
drift_ref_freq = max(freq, 0.00001);
i = 0;
loop(N_TARGETS,
  up    = target_drift_up[i];
  down  = target_drift_down[i];
  per   = target_drift_per[i];
  shape = target_drift_shape[i];

  drift_offset_local = 0;
  (up > 0 || down > 0) && per > 0 ? (
    period_samples = max(per * srate / drift_ref_freq, 1);
    new_phase = target_drift_phase[i] + 1.0 / period_samples;
    new_phase >= 1.0 ? (
      new_phase -= 1.0;
      shape == 2 ? (
        target_drift_prev[i] = target_drift_curr[i];
        target_drift_curr[i] = rand(2) - 1;
      );
    );
    target_drift_phase[i] = new_phase;

    shape == 0 ? (
      shape_val = sin(2 * $pi * new_phase);
    ) : shape == 1 ? (
      shape_val = new_phase < 0.25 ? (4 * new_phase) :
                  new_phase < 0.75 ? (2 - 4 * new_phase) :
                                     (4 * new_phase - 4);
    ) : (
      shape_val = target_drift_prev[i] +
        (target_drift_curr[i] - target_drift_prev[i]) * new_phase;
    );
    drift_offset_local = shape_val > 0 ? shape_val * up : shape_val * down;
  );
  target_drift_offset[i] = drift_offset_local;
  i += 1;
);

// Rate Value drift (target 0): offset is in the rate's current unit;
// convert to a Hz delta on freq the same way the old drift did (in
// Seconds mode it's a period delta, not a Hz delta). Clamp the result
// so an aggressive Down-by can't freeze the LFO.
rate_drift_user = target_drift_offset[0];
rate_drift_hz   = 0;
rate_drift_user != 0 ? (
  rate_mode == 0 ? (rate_drift_hz = rate_drift_user) :
  rate_mode == 1 ? (
    cur_period    = 1 / drift_ref_freq;
    new_period    = max(cur_period + rate_drift_user, 0.0001);
    rate_drift_hz = (1 / new_period) - freq;
  ) : (
    rate_drift_hz = rate_drift_user / 60;
  );
);
freq = max(freq + rate_drift_hz, 0.001);
// ===== DRIFT BLOCK END =====

// Depth dB drift (target 1): fold into depth, then compute amount/sc.
// Clamp to the slider's range (-60..0 dB).
eff_depth = max(-60, min(0, depth + target_drift_offset[1]));
amount = 2 ^ (eff_depth / 6);
sc     = 0.5 * amount;
amount = 1 - amount;

// On Duration / Attack / Release drift (targets 3, 4, 5): fold into
// the per-cycle fractions, clamped to [0, 100] %.
eff_dur_pct = max(0, min(100, dur_pct + target_drift_offset[3]));
eff_att_pct = max(0, min(100, att_pct + target_drift_offset[4]));
eff_rel_pct = max(0, min(100, rel_pct + target_drift_offset[5]));

// Pan Sweep Rate drift (target 2): fold into the pan sweep value used
// by pan modes 9/10 below (in the Pan Sweep Rate's own unit).
eff_pan_sweep_val = max(0.001, pan_sweep_val + target_drift_offset[2]);

period   = 1 / max(freq, 0.00001);
on_secs  = (eff_dur_pct / 100.0) * period;
att_secs = (eff_att_pct / 100.0) * period;
rel_secs = (eff_rel_pct / 100.0) * period;

// Play/Rest gate state machine. pr_cycle_progress accumulates
// fractional cycles at the tremolo rate; when it crosses the
// threshold for the current state (play_for_cycles when playing,
// rest_for_cycles when resting), pr_resting flips and the counter
// resets.
pr_enabled ? (
  pr_cycle_progress += freq / srate;
  !pr_resting ? (
    pr_cycle_progress >= play_for_cycles ? (
      pr_resting = 1;
      pr_cycle_progress = 0;
    );
  ) : (
    pr_cycle_progress >= rest_for_cycles ? (
      pr_resting = 0;
      pr_cycle_progress = 0;
    );
  );
);

// Smoother coefficient — used for the existing gain smoother and
// (just below) for effect_mix. Moved up from its original spot
// inside the gain section so effect_mix can reuse it.
smooth = exp(-1 / (srate * 0.003));

// in_frozen_rest gates LFO phase advancement (tremolo phase_l/r
// and pan_phase) so Freeze pauses the modulation during rest. Walk
// leaves it false and the LFOs keep cycling silently. Independent
// of Rest output, so all four LFO×output combinations work.
in_frozen_rest = pr_enabled && pr_resting && rest_lfo_mode == 1;

// effect_mix smoothly transitions between 1 (effect fully on) and
// 0 (rest target) at rest boundaries. The rest target depends on
// Rest output: 1.0 (unity gain = dry pass-through) for Pass-through,
// 0 (full silence) for Silence. The tremolo gain target blends
// between LFO-driven gain and rest_gain_target via effect_mix;
// pan output blends with the pre-pan signal (which will already
// be 0 in Silence mode because gain_l has smoothed to 0).
target_effect_mix = pr_enabled && pr_resting ? 0 : 1;
effect_mix        = effect_mix * smooth + target_effect_mix * (1 - smooth);
rest_gain_target  = (rest_output_mode == 1) ? 0 : 1;

// Advance tremolo phases unless Freeze rest is pinning them.
!in_frozen_rest ? (
  phase_l += freq / srate;
  phase_l >= 1 ? phase_l -= 1;

  slider10 == 0 ? (
    phase_r += freq / srate;
    phase_r >= 1 ? phase_r -= 1;
  ) : (
    phase_r = phase_l + phase_offset;
    phase_r >= 1 ? phase_r -= 1;
    phase_r < 0  ? phase_r += 1;
  );
);

lfo_l = calc_lfo(phase_l, on_secs, att_secs, rel_secs, period, att_shape, rel_shape);
lfo_r = calc_lfo(phase_r, on_secs, att_secs, rel_secs, period, att_shape, rel_shape);

// Gain target blends LFO-based modulation with rest_gain_target
// (1 for Walk/Freeze = dry pass-through, 0 for Silence = mute)
// based on effect_mix. During rest, effect_mix → 0, gain target
// → rest_gain_target, the smoother ramps gain there over ~3 ms.
target_gain_l = effect_mix * (lfo_l * sc + amount) + (1 - effect_mix) * rest_gain_target;
target_gain_r = effect_mix * (lfo_r * sc + amount) + (1 - effect_mix) * rest_gain_target;
gain_l = gain_l * smooth + target_gain_l * (1 - smooth);
gain_r = gain_r * smooth + target_gain_r * (1 - smooth);

spl0 *= gain_l;
spl1 *= gain_r;

// ===== PAN BLOCK SAMPLE LOGIC START =====
pan_enabled ? (
  // Per-cycle pan modes (0-8) advance pan_cycle_index on tremolo
  // phase wraps. Since the tremolo phase advancement above is
  // gated by !in_frozen_rest, cycle_fired never triggers during
  // Freeze rest — pan_cycle_index naturally pauses without needing
  // its own gate.
  cycle_fired  = (phase_l < last_phase_l);
  last_phase_l = phase_l;

  pan_mode <= 8 ? (
    cycle_fired ? (
      pan_mode == 4 || pan_mode == 6 || pan_mode == 8 ? (
        pan_cycle_index += pan_cycle_dir;
        (pan_cycle_index >= pan_cycle_steps - 1 || pan_cycle_index <= 0) ?
          pan_cycle_dir = -pan_cycle_dir;
      ) : (
        pan_cycle_index = (pan_cycle_index + 1) % pan_cycle_steps;
      );
    );
    cur_pan = percycle_pan(pan_cycle_index, pan_cycle_steps);
    pan_l = cur_pan;

  ) : pan_mode == 9 ? (
    // Pan Sweep — gate phase advance for Freeze mode. eff_pan_sweep_val
    // carries the Pan Sweep Rate drift offset (target 2).
    pan_sweep_mode == 0 ? (pan_freq = eff_pan_sweep_val) :
    pan_sweep_mode == 1 ? (pan_freq = 1 / max(eff_pan_sweep_val, 0.001)) :
                          (pan_freq = eff_pan_sweep_val / 60);
    !in_frozen_rest ? (
      pan_phase += pan_freq / srate;
      pan_phase >= 1 ? pan_phase -= 1;
    );
    cur_pan = (pan_phase * 2.0 - 1.0) * pan_spread;
    pan_l = cur_pan;

  ) : pan_mode == 10 ? (
    // Pan Sweep Flipped — gate phase advance for Freeze mode.
    pan_sweep_mode == 0 ? (pan_freq = eff_pan_sweep_val) :
    pan_sweep_mode == 1 ? (pan_freq = 1 / max(eff_pan_sweep_val, 0.001)) :
                          (pan_freq = eff_pan_sweep_val / 60);
    !in_frozen_rest ? (
      pan_phase += pan_freq / srate;
      pan_phase >= 1 ? pan_phase -= 1;
    );
    cur_pan = (1.0 - pan_phase * 2.0) * pan_spread;
    pan_l = cur_pan;

  ) : (
    // Linked Sweep — gate phase advance for Freeze mode.
    !in_frozen_rest ? (
      pan_phase += (freq * pan_sweep_ratio) / srate;
      pan_phase >= 1 ? pan_phase -= 1;
    );
    cur_pan = (pan_phase * 2.0 - 1.0) * pan_spread;
    pan_l = cur_pan;
  );

  // Glide smoothing — runs always, so pan_l_smooth still tracks
  // pan_l targets even when phases are frozen (pan_l just stays
  // constant in that case, smoother converges to it).
  pan_glide_coeff = pan_glide_ms > 0 ? exp(-1 / (srate * pan_glide_ms * 0.001)) : 0;
  pan_l_smooth = pan_l_smooth * pan_glide_coeff + pan_l * (1 - pan_glide_coeff);

  // Apply the pan, then blend the panned output with the un-panned
  // signal via effect_mix. During rest, effect_mix → 0 means the
  // output is the un-panned (post-tremolo, but tremolo has also
  // smoothed back to 1.0) signal — i.e., dry pass-through.
  pan_pos = (pan_l_smooth + 1.0) * 0.5;
  mono = (spl0 + spl1) * 0.5;
  spl0_panned = mono * cos(pan_pos * $pi * 0.5);
  spl1_panned = mono * sin(pan_pos * $pi * 0.5);
  spl0 = spl0 * (1 - effect_mix) + spl0_panned * effect_mix;
  spl1 = spl1 * (1 - effect_mix) + spl1_panned * effect_mix;
);
// ===== PAN BLOCK SAMPLE LOGIC END =====

);  // close start-delay else branch

@serialize
// Persist per-target drift configurations. Without this, only the
// most-recently-edited target's drift slider values survive a project
// save/load because sliders 29-32 hold whichever target was selected
// at save time. 6 targets × 4 config fields = 24 values; plus the
// selector.
file_mem(0, target_drift_up,    N_TARGETS);
file_mem(0, target_drift_down,  N_TARGETS);
file_mem(0, target_drift_per,   N_TARGETS);
file_mem(0, target_drift_shape, N_TARGETS);
file_var(0, last_target_select);