desc: Vowel Shaper v5 (Voice Size + balanced formant strengths)
// Designed by Rozaya, developed with Claude (Anthropic)
//
// This work is dedicated to the public domain under CC0 1.0 Universal.
// https://creativecommons.org/publicdomain/zero/1.0/
//
// v5 addresses the "huge tract, tiny lips" mismatch in v4:
//
// 1. NEW Voice Size slider. Multiplies all formant frequencies by
//    a scale factor. 1.0 = adult male reference (the corner values
//    I built the math on); 1.15 = adult female-ish; 1.3 = teen;
//    1.5 = child. Larger Voice Size = higher formants = smaller-
//    sounding tract. Below 1.0 you get deeper-than-male voices for
//    monster/giant/very large body sounds.
//
// 2. REBALANCED strengths. v4's F1=1.6/F2=0.7/F3=0.3 made F1
//    over-dominant — the body cavity dominated, the mouth-shape
//    formants (F2/F3) were quieter than they should be. v5
//    defaults to F1=1.3/F2=1.0/F3=0.5: F1 still leading but F2 and
//    F3 carry their proper share of "mouth shape" character.
//
// 3. Voice tilt default lowered to 0.3 (was 0.4) — retains a bit
//    more brightness in the F3 region for natural mouth-opening
//    character without losing the voiced source slope.

slider1:0.0<-24.0,24.0,0.1>Input Gain (dB)
slider2:0.0<0.0,1.0,0.01>Vowel Height (0 = open, 1 = close)
slider3:0.5<0.0,1.0,0.01>Vowel Backness (0 = front, 1 = back)
slider4:0.0<0.0,1.0,0.01>Lip Rounding (lowers F2/F3 of front vowels)
slider5:1.0<0.6,1.6,0.01>Voice Size (1 = adult male, >1 = smaller/higher voice)
slider6:1.3<0.0,3.0,0.01>F1 Strength
slider7:1.0<0.0,2.0,0.01>F2 Strength
slider8:0.5<0.0,2.0,0.01>F3 Strength
slider9:0.3<0.0,1.0,0.01>Voice tilt (0 = whispered, 1 = voiced character)
slider10:0.5<0.0,1.0,0.01>Output Volume

@init
srate_inv = 1.0 / srate;
pi_srate  = $pi * srate_inv;

f1_low = 0; f1_band = 0;
f2_low = 0; f2_band = 0;
f3_low = 0; f3_band = 0;

f1_damp = 0.12;
f2_damp = 0.067;
f3_damp = 0.05;

tilt_corner_hz = 1200;
tilt_coef      = exp(-2 * $pi * tilt_corner_hz / srate);
tilt_y         = 0;

dc_x = 0; dc_y = 0;

// Four-corner adult-male reference values. Voice Size multiplies
// these at @slider time.
i_F1  = 270;  i_F2  = 2290; i_F3  = 3010;
u_F1  = 300;  u_F2  = 870;  u_F3  = 2240;
ae_F1 = 660;  ae_F2 = 1720; ae_F3 = 2410;
ah_F1 = 730;  ah_F2 = 1090; ah_F3 = 2440;

@slider
in_gain    = 10 ^ (slider1 / 20);
height     = slider2;
backness   = slider3;
rounding   = slider4;
voice_size = slider5;
f1_amp     = slider6;
f2_amp     = slider7;
f3_amp     = slider8;
tilt_amt   = slider9;
vol        = slider10;

// Bilinear interpolation across four corners.
w_i  = (1 - backness) * height;
w_u  =      backness  * height;
w_ae = (1 - backness) * (1 - height);
w_ah =      backness  * (1 - height);

f1_hz = w_i * i_F1 + w_u * u_F1 + w_ae * ae_F1 + w_ah * ah_F1;
f2_hz = w_i * i_F2 + w_u * u_F2 + w_ae * ae_F2 + w_ah * ah_F2;
f3_hz = w_i * i_F3 + w_u * u_F3 + w_ae * ae_F3 + w_ah * ah_F3;

// Lip rounding (front vowels only).
front_amount = 1 - backness;
f2_hz = f2_hz - rounding * front_amount * 350;
f3_hz = f3_hz - rounding * front_amount * 700;

// Voice Size: scale all formants. Larger size = shorter tract =
// higher formants. Mouth/body proportion scales together so they
// stay in natural relationship.
f1_hz = f1_hz * voice_size;
f2_hz = f2_hz * voice_size;
f3_hz = f3_hz * voice_size;

f1_hz = max(min(f1_hz, srate * 0.45), 50);
f2_hz = max(min(f2_hz, srate * 0.45), 50);
f3_hz = max(min(f3_hz, srate * 0.45), 50);

f1_coef = min(2 * sin(pi_srate * f1_hz), 0.98);
f2_coef = min(2 * sin(pi_srate * f2_hz), 0.98);
f3_coef = min(2 * sin(pi_srate * f3_hz), 0.98);

@sample
in_mono = (spl0 + spl1) * 0.5 * in_gain;

f1_low  += f1_coef * f1_band;
f1_high  = in_mono - f1_low - f1_damp * f1_band;
f1_band += f1_coef * f1_high;

f2_low  += f2_coef * f2_band;
f2_high  = in_mono - f2_low - f2_damp * f2_band;
f2_band += f2_coef * f2_high;

f3_low  += f3_coef * f3_band;
f3_high  = in_mono - f3_low - f3_damp * f3_band;
f3_band += f3_coef * f3_high;

formant_out = (f1_band * f1_amp) - (f2_band * f2_amp) + (f3_band * f3_amp);

tilt_y = tilt_coef * tilt_y + (1 - tilt_coef) * formant_out;
tilted_out = formant_out + (tilt_y - formant_out) * tilt_amt;

dc_y = tilted_out - dc_x + 0.997 * dc_y;
dc_x = tilted_out;

out = dc_y * vol * 0.5;
out = max(min(out, 1.5), -1.5);

spl0 = out;
spl1 = out;
