desc: Mode Drone
// Designed by Rozaya, developed with Claude (Anthropic)
//
// This work is dedicated to the public domain under CC0 1.0 Universal.
// https://creativecommons.org/publicdomain/zero/1.0/
//
// One drone synth, four ways to think about sound. The Mode slider
// at the top picks which paradigm you're in; mode-specific sliders
// show up in the panel while the inactive modes' controls hide via
// slider_show (OSARA's P list still exposes every parameter — the
// hiding is for the visual REAPER UI only).
//
//   Feel     — six "vibe" sliders for someone who doesn't know synth.
//              Warmth, Brightness, Edge, Hollowness, Body, Movement.
//              The friendliest mode; the default on load.
//   Shape    — pick a wave shape (sine → triangle → saw → square),
//              tilt its symmetry, soften its highs. Three sliders.
//              PolyBLEP anti-aliasing on the saw/square edges.
//   Points   — draw the wave by setting the height of 8 points along
//              one cycle. Arrow-key drawing for blind users; the most
//              literally-shaped paradigm.
//   Additive — control the amplitude (dB) of each of 16 harmonic
//              partials directly. The Hammond-organ / synth-nerd
//              paradigm; most precise spectrum control.
//
// All four modes share the same Fundamental Hz, Master Gain, Attack
// and Release sliders. Switching mode does NOT reset oscillator
// phase — the previous mode's state persists in case you want to
// switch back. Master Gain change uses the Attack/Release timing
// (the per-partial smoother inside the additive engine is fixed at
// 3 ms — fast enough to prevent clicks on slider tweaks, slow
// enough to be inaudible).

// ===== MODE =====
slider1:0<0,3,1{Feel,Shape,Points,Additive}>Mode

// ===== GLOBAL (all modes) =====
slider2:110<20,2000,0.01>Fundamental Hz
slider3:-12<-60,0,0.1>Master Gain dB
slider4:0.5<0,10,0.01>Attack (sec)
slider5:1.5<0,10,0.01>Release (sec)

// ===== FEEL MODE (sliders 6-11) =====
// Six "vibe" sliders, all 0-100. Under the hood they drive a recipe
// of harmonic partial amplitudes; the user never sees the math.
//   Warmth     — boosts low partials 1-4 (round, warm body)
//   Brightness — boosts high partials 8-16 (air, shimmer)
//   Edge       — adds saw-like 1/N falloff across all partials (buzz)
//   Hollowness — silences even partials (reedy, square-like)
//   Body       — boosts fundamental + octave specifically (low presence)
//   Movement   — small per-partial detune (chorus-like motion)
slider6:50<0,100,0.1>Feel: Warmth
slider7:20<0,100,0.1>Feel: Brightness
slider8:0<0,100,0.1>Feel: Edge
slider9:0<0,100,0.1>Feel: Hollowness
slider10:50<0,100,0.1>Feel: Body
slider11:0<0,100,0.1>Feel: Movement

// ===== SHAPE MODE (sliders 12-14) =====
//   Shape      — continuous morph: 0=sine, 33=triangle, 66=saw, 100=square
//   Symmetry   — tilts the wave (PWM on square; reverses saw at -100)
//   Brightness — gentle lowpass; 100=bypass (full bright), 0=muffled
slider12:0<0,100,0.1>Shape: Shape (Sine -> Tri -> Saw -> Sq)
slider13:0<-100,100,0.1>Shape: Symmetry %
slider14:100<0,100,0.1>Shape: Brightness

// ===== POINTS MODE (sliders 15-22) =====
// Each Point N is the wave's height at position N/8 of the cycle, in
// percent (-100 = fully down, +100 = fully up). The wave is the line
// segments connecting Point 1 → 2 → ... → 8 → wraps back to Point 1.
// Defaults form a piecewise-linear approximation of a sine.
slider15:0<-100,100,0.1>Point 1 (start of cycle)
slider16:71<-100,100,0.1>Point 2
slider17:100<-100,100,0.1>Point 3 (peak in default sine)
slider18:71<-100,100,0.1>Point 4
slider19:0<-100,100,0.1>Point 5 (mid-cycle)
slider20:-71<-100,100,0.1>Point 6
slider21:-100<-100,100,0.1>Point 7 (trough in default sine)
slider22:-71<-100,100,0.1>Point 8

// ===== ADDITIVE MODE (sliders 23-38) =====
// Per-partial amplitude in dB. -60 dB is treated as silence (skipped
// in the engine — saves CPU). Default: only Partial 1 is audible at
// -6 dB, everything else silent (pure-ish sine on load).
slider23:-6<-60,6,0.1>Partial 1 dB (fundamental)
slider24:-60<-60,6,0.1>Partial 2 dB
slider25:-60<-60,6,0.1>Partial 3 dB
slider26:-60<-60,6,0.1>Partial 4 dB
slider27:-60<-60,6,0.1>Partial 5 dB
slider28:-60<-60,6,0.1>Partial 6 dB
slider29:-60<-60,6,0.1>Partial 7 dB
slider30:-60<-60,6,0.1>Partial 8 dB
slider31:-60<-60,6,0.1>Partial 9 dB
slider32:-60<-60,6,0.1>Partial 10 dB
slider33:-60<-60,6,0.1>Partial 11 dB
slider34:-60<-60,6,0.1>Partial 12 dB
slider35:-60<-60,6,0.1>Partial 13 dB
slider36:-60<-60,6,0.1>Partial 14 dB
slider37:-60<-60,6,0.1>Partial 15 dB
slider38:-60<-60,6,0.1>Partial 16 dB

@init

// PolyBLEP correction for a step discontinuity, used by Shape mode
// to band-limit the saw wrap and square edges. See shape_drone.jsfx
// for the standalone version with the same function. Defined inside
// @init (not above it) so eel2 sees it during the init pass — all
// the other plugins in the suite define their functions here too.
function polyblep(t, dt) local(s) (
  t < dt ? (
    s = t / dt;
    s + s - s * s - 1;
  ) : t > 1 - dt ? (
    s = (t - 1) / dt;
    s * s + s + s + 1;
  ) : (
    0;
  );
);

// ===== MEMORY LAYOUT =====
// Additive engine (used by Feel + Additive modes — same engine,
// different ways of computing the per-partial targets in @slider)
p_phase    = 0;   //  0..15  oscillator phase per partial
p_target   = 16;  // 16..31  target linear amplitude per partial
p_current  = 32;  // 32..47  smoothed current amplitude per partial
p_freq     = 48;  // 48..63  per-partial frequency (with optional detune)
point_height = 64;//  64..71 point heights for Points mode
p_db_bank  = 80;  // 80..95  mirror of slider23..slider38 for indexed access

// ===== SCALARS =====
// Shape mode + Points mode use a single shared oscillator phase
// (called phase_unified). Switching between them mid-play keeps
// the phase continuous (no click).
phase_unified      = 0;
shape_filter_state = 0;

// Master gain smoother (always runs, used by all modes)
current_master = 0;
attack_coeff   = 0;
release_coeff  = 0;

// Per-partial smoother coefficient — fixed 3 ms time constant. Fast
// enough that mid-play slider changes don't click; slow enough to be
// inaudible. Computed once in @init (depends only on srate).
partial_smooth_coeff = exp(-1 / (srate * 0.003));

// Zero per-partial state. @init re-runs on every transport play
// (Reaper default), so each play press starts with a clean attack
// ramp from silence — matches the behavior of every other plugin
// in the suite.
i = 0;
loop(16,
  p_phase[i]   = 0;
  p_current[i] = 0;
  i += 1;
);

@slider

mode        = slider1;
fundamental = slider2;
master_lin  = pow(10, slider3 / 20.0);

// Master attack/release coefficients (one-pole). Used for the master
// gain smoother regardless of mode.
slider4 > 0 ? (attack_coeff  = exp(-1 / (srate * slider4)))  : (attack_coeff  = 0);
slider5 > 0 ? (release_coeff = exp(-1 / (srate * slider5))) : (release_coeff = 0);

// ===== FEEL MODE setup =====
// Compute per-partial targets from the six feel sliders' recipe.
// See feel_drone.jsfx for the standalone with the same math.
mode == 0 ? (
  s_warmth     = slider6  / 100.0;
  s_brightness = slider7  / 100.0;
  s_edge       = slider8  / 100.0;
  s_hollowness = slider9  / 100.0;
  s_body       = slider10 / 100.0;
  s_movement   = slider11 / 100.0;

  i = 0;
  loop(16,
    n   = i + 1;
    amp = 0;

    n <= 4 ? amp += s_warmth * (0.5 / n);
    n >= 8 ? amp += s_brightness * 0.15 * (1 - (n - 8) * 0.05);
    amp += s_edge * (1.0 / n) * 0.4;
    n <= 2 ? amp += s_body * 0.35;
    (n & 1) == 0 ? amp *= (1 - s_hollowness * 0.95);

    p_target[i] = amp;

    detune_sign  = (i & 1) ? -1 : 1;
    detune_cents = s_movement * 10 * detune_sign * (1 + i * 0.1);
    detune_ratio = pow(2, detune_cents / 1200.0);
    p_freq[i]    = fundamental * n * detune_ratio;

    i += 1;
  );
);

// ===== SHAPE MODE setup =====
mode == 1 ? (
  shape_morph_norm   = slider12 / 100.0;
  shape_morph_scaled = shape_morph_norm * 3;
  shape_morph_seg    = min(2, floor(shape_morph_scaled));
  shape_morph_local  = shape_morph_scaled - shape_morph_seg;

  shape_sym_val     = slider13 / 100.0;
  shape_mid         = 0.5 - shape_sym_val * 0.45;
  shape_mid_inv     = 1 - shape_mid;
  shape_inv_mid     = 1 / shape_mid;
  shape_inv_mid_inv = 1 / shape_mid_inv;

  shape_bright_norm = slider14 / 100.0;
  shape_bright_norm >= 0.9999 ? (
    shape_filter_active = 0;
  ) : (
    shape_filter_cutoff = 50 * pow((srate * 0.45) / 50, shape_bright_norm);
    shape_filter_a      = exp(-2 * $pi * shape_filter_cutoff / srate);
    shape_filter_b      = 1 - shape_filter_a;
    shape_filter_active = 1;
  );

  shape_phase_inc = fundamental / srate;
);

// ===== POINTS MODE setup =====
mode == 2 ? (
  point_height[0] = slider15 / 100.0;
  point_height[1] = slider16 / 100.0;
  point_height[2] = slider17 / 100.0;
  point_height[3] = slider18 / 100.0;
  point_height[4] = slider19 / 100.0;
  point_height[5] = slider20 / 100.0;
  point_height[6] = slider21 / 100.0;
  point_height[7] = slider22 / 100.0;
);

// ===== ADDITIVE MODE setup =====
// Mirror dB sliders into a bank so the per-partial loop can index.
// Then compute linear targets and per-partial frequencies.
mode == 3 ? (
  p_db_bank[0]  = slider23;  p_db_bank[1]  = slider24;
  p_db_bank[2]  = slider25;  p_db_bank[3]  = slider26;
  p_db_bank[4]  = slider27;  p_db_bank[5]  = slider28;
  p_db_bank[6]  = slider29;  p_db_bank[7]  = slider30;
  p_db_bank[8]  = slider31;  p_db_bank[9]  = slider32;
  p_db_bank[10] = slider33;  p_db_bank[11] = slider34;
  p_db_bank[12] = slider35;  p_db_bank[13] = slider36;
  p_db_bank[14] = slider37;  p_db_bank[15] = slider38;

  i = 0;
  loop(16,
    db = p_db_bank[i];
    db <= -59.99 ? (
      p_target[i] = 0;
    ) : (
      p_target[i] = pow(10, db / 20.0);
    );
    p_freq[i] = fundamental * (i + 1);
    i += 1;
  );
);

// ===== SLIDER VISIBILITY =====
// Hide inactive modes' sliders from the REAPER UI. OSARA's P list
// still surfaces all parameters regardless — this hiding only
// declutters the visual panel.
slider_show(slider6,  mode == 0);
slider_show(slider7,  mode == 0);
slider_show(slider8,  mode == 0);
slider_show(slider9,  mode == 0);
slider_show(slider10, mode == 0);
slider_show(slider11, mode == 0);
slider_show(slider12, mode == 1);
slider_show(slider13, mode == 1);
slider_show(slider14, mode == 1);
slider_show(slider15, mode == 2);
slider_show(slider16, mode == 2);
slider_show(slider17, mode == 2);
slider_show(slider18, mode == 2);
slider_show(slider19, mode == 2);
slider_show(slider20, mode == 2);
slider_show(slider21, mode == 2);
slider_show(slider22, mode == 2);
slider_show(slider23, mode == 3);
slider_show(slider24, mode == 3);
slider_show(slider25, mode == 3);
slider_show(slider26, mode == 3);
slider_show(slider27, mode == 3);
slider_show(slider28, mode == 3);
slider_show(slider29, mode == 3);
slider_show(slider30, mode == 3);
slider_show(slider31, mode == 3);
slider_show(slider32, mode == 3);
slider_show(slider33, mode == 3);
slider_show(slider34, mode == 3);
slider_show(slider35, mode == 3);
slider_show(slider36, mode == 3);
slider_show(slider37, mode == 3);
slider_show(slider38, mode == 3);

@sample

// ===== RUN THE ACTIVE ENGINE =====
// Each engine produces a raw `out` value in roughly [-1, +1]. The
// master smoother below applies the user's Master Gain + Attack/
// Release timing to that raw output. Engine state (phases, filter
// state) is preserved when switching modes — no click on Mode
// changes unless the user happens to be holding a hard transition.

mode == 0 || mode == 3 ? (
  // Additive engine (Feel mode and Additive mode share it — only
  // the @slider math that filled p_target differs between them)
  out = 0;
  i = 0;
  loop(16,
    target = p_target[i];

    // Per-partial smoother — fixed 3 ms time constant, applies in
    // both directions. Prevents clicks from rapid slider tweaks
    // without adding user-perceivable lag.
    p_current[i] = target + (p_current[i] - target) * partial_smooth_coeff;

    // CPU saver: when both target AND current are effectively zero,
    // skip the oscillator (reset phase so the next attack starts
    // clean). Partials in their release tail still get phase advance
    // so the wave doesn't break shape as it fades.
    (target <= 0 && p_current[i] < 0.000001) ? (
      p_phase[i] = 0;
    ) : (
      p_phase[i] += p_freq[i] / srate;
      p_phase[i] >= 1 ? p_phase[i] -= 1;
      out += sin(p_phase[i] * 2 * $pi) * p_current[i];
    );

    i += 1;
  );
) : mode == 1 ? (
  // Shape morph engine — single oscillator with continuous wave-shape
  // morphing, symmetry warp, and optional brightness lowpass.
  phase_unified += fundamental / srate;
  phase_unified >= 1 ? phase_unified -= 1;

  // Apply symmetry warp. Two linear pieces; dwp is the warped phase
  // increment per sample (needed by PolyBLEP since the effective
  // rate near a discontinuity changes with symmetry).
  phase_unified < shape_mid ? (
    wp  = phase_unified * shape_inv_mid * 0.5;
    dwp = shape_phase_inc * shape_inv_mid * 0.5;
  ) : (
    wp  = 0.5 + (phase_unified - shape_mid) * shape_inv_mid_inv * 0.5;
    dwp = shape_phase_inc * shape_inv_mid_inv * 0.5;
  );

  // Compute the two waveforms bracketing the current Shape position
  // and blend them.
  shape_morph_seg == 0 ? (
    sm_sine = sin(wp * 2 * $pi);
    sm_tri  = wp < 0.5 ? wp * 4 - 1 : 3 - wp * 4;
    out     = sm_sine * (1 - shape_morph_local) + sm_tri * shape_morph_local;
  ) : shape_morph_seg == 1 ? (
    sm_tri = wp < 0.5 ? wp * 4 - 1 : 3 - wp * 4;
    sm_saw = wp * 2 - 1 - polyblep(wp, dwp);
    out    = sm_tri * (1 - shape_morph_local) + sm_saw * shape_morph_local;
  ) : (
    sm_saw    = wp * 2 - 1 - polyblep(wp, dwp);
    sm_wp_mid = wp + 0.5;
    sm_wp_mid >= 1 ? sm_wp_mid -= 1;
    sm_sq     = (wp < 0.5 ? 1 : -1) + polyblep(wp, dwp) - polyblep(sm_wp_mid, dwp);
    out       = sm_saw * (1 - shape_morph_local) + sm_sq * shape_morph_local;
  );

  // Apply Brightness lowpass (if active). One-pole IIR.
  shape_filter_active ? (
    shape_filter_state = shape_filter_state * shape_filter_a + out * shape_filter_b;
    out                = shape_filter_state;
  );
) : (
  // Points mode — single oscillator, piecewise-linear wave from the
  // 8 point heights.
  phase_unified += fundamental / srate;
  phase_unified >= 1 ? phase_unified -= 1;

  scaled   = phase_unified * 8;
  seg      = floor(scaled);
  local_pt = scaled - seg;
  next_seg = seg == 7 ? 0 : seg + 1;
  out      = point_height[seg] * (1 - local_pt) + point_height[next_seg] * local_pt;
);

// ===== MASTER SMOOTHER (always runs) =====
// Apply the user's Attack/Release timing to the master gain change.
// On transport start, current_master = 0 (zeroed in @init each play),
// so the gain ramps from 0 to target over the Attack time — the
// "fade-in on play" behavior every plugin in the suite has.
target_master = master_lin;
target_master > current_master ? (
  current_master = target_master + (current_master - target_master) * attack_coeff;
) : target_master < current_master ? (
  current_master = target_master + (current_master - target_master) * release_coeff;
);

// Mono output — both channels carry the same signal. Drop a chorus
// or stereo widener AFTER this plugin if you want spatial depth.
spl0 = out * current_master;
spl1 = spl0;
