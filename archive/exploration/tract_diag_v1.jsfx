desc: Tract Diag v1 (uniform tube — does it ring?)
// Designed by Rozaya, developed with Claude (Anthropic)
//
// This work is dedicated to the public domain under CC0 1.0 Universal.
// https://creativecommons.org/publicdomain/zero/1.0/
//
// Diagnostic build for the Kelly-Lochbaum waveguide.
// Strips tract_tube_v5 to the bare minimum: uniform-diameter tube,
// no tongue, no lip, no rounding, no radiation, no DC blocker.
// The ONLY question this build is asking: does the tube resonate?
//
// Expected behaviour if the scatter math is sound: a uniform 17 cm
// closed-open tube (44 segments at 88.2 kHz effective scattering)
// rings at F1 ~500 Hz, F2 ~1500 Hz, F3 ~2500 Hz. In impulse mode
// you should hear a clear pluck-and-ring-out lasting roughly 30-50
// ms. In pulse-train mode you should hear a continuous buzz with
// audible formant resonances coloring the top.
//
// Use this as the FIRST test. If you do not hear ringing here, the
// bug is in scatter() or the boundary equations — no point adding
// tongue/lip controls back until the bare tube provably rings.
//
// === HOW TO TEST ===
//
//   Quick check (impulse mode):
//     Mode = Impulse, Voice = 1, then back to 0.
//     Each 0 -> 1 transition fires ONE impulse. Listen for the
//     ring-out — should sustain a clear low formant pitch for
//     ~30-50 ms with overtones above it. If you only hear a
//     click with no ring, scatter is broken.
//
//   Sustained check (pulse-train mode):
//     Mode = Pulse train, Voice = 1.
//     Continuous buzz at the f0 you set. Listen for formant
//     peaks coloring the buzz — it should NOT sound like a raw
//     pulse train, it should sound vaguely vowel-like (even
//     though no tongue/lip controls exist here yet).
//
//   Damping A/B:
//     Set damping low (0.99) — ring should be very short.
//     Set damping high (0.99999) — ring should sustain much
//     longer. If damping doesn't audibly change ring length,
//     the damping isn't being applied correctly.
//
//   Diameter A/B:
//     Should NOT meaningfully change the formant frequencies
//     in a uniform tube (formants depend on tube LENGTH, not
//     diameter). Should only affect output level. If diameter
//     changes formant frequencies, the area / reflection
//     calculation has a bug.

slider1:110<60,400,1>Pitch f0 (Hz) — used in Pulse/Buzz modes
slider2:0<0,1,1{Silent,Sound}>Voice (Sound = excitation on; rising edge fires impulse in Mode 0)
slider3:0<0,2,1{Impulse (one-shot on Voice rising edge),Pulse train,Buzz (one-sample impulse train)}>Mode
slider4:0.9998<0.99,0.99999,0.00001>Damping per scatter step
slider5:1.5<0.1,3.0,0.05>Tube diameter (uniform; should not affect formant pitch)
slider6:0.5<0.0,1.0,0.01>Output Volume

@init
N = 44;
R = 0; L = 64; JR = 128; JL = 192; refl_bank = 256;

glottalReflection = 0.75;
lipReflection     = -0.85;
gphase = 0;

i = 0; loop(N, R[i] = 0; L[i] = 0; JR[i] = 0; JL[i] = 0; refl_bank[i] = 0; i += 1; );

last_voice      = 0;
impulse_pending = 0;
damp            = 0.9998;

// scatter() is BIT-IDENTICAL to tract_tube_v5's scatter, so the same
// junction math is being exercised. Only the surrounding control
// layer and post-processing change.
function scatter(gin) local(j, k, w) (
  JR[0]   = gin + glottalReflection * L[0];
  JL[N-1] = lipReflection * R[N-1];
  j = 1;
  while (j < N) (
    k = refl_bank[j];
    w = k * (R[j-1] + L[j]);
    JR[j]   = R[j-1] - w;
    JL[j-1] = L[j]   + w;
    j += 1;
  );
  j = 0;
  while (j < N) (
    R[j] = JR[j] * damp;
    L[j] = JL[j] * damp;
    j += 1;
  );
);

@slider
f0       = slider1;
voicelvl = slider2;
mode     = slider3;
damp     = slider4;
tube_dia = slider5;
vol      = slider6;

// Uniform tube — every segment same diameter, so every internal
// reflection coefficient is 0. Waves propagate freely through
// internal junctions; only the glottal and lip boundaries reflect.
// This is the simplest possible tube and the cleanest test of the
// scatter/boundary code.
i = 1;
while (i < N) ( refl_bank[i] = 0; i += 1; );

// Arm a one-shot impulse on Voice rising edge in Mode 0.
voicelvl > 0 && last_voice == 0 && mode == 0 ? (
  impulse_pending = 1;
);
last_voice = voicelvl;

@sample
// === Excitation ===
mode == 0 ? (
  // One-shot impulse — fires once when Voice goes 0 -> 1, then
  // stays silent so you can hear the ring-out cleanly. Toggle Voice
  // off then on again to fire another.
  impulse_pending ? (
    glottal         = 1.0;
    impulse_pending = 0;
  ) : (
    glottal = 0.0;
  );
) : mode == 1 ? (
  // Raised-cosine pulse train at f0. Pulse shape is gentler than
  // a raw impulse so the spectrum is less aliased.
  gphase += f0 / srate;
  gphase >= 1.0 ? gphase -= 1.0;
  gphase < 0.3 ? (
    glottal = 0.5 * (1.0 - cos($pi * gphase / 0.3)) * voicelvl;
  ) : gphase < 0.5 ? (
    glottal = cos(0.5 * $pi * (gphase - 0.3) / 0.2) * voicelvl;
  ) : (
    glottal = 0.0;
  );
) : (
  // Buzz: pure impulse train at f0 — one full-amplitude sample per
  // period, zero otherwise. Brightest possible excitation source.
  gphase += f0 / srate;
  gphase >= 1.0 ? (
    gphase  = gphase - 1.0;
    glottal = voicelvl;
  ) : (
    glottal = 0.0;
  );
);

// === 2x-rate scattering (identical to tract_tube_v5) ===
scatter(glottal); o1 = R[N-1];
scatter(glottal); o2 = R[N-1];
lipout = (o1 + o2) * 0.5;

// === Output ===
// Raw lip sample. No radiation. No DC blocker. No high-pass. If
// there's a DC drift, we want to KNOW about it rather than mask it.
spl0 = lipout * vol;
spl1 = lipout * vol;
