desc: Tract Diag Effect v4 (three-zone rest shape + tongue + lip)
// Designed by Rozaya, developed with Claude (Anthropic)
//
// This work is dedicated to the public domain under CC0 1.0 Universal.
// https://creativecommons.org/publicdomain/zero/1.0/
//
// Two structural fixes vs v3, both addressing "vowels but not
// clearly landing":
//
// 1. NON-UNIFORM REST TRACT SHAPE. v1-v3 used a uniform cylinder
//    of diameter 1.5 as the baseline; vowel articulation rode on
//    top of that. Real vocal tracts aren't cylinders — they have
//    a narrow pharyngeal section near the glottis (~0.6), a
//    medium-narrow mid section (~1.1), and a wider oral cavity
//    (~1.5). Pink Trombone uses this exact three-zone stepped
//    shape; copying directly. The non-uniform baseline is what
//    makes articulation-induced formants land on vowel templates
//    the ear actually recognizes.
//
// 2. TONGUE POSITION MAPPING corrected. v3's backness=1 put the
//    tongue at segment ~9, which is INSIDE the narrow pharyngeal
//    section — the tongue can't articulate there in real speech.
//    Real /u/ has its tongue constriction at the velar region,
//    where the soft palate meets the back of the oral cavity
//    (around segment 13 in a 44-segment tract). v4 remaps so
//    backness=1 lands at segment 13 (velar /u/ position) and
//    backness=0 lands at segment 32 (tongue tip / blade, /i/
//    position). This is the range Pink Trombone uses.
//
// Expected behaviour with breath input:
//   All defaults                          -> /ə/ (schwa, the
//                                            neutral rest vowel)
//   Height=0.8, Backness=0.7              -> /o/-ish (velar raised)
//   Height=0.8, Backness=0.7, Round=0.5   -> /u/ ("hoooo"!)
//   Height=0.8, Backness=0.0              -> /i/-ish (tip raised)
//   Height=0.8, Backness=0.0, Round=0.5   -> /ü/ (German "über")
//   Height=0.4, Backness=0.5              -> /ɛ/-ish (mid central)

slider1:0.0<-24.0,24.0,0.1>Input Gain (dB)
slider2:0.9998<0.99,0.99999,0.00001>Damping per scatter step
slider3:0.0<0.0,1.0,0.01>Lip Rounding (0 = open, 1 = fully rounded)
slider4:5<1,10,1>Lip extent (segments, diagnostic)
slider5:0.0<0.0,1.0,0.01>Tongue Height (0 = relaxed, 1 = raised against tract roof)
slider6:0.7<0.0,1.0,0.01>Tongue Backness (0 = tongue tip /i/, 1 = velar /u/)
slider7:0<0,1,1{No,Yes}>DC blocker on output
slider8:0.5<0.0,1.0,0.01>Output Volume

@init
N = 44;
R = 0; L = 64; JR = 128; JL = 192; diam = 256; area = 320; refl_bank = 384;

glottalReflection = 0.75;
lipReflection     = -0.85;

i = 0; loop(N, R[i] = 0; L[i] = 0; JR[i] = 0; JL[i] = 0; diam[i] = 1.5; area[i] = 2.25; refl_bank[i] = 0; i += 1; );

damp     = 0.9998;
in_gain  = 1.0;
dc_x     = 0;
dc_y     = 0;

function scatter(gin) local(j, k, w) (
  JR[0]   = gin + glottalReflection * L[0];
  JL[N-1] = lipReflection * R[N-1];
  j = 1;
  while (j < N) (
    k = refl_bank[j];
    w = k * (R[j-1] + L[j]);
    JR[j]   = R[j-1] - w;
    JL[j-1] = L[j]   + w;
    j += 1;
  );
  j = 0;
  while (j < N) (
    R[j] = JR[j] * damp;
    L[j] = JL[j] * damp;
    j += 1;
  );
);

@slider
in_gain   = 10 ^ (slider1 / 20);
damp      = slider2;
rounding  = slider3;
lipExtent = slider4;
height    = slider5;
backness  = slider6;
dc_on     = slider7;
vol       = slider8;

// === Three-zone rest tract shape (Pink Trombone's defaults) ===
// Pharyngeal/glottal (narrow):  segments 0   .. ~6.5  -> 0.6
// Mid pharyngeal (medium):      segments ~6.5 .. ~12  -> 1.1
// Oral cavity (wide):           segments ~12 .. N    -> 1.5
i = 0;
loop(N,
  i < (7.0 * N / 44.0) - 0.5 ? (
    diam[i] = 0.6;
  ) : i < (12.0 * N / 44.0) ? (
    diam[i] = 1.1;
  ) : (
    diam[i] = 1.5;
  );
  i += 1;
);

// === Tongue constriction ===
// Mapping fixed: backness=0 -> segment ~32 (tongue tip / blade, /i/)
//                backness=1 -> segment ~13 (velar, /u/)
// Constriction width 5.5 segments, Gaussian taper. Depth narrows
// from 1.5 (oral cavity rest) by `height` units; at height=1 the
// tongue narrows the tract to 0.5 at its peak, which is firm
// articulation but still passes air.
tcenter = (0.30 + (1.0 - backness) * 0.43) * N;
tdia    = 1.5 - height * 1.0;
twidth  = 5.5;
i = 0;
loop(N,
  d = (i - tcenter) / (twidth * 0.5);
  abs(d) < 1.0 ? (
    cur = tdia + (1.5 - tdia) * (d * d);
    diam[i] = min(diam[i], cur);
  );
  i += 1;
);

// === Lip rounding ===
// Narrow the last `lipExtent` segments to (1.5 - rounding * 1.0).
// At rounding=1 lip diameter is 0.5 (rounded /u/ position, air
// still flows).
ldia = 1.5 - rounding * 1.0;
i = N - lipExtent;
while (i < N) ( diam[i] = min(diam[i], ldia); i += 1; );

// Clamp diameters, compute areas.
i = 0; loop(N, diam[i] = max(diam[i], 0.0); area[i] = diam[i] * diam[i]; i += 1; );

// Internal reflection coefficients.
i = 1;
while (i < N) (
  (area[i-1] + area[i]) > 0.000001 ?
    refl_bank[i] = (area[i-1] - area[i]) / (area[i-1] + area[i]) :
    refl_bank[i] = 0.999;
  i += 1;
);

@sample
in_mono = (spl0 + spl1) * 0.5 * in_gain;

scatter(in_mono); o1 = R[N-1];
scatter(in_mono); o2 = R[N-1];
lipout = (o1 + o2) * 0.5;

dc_on > 0 ? (
  dc_y = lipout - dc_x + 0.997 * dc_y;
  dc_x = lipout;
  out  = dc_y;
) : (
  out  = lipout;
);

spl0 = out * vol;
spl1 = out * vol;
